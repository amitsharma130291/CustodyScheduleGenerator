	<script is:inline>
		function trackEvent(eventName, params = {}) {
			if (typeof window === 'undefined') return;
			if (typeof window.gtag !== 'function') return;
			try {
				window.gtag('event', eventName, params);
			} catch {
				// Analytics should never block navigation or page interaction.
			}
		}

		document.addEventListener('click', (event) => {
			const target = event.target;
			if (!(target instanceof Element)) return;
			const trackedElement = target.closest('[data-track-event]');
			if (!(trackedElement instanceof HTMLElement)) return;

			const eventName = trackedElement.dataset.trackEvent;
			if (!eventName) return;

			if (eventName === 'cta_click') {
				trackEvent(eventName, {
					cta_name: trackedElement.dataset.ctaName,
					cta_location: trackedElement.dataset.ctaLocation,
					destination: trackedElement.dataset.destination,
				});
				return;
			}

			if (eventName === 'seo_pill_click') {
				trackEvent(eventName, {
					pill_name: trackedElement.dataset.pillName,
					location: trackedElement.dataset.location,
				});
				return;
			}

			if (eventName === 'tool_card_click') {
				trackEvent(eventName, {
					tool_name: trackedElement.dataset.toolName,
					tool_status: trackedElement.dataset.toolStatus,
					location: trackedElement.dataset.location,
				});
				return;
			}

			if (eventName === 'schedule_card_click') {
				trackEvent(eventName, {
					schedule_name: trackedElement.dataset.scheduleName,
					location: trackedElement.dataset.location,
				});
			}
		});

		document.querySelectorAll('[data-faq-question][data-faq-group]').forEach((item) => {
			item.addEventListener('toggle', () => {
				if (!(item instanceof HTMLDetailsElement) || !item.open) return;
				trackEvent('faq_open', {
					question: item.dataset.faqQuestion,
					faq_group: item.dataset.faqGroup,
				});
			});
		});

		const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
		const revealCards = Array.from(document.querySelectorAll('.reveal-card'));

		if (!prefersReducedMotion && 'IntersectionObserver' in window) {
			document.documentElement.classList.add('motion-ready');
			const observer = new IntersectionObserver(
				(entries) => {
					entries.forEach((entry) => {
						if (!entry.isIntersecting) return;
						entry.target.classList.add('is-visible');
						observer.unobserve(entry.target);
					});
				},
				{ rootMargin: '0px 0px -10% 0px', threshold: 0.08 },
			);

			revealCards.forEach((card) => observer.observe(card));
		} else {
			revealCards.forEach((card) => card.classList.add('is-visible'));
		}
	</script>
