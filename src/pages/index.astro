---
import FAQ from '../components/FAQ.astro';
import Footer from '../components/Footer.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import Navbar from '../components/Navbar.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import SchedulePatternStrip from '../components/homepage/visuals/SchedulePatternStrip.astro';
import ToolPreviewCard from '../components/homepage/visuals/ToolPreviewCard.astro';
import { homepageFaqItems, platformFaqItems } from '../data/homepage';
import { getCanonicalUrl } from '../lib/seo/metadata';
import {
	buildBreadcrumbSchema,
	buildFAQSchema,
	buildOrganizationSchema,
	buildSoftwareApplicationSchema,
	buildWebPageSchema,
	buildWebSiteSchema,
} from '../lib/seo/schema';

const title = 'CustodyBuilder | Custody Schedules, Parenting Plans & Calculators';
const description =
	'Create custody schedules, compare parenting time, calculate custody percentages, build parenting plans, and manage visitation calendars for co-parents.';
const ogDescription =
	'Build custody schedules, parenting calendars, and printable co-parenting plans with free custody planning tools.';
const canonical = '/';
const canonicalUrl = getCanonicalUrl(canonical);
const dateModified = '2026-06-10';
const platformTools = [
	{ title: 'Custody Schedule Generator', href: '/custody-schedule-generator/', status: 'Available', isActive: true },
	{ title: 'Parenting Time Calculator', href: '/parenting-time-calculator/', status: 'Platform module', isActive: false },
	{ title: 'Child Support Calculator', href: '/child-support-calculator/', status: 'Platform module', isActive: false },
	{ title: 'Holiday Planner', href: '/holiday-custody-planner/', status: 'Platform module', isActive: false },
	{ title: 'Custody Agreement Builder', href: '/custody-agreement-builder/', status: 'Platform module', isActive: false },
	{ title: 'Schedule Comparison Tool', href: '/schedule-comparison-tool/', status: 'Platform module', isActive: false },
];
const schedulePills = [
	{ label: '50/50 Custody', href: '/50-50-custody-schedule/' },
	{ label: '2-2-3 Schedule', href: '/2-2-3-custody-schedule/' },
	{ label: '2-2-5-5 Schedule', href: '/2-2-5-5-custody-schedule/' },
	{ label: '5-2-2-5 Schedule', href: '/5-2-2-5-custody-schedule/' },
	{ label: '3-4-4-3 custody schedule', href: '/3-4-4-3-custody-schedule/' },
	{ label: '60/40 Custody', href: '/60-40-custody-schedule/' },
	{ label: '70/30 Custody', href: '/70-30-custody-schedule/' },
	{ label: '80/20 Custody', href: '/80-20-custody-schedule/' },
];
const hubLinks = [
	{ label: 'Custody schedule generator', href: '/custody-schedule-generator/' },
	{ label: 'Custody percentage calculator', href: '/custody-percentage-calculator/' },
	{ label: 'Parenting time calculator', href: '/parenting-time-calculator/' },
	{ label: 'Custody calendar template', href: '/custody-calendar-template/' },
	{ label: 'Parenting plan template', href: '/parenting-plan-template/' },
	{ label: '50/50 custody schedules', href: '/50-50-custody-schedule/' },
	{ label: 'Holiday custody schedule', href: '/holiday-custody-schedule/' },
	{ label: 'Custody schedules by age', href: '/custody-schedule-by-age/' },
];
const platformFeatures = [
	{
		title: 'Scheduling',
		outcome: 'Turn parenting arrangements into structured custody schedules that can become real calendars.',
		status: 'Entry point',
		statusKey: 'available',
		preview: 'calendar',
		href: '/custody-schedule-generator/',
	},
	{
		title: 'Parenting Time',
		outcome: 'Understand overnights and parenting time percentages before comparing arrangements.',
		status: 'Planning layer',
		statusKey: 'planned',
		preview: 'parenting-time',
		href: '/parenting-time-calculator/',
	},
	{
		title: 'Child Support',
		outcome: 'Connect schedule assumptions with support estimate planning and income scenarios.',
		status: 'Estimate layer',
		statusKey: 'planned',
		preview: 'support',
		href: '/child-support-calculator/',
	},
	{
		title: 'Holiday Planning',
		outcome: 'Layer school breaks, birthdays, holidays, and special days on top of the base schedule.',
		status: 'Calendar layer',
		statusKey: 'planned',
		preview: 'holidays',
		href: '/holiday-custody-planner/',
	},
	{
		title: 'Agreements',
		outcome: 'Organize exchanges, responsibilities, expenses, and terms into a clearer plan.',
		status: 'Document layer',
		statusKey: 'planned',
		preview: 'agreement',
		href: '/custody-agreement-builder/',
	},
	{
		title: 'Reporting',
		outcome: 'Package calendars, summaries, and planning outputs for review and discussion.',
		status: 'Export layer',
		statusKey: 'planned',
		preview: 'reports',
		href: '/schedule-comparison-tool/',
	},
];
const workflowSteps = [
	{
		title: 'Choose a schedule',
		description: 'Start with common custody patterns like 2-2-3, 2-2-5-5, 50/50, 60/40, or 70/30.',
		visual: 'selector',
	},
	{
		title: 'Generate a calendar',
		description: 'Turn your arrangement into a clear monthly parenting calendar.',
		visual: 'calendar',
	},
	{
		title: 'Calculate parenting time',
		description: 'Estimate overnights and parenting percentages across the year.',
		visual: 'parenting-time',
	},
	{
		title: 'Plan holidays',
		description: 'Organize school breaks, holidays, birthdays, and special days.',
		visual: 'holidays',
	},
	{
		title: 'Prepare agreements',
		description: 'Structure parenting plan terms, exchanges, expenses, and responsibilities.',
		visual: 'agreement',
	},
	{
		title: 'Export and share',
		description: 'Print, save, or share custody calendars and planning details.',
		visual: 'export',
	},
];
const scheduleCards = [
	{ title: '2-2-3 Schedule', split: '50/50', href: '/2-2-3-custody-schedule/', description: 'Frequent exchanges with alternating weekends for a balanced 50/50 pattern.', pattern: ['A', 'A', 'B', 'B', 'A', 'A', 'A', 'B', 'B', 'A', 'A', 'B', 'B', 'B'] },
	{ title: '2-2-5-5 Schedule', split: '50/50', href: '/2-2-5-5-custody-schedule/', description: 'Stable weekdays with each parent keeping the same two weekdays.', pattern: ['A', 'A', 'B', 'B', 'A', 'A', 'A', 'A', 'A', 'B', 'B', 'A', 'A', 'B'] },
	{ title: '5-2-2-5 Schedule', split: '50/50', href: '/5-2-2-5-custody-schedule/', description: 'Predictable blocks with consistent weekday parenting time.', pattern: ['A', 'A', 'A', 'A', 'A', 'B', 'B', 'A', 'A', 'B', 'B', 'B', 'B', 'B'] },
	{ title: '3-4-4-3 custody schedule', split: '50/50', href: '/3-4-4-3-custody-schedule/', description: 'A balanced 50/50 rotation with longer blocks and fewer exchanges than 2-2-3.', pattern: ['A', 'A', 'A', 'B', 'B', 'B', 'B', 'A', 'A', 'A', 'A', 'B', 'B', 'B'] },
	{ title: '50/50 Custody', split: 'Equal time', href: '/50-50-custody-schedule/', description: 'Equal parenting time options for families comparing shared custody plans.', pattern: ['A', 'A', 'A', 'A', 'A', 'A', 'A', 'B', 'B', 'B', 'B', 'B', 'B', 'B'] },
	{ title: '60/40 Custody', split: '60/40', href: '/60-40-custody-schedule/', description: 'A substantial parenting time split with one slightly larger school-week home.', pattern: ['A', 'A', 'A', 'A', 'B', 'B', 'B', 'A', 'A', 'A', 'A', 'B', 'B', 'A'] },
	{ title: '70/30 Custody', split: '70/30', href: '/70-30-custody-schedule/', description: 'A primary-home routine with regular overnight time in the other home.', pattern: ['A', 'A', 'A', 'A', 'A', 'B', 'B', 'A', 'A', 'A', 'A', 'A', 'B', 'A'] },
	{ title: '80/20 Custody', split: '80/20', href: '/80-20-custody-schedule/', description: 'A primary residence schedule with recurring weekends or set parenting blocks.', pattern: ['A', 'A', 'A', 'A', 'A', 'B', 'B', 'A', 'A', 'A', 'A', 'A', 'A', 'A'] },
];
const resourceCards = [
	{ title: 'Parenting Plans', href: '/resources/parenting-plans/', description: 'Learn what to include when turning a custody calendar into a parenting plan.' },
	{ title: 'Child Support', href: '/resources/child-support/', description: 'Understand how support estimates and parenting schedules may fit together.' },
	{ title: 'Joint Custody', href: '/resources/joint-custody/', description: 'Compare shared custody arrangements, responsibilities, and planning tradeoffs.' },
	{ title: 'Sole Custody', href: '/resources/sole-custody/', description: 'Review planning considerations for primary-home and limited-time schedules.' },
	{ title: 'Holiday Schedules', href: '/resources/holiday-schedules/', description: 'Plan holidays, school breaks, birthdays, and special days around the base schedule.' },
	{ title: 'Long Distance Parenting', href: '/resources/long-distance-parenting/', description: 'Explore custody planning when travel time and school breaks matter most.' },
	{ title: 'School Year Schedules', href: '/resources/school-year-schedules/', description: 'Organize school nights, activities, transportation, and predictable routines.' },
	{ title: 'Summer Custody', href: '/resources/summer-custody/', description: 'Plan summer parenting time, travel blocks, camps, and vacation schedules.' },
];
const ecosystemGroups = [
	{
		title: 'Plan',
		description: 'Create the foundation for the parenting arrangement and calendar.',
		items: ['Create custody plan', 'Choose schedule pattern', 'Compare arrangements'],
	},
	{
		title: 'Calculate',
		description: 'Turn the plan into numbers parents can understand and discuss.',
		items: ['Parenting time totals', 'Overnight percentages', 'Support estimate inputs'],
	},
	{
		title: 'Organize',
		description: 'Keep holidays, school breaks, and special days connected to the plan.',
		items: ['Holiday planning', 'School breaks', 'Summer blocks'],
	},
	{
		title: 'Prepare',
		description: 'Translate decisions into clearer agreement terms and checklists.',
		items: ['Exchange details', 'Decision making', 'Expense responsibilities'],
	},
	{
		title: 'Share',
		description: 'Package calendars, summaries, and records for practical use.',
		items: ['Printable exports', 'Annual summaries', 'Parenting time reports'],
	},
];
const roadmapItems = [
	'Parenting Time Calculator',
	'Child Support Calculator',
	'Holiday Planner',
	'Agreement Builder',
	'Reports',
];
const schema = [
	buildFAQSchema([...platformFaqItems, ...homepageFaqItems]),
	buildBreadcrumbSchema([{ name: 'Home', url: canonicalUrl }]),
	{
		...buildWebPageSchema({
			name: title,
			description,
			url: canonicalUrl,
		}),
		dateModified,
		isAccessibleForFree: true,
		about: [
			'custody tools',
			'custody planner',
			'custody planning software',
			'parenting time calculator',
			'parenting schedule tools',
			'co parenting tools',
			'co-parenting planning',
		],
	},
	buildWebSiteSchema({
		name: 'CustodyBuilder',
		description,
		url: canonicalUrl,
	}),
	{
		...buildOrganizationSchema({
			name: 'CustodyBuilder',
			url: canonicalUrl,
		}),
		logo: getCanonicalUrl('/logo/custodybuilder-icon.svg'),
	},
	{
		...buildSoftwareApplicationSchema({
			name: 'CustodyBuilder',
			description:
				'CustodyBuilder helps parents create custody schedules, parenting calendars, parenting time estimates, and printable custody planning documents.',
			url: canonicalUrl,
			applicationCategory: 'LegalApplication',
		}),
		operatingSystem: 'Web',
		isAccessibleForFree: true,
		featureList: [
			'Custody schedule generator',
			'Parenting time calculator',
			'Child support calculator',
			'Holiday planner',
			'Custody agreement builder',
			'Custody arrangement comparison',
			'Co-parenting planning tools',
		],
	},
	{
		'@context': 'https://schema.org',
		'@type': 'ItemList',
		name: 'CustodyBuilder custody planning tools',
		inLanguage: 'en-US',
		itemListElement: platformTools.map((tool, index) => ({
			'@type': 'ListItem',
			position: index + 1,
			name: tool.title,
			url: getCanonicalUrl(tool.href),
		})),
	},
];
---

<BaseLayout title={title} description={description} canonical={canonical} ogTitle={title} ogDescription={ogDescription} ogType="website">
	<JsonLd slot="head" data={schema} />
	<Navbar />
	<main class="relative overflow-x-clip">
		<section class="platform-hero atmosphere container-shell relative grid items-center gap-7 py-8 sm:py-10 lg:grid-cols-[0.95fr_1.05fr] lg:gap-10 lg:py-14 xl:py-16">
			<div class="platform-blob platform-blob-a" aria-hidden="true"></div>
			<div class="platform-blob platform-blob-b" aria-hidden="true"></div>
			<div class="relative z-10 motion-load motion-load-primary">
				<p class="inline-flex rounded-full border border-line-subtle bg-surface/50 px-4 py-2 text-[11px] font-semibold uppercase tracking-[0.22em] text-muted shadow-[inset_0_1px_0_rgba(255,255,255,0.08)] backdrop-blur-xl">
					Custody Planning Platform
				</p>
				<h1 class="mt-4 max-w-[760px] text-[clamp(48px,12vw,64px)] font-semibold leading-[0.94] tracking-[-0.065em] text-primary lg:text-[clamp(62px,5.35vw,82px)] lg:leading-[0.9]">
					Build Your Complete Custody Plan
				</h1>
				<p class="mt-6 max-w-[660px] text-lg leading-[1.65] text-secondary lg:text-xl">
					Plan parenting schedules, holidays, parenting time, support estimates, and custody documents in one connected workspace.
				</p>
				<div class="mt-6 flex flex-col gap-3 sm:flex-row">
					<a
						href="/custody-schedule-generator/"
						class="btn-primary inline-flex h-13 w-full items-center justify-center whitespace-nowrap rounded-full px-8 text-base font-semibold transition-all duration-200 ease-out hover:-translate-y-px active:translate-y-0 sm:w-auto"
						aria-label="Open Schedule Generator"
						data-track-event="cta_click"
						data-cta-name="launch_schedule_generator"
						data-cta-location="homepage_hero"
						data-destination="/custody-schedule-generator/"
					>
						Launch Schedule Generator
					</a>
					<a
						href="#tools"
						class="btn-secondary inline-flex h-13 w-full items-center justify-center whitespace-nowrap rounded-full px-8 text-base font-semibold transition-all duration-200 ease-out hover:-translate-y-px active:translate-y-0 sm:w-auto"
						aria-label="Explore CustodyBuilder tools"
						data-track-event="cta_click"
						data-cta-name="explore_platform"
						data-cta-location="homepage_hero"
						data-destination="#tools"
					>
						Explore Platform
					</a>
				</div>
				<div class="mt-5 max-w-2xl rounded-2xl bg-surface/70 px-4 py-3 text-xs font-semibold leading-5 text-secondary shadow-[0_14px_34px_rgba(15,23,42,0.035),inset_0_0_0_1px_var(--border-subtle)] backdrop-blur-xl" aria-label="Available CustodyBuilder features">
					<span class="text-parent-b" aria-hidden="true">✓</span> Available now: custody schedule generator, parenting time percentages, printable exports
				</div>
			</div>

			<article class="platform-cluster motion-load motion-load-secondary premium-card relative min-h-[560px] overflow-visible rounded-[2rem] p-4 sm:min-h-[620px]" aria-label="CustodyBuilder product ecosystem preview">
				<div class="platform-cluster-glow" aria-hidden="true"></div>
				<svg class="cluster-connectors absolute inset-0 h-full w-full" viewBox="0 0 600 620" preserveAspectRatio="none" aria-hidden="true">
					<line class="cluster-line-live" x1="300" y1="310" x2="132" y2="135"></line>
					<line class="cluster-line" x1="300" y1="310" x2="474" y2="90"></line>
					<line class="cluster-line" x1="300" y1="310" x2="500" y2="295"></line>
					<line class="cluster-line" x1="300" y1="310" x2="410" y2="520"></line>
					<line class="cluster-line" x1="300" y1="310" x2="145" y2="512"></line>
					<line class="cluster-line" x1="300" y1="310" x2="95" y2="330"></line>
				</svg>

				<div class="cluster-center-node" aria-hidden="true"></div>

				<a
					href="/custody-schedule-generator/"
					class="cluster-module cluster-module-live group"
					data-track-event="cta_click"
					data-cta-name="launch_schedule_generator"
					data-cta-location="hero_active_module"
					data-destination="/custody-schedule-generator/"
				>
					<span class="cluster-live-ring" aria-hidden="true"></span>
					<div class="flex items-center justify-between gap-3">
						<div class="flex items-center gap-2">
							<span class="cluster-live-dot" aria-hidden="true"></span>
							<p class="text-xs font-semibold uppercase tracking-[0.16em] text-parent-b">Active Module</p>
						</div>
					</div>
					<h3 class="mt-3 text-2xl font-semibold tracking-[-0.045em] text-primary">Custody Schedule Builder</h3>
					<p class="mt-2 text-sm leading-6 text-secondary">Generate 50/50, 60/40, 70/30, 80/20, 2-2-3, 2-2-5-5, and custom schedules.</p>
					<div class="mt-4 rounded-2xl bg-page/70 p-2.5 shadow-[inset_0_0_0_1px_var(--border-subtle)]">
						<div class="flex items-center justify-between text-[10px] font-bold uppercase tracking-[0.12em] text-muted">
							<span>Plan setup</span>
							<span>Step 1</span>
						</div>
						<div class="mt-2.5 grid grid-cols-5 gap-1.5" aria-hidden="true">
							{['A', 'A', 'B', 'B', 'A'].map((day) => (
								<span class={day === 'A' ? 'h-7 rounded-xl bg-parent-a/20' : 'h-7 rounded-xl bg-parent-b/20'}></span>
							))}
						</div>
						<div class="mt-2.5 h-1.5 overflow-hidden rounded-full bg-surface">
							<div class="h-full w-[72%] rounded-full bg-gradient-to-r from-parent-a to-parent-b"></div>
						</div>
					</div>
					<span class="cluster-live-cta mt-4 inline-flex items-center justify-center rounded-full px-4 py-2.5 text-sm font-semibold transition-all duration-200 group-hover:-translate-y-0.5 group-focus-visible:outline group-focus-visible:outline-2 group-focus-visible:outline-offset-2 group-focus-visible:outline-accent">
						Launch Schedule Generator
					</span>
				</a>

				{[
					{ title: 'Calculate Time', meta: 'Overnights and parenting percentages', className: 'cluster-module-parenting' },
					{ title: 'Plan Holidays', meta: 'Breaks, birthdays, and special days', className: 'cluster-module-holidays' },
					{ title: 'Prepare Documents', meta: 'Terms, exchanges, and responsibilities', className: 'cluster-module-agreement' },
					{ title: 'Estimate Support', meta: 'Income and custody context', className: 'cluster-module-support' },
					{ title: 'Export Records', meta: 'Calendars, summaries, and plan history', className: 'cluster-module-reports' },
				].map((module) => (
					<div class={`cluster-module ${module.className}`}>
						<div class="mb-3 flex gap-1.5" aria-hidden="true">
							<span class="h-1.5 w-6 rounded-full bg-accent/25"></span>
							<span class="h-1.5 w-3 rounded-full bg-parent-b/20"></span>
						</div>
						<h3 class="text-lg font-semibold tracking-[-0.03em] text-primary">{module.title}</h3>
						<p class="mt-2 text-xs leading-5 text-secondary">{module.meta}</p>
					</div>
				))}
			</article>
		</section>

		<section class="container-shell pb-8 lg:pb-10" aria-label="Popular custody planning tools">
			<div class="soft-card flex flex-col gap-3 rounded-[1.5rem] p-4 sm:flex-row sm:flex-wrap sm:items-center">
				<p class="text-xs font-semibold uppercase tracking-[0.18em] text-secondary">Used to plan the most common custody arrangements.</p>
				<div class="flex flex-wrap gap-2">
					{schedulePills.map((pill) => (
						<a
							href={pill.href}
							class="rounded-full bg-surface px-3 py-1.5 text-xs font-semibold text-secondary shadow-[inset_0_0_0_1px_var(--border-subtle)] transition-all duration-200 hover:-translate-y-0.5 hover:bg-surface-hover hover:text-primary hover:shadow-[0_10px_24px_rgba(15,23,42,0.05),inset_0_0_0_1px_var(--border-subtle)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
							data-track-event="seo_pill_click"
							data-pill-name={pill.label}
							data-location="homepage_trust_bar"
						>
							{pill.label}
						</a>
					))}
				</div>
			</div>
		</section>

		<section class="container-shell pb-8 lg:pb-10" aria-label="CustodyBuilder planning hubs">
			<div class="premium-card rounded-[1.75rem] p-5 lg:p-6">
				<div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
					<div>
						<p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">Planning hubs</p>
						<h2 class="mt-2 text-2xl font-semibold tracking-[-0.04em] text-primary">Custody tools for schedules, calendars, plans, and holidays</h2>
					</div>
					<a href="/custody-schedule-by-age/" class="btn-secondary inline-flex h-11 items-center justify-center rounded-full px-5 text-sm font-semibold">Compare by child age</a>
				</div>
				<div class="mt-5 flex flex-wrap gap-2">
					{hubLinks.map((link) => (
						<a href={link.href} class="rounded-full bg-surface px-3 py-2 text-xs font-semibold text-secondary shadow-[inset_0_0_0_1px_var(--border-subtle)] transition-all duration-200 hover:-translate-y-0.5 hover:bg-surface-hover hover:text-primary">
							{link.label}
						</a>
					))}
				</div>
			</div>
		</section>

		<section id="connected-system" class="container-shell scroll-mt-24 py-12 lg:py-20" aria-labelledby="connected-system-title">
			<div class="mx-auto max-w-3xl text-center">
				<p class="text-[11px] font-semibold uppercase tracking-[0.22em] text-muted">Connected system</p>
				<h2 id="connected-system-title" class="mt-2 text-4xl font-semibold leading-[1.03] tracking-[-0.055em] text-primary sm:text-5xl">
					Everything stays connected
				</h2>
				<p class="mt-5 text-base leading-8 text-secondary">
					Start with a custody schedule, then use the same plan to understand parenting time, holidays, support estimates, agreements, and exports.
				</p>
			</div>

			<div class="connected-system-grid relative mt-8 grid gap-4 lg:grid-cols-[1fr_auto_1fr] lg:items-stretch">
				<article class="reveal-card connected-card soft-card rounded-[1.8rem] p-5 lg:p-6">
					<p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">Without CustodyBuilder</p>
					<h3 class="mt-3 text-2xl font-semibold tracking-[-0.045em] text-primary">Fragmented planning</h3>
					<div class="mt-5 grid gap-3 text-sm font-semibold text-secondary">
						{['Separate calendars', 'Manual overnight counts', 'Spreadsheet support estimates', 'Scattered documents', 'Hard-to-share plans'].map((item) => (
							<div class="flex items-center gap-3 rounded-2xl bg-page/70 px-4 py-3 shadow-[inset_0_0_0_1px_var(--border-subtle)]">
								<span class="h-2 w-2 rounded-full bg-muted/45" aria-hidden="true"></span>
								<span>{item}</span>
							</div>
						))}
					</div>
				</article>

				<div class="connected-arrow reveal-card hidden place-items-center lg:grid" aria-hidden="true">
					<span class="grid h-12 w-12 place-items-center rounded-full bg-surface-elevated text-accent shadow-[0_18px_44px_rgba(15,23,42,0.08),inset_0_0_0_1px_var(--border-subtle)]">→</span>
				</div>

