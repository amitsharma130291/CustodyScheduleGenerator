---
import FAQ from '../components/FAQ.astro';
import Footer from '../components/Footer.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import Navbar from '../components/Navbar.astro';
import HeroCalendarPreview from '../components/homepage/authority/HeroCalendarPreview.astro';
import ProductFlowGraphic from '../components/homepage/authority/ProductFlowGraphic.astro';
import SiteArchitectureMapGraphic from '../components/homepage/authority/SiteArchitectureMapGraphic.astro';
import TrustMethodologyGraphic from '../components/homepage/authority/TrustMethodologyGraphic.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCanonicalUrl } from '../lib/seo/metadata';
import {
	buildBreadcrumbSchema,
	buildFAQSchema,
	buildOrganizationSchema,
	buildWebPageSchema,
	buildWebSiteSchema,
} from '../lib/seo/schema';
import {
	chooseBySituation,
	editorialBlock,
	exploreByChildStage,
	faqItems,
	faqSection,
	hero,
	howItWorks,
	meta,
	planningDocuments,
	popularGuides,
	startWithTool,
	whyDifferent,
} from '../data/homepageAuthority';

const canonical = '/';
const canonicalUrl = getCanonicalUrl(canonical);

const schema = [
	buildWebPageSchema({ name: meta.title, description: meta.description, url: canonicalUrl }),
	buildFAQSchema(faqItems),
	buildBreadcrumbSchema([{ name: 'Home', url: canonicalUrl }]),
	buildWebSiteSchema({ name: 'CustodyBuilder', description: meta.description, url: canonicalUrl }),
	buildOrganizationSchema({ name: 'CustodyBuilder', url: canonicalUrl }),
];

const toolAccentStyles: Record<string, string> = {
	calendar: 'border-l-parent-a bg-parent-a/5',
	percent: 'border-l-accent bg-accent/5',
	log: 'border-l-parent-b bg-parent-b/5',
	texas: 'border-l-amber-600/80 bg-amber-500/5',
};
---

<BaseLayout title={meta.title} description={meta.description} canonical={canonical} ogType="website">
	<JsonLd slot="head" data={schema} />
	<Navbar />
	<main>
		<!-- Hero -->
		<section class="container-shell py-10 lg:py-16">
			<div class="grid items-center gap-10 lg:grid-cols-[1.05fr_0.95fr] lg:gap-12">
				<div class="max-w-2xl">
					<p class="text-xs font-bold uppercase tracking-[0.18em] text-accent">{hero.eyebrow}</p>
					<h1 class="mt-4 text-4xl font-semibold leading-[0.98] tracking-[-0.055em] text-primary sm:text-5xl lg:text-[3.25rem]">{hero.headline}</h1>
					<p class="mt-5 text-lg leading-8 text-secondary">{hero.intro}</p>
					<div class="mt-7 flex flex-col gap-3 sm:flex-row">
						<a href={hero.primaryCta.href} class="btn-primary inline-flex h-12 items-center justify-center rounded-full px-6 text-sm font-semibold">{hero.primaryCta.label}</a>
						<a href={hero.secondaryCta.href} class="btn-secondary inline-flex h-12 items-center justify-center rounded-full px-6 text-sm font-semibold">{hero.secondaryCta.label}</a>
					</div>
					<p class="mt-5 text-xs leading-5 text-muted">
						Reviewed by CustodyBuilder Editorial Team · Updated {meta.dateModified} ·{' '}
						<a href="/disclaimer/" class="font-semibold text-secondary underline">Educational disclaimer</a>
					</p>
				</div>
				<HeroCalendarPreview />
			</div>
		</section>

		<!-- Start With The Right Tool -->
		<section id="tools" class="container-shell scroll-mt-24 border-t border-line-subtle py-10 lg:py-14">
			<div class="max-w-2xl">
				<h2 class="text-2xl font-semibold tracking-[-0.03em] text-primary sm:text-3xl">{startWithTool.title}</h2>
				<p class="mt-3 text-secondary">{startWithTool.intro}</p>
			</div>
			<ul class="mt-8 grid gap-4 sm:grid-cols-2">
				{startWithTool.tools.map((tool) => (
					<li>
						<a
							href={tool.href}
							class={`soft-card block rounded-[1.35rem] border-l-4 p-5 transition-colors hover:border-accent/40 ${toolAccentStyles[tool.accent] ?? 'border-l-line'}`}
						>
							<p class="text-[11px] font-bold uppercase tracking-[0.1em] text-muted">Answers</p>
							<p class="mt-1 text-sm font-medium italic text-secondary">"{tool.question}"</p>
							<h3 class="mt-3 text-lg font-semibold text-primary">{tool.label}</h3>
							<p class="mt-2 text-sm text-secondary">{tool.detail}</p>
						</a>
					</li>
				))}
			</ul>
		</section>

		<!-- How CustodyBuilder Works -->
		<section class="container-shell scroll-mt-24 border-t border-line-subtle py-10 lg:py-14">
			<div class="grid gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-start">
				<div>
					<h2 class="text-2xl font-semibold tracking-[-0.03em] text-primary sm:text-3xl">{howItWorks.title}</h2>
					<p class="mt-3 text-secondary">{howItWorks.intro}</p>
					<ol class="mt-8 space-y-5">
						{howItWorks.steps.map((step) => (
							<li class="flex gap-4">
								<span class="grid h-9 w-9 shrink-0 place-items-center rounded-full bg-primary text-sm font-bold text-white">{step.step}</span>
								<div>
									<h3 class="font-semibold text-primary">{step.heading}</h3>
									<p class="mt-2 text-sm leading-6 text-secondary">{step.body}</p>
								</div>
							</li>
						))}
					</ol>
					<p class="mt-6">
						<a href={howItWorks.link.href} class="text-sm font-semibold text-accent underline">{howItWorks.link.label} →</a>
					</p>
				</div>
				<ProductFlowGraphic />
			</div>
		</section>

		<!-- Choose By Situation + Site Architecture -->
		<section class="container-shell scroll-mt-24 border-t border-line-subtle py-10 lg:py-14">
			<div class="grid gap-12 lg:grid-cols-2 lg:items-start">
				<div>
					<h2 class="text-2xl font-semibold tracking-[-0.03em] text-primary sm:text-3xl">{chooseBySituation.title}</h2>
					<p class="mt-3 text-secondary">{chooseBySituation.intro}</p>
					<ul class="mt-6 space-y-3">
						{chooseBySituation.routes.map((route) => (
							<li>
								<a href={route.href} class="soft-card block rounded-[1.15rem] p-4 transition-colors hover:border-accent/30">
									<h3 class="font-semibold text-primary">{route.label}</h3>
									<p class="mt-1 text-sm text-secondary">{route.detail}</p>
								</a>
							</li>
						))}
					</ul>
				</div>
				<SiteArchitectureMapGraphic />
			</div>
		</section>

		<!-- Explore By Child Stage -->
		<section class="container-shell scroll-mt-24 border-t border-line-subtle py-10 lg:py-12">
			<h2 class="text-2xl font-semibold tracking-[-0.03em] text-primary sm:text-3xl">{exploreByChildStage.title}</h2>
			<p class="mt-3 max-w-2xl text-secondary">{exploreByChildStage.intro}</p>
			<ul class="mt-6 grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
				{exploreByChildStage.stages.map((stage) => (
					<li>
						<a href={stage.href} class="soft-card block rounded-[1.15rem] p-4 text-center transition-colors hover:border-accent/30">
							<h3 class="font-semibold text-primary">{stage.label}</h3>
							<p class="mt-2 text-xs leading-5 text-secondary">{stage.phrase}</p>
						</a>
					</li>
				))}
			</ul>
		</section>

		<!-- Popular Schedule Guides -->
		<section id="schedules" class="container-shell scroll-mt-24 border-t border-line-subtle py-10 lg:py-12">
			<h2 class="text-2xl font-semibold tracking-[-0.03em] text-primary sm:text-3xl">{popularGuides.title}</h2>
			<p class="mt-3 max-w-2xl text-secondary">{popularGuides.intro}</p>
			<ul class="mt-6 grid gap-3 grid-cols-2 sm:grid-cols-3 lg:grid-cols-6">
				{popularGuides.guides.map((guide) => (
					<li>
						<a href={guide.href} class="soft-card block rounded-[1.1rem] p-3 text-center transition-colors hover:border-accent/30">
							<h3 class="text-sm font-semibold text-primary">{guide.label}</h3>
							<p class="mt-1 text-[10px] font-medium leading-4 text-muted">{guide.tag}</p>
						</a>
					</li>
				))}
			</ul>
		</section>

		<!-- Planning Documents -->
		<section id="templates" class="container-shell scroll-mt-24 border-t border-line-subtle py-10 lg:py-12">
			<h2 class="text-2xl font-semibold tracking-[-0.03em] text-primary sm:text-3xl">{planningDocuments.title}</h2>
			<p class="mt-3 max-w-2xl text-secondary">{planningDocuments.intro}</p>
			<ul class="mt-6 grid gap-3 sm:grid-cols-2">
				{planningDocuments.documents.map((doc) => (
					<li>
						<a href={doc.href} class="block border-l-2 border-accent/30 py-1 pl-4 hover:border-accent">
							<h3 class="font-semibold text-primary">{doc.label}</h3>
							<p class="mt-1 text-sm text-secondary">{doc.detail}</p>
						</a>
					</li>
				))}
			</ul>
		</section>

		<!-- Why Different -->
		<section class="container-shell scroll-mt-24 border-t border-line-subtle py-10 lg:py-14">
			<h2 class="text-2xl font-semibold tracking-[-0.03em] text-primary sm:text-3xl">{whyDifferent.title}</h2>
			<ul class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
				{whyDifferent.points.map((p) => (
					<li class="soft-card rounded-[1.25rem] p-5">
						<h3 class="font-semibold text-primary">{p.heading}</h3>
						<p class="mt-2 text-sm leading-6 text-secondary">{p.body}</p>
					</li>
				))}
			</ul>
		</section>

		<!-- Editorial Review -->
		<section class="container-shell scroll-mt-24 border-t border-line-subtle py-10 lg:py-14">
			<div class="premium-card rounded-[2rem] p-3">
				<div class="rounded-[1.7rem] bg-surface-elevated/80 p-5 sm:p-8">
					<div class="grid gap-10 lg:grid-cols-[1fr_1.1fr] lg:items-start">
						<div>
							<h2 class="text-2xl font-semibold tracking-[-0.03em] text-primary sm:text-3xl">{editorialBlock.title}</h2>
							<p class="mt-4 text-secondary">{editorialBlock.intro}</p>
							<ul class="mt-6 space-y-2">
								{editorialBlock.reviewItems.map((item) => (
									<li class="flex gap-2 text-sm text-secondary">
										<span class="font-bold text-accent" aria-hidden="true">✓</span>
										{item}
									</li>
								))}
							</ul>
							<p class="mt-6 rounded-xl bg-page/60 p-4 text-sm leading-6 text-muted shadow-[inset_0_0_0_1px_var(--border-subtle)]">{editorialBlock.boundary}</p>
							<ul class="mt-6 space-y-3">
								{editorialBlock.links.map((link) => (
									<li>
										<a href={link.href} class="font-semibold text-accent underline">{link.label}</a>
										<span class="text-sm text-secondary"> — {link.detail}</span>
									</li>
								))}
							</ul>
						</div>
						<TrustMethodologyGraphic />
					</div>
				</div>
			</div>
		</section>

		<FAQ items={faqItems} title={faqSection.title} description={faqSection.description} />
	</main>
	<Footer />
</BaseLayout>
