---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import FAQ from '../components/FAQ.astro';
import CtaButton from '../components/CtaButton.astro';
import ScheduleHeroGeneratorPanel from '../components/schedules/ScheduleHeroGeneratorPanel.astro';
import DrivingFreedomTimelineGraphic from '../components/schedules/50-50-custody-schedule-for-teenagers/DrivingFreedomTimelineGraphic.astro';
import TeenSchedulePressureMapGraphic from '../components/schedules/50-50-custody-schedule-for-teenagers/TeenSchedulePressureMapGraphic.astro';
import CalendarFlexibilityGraphic from '../components/schedules/50-50-custody-schedule-for-teenagers/CalendarFlexibilityGraphic.astro';
import { generateSchedule } from '../lib/schedules/generateSchedule';
import { getDefaultStartDate } from '../lib/schedules/format';
import { getCanonicalUrl } from '../lib/seo/metadata';
import {
	buildArticleSchema,
	buildBreadcrumbSchema,
	buildFAQSchema,
	buildWebPageSchema,
} from '../lib/seo/schema';
import {
	articleTocItems,
	editorialReview,
	faqItems,
	faqSection,
	hero,
	heroKeyStats,
	heroTrustSignals,
	meta,
	postContentCta,
	permissionEnds,
	drivingFreedom,
	schedulePressure,
	calendarFlexibility,
	independenceMistakes,
} from '../data/fiftyFiftyCustodyScheduleForTeenagers';

const canonical = '/50-50-custody-schedule-for-teenagers/';
const canonicalUrl = getCanonicalUrl(canonical);
const startDate = getDefaultStartDate();
const generatedSchedule = generateSchedule({
	scheduleId: 'week-on-week-off',
	startDate,
	parentNames: { parentA: 'Parent A', parentB: 'Parent B' },
});

const breadcrumbs = [
	{ name: 'Home', url: getCanonicalUrl('/') },
	{ name: '50/50 Custody Schedule', url: getCanonicalUrl('/50-50-custody-schedule/') },
	{ name: '50/50 Schedule for Teenagers', url: canonicalUrl },
];

const schema = [
	buildWebPageSchema({ name: meta.title, description: meta.description, url: canonicalUrl }),
	buildArticleSchema({
		headline: hero.headline,
		description: meta.description,
		url: canonicalUrl,
		datePublished: meta.datePublished,
		dateModified: meta.dateModified,
		authorName: editorialReview.reviewer,
	}),
	buildFAQSchema(faqItems),
	buildBreadcrumbSchema(breadcrumbs),
	{
		'@context': 'https://schema.org',
		'@type': 'WebApplication',
		name: 'Teen Independence Calendar Preview Generator',
		description: meta.description,
		url: canonicalUrl,
		inLanguage: 'en-US',
		areaServed: 'US',
		applicationCategory: 'LegalApplication',
		operatingSystem: 'Web',
		offers: {
			'@type': 'Offer',
			price: '0',
			priceCurrency: 'USD',
		},
	},
];
---

<BaseLayout title={meta.title} description={meta.description} canonical={canonical}>
	<JsonLd slot="head" data={schema} />
	<Navbar />
	<Breadcrumbs items={breadcrumbs} />
	<main class="teen-fifty-fifty-page">
		<section
			class="container-shell grid grid-cols-1 gap-5 py-4 sm:py-5 lg:grid-cols-[minmax(0,0.88fr)_minmax(704px,1.12fr)] lg:items-start lg:gap-7 lg:py-6 xl:w-[min(100%,1360px)]"
			id="schedule-generator"
		>
			<div class="order-1 min-w-0 lg:col-start-1 lg:row-start-1 lg:pt-1">
				<h1 class="max-w-3xl text-4xl font-semibold leading-[0.98] tracking-[-0.055em] text-primary sm:text-5xl">
					{hero.headline}
				</h1>

				<dl class="mt-4 grid grid-cols-3 gap-2">
					{heroKeyStats.map((stat) => (
						<div class="rounded-[1rem] bg-accent/10 px-2 py-2.5 text-center shadow-[inset_0_0_0_1px_rgba(37,99,235,0.15)] sm:px-3">
							<dd class="text-lg font-bold tabular-nums tracking-tight text-accent sm:text-xl">{stat.value}</dd>
							<dt class="mt-0.5 text-[10px] font-semibold uppercase leading-4 tracking-[0.08em] text-secondary">{stat.label}</dt>
						</div>
					))}
				</dl>

				<p class="mt-3 max-w-2xl text-base leading-7 text-secondary">{hero.intro}</p>
				<p class="mt-3 max-w-2xl text-sm leading-6 text-secondary" set:html={hero.boundary} />

				<div class="mt-3 max-w-2xl text-xs leading-5 text-muted">
					<p class="font-semibold text-secondary">Reviewed for:</p>
					<ul class="mt-1 list-inside list-disc space-y-0.5">
						{editorialReview.reviewedFor.map((item) => (
							<li>{item}</li>
						))}
					</ul>
					<p class="mt-2">
						Reviewed by{' '}
						<a href={editorialReview.reviewerHref} class="font-semibold text-secondary underline decoration-line underline-offset-4 hover:text-primary">
							{editorialReview.reviewer}
						</a>
						{' · '}
						Methodology:{' '}
						<a href={editorialReview.methodologyHref} class="font-semibold text-secondary underline decoration-line underline-offset-4 hover:text-primary">
							{editorialReview.methodologyLabel}
						</a>
						{' · '}{editorialReview.disclaimer}
					</p>
				</div>
			</div>

			<ScheduleHeroGeneratorPanel
				selectedScheduleId="week-on-week-off"
				generatedSchedule={generatedSchedule}
				heroTrustSignals={heroTrustSignals}
			/>
		</section>

		<nav class="container-shell border-y border-line-subtle py-3" aria-label="On this page">
			<ul class="flex flex-wrap gap-x-4 gap-y-1 text-xs font-semibold text-secondary">
				{articleTocItems.map((item) => (
					<li><a href={`#${item.id}`} class="hover:text-accent">{item.label}</a></li>
				))}
			</ul>
		</nav>

		<section id="permission-ends" class="container-shell scroll-mt-24 py-10 lg:py-12" aria-labelledby="permission-ends-title">
			<h2 id="permission-ends-title" class="max-w-3xl text-2xl font-semibold tracking-[-0.04em] text-primary sm:text-3xl">
				{permissionEnds.title}
			</h2>
			<p class="mt-3 max-w-3xl text-base leading-7 text-secondary">{permissionEnds.intro}</p>
			<div class="mt-6 max-w-3xl space-y-5">
				{permissionEnds.signals.map((signal) => (
					<article class="border-l-2 border-accent/30 pl-4">
						<h3 class="text-base font-semibold text-primary">{signal.heading}</h3>
						<p class="mt-2 text-sm leading-6 text-secondary">{signal.body}</p>
					</article>
				))}
			</div>
			<p class="mt-6 max-w-3xl text-sm leading-6 text-secondary" set:html={permissionEnds.closing} />
		</section>

		<section id="driving-freedom" class="container-shell scroll-mt-24 border-t border-line-subtle py-10 lg:py-12" aria-labelledby="driving-freedom-title">
			<div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_minmax(260px,320px)] lg:items-start">
				<div class="min-w-0">
					<h2 id="driving-freedom-title" class="text-2xl font-semibold tracking-[-0.04em] text-primary sm:text-3xl">
						{drivingFreedom.title}
					</h2>
					<p class="mt-3 text-base leading-7 text-secondary">{drivingFreedom.intro}</p>
					<div class="mt-6 space-y-5">
						{drivingFreedom.points.map((point) => (
							<article>
								<h3 class="text-base font-semibold text-primary">{point.heading}</h3>
								<p class="mt-2 text-sm leading-6 text-secondary">{point.body}</p>
							</article>
						))}
					</div>
				</div>
				<DrivingFreedomTimelineGraphic />
			</div>
		</section>

		<section id="schedule-pressure" class="container-shell scroll-mt-24 border-t border-line-subtle py-10 lg:py-12" aria-labelledby="schedule-pressure-title">
			<div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_minmax(280px,360px)] lg:items-start">
				<div class="min-w-0">
					<h2 id="schedule-pressure-title" class="text-2xl font-semibold tracking-[-0.04em] text-primary sm:text-3xl">
						{schedulePressure.title}
					</h2>
					<p class="mt-3 text-base leading-7 text-secondary">{schedulePressure.intro}</p>
					<div class="mt-6 overflow-x-auto rounded-[1.25rem] border border-line bg-surface shadow-[0_18px_44px_rgba(15,23,42,0.06)]">
						<table class="min-w-[520px] w-full text-left text-sm">
							<thead class="bg-surface-elevated text-xs uppercase tracking-[0.16em] text-muted">
								<tr>
									<th class="px-4 py-3">Calendar</th>
									<th class="px-4 py-3">Example</th>
									<th class="px-4 py-3">Conflicts with</th>
								</tr>
							</thead>
							<tbody class="divide-y divide-line text-secondary">
								{schedulePressure.pressures.map((row) => (
									<tr>
										<td class="px-4 py-4 font-semibold text-primary">{row.source}</td>
										<td class="px-4 py-4">{row.example}</td>
										<td class="px-4 py-4">{row.conflicts}</td>
									</tr>
								))}
							</tbody>
						</table>
					</div>
				</div>
				<TeenSchedulePressureMapGraphic />
			</div>
		</section>

		<section id="calendar-flexibility" class="container-shell scroll-mt-24 border-t border-line-subtle py-10 lg:py-12" aria-labelledby="calendar-flexibility-title">
			<div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_minmax(280px,360px)] lg:items-start">
				<div class="min-w-0">
					<h2 id="calendar-flexibility-title" class="text-2xl font-semibold tracking-[-0.04em] text-primary sm:text-3xl">
						{calendarFlexibility.title}
					</h2>
					<p class="mt-3 text-base leading-7 text-secondary">{calendarFlexibility.intro}</p>
					<div class="mt-6 grid gap-4 sm:grid-cols-2">
						<div class="rounded-[1rem] bg-rose-500/8 p-4 ring-1 ring-rose-500/25">
							<h3 class="text-sm font-semibold text-primary">Rigid rotation friction</h3>
							<ul class="mt-3 list-disc space-y-2 pl-4 text-sm leading-6 text-secondary">
								{calendarFlexibility.rigid.map((item) => <li>{item}</li>)}
							</ul>
						</div>
						<div class="rounded-[1rem] bg-emerald-500/8 p-4 ring-1 ring-emerald-500/25">
							<h3 class="text-sm font-semibold text-primary">Flexible rotation relief</h3>
							<ul class="mt-3 list-disc space-y-2 pl-4 text-sm leading-6 text-secondary">
								{calendarFlexibility.flexible.map((item) => <li>{item}</li>)}
							</ul>
						</div>
					</div>
					<p class="mt-6 text-sm leading-6 text-secondary" set:html={calendarFlexibility.closing} />
				</div>
				<CalendarFlexibilityGraphic />
			</div>
		</section>

		<section id="independence-mistakes" class="container-shell scroll-mt-24 border-t border-line-subtle py-10 lg:py-12" aria-labelledby="independence-mistakes-title">
			<h2 id="independence-mistakes-title" class="max-w-3xl text-2xl font-semibold tracking-[-0.04em] text-primary sm:text-3xl">
				Independence Mistakes On Equal-Time Teen Calendars
			</h2>
			<p class="mt-3 max-w-3xl text-base leading-7 text-secondary">
				Calendar rigidity errors — not parenting style — that show up when teens drive and work on top of equal time.
			</p>
			<ul class="mt-6 max-w-3xl space-y-4">
				{independenceMistakes.map((item) => (
					<li class="border-l-2 border-rose-500/30 pl-4">
						<h3 class="text-base font-semibold text-primary">{item.mistake}</h3>
						<p class="mt-2 text-sm leading-6 text-secondary">{item.detail}</p>
					</li>
				))}
			</ul>
		</section>

		<section id="convert-cta" class="container-shell scroll-mt-24 border-t border-line-subtle py-10 lg:py-12" aria-labelledby="convert-cta-title">
			<div class="max-w-2xl rounded-[1.25rem] border border-line bg-surface/40 p-6 sm:p-7">
				<h2 id="convert-cta-title" class="text-2xl font-semibold tracking-[-0.04em] text-primary sm:text-[1.65rem]">
					{postContentCta.heading}
				</h2>
				<p class="mt-3 text-sm leading-6 text-secondary sm:text-base sm:leading-7">{postContentCta.body}</p>
				<div class="mt-5 flex flex-col gap-3 sm:flex-row sm:items-center sm:gap-5">
					<CtaButton href={postContentCta.primaryHref} variant="primary" size="large">
						{postContentCta.primaryLabel}
					</CtaButton>
					<a
						href={postContentCta.secondaryHref}
						class="text-sm font-semibold text-accent underline decoration-line underline-offset-4 hover:text-primary"
					>
						{postContentCta.secondaryLabel}
					</a>
				</div>
			</div>
		</section>

		<FAQ items={faqItems} title={faqSection.title} description={faqSection.description} />
	</main>
	<Footer />
</BaseLayout>
