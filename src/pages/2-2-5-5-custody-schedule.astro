---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import FAQ from '../components/FAQ.astro';
import CtaButton from '../components/CtaButton.astro';
import ArticleTOC from '../components/ArticleTOC.astro';
import GeneratorPanel from '../components/tool/GeneratorPanel.astro';
import CalendarPreview from '../components/tool/CalendarPreview.astro';
import ExportActions from '../components/tool/ExportActions.astro';
import { generateSchedule } from '../lib/schedules/generateSchedule';
import { getDefaultStartDate } from '../lib/schedules/format';
import { getCanonicalUrl } from '../lib/seo/metadata';
import {
	buildArticleSchema,
	buildBreadcrumbSchema,
	buildFAQSchema,
	buildWebPageSchema,
} from '../lib/seo/schema';
import {
	articleTocItems,
	calendarGlance,
	faqItems,
	fixedDaysSection,
	hero,
	meta,
	parentingPlanSection,
	problemsSection,
	quickFacts,
	vs5225,
	weekNeverChanges,
	workSchedulesSection,
} from '../data/fiftyFiftyCustodySchedule2255';

const canonical = '/2-2-5-5-custody-schedule/';
const canonicalUrl = getCanonicalUrl(canonical);
const startDate = getDefaultStartDate();
const generatedSchedule = generateSchedule({
	scheduleId: '2255',
	startDate,
	parentNames: { parentA: 'Parent A', parentB: 'Parent B' },
});

const breadcrumbs = [
	{ name: 'Home', url: getCanonicalUrl('/') },
	{ name: '50/50 Custody Schedule', url: getCanonicalUrl('/50-50-custody-schedule/') },
	{ name: '2-2-5-5 Custody Schedule', url: canonicalUrl },
];

const schema = [
	buildWebPageSchema({ name: meta.title, description: meta.description, url: canonicalUrl }),
	buildArticleSchema({
		headline: hero.headline,
		description: meta.description,
		url: canonicalUrl,
		datePublished: meta.datePublished,
		dateModified: meta.dateModified,
		authorName: 'CustodyBuilder Editorial Team',
	}),
	buildFAQSchema(faqItems),
	buildBreadcrumbSchema(breadcrumbs),
];
---

<BaseLayout title={meta.title} description={meta.description} canonical={canonical}>
	<JsonLd slot="head" data={schema} />
	<Navbar />
	<Breadcrumbs items={breadcrumbs} />
	<main>
		<section
			class="container-shell schedule-hero-section grid gap-10 py-12 xl:grid-cols-[minmax(0,1fr)_minmax(704px,720px)] xl:items-start xl:justify-center xl:gap-8 xl:py-16"
			id="schedule-generator"
		>
			<div class="min-w-0 max-w-[820px]">
				<p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">Fixed weekday schedule</p>
				<h1 class="mt-4 text-4xl font-semibold leading-[1.02] tracking-[-0.05em] text-primary sm:text-5xl lg:text-6xl">
					{hero.headline}
				</h1>
				<p class="mt-5 text-lg leading-8 text-secondary">{hero.opening}</p>
				<p class="mt-4 text-base leading-7 text-secondary">{hero.difference}</p>

				<div class="mt-6 soft-card rounded-[1.5rem] p-5">
					<p class="text-xs font-semibold uppercase tracking-[0.16em] text-muted">{quickFacts.title}</p>
					<dl class="mt-3 grid gap-3 sm:grid-cols-2">
						{quickFacts.items.map((fact) => (
							<div class="rounded-[1rem] bg-surface/70 p-3 shadow-[inset_0_0_0_1px_var(--border-subtle)]">
								<dt class="text-xs font-semibold uppercase tracking-[0.12em] text-muted">{fact.label}</dt>
								<dd class="mt-1 text-sm font-semibold leading-6 text-primary">{fact.value}</dd>
							</div>
						))}
					</dl>
				</div>

				<div class="mt-6 soft-card rounded-[1.5rem] p-6">
					<p class="text-sm font-semibold text-primary">{hero.question}</p>
					<div class="mt-4 grid gap-4 sm:grid-cols-2">
						<div class="rounded-[1.25rem] bg-surface/70 p-4 shadow-[inset_0_0_0_1px_var(--border-subtle)]">
							<p class="text-xs font-semibold uppercase tracking-[0.16em] text-accent">{hero.compare2255.label}</p>
							<ul class="mt-3 space-y-2 text-sm leading-6 text-secondary">
								{hero.compare2255.points.map((point) => (
									<li class="flex gap-2">
										<span class="text-accent" aria-hidden="true">→</span>
										{point}
									</li>
								))}
							</ul>
						</div>
						<div class="rounded-[1.25rem] bg-surface/70 p-4 shadow-[inset_0_0_0_1px_var(--border-subtle)]">
							<p class="text-xs font-semibold uppercase tracking-[0.16em] text-muted">
								<a href={hero.compare5225.href} class="text-secondary underline decoration-line underline-offset-4 hover:text-accent">{hero.compare5225.label}</a>
							</p>
							<ul class="mt-3 space-y-2 text-sm leading-6 text-secondary">
								{hero.compare5225.points.map((point) => (
									<li class="flex gap-2">
										<span class="text-muted" aria-hidden="true">→</span>
										{point}
									</li>
								))}
							</ul>
						</div>
					</div>
				</div>

				<p class="mt-4 text-sm leading-6 text-muted">
					Not legal advice.
					<a href="/disclaimer/" class="ml-1 font-semibold text-secondary underline decoration-line underline-offset-4 hover:text-primary">Read disclaimer</a>
				</p>

				<div class="mt-6 xl:hidden">
					<CtaButton href="#schedule-generator-panel" variant="primary" size="large">
						Generate my 2-2-5-5 calendar
					</CtaButton>
				</div>
			</div>

			<div class="hero-generator-shell relative w-full min-w-0 xl:sticky xl:top-24 xl:min-w-[704px] xl:max-w-[720px] xl:justify-self-end">
				<div class="grid gap-5">
					<section id="calendar-glance" class="soft-card scroll-mt-24 rounded-[1.5rem] p-5" aria-labelledby="calendar-glance-title">
						<h2 id="calendar-glance-title" class="text-lg font-semibold tracking-[-0.03em] text-primary">
							{calendarGlance.title}
						</h2>
						<div class="mt-4 overflow-x-auto">
							{calendarGlance.weeks.map((week, weekIndex) => (
								<div class:list={[weekIndex > 0 && 'mt-4']}>
									<p class="mb-2 text-xs font-semibold uppercase tracking-[0.14em] text-muted">{calendarGlance.weekLabels[weekIndex]}</p>
									<table class="w-full min-w-[320px] border-collapse text-center text-sm">
										<thead>
											<tr>
												{calendarGlance.dayLabels.map((day) => (
													<th class="px-1 py-2 text-xs font-semibold uppercase tracking-[0.1em] text-muted">{day}</th>
												))}
											</tr>
										</thead>
										<tbody>
											<tr>
												{week.map((parent) => (
													<td class="px-1 py-2">
														<span
															class:list={[
																'inline-flex h-8 w-8 items-center justify-center rounded-lg text-xs font-bold',
																parent === 'A'
																	? 'bg-accent/15 text-accent'
																	: 'bg-surface/80 text-secondary shadow-[inset_0_0_0_1px_var(--border-subtle)]',
															]}
														>
															{parent}
														</span>
													</td>
												))}
											</tr>
										</tbody>
									</table>
								</div>
							))}
						</div>
						<div class="mt-4 space-y-2">
							{calendarGlance.notes.map((note) => (
								<p class="text-xs leading-5 text-secondary">{note}</p>
							))}
						</div>
					</section>

					<div id="schedule-generator-panel" class="premium-card relative overflow-visible rounded-[1.75rem] border-line p-4 sm:rounded-[2.25rem] sm:p-5">
						<p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">2-2-5-5 calendar</p>
						<p class="mt-2 text-sm leading-6 text-secondary">
							Set a start date and parent names to see fixed weekdays and alternating five-day blocks on your month.
						</p>
						<div class="hero-generator-inner mt-4 rounded-[1.4rem] bg-surface-elevated p-0 shadow-[inset_0_1px_0_rgba(255,255,255,0.07)] sm:rounded-[1.8rem]">
							<div class="hero-generator-grid generator-shell grid grid-cols-1 items-start gap-6 xl:grid-cols-[minmax(380px,1fr)_260px]">
								<div class="generator-form-panel min-w-0">
									<GeneratorPanel selectedScheduleId="2255" compact />
								</div>
								<div class="hero-calendar-column calendar-preview-panel grid w-full min-w-0 gap-3 xl:w-[260px] xl:min-w-[260px]">
									<CalendarPreview schedule={generatedSchedule}>
										<ExportActions slot="actions" />
									</CalendarPreview>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<ArticleTOC items={articleTocItems} />

		<section id="week-never-changes" class="container-shell scroll-mt-24 pb-section" aria-labelledby="week-never-changes-title">
			<div class="max-w-3xl">
				<p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">Fixed weekday routine</p>
				<h2 id="week-never-changes-title" class="mt-3 text-3xl font-semibold tracking-[-0.04em] text-primary sm:text-4xl">
					{weekNeverChanges.title}
				</h2>
				<p class="mt-4 text-base leading-7 text-secondary">{weekNeverChanges.intro}</p>
			</div>
			<div class="mt-8 max-w-3xl space-y-4">
				{weekNeverChanges.weekdays.map((entry) => (
					<article class="soft-card rounded-[1.25rem] p-4">
						<p class="text-sm font-semibold text-accent">{entry.day}</p>
						<p class="mt-2 text-sm leading-6 text-secondary">{entry.details}</p>
					</article>
				))}
				<p class="text-base leading-7 text-secondary">{weekNeverChanges.close}</p>
			</div>
		</section>

		<section id="fixed-days" class="container-shell scroll-mt-24 py-section" aria-labelledby="fixed-days-title">
			<div class="max-w-3xl">
				<p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">Fixed weekday duties</p>
				<h2 id="fixed-days-title" class="mt-3 text-3xl font-semibold tracking-[-0.04em] text-primary sm:text-4xl">
					{fixedDaysSection.title}
				</h2>
				<p class="mt-4 text-base leading-7 text-secondary">{fixedDaysSection.intro}</p>
			</div>
			<div class="mt-8 max-w-3xl space-y-8">
				{fixedDaysSection.scenarios.map((scenario) => (
					<article>
						<h3 class="text-xl font-semibold tracking-[-0.03em] text-primary">{scenario.heading}</h3>
						<p class="mt-3 text-base leading-7 text-secondary">{scenario.body}</p>
					</article>
				))}
				<p class="text-base leading-7 text-secondary">{fixedDaysSection.close}</p>
			</div>
		</section>

		<section id="vs-5225" class="container-shell scroll-mt-24 py-section" aria-labelledby="vs-5225-title">
			<div class="max-w-3xl">
				<p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">2-2-5-5 vs 5-2-2-5</p>
				<h2 id="vs-5225-title" class="mt-3 text-3xl font-semibold tracking-[-0.04em] text-primary sm:text-4xl">
					{vs5225.title}
				</h2>
				<p class="mt-4 text-base leading-7 text-secondary">{vs5225.intro}</p>
			</div>
			<div class="mt-8 max-w-3xl space-y-6">
				{vs5225.families.map((family) => (
					<article class="soft-card rounded-[1.5rem] p-5">
						<h3 class="text-lg font-semibold text-primary">{family.title}</h3>
						<p class="mt-3 text-sm leading-6 text-secondary">{family.situation}</p>
						<p class="mt-3 text-sm leading-6 text-secondary">
							<span class="font-semibold text-accent">Why:</span>{' '}
							<span set:html={family.why} />
						</p>
					</article>
				))}
				<p class="text-base leading-7 text-secondary">{vs5225.close}</p>
			</div>
		</section>

		<section id="work-schedules" class="container-shell scroll-mt-24 py-section" aria-labelledby="work-schedules-title">
			<div class="max-w-3xl">
				<p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">Work and shifts</p>
				<h2 id="work-schedules-title" class="mt-3 text-3xl font-semibold tracking-[-0.04em] text-primary sm:text-4xl">
					{workSchedulesSection.title}
				</h2>
				<p class="mt-4 text-base leading-7 text-secondary">{workSchedulesSection.intro}</p>
			</div>
			<div class="mt-8 max-w-3xl space-y-8">
				{workSchedulesSection.examples.map((example) => (
					<article>
						<h3 class="text-xl font-semibold tracking-[-0.03em] text-primary">{example.heading}</h3>
						<p class="mt-3 text-base leading-7 text-secondary">{example.body}</p>
					</article>
				))}
				<p class="text-base leading-7 text-secondary">{workSchedulesSection.close}</p>
			</div>
		</section>

		<section id="problems" class="container-shell scroll-mt-24 py-section" aria-labelledby="problems-title">
			<div class="max-w-3xl">
				<p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">2-2-5-5 troubleshooting</p>
				<h2 id="problems-title" class="mt-3 text-3xl font-semibold tracking-[-0.04em] text-primary sm:text-4xl">
					{problemsSection.title}
				</h2>
				<p class="mt-4 text-base leading-7 text-secondary">{problemsSection.intro}</p>
			</div>
			<div class="mt-8 max-w-3xl space-y-6">
				{problemsSection.problems.map((item) => (
					<article class="soft-card rounded-[1.5rem] p-5">
						<h3 class="text-lg font-semibold text-primary">{item.problem}</h3>
						<p class="mt-3 text-sm leading-6 text-secondary">
							<span class="font-semibold text-accent">What helps:</span> {item.solution}
						</p>
					</article>
				))}
			</div>
		</section>

		<section id="parenting-plan" class="container-shell scroll-mt-24 py-section" aria-labelledby="parenting-plan-title">
			<div class="max-w-3xl">
				<p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">Fixed weekday plan clause</p>
				<h2 id="parenting-plan-title" class="mt-3 text-3xl font-semibold tracking-[-0.04em] text-primary sm:text-4xl">
					{parentingPlanSection.title}
				</h2>
				<p class="mt-4 text-base leading-7 text-secondary">{parentingPlanSection.intro}</p>
				<ul class="mt-4 space-y-2 text-sm leading-6 text-secondary">
					{parentingPlanSection.topics.map((topic) => (
						<li class="flex gap-2">
							<span class="text-accent" aria-hidden="true">•</span>
							{topic}
						</li>
					))}
				</ul>
				<figure class="premium-card mt-6 rounded-[1.5rem] p-5">
					<blockquote class="text-sm leading-7 text-secondary">{parentingPlanSection.clause}</blockquote>
					<figcaption class="mt-4 rounded-2xl bg-page/55 p-3 text-sm leading-6 text-secondary shadow-[inset_0_0_0_1px_var(--border-subtle)]">
						{parentingPlanSection.disclaimer}
					</figcaption>
				</figure>
			</div>
		</section>

		<section id="faq" class="container-shell scroll-mt-24 pb-section" aria-labelledby="faq-title">
			<div class="max-w-3xl">
				<h2 id="faq-title" class="text-3xl font-semibold tracking-[-0.04em] text-primary">2-2-5-5 Custody Schedule FAQ</h2>
				<div class="mt-6">
					<FAQ items={faqItems} />
				</div>
			</div>
		</section>
	</main>
	<Footer />
</BaseLayout>
