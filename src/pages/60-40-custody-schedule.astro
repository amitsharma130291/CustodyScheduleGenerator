---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import FAQ from '../components/FAQ.astro';
import CtaButton from '../components/CtaButton.astro';
import ArticleTOC from '../components/ArticleTOC.astro';
import ScheduleHeroCalendarGlance from '../components/schedules/ScheduleHeroCalendarGlance.astro';
import ScheduleHeroGeneratorPanel from '../components/schedules/ScheduleHeroGeneratorPanel.astro';
import { generateSchedule } from '../lib/schedules/generateSchedule';
import { getDefaultStartDate } from '../lib/schedules/format';
import { getCanonicalUrl } from '../lib/seo/metadata';
import {
	buildArticleSchema,
	buildBreadcrumbSchema,
	buildFAQSchema,
	buildWebPageSchema,
} from '../lib/seo/schema';
import {
	articleTocItems,
	builderHelp,
	calendarGlance,
	editorialReview,
	faqItems,
	faqSection,
	hero,
	heroTrustSignals,
	meta,
	planLanguage,
	problemsFixes,
	quickFacts,
	transitions,
	vsFiftyFifty,
	vsSeventyThirty,
	weekInFamily,
} from '../data/sixtyFortyCustodySchedule';

const canonical = '/60-40-custody-schedule/';
const canonicalUrl = getCanonicalUrl(canonical);
const startDate = getDefaultStartDate();
const generatedSchedule = generateSchedule({
	scheduleId: '60-40',
	startDate,
	parentNames: { parentA: 'Parent A', parentB: 'Parent B' },
});

const breadcrumbs = [
	{ name: 'Home', url: getCanonicalUrl('/') },
	{ name: 'Schedules', url: getCanonicalUrl('/custody-schedule-generator/') },
	{ name: '60/40 Custody Schedule', url: canonicalUrl },
];

const schema = [
	buildWebPageSchema({ name: meta.title, description: meta.description, url: canonicalUrl }),
	buildArticleSchema({
		headline: hero.headline,
		description: meta.description,
		url: canonicalUrl,
		datePublished: meta.datePublished,
		dateModified: meta.dateModified,
		authorName: editorialReview.reviewer,
	}),
	buildFAQSchema(faqItems),
	buildBreadcrumbSchema(breadcrumbs),
	{
		'@context': 'https://schema.org',
		'@type': 'WebApplication',
		name: '60/40 Custody Schedule Calendar Generator',
		description: meta.description,
		url: canonicalUrl,
		inLanguage: 'en-US',
		areaServed: 'US',
		applicationCategory: 'LegalApplication',
		operatingSystem: 'Web',
		offers: {
			'@type': 'Offer',
			price: '0',
			priceCurrency: 'USD',
		},
	},
	{
		'@context': 'https://schema.org',
		'@type': 'HowTo',
		name: 'How to create a 60/40 Custody Schedule',
		description: 'Use the custody calendar generator to preview, compare, and export a 60/40 parenting schedule.',
		inLanguage: 'en-US',
		totalTime: 'PT5M',
		step: [
			{
				'@type': 'HowToStep',
				name: 'Choose the 60/40 schedule type',
				text: 'Select 60/40 Custody Schedule in the generator.',
			},
			{
				'@type': 'HowToStep',
				name: 'Pick a pattern and start date',
				text: 'Compare 4-3, extended weekend, and exact 60/40 ten-day patterns.',
			},
			{
				'@type': 'HowToStep',
				name: 'Review overnight percentages',
				text: 'Check the monthly calendar and generated annual average before exporting or printing.',
			},
		],
	},
];
---

<BaseLayout title={meta.title} description={meta.description} canonical={canonical}>
	<JsonLd slot="head" data={schema} />
	<Navbar />
	<Breadcrumbs items={breadcrumbs} />
	<main>
		<section
			class="container-shell grid grid-cols-1 gap-5 py-4 sm:py-5 lg:grid-cols-[minmax(0,0.88fr)_minmax(704px,1.12fr)] lg:items-start lg:gap-7 lg:py-6 xl:w-[min(100%,1360px)]"
			id="schedule-generator"
		>
			<div class="order-1 min-w-0 lg:col-start-1 lg:row-start-1 lg:pt-1">
				<p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">60/40 calendar generator</p>
				<h1 class="mt-2.5 max-w-3xl text-4xl font-semibold leading-[0.98] tracking-[-0.055em] text-primary sm:text-5xl">
					{hero.headline}
				</h1>
				{hero.intro.map((paragraph) => (
					<p class="mt-3 max-w-2xl text-base leading-7 text-secondary">{paragraph}</p>
				))}
				<p class="mt-2 max-w-2xl text-sm leading-6 text-secondary">
					<a href="/custody-schedule-generator/" class="font-semibold text-accent underline decoration-line underline-offset-4 hover:text-primary">Build a 60/40 calendar</a>.
				</p>

				<dl class="mt-4 grid gap-2 sm:grid-cols-3">
					{quickFacts.items.map((fact) => (
						<div class="rounded-[1rem] bg-surface/70 px-3 py-2.5 shadow-[inset_0_0_0_1px_var(--border-subtle)]">
							<dt class="text-[10px] font-semibold uppercase tracking-[0.12em] text-muted">{fact.label}</dt>
							<dd class="mt-1 text-xs font-semibold leading-5 text-primary">{fact.value}</dd>
						</div>
					))}
				</dl>

			</div>

			<ScheduleHeroGeneratorPanel
				selectedScheduleId="60-40"
				generatedSchedule={generatedSchedule}
				heroTrustSignals={heroTrustSignals}
			/>

			<div class="order-3 min-w-0 lg:col-start-1 lg:row-start-2">
				<ScheduleHeroCalendarGlance
					calendarGlance={calendarGlance}
					legendA="60% home"
					legendB="40% block"
				/>
				<p class="mt-3 text-xs leading-5 text-muted">
					Not legal advice.
					<a href="/disclaimer/" class="ml-1 font-semibold text-secondary underline decoration-line underline-offset-4 hover:text-primary">Read disclaimer</a>
				</p>
			</div>
		</section>

		<section id="editorial-review" class="container-shell pb-5">
			<div class="max-w-3xl rounded-2xl bg-page/70 p-4 text-sm leading-6 text-secondary shadow-[inset_0_0_0_1px_var(--border-subtle)]">
				<p>
					<strong class="text-primary">Last reviewed: {editorialReview.lastReviewed}</strong>
					<br />
					Reviewed by:{' '}
					<a href={editorialReview.reviewerHref} class="font-semibold text-accent underline decoration-line underline-offset-4 hover:text-primary">
						{editorialReview.reviewer}
					</a>
				</p>
				<p class="mt-2">{editorialReview.body}</p>
			</div>
		</section>

		<ArticleTOC items={articleTocItems} />

		<section id="week-in-family" class="container-shell scroll-mt-24 pb-section" aria-labelledby="week-in-family-title">
			<div class="max-w-3xl">
				<p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">Real-life 60/40</p>
				<h2 id="week-in-family-title" class="mt-3 text-3xl font-semibold tracking-[-0.04em] text-primary sm:text-4xl">
					{weekInFamily.title}
				</h2>
				<p class="mt-2 text-lg font-medium text-secondary">{weekInFamily.subtitle}</p>
				<p class="mt-4 text-base leading-7 text-secondary">{weekInFamily.intro}</p>
			</div>
			<div class="mt-8 max-w-3xl space-y-6">
				{weekInFamily.days.map((item) => (
					<article class="soft-card rounded-[1.5rem] p-5">
						<p class="text-xs font-semibold uppercase tracking-[0.14em] text-accent">{item.day}</p>
						<h3 class="mt-2 text-xl font-semibold tracking-[-0.03em] text-primary">{item.heading}</h3>
						<p class="mt-3 text-base leading-7 text-secondary">{item.body}</p>
					</article>
				))}
				<p class="text-base leading-7 text-secondary" set:html={weekInFamily.close} />
			</div>
		</section>

		<section id="vs-fifty-fifty" class="container-shell scroll-mt-24 py-section" aria-labelledby="vs-fifty-fifty-title">
			<div class="max-w-3xl">
				<p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">60/40 vs 50/50</p>
				<h2 id="vs-fifty-fifty-title" class="mt-3 text-3xl font-semibold tracking-[-0.04em] text-primary sm:text-4xl">
					{vsFiftyFifty.title}
				</h2>
				<p class="mt-4 text-base leading-7 text-secondary">{vsFiftyFifty.intro}</p>
			</div>
			<div class="mt-8 max-w-3xl space-y-6">
				{vsFiftyFifty.differences.map((item) => (
					<article>
						<h3 class="text-xl font-semibold tracking-[-0.03em] text-primary">{item.heading}</h3>
						<p class="mt-3 text-base leading-7 text-secondary" set:html={item.body} />
					</article>
				))}
				<p class="text-base leading-7 text-secondary">{vsFiftyFifty.close}</p>
			</div>
		</section>

		<section id="vs-seventy-thirty" class="container-shell scroll-mt-24 py-section" aria-labelledby="vs-seventy-thirty-title">
			<div class="max-w-3xl">
				<p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">60/40 vs 70/30</p>
				<h2 id="vs-seventy-thirty-title" class="mt-3 text-3xl font-semibold tracking-[-0.04em] text-primary sm:text-4xl">
					{vsSeventyThirty.title}
				</h2>
				<p class="mt-4 text-base leading-7 text-secondary">{vsSeventyThirty.intro}</p>
			</div>
			<div class="mt-8 max-w-3xl space-y-6">
				{vsSeventyThirty.points.map((item) => (
					<article>
						<h3 class="text-xl font-semibold tracking-[-0.03em] text-primary">{item.heading}</h3>
						<p class="mt-3 text-base leading-7 text-secondary" set:html={item.body} />
					</article>
				))}
				<p class="text-base leading-7 text-secondary">{vsSeventyThirty.close}</p>
			</div>
		</section>

		<section id="problems-fixes" class="container-shell scroll-mt-24 py-section" aria-labelledby="problems-fixes-title">
			<div class="max-w-3xl">
				<p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">60/40 failure points</p>
				<h2 id="problems-fixes-title" class="mt-3 text-3xl font-semibold tracking-[-0.04em] text-primary sm:text-4xl">
					{problemsFixes.title}
				</h2>
				<p class="mt-4 text-base leading-7 text-secondary">{problemsFixes.intro}</p>
			</div>
			<div class="mt-8 max-w-3xl space-y-4">
				{problemsFixes.items.map((item) => (
					<article class="soft-card rounded-[1.25rem] p-4">
						<h3 class="text-lg font-semibold text-primary">{item.title}</h3>
						<p class="mt-3 text-sm leading-6 text-secondary">{item.stakes}</p>
						<p class="mt-3 text-sm leading-6 text-secondary">
							<span class="font-semibold text-accent">Practical fix:</span> {item.fix}
						</p>
					</article>
				))}
			</div>
		</section>

		<section id="transitions" class="container-shell scroll-mt-24 py-section" aria-labelledby="transitions-title">
			<div class="max-w-3xl">
				<p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">Schedule shifts</p>
				<h2 id="transitions-title" class="mt-3 text-3xl font-semibold tracking-[-0.04em] text-primary sm:text-4xl">
					{transitions.title}
				</h2>
				<p class="mt-4 text-base leading-7 text-secondary">{transitions.intro}</p>
			</div>
			<div class="mt-8 max-w-3xl space-y-6">
				{transitions.scenarios.map((scenario) => (
					<article class="soft-card rounded-[1.5rem] p-5">
						<p class="text-xs font-semibold uppercase tracking-[0.14em] text-muted">{scenario.direction}</p>
						<h3 class="mt-2 text-lg font-semibold text-primary">{scenario.heading}</h3>
						<p class="mt-3 text-base leading-7 text-secondary" set:html={scenario.body} />
					</article>
				))}
				<p class="text-base leading-7 text-secondary">{transitions.close}</p>
			</div>
		</section>

		<section id="plan-language" class="container-shell scroll-mt-24 py-section" aria-labelledby="plan-language-title">
			<div class="max-w-3xl">
				<p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">Written plan language</p>
				<h2 id="plan-language-title" class="mt-3 text-3xl font-semibold tracking-[-0.04em] text-primary sm:text-4xl">
					{planLanguage.title}
				</h2>
				<p class="mt-4 text-sm leading-6 text-muted">{planLanguage.disclaimer}</p>
				<p class="mt-2 text-sm leading-6 text-secondary">{planLanguage.adaptationNote}</p>
				<p class="mt-4 text-base leading-7 text-secondary">{planLanguage.intro}</p>
				<p class="mt-3 text-base leading-7 text-secondary">{planLanguage.whyItHelps}</p>
			</div>
			<div class="mt-6 max-w-3xl">
				<blockquote class="soft-card rounded-[1.5rem] border-l-4 border-accent p-5 text-sm leading-7 text-secondary">
					{planLanguage.clause}
				</blockquote>
				<ul class="mt-4 space-y-2 text-sm leading-6 text-secondary">
					{planLanguage.notes.map((note) => (
						<li class="flex gap-2">
							<span class="text-accent" aria-hidden="true">→</span>
							{note}
						</li>
					))}
				</ul>
				<p class="mt-4 text-sm leading-6 text-secondary">
					Organize exchanges, holidays, and change rules in the{' '}
					<a href="/parenting-plan-template/" class="font-semibold text-accent underline decoration-line underline-offset-4 hover:text-primary">parenting plan template</a>.
				</p>
			</div>
		</section>

		<section id="builder-help" class="container-shell scroll-mt-24 py-section" aria-labelledby="builder-help-title">
			<div class="max-w-3xl">
				<p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">Pattern testing</p>
				<h2 id="builder-help-title" class="mt-3 text-3xl font-semibold tracking-[-0.04em] text-primary sm:text-4xl">
					{builderHelp.title}
				</h2>
				<p class="mt-4 text-base leading-7 text-secondary" set:html={builderHelp.intro} />
				<ul class="mt-4 space-y-2 text-sm leading-6 text-secondary">
					{builderHelp.features.map((feature) => (
						<li class="flex gap-2">
							<span class="text-accent" aria-hidden="true">→</span>
							{feature}
						</li>
					))}
				</ul>
				<p class="mt-4 text-sm leading-6 text-secondary">
					Verify overnight totals with the{' '}
					<a href="/custody-percentage-calculator/" class="font-semibold text-accent underline decoration-line underline-offset-4 hover:text-primary">custody percentage calculator</a>.
				</p>
				<div class="mt-6">
					<CtaButton href="#schedule-generator-panel" variant="primary" size="large">
						{builderHelp.cta}
					</CtaButton>
				</div>
			</div>
		</section>

		<FAQ
			items={faqItems}
			title={faqSection.title}
			description={faqSection.description}
		/>
	</main>
	<Footer />
</BaseLayout>
