---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import GeneratorPanel from '../components/tool/GeneratorPanel.astro';
import CalendarPreview from '../components/tool/CalendarPreview.astro';
import ExportActions from '../components/tool/ExportActions.astro';
import PrintableSchedule from '../components/tool/PrintableSchedule.astro';
import { generateSchedule } from '../lib/schedules/generateSchedule';
import { getDefaultStartDate } from '../lib/schedules/format';
import { getCanonicalUrl } from '../lib/seo/metadata';
import {
	buildBreadcrumbSchema,
	buildFAQSchema,
	buildWebPageSchema,
} from '../lib/seo/schema';

const title = 'Custody Calendar Template | Printable Parenting Schedule';
const description =
	'Use a custody calendar template to organize parenting time, exchanges, holidays, school breaks, and visitation days.';
const canonical = '/custody-calendar-template/';
const canonicalUrl = getCanonicalUrl(canonical);
const generatedSchedule = generateSchedule({
	scheduleId: '223',
	startDate: getDefaultStartDate(),
	parentNames: {
		parentA: 'Parent A',
		parentB: 'Parent B',
	},
});
const exampleWeeks = [
	{
		label: 'Week 1',
		blocks: [
			{ day: 'Monday', parent: 'Parent A' },
			{ day: 'Tuesday', parent: 'Parent A' },
			{ day: 'Wednesday', parent: 'Parent B' },
			{ day: 'Thursday', parent: 'Parent B' },
			{ day: 'Friday-Sunday', parent: 'Parent A' },
		],
	},
	{
		label: 'Week 2',
		blocks: [
			{ day: 'Monday', parent: 'Parent B' },
			{ day: 'Tuesday', parent: 'Parent B' },
			{ day: 'Wednesday', parent: 'Parent A' },
			{ day: 'Thursday', parent: 'Parent A' },
			{ day: 'Friday-Sunday', parent: 'Parent B' },
		],
	},
];
const includeItems = [
	'Parenting time days',
	'Overnights',
	'Exchange days',
	'Holidays',
	'School breaks',
	'Summer schedule',
	'Notes or special arrangements',
];
const comparisonRows = [
	{
		tool: 'Custody calendar template',
		bestFor: 'A visual month-by-month calendar for parenting time and exchanges.',
		href: '/custody-calendar-template/',
	},
	{
		tool: 'Custody schedule template',
		bestFor: 'A written rotation or parenting plan structure.',
		href: '/custody-schedule-template/',
	},
	{
		tool: 'Custody percentage calculator',
		bestFor: 'Calculating parenting time percentages from overnight totals.',
		href: '/custody-percentage-calculator/',
	},
];
const calendarPatterns = [
	{
		title: '2-2-3 Custody Schedule',
		href: '/2-2-3-custody-schedule/',
		description: 'A frequent-contact 50/50 pattern with alternating weekends.',
	},
	{
		title: '2-2-5-5 Custody Schedule',
		href: '/2-2-5-5-custody-schedule/',
		description: 'A steady weekday rotation that keeps the same midweek days.',
	},
	{
		title: '5-2-2-5 Custody Schedule',
		href: '/5-2-2-5-custody-schedule/',
		description: 'A two-week rotation that balances weekdays and weekends.',
	},
	{
		title: '3-4-4-3 Custody Schedule',
		href: '/3-4-4-3-custody-schedule/',
		description: 'A predictable two-week calendar with fewer exchanges.',
	},
	{
		title: 'Week On Week Off Custody Schedule',
		href: '/week-on-week-off-custody-schedule/',
		description: 'Alternating full weeks for older children and simpler exchanges.',
	},
	{
		title: '50/50 Custody Schedule',
		href: '/50-50-custody-schedule/',
		description: 'Compare common equal parenting time schedule patterns.',
	},
];
const faq = [
	{
		question: 'What is a custody calendar template?',
		answer:
			'A custody calendar template is a visual parenting time calendar for mapping overnights, exchanges, holidays, and recurring custody schedule patterns.',
	},
	{
		question: 'Can I print this custody calendar?',
		answer:
			'Yes. Use the Print button in the calendar tool to create a printable custody calendar for review, planning, or co-parenting discussions.',
	},
	{
		question: 'What should a custody calendar include?',
		answer:
			'A useful custody calendar usually includes parenting days, overnights, exchange days, holidays, school breaks, summer schedules, and notes for special arrangements.',
	},
	{
		question: 'Is this the same as a parenting plan?',
		answer:
			'No. A custody calendar is a visual planning tool. A parenting plan is usually a fuller written agreement that may cover decision-making, transportation, communication, and dispute rules.',
	},
	{
		question: 'Can I use this for visitation schedules?',
		answer:
			'Yes. The same custody calendar example format can help visualize visitation days, overnight schedules, and parenting time percentages.',
	},
	{
		question: 'Does this replace legal advice?',
		answer:
			'No. This template is for planning and education only. Custody rules vary by jurisdiction, so speak with a qualified professional for legal advice.',
	},
];
const relatedLinks = [
	{
		title: 'Custody Schedule Template',
		href: '/custody-schedule-template/',
		description: 'Use a written structure for parenting time rotations.',
	},
	{
		title: 'Custody Percentage Calculator',
		href: '/custody-percentage-calculator/',
		description: 'Calculate parenting time percentages from overnight counts.',
	},
	{
		title: 'Visitation Calculator',
		href: '/visitation-calculator/',
		description: 'Estimate visitation percentages and parenting time totals.',
	},
	{
		title: '50/50 Custody Schedule',
		href: '/50-50-custody-schedule/',
		description: 'Compare common equal parenting schedule patterns.',
	},
	{
		title: '2-2-3 Custody Schedule',
		href: '/2-2-3-custody-schedule/',
		description: 'Preview a common alternating weekend custody calendar.',
	},
	{
		title: 'Parenting Plan Template',
		href: '/parenting-plan-template/',
		description: 'Document calendar rules, holidays, exchanges, and decision-making details.',
	},
	{
		title: 'Holiday Custody Schedule',
		href: '/holiday-custody-schedule/',
		description: 'Add holidays, school breaks, and special days to the regular calendar.',
	},
];
const breadcrumbs = [
	{ name: 'Home', url: getCanonicalUrl('/') },
	{ name: 'Templates', url: getCanonicalUrl('/custody-schedule-template/') },
	{ name: 'Custody Calendar Template', url: canonicalUrl },
];
const schema = [
	buildFAQSchema(faq),
	buildBreadcrumbSchema(breadcrumbs),
	buildWebPageSchema({ name: title, description, url: canonicalUrl }),
];
---

<BaseLayout title={title} description={description} canonical={canonical}>
	<JsonLd slot="head" data={schema} />
	<Navbar />
	<Breadcrumbs items={breadcrumbs} />
	<main>
		<section id="template" class="container-shell grid gap-8 py-12 lg:grid-cols-[0.9fr_1.1fr] lg:items-start lg:py-16">
			<div>
				<p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">Parenting time calendar template</p>
				<h1 class="mt-4 max-w-3xl text-5xl font-semibold leading-[0.98] tracking-[-0.055em] text-primary lg:text-6xl">
					Custody Calendar Template
				</h1>
				<p class="mt-6 max-w-2xl text-lg leading-8 text-secondary">
					Create a clear custody calendar template for parenting time, visitation days, and overnight schedules. Choose a schedule pattern, set a start date, and preview a printable custody calendar for planning.
				</p>
				<div class="mt-8 flex flex-col gap-3 sm:flex-row">
					<a href="#template" class="btn-primary inline-flex h-13 w-full items-center justify-center rounded-full px-8 text-base font-semibold transition-all duration-200 ease-out hover:-translate-y-px hover:shadow-[0_10px_30px_rgba(37,99,235,0.14)] active:translate-y-0 sm:w-auto">
						Create Calendar
					</a>
					<a href="#patterns" class="btn-secondary inline-flex h-13 w-full items-center justify-center rounded-full px-8 text-base font-semibold transition-all duration-200 ease-out hover:-translate-y-px hover:shadow-[0_10px_24px_rgba(0,0,0,0.12)] active:translate-y-0 sm:w-auto">
						View Schedule Examples
					</a>
				</div>
			</div>

			<div class="hero-generator-shell schedule-generator-shell relative">
				<div class="absolute -inset-8 rounded-full bg-[radial-gradient(circle,rgba(37,99,235,0.16),transparent_66%)] blur-3xl" aria-hidden="true"></div>
				<div class="premium-card hero-generator-card schedule-generator-card relative overflow-visible rounded-[1.75rem] border-line p-4 sm:rounded-[2.25rem] sm:p-5">
					<div class="absolute inset-x-10 top-0 h-px bg-gradient-to-r from-transparent via-white/30 to-transparent" aria-hidden="true"></div>
					<div class="hero-generator-inner rounded-[1.4rem] bg-surface-elevated p-0 shadow-[inset_0_1px_0_rgba(255,255,255,0.07)] sm:rounded-[1.8rem]">
						<div class="hero-generator-grid">
							<GeneratorPanel selectedScheduleId="223" compact />
							<div class="hero-calendar-column grid gap-3">
								<CalendarPreview schedule={generatedSchedule}>
									<ExportActions slot="actions" />
								</CalendarPreview>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<section class="container-shell grid gap-8 py-12 lg:grid-cols-[0.72fr_1.28fr] lg:py-16">
			<aside class="h-fit">
				<details class="group soft-card rounded-[1.5rem] p-5 md:hidden">
					<summary class="flex cursor-pointer list-none items-center justify-between gap-4 text-sm font-semibold text-primary">
						Jump to section
						<span class="text-muted transition-transform duration-200 group-open:rotate-180" aria-hidden="true">▼</span>
					</summary>
					<ul class="mt-4 space-y-3 text-sm text-secondary">
						<li><a href="#template" class="hover:text-primary">Template</a></li>
						<li><a href="#how-to-use" class="hover:text-primary">How to use</a></li>
						<li><a href="#include" class="hover:text-primary">What to include</a></li>
						<li><a href="#examples" class="hover:text-primary">Examples</a></li>
						<li><a href="#faq" class="hover:text-primary">FAQ</a></li>
						<li><a href="#related" class="hover:text-primary">Related tools</a></li>
					</ul>
				</details>
				<div class="soft-card hidden rounded-[1.5rem] p-6 md:block">
					<p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">On this page</p>
					<ul class="mt-4 space-y-3 text-sm text-secondary">
						<li><a href="#template" class="hover:text-primary">Template</a></li>
						<li><a href="#how-to-use" class="hover:text-primary">How to use</a></li>
						<li><a href="#include" class="hover:text-primary">What to include</a></li>
						<li><a href="#examples" class="hover:text-primary">Examples</a></li>
						<li><a href="#faq" class="hover:text-primary">FAQ</a></li>
						<li><a href="#related" class="hover:text-primary">Related tools</a></li>
					</ul>
				</div>
			</aside>

			<div class="grid gap-10">
				<section id="how-to-use" class="grid gap-4">
					<h2 class="text-3xl font-semibold tracking-[-0.04em] text-primary">How to use this custody calendar template</h2>
					<p class="text-base leading-8 text-secondary">
						Choose a schedule pattern, enter a start date, and name Parent A and Parent B. The calendar preview updates as you change the details so you can review parenting time, overnights, and exchange rhythm before printing or comparing it with a <a href="/custody-schedule-template/" class="font-medium text-primary hover:text-accent">custody schedule template</a>.
					</p>
					<p class="text-base leading-8 text-secondary">
						When the calendar looks right, use Print for a clean printable view or Copy link to share the current schedule, start date, and parent names.
					</p>
				</section>

				<section id="include" class="grid gap-5">
					<div>
						<p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">Calendar details</p>
						<h2 class="mt-2 text-3xl font-semibold tracking-[-0.04em] text-primary">What to include in a custody calendar</h2>
						<p class="mt-3 text-base leading-8 text-secondary">
							A useful parenting time calendar should make the practical details easy to scan, especially when you also need to calculate percentages with a <a href="/custody-percentage-calculator/" class="font-medium text-primary hover:text-accent">custody percentage calculator</a>.
						</p>
					</div>
					<div class="grid gap-4 sm:grid-cols-2">
						{includeItems.map((item) => (
							<div class="soft-card rounded-[1.5rem] p-5">
								<h3 class="text-lg font-semibold tracking-[-0.03em] text-primary">{item}</h3>
							</div>
						))}
					</div>
				</section>

				<section id="examples" class="grid gap-5">
					<div>
						<p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">Example</p>
						<h2 class="mt-2 text-3xl font-semibold tracking-[-0.04em] text-primary">Printable custody calendar example</h2>
						<p class="mt-3 text-base leading-8 text-secondary">
							This printable custody calendar example shows how parenting time can be organized across a repeating schedule.
						</p>
						<p class="mt-3 text-base leading-8 text-secondary">
							A 2-2-3 custody calendar gives Parent A two days, Parent B two days, then alternates the long weekend. The next week flips so both parents get regular weekday time and alternating weekends. For more equal-time options, compare common <a href="/50-50-custody-schedule/" class="font-medium text-primary hover:text-accent">50/50 custody schedules</a>.
						</p>
					</div>
					<div class="premium-card overflow-hidden rounded-[1.5rem]">
						<div class="grid divide-y divide-line-subtle md:grid-cols-2 md:divide-x md:divide-y-0">
							{exampleWeeks.map((week) => (
								<div class="p-5">
									<h3 class="text-lg font-semibold tracking-[-0.03em] text-primary">{week.label}</h3>
									<div class="mt-4 grid gap-3">
										{week.blocks.map((block) => (
											<div class="grid grid-cols-[0.45fr_0.55fr] items-center gap-4 rounded-2xl bg-surface/70 p-3 shadow-[inset_0_0_0_1px_var(--border-subtle)]">
												<p class="text-sm font-semibold text-primary">{block.parent}</p>
												<p class="text-sm text-secondary">{block.day}</p>
											</div>
										))}
									</div>
								</div>
							))}
						</div>
					</div>
					<p class="text-sm leading-6 text-muted">
						Actual calendars may include holidays, school breaks, vacations, and special arrangements.
					</p>
					<PrintableSchedule schedule={generatedSchedule} />
					<div class="soft-card rounded-[1.5rem] p-6">
						<h3 class="text-2xl font-semibold tracking-[-0.04em] text-primary">Create your printable custody calendar</h3>
						<p class="mt-3 text-sm leading-6 text-secondary">
							Generate a custody calendar, customize parent names, choose a schedule pattern, and print a clean calendar for planning purposes.
						</p>
						<div class="mt-5 flex flex-col gap-3 sm:flex-row">
							<a href="#template" class="btn-primary inline-flex h-12 w-full items-center justify-center rounded-full px-6 text-sm font-semibold transition-all duration-200 ease-out hover:-translate-y-px hover:shadow-[0_10px_30px_rgba(37,99,235,0.14)] active:translate-y-0 sm:w-auto">
								Create Calendar
							</a>
							<a href="#patterns" class="btn-secondary inline-flex h-12 w-full items-center justify-center rounded-full px-6 text-sm font-semibold transition-all duration-200 ease-out hover:-translate-y-px hover:shadow-[0_10px_24px_rgba(0,0,0,0.12)] active:translate-y-0 sm:w-auto">
								View Schedule Examples
							</a>
						</div>
					</div>
				</section>

				<section class="grid gap-5">
					<div>
						<h2 class="text-3xl font-semibold tracking-[-0.04em] text-primary">Custody calendar template vs custody schedule template</h2>
						<p class="mt-3 text-base leading-8 text-secondary">
							These tools work together, but each one answers a different planning question.
						</p>
					</div>
					<div class="premium-card overflow-x-auto rounded-[1.5rem]">
						<table class="w-full min-w-[680px] border-collapse text-left text-sm">
							<thead class="text-xs uppercase tracking-[0.14em] text-muted">
								<tr class="border-b border-line-subtle">
									<th class="px-5 py-4 font-semibold">Tool</th>
									<th class="px-5 py-4 font-semibold">Best for</th>
								</tr>
							</thead>
							<tbody class="divide-y divide-line-subtle text-secondary">
								{comparisonRows.map((row) => (
									<tr>
										<td class="px-5 py-4 font-semibold text-primary"><a href={row.href} class="hover:text-accent">{row.tool}</a></td>
										<td class="px-5 py-4">{row.bestFor}</td>
									</tr>
								))}
							</tbody>
						</table>
					</div>
				</section>

				<section id="patterns" class="grid gap-5">
					<div>
						<p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">Schedule examples</p>
						<h2 class="mt-2 text-3xl font-semibold tracking-[-0.04em] text-primary">Common custody calendar patterns</h2>
						<p class="mt-3 text-base leading-8 text-secondary">
							These patterns can also help when you are building a printable custody calendar for a visitation arrangement. For percentage-only planning, use the <a href="/visitation-calculator/" class="font-medium text-primary hover:text-accent">visitation calculator</a>.
						</p>
					</div>
					<div class="grid gap-4 md:grid-cols-2">
						{calendarPatterns.map((item) => (
							<a href={item.href} class="soft-card rounded-[1.5rem] p-5">
								<h3 class="text-lg font-semibold tracking-[-0.03em] text-primary">{item.title}</h3>
								<p class="mt-2 text-sm leading-6 text-secondary">{item.description}</p>
							</a>
						))}
					</div>
				</section>

				<section id="faq" class="grid gap-5">
					<h2 class="text-3xl font-semibold tracking-[-0.04em] text-primary">FAQ</h2>
					<div class="premium-card divide-y divide-line-subtle overflow-hidden rounded-[1.5rem]">
						{faq.map((item) => (
							<details class="group p-5 transition-colors duration-200 open:bg-surface-elevated/70 hover:bg-surface-hover/60">
								<summary class="flex cursor-pointer list-none items-center justify-between gap-6 text-left text-base font-semibold tracking-[-0.02em] text-primary">
									{item.question}
									<span class="grid h-7 w-7 shrink-0 place-items-center rounded-full bg-surface/80 text-muted shadow-[inset_0_0_0_1px_var(--border-subtle)] transition-transform duration-200 group-open:rotate-45">+</span>
								</summary>
								<p class="mt-4 text-sm leading-6 text-secondary">{item.answer}</p>
							</details>
						))}
					</div>
				</section>

				<section id="related" class="grid gap-5">
					<h2 class="text-3xl font-semibold tracking-[-0.04em] text-primary">Related tools</h2>
					<div class="grid gap-4 md:grid-cols-3">
						{relatedLinks.map((item) => (
							<a href={item.href} class="soft-card rounded-[1.5rem] p-5">
								<h3 class="text-lg font-semibold tracking-[-0.03em] text-primary">{item.title}</h3>
								<p class="mt-2 text-sm leading-6 text-secondary">{item.description}</p>
							</a>
						))}
					</div>
				</section>
			</div>
		</section>
	</main>
	<Footer />
</BaseLayout>
