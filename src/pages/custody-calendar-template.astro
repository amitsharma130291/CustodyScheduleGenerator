---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import FAQ from '../components/FAQ.astro';
import CtaButton from '../components/CtaButton.astro';
import ScheduleHeroGeneratorPanel from '../components/schedules/ScheduleHeroGeneratorPanel.astro';
import TwelveMonthPreviewGraphic from '../components/schedules/custody-calendar-template/TwelveMonthPreviewGraphic.astro';
import HolidayOverlayGraphic from '../components/schedules/custody-calendar-template/HolidayOverlayGraphic.astro';
import ColorCodedMonthGraphic from '../components/schedules/custody-calendar-template/ColorCodedMonthGraphic.astro';
import { generateSchedule } from '../lib/schedules/generateSchedule';
import { getDefaultStartDate } from '../lib/schedules/format';
import { getCanonicalUrl } from '../lib/seo/metadata';
import { buildArticleSchema, buildBreadcrumbSchema, buildFAQSchema, buildWebPageSchema } from '../lib/seo/schema';
import {
	articleTocItems, colorMonth, editorialReview, faqItems, faqSection, hero, heroKeyStats, heroTrustSignals,
	holidayOverlay, meta, monthPreview, printExport, schoolSummer,
} from '../data/custodyCalendarTemplate';

const canonical = '/custody-calendar-template/';
const canonicalUrl = getCanonicalUrl(canonical);
const generatedSchedule = generateSchedule({ scheduleId: '2-2-3', startDate: getDefaultStartDate(), parentNames: { parentA: 'Parent A', parentB: 'Parent B' } });
const breadcrumbs = [{ name: 'Home', url: getCanonicalUrl('/') }, { name: 'Custody Calendar Template', url: canonicalUrl }];
const schema = [
	buildWebPageSchema({ name: meta.title, description: meta.description, url: canonicalUrl }),
	buildArticleSchema({ headline: hero.headline, description: meta.description, url: canonicalUrl, datePublished: meta.datePublished, dateModified: meta.dateModified, authorName: editorialReview.reviewer }),
	buildFAQSchema(faqItems), buildBreadcrumbSchema(breadcrumbs),
	{ '@context': 'https://schema.org', '@type': 'WebApplication', name: 'Custody Calendar Template Generator', description: meta.description, url: canonicalUrl, inLanguage: 'en-US', areaServed: 'US', applicationCategory: 'LegalApplication', operatingSystem: 'Web', offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' } },
];
---

<BaseLayout title={meta.title} description={meta.description} canonical={canonical}>
	<JsonLd slot="head" data={schema} />
	<Navbar /><Breadcrumbs items={breadcrumbs} />
	<main>
		<section class="container-shell grid grid-cols-1 gap-5 py-4 sm:py-5 lg:grid-cols-[minmax(0,0.88fr)_minmax(704px,1.12fr)] lg:items-start lg:gap-7 lg:py-6 xl:w-[min(100%,1360px)]" id="schedule-generator">
			<div class="order-1 min-w-0 lg:col-start-1 lg:row-start-1 lg:pt-1">
				<h1 class="max-w-3xl text-4xl font-semibold leading-[0.98] tracking-[-0.055em] text-primary sm:text-5xl">{hero.headline}</h1>
				<dl class="mt-4 grid grid-cols-3 gap-2">{heroKeyStats.map((s) => (<div class="rounded-[1rem] bg-accent/10 px-2 py-2.5 text-center sm:px-3"><dd class="text-lg font-bold text-accent sm:text-xl">{s.value}</dd><dt class="mt-0.5 text-[10px] font-semibold uppercase text-secondary">{s.label}</dt></div>))}</dl>
				<p class="mt-3 max-w-2xl text-base leading-7 text-secondary">{hero.intro}</p>
				<p class="mt-3 max-w-2xl text-sm leading-6 text-secondary" set:html={hero.boundary} />
				<div class="mt-3 max-w-2xl text-xs leading-5 text-muted">
					<p class="font-semibold text-secondary">Reviewed for:</p><ul class="mt-1 list-inside list-disc">{editorialReview.reviewedFor.map((i) => <li>{i}</li>)}</ul>
					<p class="mt-2">Reviewed by <a href={editorialReview.reviewerHref} class="font-semibold text-secondary underline">{editorialReview.reviewer}</a> · <a href={editorialReview.methodologyHref} class="font-semibold text-secondary underline">{editorialReview.methodologyLabel}</a> · {editorialReview.disclaimer}</p>
				</div>
			</div>
			<ScheduleHeroGeneratorPanel selectedScheduleId="2-2-3" generatedSchedule={generatedSchedule} heroTrustSignals={heroTrustSignals} />
		</section>
		<nav class="container-shell border-y border-line-subtle py-3" aria-label="On this page"><ul class="flex flex-wrap gap-x-4 gap-y-1 text-xs font-semibold text-secondary">{articleTocItems.map((i) => <li><a href={`#${i.id}`} class="hover:text-accent">{i.label}</a></li>)}</ul></nav>
		<section id="month-preview" class="container-shell scroll-mt-24 py-10 lg:py-12"><div class="grid gap-8 lg:grid-cols-[1fr_360px]"><div><h2 class="text-2xl font-semibold text-primary sm:text-3xl">{monthPreview.title}</h2><p class="mt-3 text-secondary">{monthPreview.intro}</p><ul class="mt-6 space-y-4">{monthPreview.points.map((p) => <li class="border-l-2 border-accent/30 pl-4"><h3 class="font-semibold text-primary">{p.heading}</h3><p class="mt-2 text-sm text-secondary">{p.body}</p></li>)}</ul></div><TwelveMonthPreviewGraphic /></div></section>
		<section id="holiday-overlay" class="container-shell scroll-mt-24 border-t border-line-subtle py-10 lg:py-12"><div class="grid gap-8 lg:grid-cols-[1fr_360px]"><div><h2 class="text-2xl font-semibold text-primary sm:text-3xl">{holidayOverlay.title}</h2><p class="mt-3 text-secondary">{holidayOverlay.intro}</p><ol class="mt-6 list-decimal space-y-2 pl-5 text-sm text-secondary">{holidayOverlay.steps.map((s) => <li set:html={s} />)}</ol></div><HolidayOverlayGraphic /></div></section>
		<section id="color-month" class="container-shell scroll-mt-24 border-t border-line-subtle py-10 lg:py-12"><div class="grid gap-8 lg:grid-cols-[1fr_360px]"><div><h2 class="text-2xl font-semibold text-primary sm:text-3xl">{colorMonth.title}</h2><p class="mt-3 text-secondary">{colorMonth.intro}</p><ul class="mt-6 space-y-4">{colorMonth.legend.map((l) => <li class="border-l-2 border-accent/30 pl-4"><h3 class="font-semibold text-primary">{l.heading}</h3><p class="mt-2 text-sm text-secondary">{l.body}</p></li>)}</ul></div><ColorCodedMonthGraphic /></div></section>
		<section id="school-summer" class="container-shell scroll-mt-24 border-t border-line-subtle py-10 lg:py-12"><h2 class="text-2xl font-semibold text-primary sm:text-3xl">{schoolSummer.title}</h2><p class="mt-3 max-w-3xl text-secondary">{schoolSummer.intro}</p><ul class="mt-6 max-w-3xl space-y-4">{schoolSummer.items.map((i) => <li class="rounded-[1rem] bg-surface/50 p-4 ring-1 ring-line-subtle"><h3 class="font-semibold text-primary">{i.heading}</h3><p class="mt-2 text-sm text-secondary" set:html={i.body} /></li>)}</ul></section>
		<section id="print-export" class="container-shell scroll-mt-24 border-t border-line-subtle py-10 lg:py-12"><div class="max-w-2xl rounded-[1.25rem] border border-line bg-surface/40 p-6"><h2 class="text-2xl font-semibold text-primary">{printExport.title}</h2><p class="mt-3 text-secondary">{printExport.body}</p><div class="mt-5 flex flex-col gap-3 sm:flex-row"><CtaButton href={printExport.primaryHref} variant="primary" size="large">{printExport.primaryLabel}</CtaButton><a href={printExport.secondaryHref} class="text-sm font-semibold text-accent underline">{printExport.secondaryLabel}</a></div></div></section>
		<FAQ items={faqItems} title={faqSection.title} description={faqSection.description} />
	</main>
	<Footer />
</BaseLayout>
