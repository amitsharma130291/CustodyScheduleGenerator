---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import FAQ from '../components/FAQ.astro';
import CtaButton from '../components/CtaButton.astro';
import ScheduleHeroGeneratorPanel from '../components/schedules/ScheduleHeroGeneratorPanel.astro';
import WeekOnWeekOffExchangeCountGraphic from '../components/schedules/week-on-week-off/WeekOnWeekOffExchangeCountGraphic.astro';
import WeekOnWeekOffHolidayTimeline from '../components/schedules/week-on-week-off/WeekOnWeekOffHolidayTimeline.astro';
import WeekOnWeekOffMonthStripGraphic from '../components/schedules/week-on-week-off/WeekOnWeekOffMonthStripGraphic.astro';
import WeekOnWeekOffPrintableSample from '../components/schedules/week-on-week-off/WeekOnWeekOffPrintableSample.astro';
import { generateSchedule } from '../lib/schedules/generateSchedule';
import { getDefaultStartDate } from '../lib/schedules/format';
import { getCanonicalUrl } from '../lib/seo/metadata';
import {
	buildArticleSchema,
	buildBreadcrumbSchema,
	buildFAQSchema,
	buildWebPageSchema,
} from '../lib/seo/schema';
import {
	articleTocItems,
	costOfFewerHandoffs,
	editorialReview,
	exchangeCountDeciding,
	faqItems,
	faqSection,
	fitAndStays,
	hero,
	heroKeyStats,
	heroTrustSignals,
	meta,
	nothingMidweek,
	parkingLotSchedule,
	planLanguage,
	postContentCta,
	typicalExchangeWeek,
	whenAnotherBetter,
	whenUsuallyFails,
} from '../data/weekOnWeekOffCustodySchedule';

const canonical = '/week-on-week-off-custody-schedule/';
const canonicalUrl = getCanonicalUrl(canonical);
const startDate = getDefaultStartDate();
const generatedSchedule = generateSchedule({
	scheduleId: 'week-on-week-off',
	startDate,
	parentNames: { parentA: 'Parent A', parentB: 'Parent B' },
});

const breadcrumbs = [
	{ name: 'Home', url: getCanonicalUrl('/') },
	{ name: '50/50 Custody Schedule', url: getCanonicalUrl('/50-50-custody-schedule/') },
	{ name: 'Week-On Week-Off Custody Schedule', url: canonicalUrl },
];

const schema = [
	buildWebPageSchema({ name: meta.title, description: meta.description, url: canonicalUrl }),
	buildArticleSchema({
		headline: hero.headline,
		description: meta.description,
		url: canonicalUrl,
		datePublished: meta.datePublished,
		dateModified: meta.dateModified,
		authorName: editorialReview.reviewer,
	}),
	buildFAQSchema(faqItems),
	buildBreadcrumbSchema(breadcrumbs),
	{
		'@context': 'https://schema.org',
		'@type': 'WebApplication',
		name: 'Week-On Week-Off Custody Schedule Calendar Generator',
		description: meta.description,
		url: canonicalUrl,
		inLanguage: 'en-US',
		areaServed: 'US',
		applicationCategory: 'LegalApplication',
		operatingSystem: 'Web',
		offers: {
			'@type': 'Offer',
			price: '0',
			priceCurrency: 'USD',
		},
	},
];
---

<BaseLayout title={meta.title} description={meta.description} canonical={canonical}>
	<JsonLd slot="head" data={schema} />
	<Navbar />
	<Breadcrumbs items={breadcrumbs} />
	<main class="wow-page">
		<section
			class="container-shell grid grid-cols-1 gap-5 py-4 sm:py-5 lg:grid-cols-[minmax(0,0.88fr)_minmax(704px,1.12fr)] lg:items-start lg:gap-7 lg:py-6 xl:w-[min(100%,1360px)]"
			id="schedule-generator"
		>
			<div class="order-1 min-w-0 lg:col-start-1 lg:row-start-1 lg:pt-1">
				<h1 class="max-w-3xl text-4xl font-semibold leading-[0.98] tracking-[-0.055em] text-primary sm:text-5xl">
					{hero.headline}
				</h1>

				<dl class="mt-4 grid grid-cols-3 gap-2">
					{heroKeyStats.map((stat) => (
						<div class="rounded-[1rem] bg-accent/10 px-2 py-2.5 text-center shadow-[inset_0_0_0_1px_rgba(37,99,235,0.15)] sm:px-3">
							<dd class="text-lg font-bold tabular-nums tracking-tight text-accent sm:text-xl">{stat.value}</dd>
							<dt class="mt-0.5 text-[10px] font-semibold uppercase leading-4 tracking-[0.08em] text-secondary">{stat.label}</dt>
						</div>
					))}
				</dl>

				<p class="mt-3 max-w-2xl text-base leading-7 text-secondary" set:html={hero.intro} />

				<p class="mt-3 text-xs leading-5 text-muted" set:html={editorialReview.trustLine} />
			</div>

			<ScheduleHeroGeneratorPanel
				selectedScheduleId="week-on-week-off"
				generatedSchedule={generatedSchedule}
				heroTrustSignals={heroTrustSignals}
			/>

			<div class="order-3 min-w-0 lg:col-start-1 lg:row-start-2">
				<WeekOnWeekOffPrintableSample />
			</div>
		</section>

		<nav class="container-shell border-y border-line-subtle py-3" aria-label="On this page">
			<ul class="flex flex-wrap gap-x-4 gap-y-1 text-xs font-semibold text-secondary">
				{articleTocItems.map((item) => (
					<li><a href={`#${item.id}`} class="hover:text-accent">{item.label}</a></li>
				))}
			</ul>
		</nav>

		<section id="typical-exchange-week" class="container-shell scroll-mt-24 py-8 lg:py-10" aria-labelledby="typical-exchange-week-title">
			<div class="grid gap-5 lg:grid-cols-[minmax(0,1fr)_minmax(280px,360px)] lg:items-start">
				<aside class="rounded-[1.25rem] border border-accent/25 bg-accent/5 p-5 sm:p-6">
					<h2 id="typical-exchange-week-title" class="text-lg font-semibold tracking-[-0.03em] text-primary sm:text-xl">
						{typicalExchangeWeek.title}
					</h2>
					<p class="mt-3 text-sm leading-6 text-secondary sm:text-base sm:leading-7">{typicalExchangeWeek.body}</p>
				</aside>
				<WeekOnWeekOffMonthStripGraphic />
			</div>
		</section>

		<section id="exchange-count-factor" class="container-shell scroll-mt-24 border-t border-line-subtle py-10 lg:py-12" aria-labelledby="exchange-count-factor-title">
			<div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_minmax(300px,420px)] lg:items-start">
				<div class="min-w-0">
					<h2 id="exchange-count-factor-title" class="text-2xl font-semibold tracking-[-0.04em] text-primary sm:text-3xl">
						{exchangeCountDeciding.title}
					</h2>
					<p class="mt-3 text-base leading-7 text-secondary" set:html={exchangeCountDeciding.intro} />
					<div class="mt-6 space-y-5">
						{exchangeCountDeciding.points.map((item) => (
							<article>
								<h3 class="text-lg font-semibold text-primary">{item.heading}</h3>
								<p class="mt-2 text-sm leading-6 text-secondary" set:html={item.body} />
							</article>
						))}
					</div>
				</div>
				<WeekOnWeekOffExchangeCountGraphic />
			</div>
		</section>

		<section id="nothing-midweek" class="container-shell scroll-mt-24 border-t border-line-subtle py-10 lg:py-12" aria-labelledby="nothing-midweek-title">
			<h2 id="nothing-midweek-title" class="max-w-3xl text-2xl font-semibold tracking-[-0.04em] text-primary sm:text-3xl">
				{nothingMidweek.title}
			</h2>
			<p class="mt-3 max-w-3xl text-base leading-7 text-secondary">{nothingMidweek.intro}</p>
			<div class="mt-6 grid gap-3 sm:grid-cols-2">
				{nothingMidweek.layers.map((item) => (
					<article class="rounded-xl bg-surface/60 p-4 shadow-[inset_0_0_0_1px_var(--border-subtle)]">
						<h3 class="text-base font-semibold text-primary">{item.heading}</h3>
						<p class="mt-2 text-sm leading-6 text-secondary" set:html={item.body} />
					</article>
				))}
			</div>
		</section>

		<section id="cost-of-fewer-handoffs" class="container-shell scroll-mt-24 border-t border-line-subtle py-10 lg:py-12" aria-labelledby="cost-of-fewer-handoffs-title">
			<div class="grid gap-8 lg:grid-cols-2 lg:items-start">
				<div>
					<h2 id="cost-of-fewer-handoffs-title" class="text-2xl font-semibold tracking-[-0.04em] text-primary sm:text-3xl">
						{costOfFewerHandoffs.title}
					</h2>
					<p class="mt-3 text-base leading-7 text-secondary">{costOfFewerHandoffs.intro}</p>
					<div class="mt-6 space-y-4">
						{costOfFewerHandoffs.items.map((item) => (
							<article>
								<h3 class="text-base font-semibold text-primary">{item.heading}</h3>
								<p class="mt-2 text-sm leading-6 text-secondary" set:html={item.body} />
							</article>
						))}
					</div>
				</div>
				<WeekOnWeekOffHolidayTimeline />
			</div>
		</section>

		<section id="parking-lot-schedule" class="container-shell scroll-mt-24 border-t border-line-subtle py-10 lg:py-12" aria-labelledby="parking-lot-schedule-title">
			<h2 id="parking-lot-schedule-title" class="max-w-3xl text-2xl font-semibold tracking-[-0.04em] text-primary sm:text-3xl">
				{parkingLotSchedule.title}
			</h2>
			<p class="mt-3 max-w-3xl text-base leading-7 text-secondary" set:html={parkingLotSchedule.intro} />
			<div class="mt-6 grid gap-3 sm:grid-cols-2">
				{parkingLotSchedule.scenes.map((item) => (
					<article class="rounded-xl border-l-2 border-accent/40 bg-page/50 py-3 pl-4 pr-3">
						<h3 class="text-base font-semibold text-primary">{item.heading}</h3>
						<p class="mt-2 text-sm leading-6 text-secondary">{item.body}</p>
					</article>
				))}
			</div>
		</section>

		<section id="fit-and-stays" class="container-shell scroll-mt-24 border-t border-line-subtle py-10 lg:py-12" aria-labelledby="fit-and-stays-title">
			<h2 id="fit-and-stays-title" class="max-w-3xl text-2xl font-semibold tracking-[-0.04em] text-primary sm:text-3xl">
				{fitAndStays.title}
			</h2>
			<p class="mt-3 max-w-3xl text-base leading-7 text-secondary">{fitAndStays.intro}</p>
			<ol class="mt-6 max-w-3xl space-y-4">
				{fitAndStays.points.map((item, index) => (
					<li class="flex gap-4">
						<span class="grid h-7 w-7 shrink-0 place-items-center rounded-full bg-accent/15 text-xs font-bold text-accent">{index + 1}</span>
						<div>
							<h3 class="text-base font-semibold text-primary">{item.heading}</h3>
							<p class="mt-1 text-sm leading-6 text-secondary" set:html={item.body} />
						</div>
					</li>
				))}
			</ol>
		</section>

		<section id="when-usually-fails" class="container-shell scroll-mt-24 border-t border-line-subtle py-10 lg:py-12" aria-labelledby="when-usually-fails-title">
			<h2 id="when-usually-fails-title" class="max-w-3xl text-2xl font-semibold tracking-[-0.04em] text-primary sm:text-3xl">
				{whenUsuallyFails.title}
			</h2>
			<p class="mt-3 max-w-3xl text-base leading-7 text-secondary">{whenUsuallyFails.intro}</p>
			<ul class="mt-6 max-w-3xl space-y-4">
				{whenUsuallyFails.cases.map((item) => (
					<li class="border-l-2 border-line pl-4">
						<h3 class="text-base font-semibold text-primary">{item.heading}</h3>
						<p class="mt-1 text-sm leading-6 text-secondary" set:html={item.body} />
					</li>
				))}
			</ul>
		</section>

		<section id="plan-language" class="container-shell scroll-mt-24 border-t border-line-subtle py-10 lg:py-12" aria-labelledby="plan-language-title">
			<h2 id="plan-language-title" class="max-w-3xl text-2xl font-semibold tracking-[-0.04em] text-primary sm:text-3xl">
				{planLanguage.title}
			</h2>
			<p class="mt-2 text-xs text-muted">{planLanguage.disclaimer}</p>
			<p class="mt-3 max-w-3xl text-base leading-7 text-secondary">{planLanguage.intro}</p>
			<blockquote class="mt-5 max-w-3xl rounded-xl border border-line bg-surface/40 p-4 text-sm leading-7 text-secondary">
				{planLanguage.clause}
			</blockquote>
			<ul class="mt-4 max-w-3xl space-y-1 text-sm text-secondary">
				{planLanguage.notes.map((note) => (
					<li class="flex gap-2">
						<span class="text-accent" aria-hidden="true">·</span>
						{note}
					</li>
				))}
			</ul>
		</section>

		<section id="when-another-better" class="container-shell scroll-mt-24 border-t border-line-subtle py-10 lg:py-12" aria-labelledby="when-another-better-title">
			<h2 id="when-another-better-title" class="max-w-3xl text-2xl font-semibold tracking-[-0.04em] text-primary sm:text-3xl">
				{whenAnotherBetter.title}
			</h2>
			<p class="mt-3 max-w-3xl text-base leading-7 text-secondary">{whenAnotherBetter.intro}</p>
			<div class="mt-6 grid gap-3 sm:grid-cols-2">
				{whenAnotherBetter.blocks.map((item) => (
					<article class="rounded-xl bg-surface/60 p-4 shadow-[inset_0_0_0_1px_var(--border-subtle)]">
						<h3 class="text-base font-semibold text-primary">{item.heading}</h3>
						<p class="mt-2 text-sm leading-6 text-secondary" set:html={item.body} />
					</article>
				))}
			</div>
		</section>

		<section id="convert-cta" class="container-shell scroll-mt-24 border-t border-line-subtle py-10 lg:py-12" aria-labelledby="convert-cta-title">
			<div class="max-w-2xl rounded-[1.25rem] border border-line bg-surface/40 p-6 sm:p-7">
				<h2 id="convert-cta-title" class="text-2xl font-semibold tracking-[-0.04em] text-primary sm:text-[1.65rem]">
					{postContentCta.heading}
				</h2>
				<p class="mt-3 text-sm leading-6 text-secondary sm:text-base sm:leading-7">{postContentCta.body}</p>
				<div class="mt-5 flex flex-col gap-3 sm:flex-row sm:items-center sm:gap-5">
					<CtaButton href={postContentCta.primaryHref} variant="primary" size="large">
						{postContentCta.primaryLabel}
					</CtaButton>
					<a
						href={postContentCta.secondaryHref}
						class="text-sm font-semibold text-accent underline decoration-line underline-offset-4 hover:text-primary"
					>
						{postContentCta.secondaryLabel}
					</a>
				</div>
			</div>
		</section>

		<FAQ items={faqItems} title={faqSection.title} description={faqSection.description} />
	</main>
	<Footer />
</BaseLayout>
