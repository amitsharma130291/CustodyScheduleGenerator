---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import FAQ from '../components/FAQ.astro';
import CtaButton from '../components/CtaButton.astro';
import ScheduleHeroGeneratorPanel from '../components/schedules/ScheduleHeroGeneratorPanel.astro';
import ScenarioFailureMapGraphic from '../components/schedules/50-50-custody-schedule-examples/ScenarioFailureMapGraphic.astro';
import TuesdayPianoCollisionGraphic from '../components/schedules/50-50-custody-schedule-examples/TuesdayPianoCollisionGraphic.astro';
import ShiftWorkPressureGraphic from '../components/schedules/50-50-custody-schedule-examples/ShiftWorkPressureGraphic.astro';
import { generateSchedule } from '../lib/schedules/generateSchedule';
import { getDefaultStartDate } from '../lib/schedules/format';
import { getCanonicalUrl } from '../lib/seo/metadata';
import {
	buildArticleSchema,
	buildBreadcrumbSchema,
	buildFAQSchema,
	buildWebPageSchema,
} from '../lib/seo/schema';
import {
	articleTocItems,
	editorialReview,
	faqItems,
	faqSection,
	hero,
	heroKeyStats,
	heroTrustSignals,
	holidays,
	howToUse,
	leave5050,
	loadGenerator,
	meta,
	schoolActivities,
	stopsEqual,
	workSchedules,
} from '../data/fiftyFiftyScheduleExamples';

const canonical = '/50-50-custody-schedule-examples/';
const canonicalUrl = getCanonicalUrl(canonical);
const startDate = getDefaultStartDate();
const generatedSchedule = generateSchedule({
	scheduleId: '2-2-3',
	startDate,
	parentNames: { parentA: 'Parent A', parentB: 'Parent B' },
});

const breadcrumbs = [
	{ name: 'Home', url: getCanonicalUrl('/') },
	{ name: '50/50 Custody Schedule', url: getCanonicalUrl('/50-50-custody-schedule/') },
	{ name: '50/50 Schedule Examples', url: canonicalUrl },
];

const schema = [
	buildWebPageSchema({ name: meta.title, description: meta.description, url: canonicalUrl }),
	buildArticleSchema({
		headline: hero.headline,
		description: meta.description,
		url: canonicalUrl,
		datePublished: meta.datePublished,
		dateModified: meta.dateModified,
		authorName: editorialReview.reviewer,
	}),
	buildFAQSchema(faqItems),
	buildBreadcrumbSchema(breadcrumbs),
	{
		'@context': 'https://schema.org',
		'@type': 'WebApplication',
		name: '50/50 Failure Scenario Calendar Generator',
		description: meta.description,
		url: canonicalUrl,
		inLanguage: 'en-US',
		areaServed: 'US',
		applicationCategory: 'LegalApplication',
		operatingSystem: 'Web',
		offers: {
			'@type': 'Offer',
			price: '0',
			priceCurrency: 'USD',
		},
	},
];
---

<BaseLayout title={meta.title} description={meta.description} canonical={canonical}>
	<JsonLd slot="head" data={schema} />
	<Navbar />
	<Breadcrumbs items={breadcrumbs} />
	<main class="fifty-fifty-examples-page">
		<section
			class="container-shell grid grid-cols-1 gap-5 py-4 sm:py-5 lg:grid-cols-[minmax(0,0.88fr)_minmax(704px,1.12fr)] lg:items-start lg:gap-7 lg:py-6 xl:w-[min(100%,1360px)]"
			id="schedule-generator"
		>
			<div class="order-1 min-w-0 lg:col-start-1 lg:row-start-1 lg:pt-1">
				<h1 class="max-w-3xl text-4xl font-semibold leading-[0.98] tracking-[-0.055em] text-primary sm:text-5xl">
					{hero.headline}
				</h1>

				<dl class="mt-4 grid grid-cols-3 gap-2">
					{heroKeyStats.map((stat) => (
						<div class="rounded-[1rem] bg-accent/10 px-2 py-2.5 text-center shadow-[inset_0_0_0_1px_rgba(37,99,235,0.15)] sm:px-3">
							<dd class="text-lg font-bold tabular-nums tracking-tight text-accent sm:text-xl">{stat.value}</dd>
							<dt class="mt-0.5 text-[10px] font-semibold uppercase leading-4 tracking-[0.08em] text-secondary">{stat.label}</dt>
						</div>
					))}
				</dl>

				<p class="mt-3 max-w-2xl text-base leading-7 text-secondary">{hero.intro}</p>
				<p class="mt-3 max-w-2xl text-sm leading-6 text-secondary" set:html={hero.boundary} />

				<div class="mt-3 max-w-2xl text-xs leading-5 text-muted">
					<p class="font-semibold text-secondary">Reviewed for:</p>
					<ul class="mt-1 list-inside list-disc space-y-0.5">
						{editorialReview.reviewedFor.map((item) => (
							<li>{item}</li>
						))}
					</ul>
					<p class="mt-2">
						Reviewed by{' '}
						<a href={editorialReview.reviewerHref} class="font-semibold text-secondary underline decoration-line underline-offset-4 hover:text-primary">
							{editorialReview.reviewer}
						</a>
						{' · '}
						Methodology:{' '}
						<a href={editorialReview.methodologyHref} class="font-semibold text-secondary underline decoration-line underline-offset-4 hover:text-primary">
							{editorialReview.methodologyLabel}
						</a>
						{' · '}{editorialReview.disclaimer}
					</p>
				</div>
			</div>

			<ScheduleHeroGeneratorPanel
				selectedScheduleId="2-2-3"
				generatedSchedule={generatedSchedule}
				heroTrustSignals={heroTrustSignals}
			/>
		</section>

		<nav class="container-shell border-y border-line-subtle py-3" aria-label="On this page">
			<ul class="flex flex-wrap gap-x-4 gap-y-1 text-xs font-semibold text-secondary">
				{articleTocItems.map((item) => (
					<li><a href={`#${item.id}`} class="hover:text-accent">{item.label}</a></li>
				))}
			</ul>
		</nav>

		<section id="how-to-use" class="container-shell scroll-mt-24 py-10 lg:py-12" aria-labelledby="how-to-use-title">
			<div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_minmax(280px,360px)] lg:items-start">
				<div class="min-w-0">
					<h2 id="how-to-use-title" class="text-2xl font-semibold tracking-[-0.04em] text-primary sm:text-3xl">
						{howToUse.title}
					</h2>
					<p class="mt-3 text-base leading-7 text-secondary">{howToUse.intro}</p>
					<ol class="mt-6 list-decimal space-y-2 pl-5 text-sm leading-6 text-secondary">
						{howToUse.steps.map((step) => (
							<li class="mt-2">{step}</li>
						))}
					</ol>
				</div>
				<ScenarioFailureMapGraphic />
			</div>
		</section>

		<section id="school-activities" class="container-shell scroll-mt-24 border-t border-line-subtle py-10 lg:py-12" aria-labelledby="school-activities-title">
			<div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_minmax(280px,360px)] lg:items-start">
				<div class="min-w-0">
					<h2 id="school-activities-title" class="text-2xl font-semibold tracking-[-0.04em] text-primary sm:text-3xl">
						{schoolActivities.title}
					</h2>
					<p class="mt-3 text-base leading-7 text-secondary">{schoolActivities.intro}</p>
					<ul class="mt-6 space-y-5">
						{schoolActivities.scenarios.map((scenario) => (
							<li class="rounded-[1rem] bg-surface/50 p-4 ring-1 ring-line-subtle">
								<h3 class="text-base font-semibold text-primary">{scenario.heading}</h3>
								<p class="mt-2 text-sm leading-6 text-secondary"><span class="font-semibold text-primary">Situation:</span> {scenario.situation}</p>
								<p class="mt-1 text-sm leading-6 text-secondary"><span class="font-semibold text-rose-600">Failure:</span> {scenario.failure}</p>
								<p class="mt-1 text-sm leading-6 text-secondary"><span class="font-semibold text-accent">Adjustment:</span> <span set:html={scenario.adjustment} /></p>
							</li>
						))}
					</ul>
				</div>
				<TuesdayPianoCollisionGraphic />
			</div>
		</section>

		<section id="work-schedules" class="container-shell scroll-mt-24 border-t border-line-subtle py-10 lg:py-12" aria-labelledby="work-schedules-title">
			<div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_minmax(280px,360px)] lg:items-start">
				<div class="min-w-0">
					<h2 id="work-schedules-title" class="text-2xl font-semibold tracking-[-0.04em] text-primary sm:text-3xl">
						{workSchedules.title}
					</h2>
					<p class="mt-3 text-base leading-7 text-secondary">{workSchedules.intro}</p>
					<ul class="mt-6 space-y-5">
						{workSchedules.scenarios.map((scenario) => (
							<li class="rounded-[1rem] bg-surface/50 p-4 ring-1 ring-line-subtle">
								<h3 class="text-base font-semibold text-primary">{scenario.heading}</h3>
								<p class="mt-2 text-sm leading-6 text-secondary"><span class="font-semibold text-primary">Situation:</span> {scenario.situation}</p>
								<p class="mt-1 text-sm leading-6 text-secondary"><span class="font-semibold text-rose-600">Failure:</span> {scenario.failure}</p>
								<p class="mt-1 text-sm leading-6 text-secondary"><span class="font-semibold text-accent">Adjustment:</span> <span set:html={scenario.adjustment} /></p>
							</li>
						))}
					</ul>
				</div>
				<ShiftWorkPressureGraphic />
			</div>
		</section>

		<section id="holidays" class="container-shell scroll-mt-24 border-t border-line-subtle py-10 lg:py-12" aria-labelledby="holidays-title">
			<h2 id="holidays-title" class="max-w-3xl text-2xl font-semibold tracking-[-0.04em] text-primary sm:text-3xl">
				{holidays.title}
			</h2>
			<p class="mt-3 max-w-3xl text-base leading-7 text-secondary">{holidays.intro}</p>
			<ul class="mt-6 max-w-3xl space-y-5">
				{holidays.scenarios.map((scenario) => (
					<li class="rounded-[1rem] bg-surface/50 p-4 ring-1 ring-line-subtle">
						<h3 class="text-base font-semibold text-primary">{scenario.heading}</h3>
						<p class="mt-2 text-sm leading-6 text-secondary"><span class="font-semibold text-primary">Situation:</span> {scenario.situation}</p>
						<p class="mt-1 text-sm leading-6 text-secondary"><span class="font-semibold text-rose-600">Failure:</span> {scenario.failure}</p>
						<p class="mt-1 text-sm leading-6 text-secondary"><span class="font-semibold text-accent">Adjustment:</span> <span set:html={scenario.adjustment} /></p>
					</li>
				))}
			</ul>
		</section>

		<section id="stops-equal" class="container-shell scroll-mt-24 border-t border-line-subtle py-10 lg:py-12" aria-labelledby="stops-equal-title">
			<h2 id="stops-equal-title" class="max-w-3xl text-2xl font-semibold tracking-[-0.04em] text-primary sm:text-3xl">
				{stopsEqual.title}
			</h2>
			<p class="mt-3 max-w-3xl text-base leading-7 text-secondary">{stopsEqual.intro}</p>
			<ul class="mt-6 max-w-3xl space-y-5">
				{stopsEqual.scenarios.map((scenario) => (
					<li class="rounded-[1rem] bg-surface/50 p-4 ring-1 ring-line-subtle">
						<h3 class="text-base font-semibold text-primary">{scenario.heading}</h3>
						<p class="mt-2 text-sm leading-6 text-secondary"><span class="font-semibold text-primary">Situation:</span> {scenario.situation}</p>
						<p class="mt-1 text-sm leading-6 text-secondary"><span class="font-semibold text-rose-600">Failure:</span> {scenario.failure}</p>
						<p class="mt-1 text-sm leading-6 text-secondary"><span class="font-semibold text-accent">Adjustment:</span> {scenario.adjustment}</p>
					</li>
				))}
			</ul>
		</section>

		<section id="leave-5050" class="container-shell scroll-mt-24 border-t border-line-subtle py-10 lg:py-12" aria-labelledby="leave-5050-title">
			<h2 id="leave-5050-title" class="max-w-3xl text-2xl font-semibold tracking-[-0.04em] text-primary sm:text-3xl">
				{leave5050.title}
			</h2>
			<p class="mt-3 max-w-3xl text-base leading-7 text-secondary">{leave5050.intro}</p>
			<ul class="mt-6 max-w-3xl space-y-4">
				{leave5050.signals.map((signal) => (
					<li class="border-l-2 border-accent/30 pl-4">
						<h3 class="text-base font-semibold text-primary">{signal.heading}</h3>
						<p class="mt-2 text-sm leading-6 text-secondary" set:html={signal.body} />
					</li>
				))}
			</ul>
		</section>

		<section id="load-generator" class="container-shell scroll-mt-24 border-t border-line-subtle py-10 lg:py-12" aria-labelledby="load-generator-title">
			<div class="max-w-2xl rounded-[1.25rem] border border-line bg-surface/40 p-6 sm:p-7">
				<h2 id="load-generator-title" class="text-2xl font-semibold tracking-[-0.04em] text-primary sm:text-[1.65rem]">
					{loadGenerator.title}
				</h2>
				<p class="mt-3 text-sm leading-6 text-secondary sm:text-base sm:leading-7">{loadGenerator.body}</p>
				<div class="mt-5 flex flex-col gap-3 sm:flex-row sm:items-center sm:gap-5">
					<CtaButton href={loadGenerator.primaryHref} variant="primary" size="large">
						{loadGenerator.primaryLabel}
					</CtaButton>
					<a
						href={loadGenerator.secondaryHref}
						class="text-sm font-semibold text-accent underline decoration-line underline-offset-4 hover:text-primary"
					>
						{loadGenerator.secondaryLabel}
					</a>
				</div>
			</div>
		</section>

		<FAQ items={faqItems} title={faqSection.title} description={faqSection.description} />
	</main>
	<Footer />
</BaseLayout>
