---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import BackToGeneratorCta from '../components/BackToGeneratorCta.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import FAQ from '../components/FAQ.astro';
import CtaButton from '../components/CtaButton.astro';
import ArticleTOC from '../components/ArticleTOC.astro';
import ScheduleHeroCalendarGlance from '../components/schedules/ScheduleHeroCalendarGlance.astro';
import ScheduleHeroGeneratorPanel from '../components/schedules/ScheduleHeroGeneratorPanel.astro';
import { generateSchedule } from '../lib/schedules/generateSchedule';
import { getDefaultStartDate } from '../lib/schedules/format';
import { getCanonicalUrl } from '../lib/seo/metadata';
import {
	buildArticleSchema,
	buildBreadcrumbSchema,
	buildFAQSchema,
	buildWebPageSchema,
} from '../lib/seo/schema';
import {
	articleTocItems,
	breakdowns,
	builderHelp,
	calendarGlance,
	editorialReview,
	faqItems,
	faqSection,
	hero,
	heroTrustSignals,
	meta,
	move2255,
	planLanguage,
	quickFacts,
	schoolWeekOwnership,
	vs223,
	vs2255Callout,
	whyElementary,
} from '../data/fiveTwoTwoFiveCustodySchedule';

const canonical = '/5-2-2-5-custody-schedule/';
const canonicalUrl = getCanonicalUrl(canonical);
const startDate = getDefaultStartDate();
const generatedSchedule = generateSchedule({
	scheduleId: '5225',
	startDate,
	parentNames: { parentA: 'Parent A', parentB: 'Parent B' },
});

const breadcrumbs = [
	{ name: 'Home', url: getCanonicalUrl('/') },
	{ name: '50/50 Custody Schedule', url: getCanonicalUrl('/50-50-custody-schedule/') },
	{ name: '5-2-2-5 Custody Schedule', url: canonicalUrl },
];

const schema = [
	buildWebPageSchema({ name: meta.title, description: meta.description, url: canonicalUrl }),
	buildArticleSchema({
		headline: meta.title,
		description: meta.description,
		url: canonicalUrl,
		datePublished: meta.datePublished,
		dateModified: meta.dateModified,
		authorName: editorialReview.reviewer,
	}),
	buildFAQSchema(faqItems),
	buildBreadcrumbSchema(breadcrumbs),
	{
		'@context': 'https://schema.org',
		'@type': 'WebApplication',
		name: '5-2-2-5 Custody Schedule Calendar Generator',
		description: meta.description,
		url: canonicalUrl,
		inLanguage: 'en-US',
		areaServed: 'US',
		applicationCategory: 'LegalApplication',
		operatingSystem: 'Web',
		offers: {
			'@type': 'Offer',
			price: '0',
			priceCurrency: 'USD',
		},
	},
	{
		'@context': 'https://schema.org',
		'@type': 'HowTo',
		name: 'How to create a 5-2-2-5 Custody Schedule',
		description: 'Use the custody calendar generator to preview, compare, and export a 5-2-2-5 parenting schedule.',
		inLanguage: 'en-US',
		totalTime: 'PT5M',
		step: [
			{
				'@type': 'HowToStep',
				name: 'Choose the 5-2-2-5 schedule type',
				text: 'Select 5-2-2-5 Custody Schedule in the generator.',
			},
			{
				'@type': 'HowToStep',
				name: 'Pick a Monday-aligned start date',
				text: 'Align the first five-day block with a full school week.',
			},
			{
				'@type': 'HowToStep',
				name: 'Review overnight percentages',
				text: 'Check school-week blocks and annual totals before exporting or printing.',
			},
		],
	},
];
---

<BaseLayout title={meta.title} description={meta.description} canonical={canonical}>
	<JsonLd slot="head" data={schema} />
	<Navbar />
	<Breadcrumbs items={breadcrumbs} />
	<main>
		<section
			class="container-shell grid grid-cols-1 gap-5 py-4 sm:py-5 lg:grid-cols-[minmax(0,0.88fr)_minmax(704px,1.12fr)] lg:items-start lg:gap-7 lg:py-6 xl:w-[min(100%,1360px)]"
			id="schedule-generator"
		>
			<div class="order-1 min-w-0 lg:col-start-1 lg:row-start-1 lg:pt-1">
				<p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">5-2-2-5 calendar generator</p>
				<h1 class="mt-2.5 max-w-3xl text-4xl font-semibold leading-[0.98] tracking-[-0.055em] text-primary sm:text-5xl">
					{hero.headline}
				</h1>
				{hero.intro.map((paragraph) => (
					<p class="mt-3 max-w-2xl text-base leading-7 text-secondary">{paragraph}</p>
				))}
				<p class="mt-2 max-w-2xl text-sm leading-6 text-secondary">
					<a href="#schedule-generator-panel" class="font-semibold text-accent underline decoration-line underline-offset-4 hover:text-primary">Build a 5-2-2-5 calendar</a>.
				</p>

				<dl class="mt-4 grid gap-2 sm:grid-cols-2">
					{quickFacts.items.map((fact) => (
						<div class="rounded-[1rem] bg-surface/70 px-3 py-2.5 shadow-[inset_0_0_0_1px_var(--border-subtle)]">
							<dt class="text-[10px] font-semibold uppercase tracking-[0.12em] text-muted">{fact.label}</dt>
							<dd class="mt-1 text-xs font-semibold leading-5 text-primary">{fact.value}</dd>
						</div>
					))}
				</dl>

				<div class="mt-4 max-w-2xl rounded-2xl bg-page/70 p-3 text-xs leading-5 text-secondary shadow-[inset_0_0_0_1px_var(--border-subtle)] lg:hidden">
					<p>
						<strong class="text-primary">Last reviewed: {editorialReview.lastReviewed}</strong>
						<br />
						Reviewed by:{' '}
						<a href={editorialReview.reviewerHref} class="font-semibold text-accent underline decoration-line underline-offset-4 hover:text-primary">
							{editorialReview.reviewer}
						</a>
					</p>
					<p class="mt-2 text-muted">Educational use only. Not legal advice.</p>
				</div>
			</div>

			<ScheduleHeroGeneratorPanel
				selectedScheduleId="5225"
				generatedSchedule={generatedSchedule}
				heroTrustSignals={heroTrustSignals}
			/>

			<div class="order-3 min-w-0 lg:col-start-1 lg:row-start-2">
				<ScheduleHeroCalendarGlance calendarGlance={calendarGlance} />
				<p class="mt-3 text-xs leading-5 text-muted">
					Not legal advice.
					<a href="/disclaimer/" class="ml-1 font-semibold text-secondary underline decoration-line underline-offset-4 hover:text-primary">Read disclaimer</a>
				</p>
			</div>
		</section>

		<section id="editorial-review" class="container-shell pb-5">
			<div class="max-w-3xl rounded-2xl bg-page/70 p-4 text-sm leading-6 text-secondary shadow-[inset_0_0_0_1px_var(--border-subtle)]">
				<p>
					<strong class="text-primary">Last reviewed: {editorialReview.lastReviewed}</strong>
					<br />
					Reviewed by:{' '}
					<a href={editorialReview.reviewerHref} class="font-semibold text-accent underline decoration-line underline-offset-4 hover:text-primary">
						{editorialReview.reviewer}
					</a>
				</p>
				<p class="mt-2">{editorialReview.body}</p>
			</div>
		</section>

		<ArticleTOC items={articleTocItems} />

		<section id="why-elementary" class="container-shell scroll-mt-24 pb-section" aria-labelledby="why-elementary-title">
			<div class="max-w-3xl">
				<p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">After elementary starts</p>
				<h2 id="why-elementary-title" class="mt-3 text-3xl font-semibold tracking-[-0.04em] text-primary sm:text-4xl">
					{whyElementary.title}
				</h2>
				<p class="mt-4 text-base leading-7 text-secondary">{whyElementary.intro}</p>
			</div>
			<div class="mt-8 max-w-3xl space-y-6">
				{whyElementary.points.map((item) => (
					<article>
						<h3 class="text-xl font-semibold tracking-[-0.03em] text-primary">{item.heading}</h3>
						<p class="mt-3 text-base leading-7 text-secondary">{item.body}</p>
					</article>
				))}
				<p class="text-base leading-7 text-secondary" set:html={whyElementary.close} />
			</div>
		</section>

		<section id="school-week-ownership" class="container-shell scroll-mt-24 py-section" aria-labelledby="school-week-ownership-title">
			<div class="max-w-3xl">
				<p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">School-week ownership</p>
				<h2 id="school-week-ownership-title" class="mt-3 text-3xl font-semibold tracking-[-0.04em] text-primary sm:text-4xl">
					{schoolWeekOwnership.title}
				</h2>
				<p class="mt-4 text-base leading-7 text-secondary">{schoolWeekOwnership.intro}</p>
			</div>
			<div class="mt-8 max-w-3xl space-y-6">
				{schoolWeekOwnership.layers.map((item) => (
					<article class="soft-card rounded-[1.5rem] p-5">
						<h3 class="text-xl font-semibold tracking-[-0.03em] text-primary">{item.heading}</h3>
						<p class="mt-3 text-base leading-7 text-secondary">{item.body}</p>
					</article>
				))}
				<p class="text-base leading-7 text-secondary" set:html={schoolWeekOwnership.close} />
			</div>
		</section>

		<section id="vs-2255-callout" class="container-shell scroll-mt-24 pb-section" aria-labelledby="vs-2255-callout-title">
			<div class="max-w-3xl rounded-2xl bg-page/70 p-5 shadow-[inset_0_0_0_1px_var(--border-subtle)]">
				<h2 id="vs-2255-callout-title" class="text-xl font-semibold tracking-[-0.03em] text-primary">
					{vs2255Callout.title}
				</h2>
				<p class="mt-3 text-base leading-7 text-secondary" set:html={vs2255Callout.body} />
			</div>
		</section>

		<section id="vs-223" class="container-shell scroll-mt-24 py-section" aria-labelledby="vs-223-title">
			<div class="max-w-3xl">
				<p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">Outgrowing 2-2-3</p>
				<h2 id="vs-223-title" class="mt-3 text-3xl font-semibold tracking-[-0.04em] text-primary sm:text-4xl">
					{vs223.title}
				</h2>
				<p class="mt-4 text-base leading-7 text-secondary">{vs223.intro}</p>
			</div>
			<div class="mt-8 max-w-3xl space-y-6">
				{vs223.reasons.map((item) => (
					<article>
						<h3 class="text-xl font-semibold tracking-[-0.03em] text-primary">{item.heading}</h3>
						<p class="mt-3 text-base leading-7 text-secondary" set:html={item.body} />
					</article>
				))}
				<p class="text-base leading-7 text-secondary">{vs223.close}</p>
			</div>
		</section>

		<section id="move-2255" class="container-shell scroll-mt-24 py-section" aria-labelledby="move-2255-title">
			<div class="max-w-3xl">
				<p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">Schedule shifts</p>
				<h2 id="move-2255-title" class="mt-3 text-3xl font-semibold tracking-[-0.04em] text-primary sm:text-4xl">
					{move2255.title}
				</h2>
				<p class="mt-4 text-base leading-7 text-secondary">{move2255.intro}</p>
			</div>
			<div class="mt-8 max-w-3xl space-y-6">
				{move2255.scenarios.map((item) => (
					<article class="soft-card rounded-[1.5rem] p-5">
						<h3 class="text-lg font-semibold text-primary">{item.heading}</h3>
						<p class="mt-3 text-base leading-7 text-secondary" set:html={item.body} />
					</article>
				))}
				<p class="text-base leading-7 text-secondary">{move2255.close}</p>
			</div>
		</section>

		<section id="breakdowns" class="container-shell scroll-mt-24 py-section" aria-labelledby="breakdowns-title">
			<div class="max-w-3xl">
				<p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">5-2-2-5 failure points</p>
				<h2 id="breakdowns-title" class="mt-3 text-3xl font-semibold tracking-[-0.04em] text-primary sm:text-4xl">
					{breakdowns.title}
				</h2>
				<p class="mt-4 text-base leading-7 text-secondary">{breakdowns.intro}</p>
			</div>
			<div class="mt-8 max-w-3xl space-y-4">
				{breakdowns.items.map((item) => (
					<article class="soft-card rounded-[1.25rem] p-4">
						<h3 class="text-lg font-semibold text-primary">{item.title}</h3>
						<p class="mt-3 text-sm leading-6 text-secondary">
							<span class="font-semibold text-primary">What actually happens:</span> {item.whatHappens}
						</p>
						<p class="mt-3 text-sm leading-6 text-secondary">
							<span class="font-semibold text-accent">What families usually write into the plan:</span> {item.planFix}
						</p>
					</article>
				))}
			</div>
		</section>

		<section id="plan-language" class="container-shell scroll-mt-24 py-section" aria-labelledby="plan-language-title">
			<div class="max-w-3xl">
				<p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">Written plan language</p>
				<h2 id="plan-language-title" class="mt-3 text-3xl font-semibold tracking-[-0.04em] text-primary sm:text-4xl">
					{planLanguage.title}
				</h2>
				<p class="mt-4 text-sm leading-6 text-muted">{planLanguage.disclaimer}</p>
				<p class="mt-2 text-sm leading-6 text-secondary">{planLanguage.adaptationNote}</p>
				<p class="mt-4 text-base leading-7 text-secondary">{planLanguage.intro}</p>
				<p class="mt-3 text-base leading-7 text-secondary">{planLanguage.whyItHelps}</p>
			</div>
			<div class="mt-6 max-w-3xl">
				<blockquote class="soft-card rounded-[1.5rem] border-l-4 border-accent p-5 text-sm leading-7 text-secondary">
					{planLanguage.clause}
				</blockquote>
				<ul class="mt-4 space-y-2 text-sm leading-6 text-secondary">
					{planLanguage.notes.map((note) => (
						<li class="flex gap-2">
							<span class="text-accent" aria-hidden="true">→</span>
							{note}
						</li>
					))}
				</ul>
				<p class="mt-4 text-sm leading-6 text-secondary">
					Organize exchanges, holidays, and change rules in the{' '}
					<a href="/parenting-plan-template/" class="font-semibold text-accent underline decoration-line underline-offset-4 hover:text-primary">parenting plan template</a>.
					Compare real layouts in <a href="/50-50-custody-schedule-examples/" class="font-semibold text-accent underline decoration-line underline-offset-4 hover:text-primary">50/50 custody schedule examples</a>.
				</p>
			</div>
		</section>

		<section id="builder-help" class="container-shell scroll-mt-24 py-section" aria-labelledby="builder-help-title">
			<div class="max-w-3xl">
				<p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">Pattern testing</p>
				<h2 id="builder-help-title" class="mt-3 text-3xl font-semibold tracking-[-0.04em] text-primary sm:text-4xl">
					{builderHelp.title}
				</h2>
				<p class="mt-4 text-base leading-7 text-secondary" set:html={builderHelp.intro} />
				<ul class="mt-4 space-y-2 text-sm leading-6 text-secondary">
					{builderHelp.features.map((feature) => (
						<li class="flex gap-2">
							<span class="text-accent" aria-hidden="true">→</span>
							<span set:html={feature} />
						</li>
					))}
				</ul>
				<p class="mt-4 text-sm leading-6 text-secondary">
					Compare patterns by age in the{' '}
					<a href="/best-50-50-custody-schedule/" class="font-semibold text-accent underline decoration-line underline-offset-4 hover:text-primary">best 50/50 custody schedule</a> guide.
					Verify overnight totals with the{' '}
					<a href="/custody-percentage-calculator/" class="font-semibold text-accent underline decoration-line underline-offset-4 hover:text-primary">custody percentage calculator</a>.
				</p>
				<div class="mt-6">
					<CtaButton href="#schedule-generator-panel" variant="primary" size="large">
						{builderHelp.cta}
					</CtaButton>
				</div>
			</div>
		</section>

		<FAQ
			items={faqItems}
			title={faqSection.title}
			description={faqSection.description}
		/>
		<BackToGeneratorCta />
	</main>
	<Footer />
</BaseLayout>
