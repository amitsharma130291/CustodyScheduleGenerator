---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import BackToGeneratorCta from '../components/BackToGeneratorCta.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import FAQ from '../components/FAQ.astro';
import CtaButton from '../components/CtaButton.astro';
import ArticleTOC from '../components/ArticleTOC.astro';
import ScheduleHeroCalendarGlance from '../components/schedules/ScheduleHeroCalendarGlance.astro';
import ScheduleHeroGeneratorPanel from '../components/schedules/ScheduleHeroGeneratorPanel.astro';
import { generateSchedule } from '../lib/schedules/generateSchedule';
import { getDefaultStartDate } from '../lib/schedules/format';
import { getCanonicalUrl } from '../lib/seo/metadata';
import {
	buildArticleSchema,
	buildBreadcrumbSchema,
	buildFAQSchema,
	buildItemListSchema,
	buildWebPageSchema,
} from '../lib/seo/schema';
import {
	articleTocItems,
	builderHelp,
	calendarGlance,
	decisionGuide,
	editorialReview,
	familyExample,
	faqItems,
	faqSection,
	hero,
	heroTrustSignals,
	meta,
	overnightCheck,
	quickFacts,
	whenNot5050,
} from '../data/fiftyFiftyCustodySchedule';

const canonical = '/50-50-custody-schedule/';
const canonicalUrl = getCanonicalUrl(canonical);
const startDate = getDefaultStartDate();
const generatedSchedule = generateSchedule({
	scheduleId: '223',
	startDate,
	parentNames: { parentA: 'Parent A', parentB: 'Parent B' },
});

const breadcrumbs = [
	{ name: 'Home', url: getCanonicalUrl('/') },
	{ name: 'Schedules', url: getCanonicalUrl('/custody-schedule-generator/') },
	{ name: '50/50 Custody Schedule', url: canonicalUrl },
];

const patternGuideUrls: Record<string, string> = {
	'choose-223': '/2-2-3-custody-schedule/',
	'choose-5225': '/5-2-2-5-custody-schedule/',
	'choose-2255': '/2-2-5-5-custody-schedule/',
	'choose-3443': '/3-4-4-3-custody-schedule/',
	'choose-week-on-week-off': '/week-on-week-off-custody-schedule/',
};

const schema = [
	buildWebPageSchema({ name: meta.title, description: meta.description, url: canonicalUrl }),
	buildArticleSchema({
		headline: hero.headline,
		description: meta.description,
		url: canonicalUrl,
		datePublished: meta.datePublished,
		dateModified: meta.dateModified,
		authorName: editorialReview.reviewer,
	}),
	buildItemListSchema({
		name: '50/50 custody schedule patterns',
		description: 'Equal parenting time patterns compared for family fit.',
		url: canonicalUrl,
		items: decisionGuide.choices.map((choice) => ({
			name: choice.heading.replace('…', ''),
			url: getCanonicalUrl(patternGuideUrls[choice.id] ?? canonical),
		})),
	}),
	buildFAQSchema(faqItems),
	buildBreadcrumbSchema(breadcrumbs),
	{
		'@context': 'https://schema.org',
		'@type': 'WebApplication',
		name: '50/50 Custody Schedule Calendar Generator',
		description: meta.description,
		url: canonicalUrl,
		inLanguage: 'en-US',
		areaServed: 'US',
		applicationCategory: 'LegalApplication',
		operatingSystem: 'Web',
		offers: {
			'@type': 'Offer',
			price: '0',
			priceCurrency: 'USD',
		},
	},
	{
		'@context': 'https://schema.org',
		'@type': 'HowTo',
		name: 'How to choose a 50/50 custody schedule',
		description: 'Compare equal-time patterns, pick the best fit, and generate a printable calendar.',
		inLanguage: 'en-US',
		totalTime: 'PT10M',
		step: [
			{
				'@type': 'HowToStep',
				name: 'Match your family to a pattern',
				text: 'Use the decision guide to choose among 2-2-3, 2-2-5-5, 5-2-2-5, 3-4-4-3, or week-on/week-off.',
			},
			{
				'@type': 'HowToStep',
				name: 'Select the schedule in the generator',
				text: 'Open the generator, pick your pattern, and set a start date.',
			},
			{
				'@type': 'HowToStep',
				name: 'Verify overnights and export',
				text: 'Check the monthly preview and annual overnight estimate, then print or export.',
			},
		],
	},
];
---

<BaseLayout title={meta.title} description={meta.description} canonical={canonical}>
	<JsonLd slot="head" data={schema} />
	<Navbar />
	<Breadcrumbs items={breadcrumbs} />
	<main>
		<section
			class="container-shell grid grid-cols-1 gap-5 py-4 sm:py-5 lg:grid-cols-[minmax(0,0.88fr)_minmax(704px,1.12fr)] lg:items-start lg:gap-7 lg:py-6 xl:w-[min(100%,1360px)]"
			id="schedule-generator"
		>
			<div class="order-1 min-w-0 lg:col-start-1 lg:row-start-1 lg:pt-1">
				<p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">50/50 schedule hub</p>
				<h1 class="mt-2.5 max-w-3xl text-4xl font-semibold leading-[0.98] tracking-[-0.055em] text-primary sm:text-5xl">
					{hero.headline}
				</h1>
				{hero.intro.map((paragraph) => (
					<p class="mt-3 max-w-2xl text-base leading-7 text-secondary">{paragraph}</p>
				))}

				<dl class="mt-4 grid gap-2 sm:grid-cols-3">
					{quickFacts.items.map((fact) => (
						<div class="rounded-[1rem] bg-surface/70 px-3 py-2.5 shadow-[inset_0_0_0_1px_var(--border-subtle)]">
							<dt class="text-[10px] font-semibold uppercase tracking-[0.12em] text-muted">{fact.label}</dt>
							<dd class="mt-1 text-xs font-semibold leading-5 text-primary">{fact.value}</dd>
						</div>
					))}
				</dl>

				<div class="mt-4 max-w-2xl rounded-[1rem] bg-page/70 px-3 py-2.5 text-xs leading-5 text-secondary shadow-[inset_0_0_0_1px_var(--border-subtle)]">
					<p>
						<strong class="text-primary">Last reviewed: {editorialReview.lastReviewed}</strong>
						{' · '}
						Reviewed by{' '}
						<a href={editorialReview.reviewerHref} class="font-semibold text-accent underline decoration-line underline-offset-4 hover:text-primary">
							{editorialReview.reviewer}
						</a>
					</p>
					<p class="mt-1 text-muted">{editorialReview.body}</p>
				</div>

				<p class="mt-3 text-xs leading-5 text-muted lg:hidden">
					<a href="/disclaimer/" class="font-semibold text-secondary underline decoration-line underline-offset-4 hover:text-primary">Full disclaimer</a>
				</p>
			</div>

			<ScheduleHeroGeneratorPanel
				selectedScheduleId="223"
				generatedSchedule={generatedSchedule}
				heroTrustSignals={heroTrustSignals}
			/>

			<div class="order-3 min-w-0 lg:col-start-1 lg:row-start-2">
				<ScheduleHeroCalendarGlance
					calendarGlance={calendarGlance}
					extraNote="Other 50/50 patterns use different grids — see the decision guide below."
				/>
				<p class="mt-3 text-xs leading-5 text-muted">
					<a href="/disclaimer/" class="font-semibold text-secondary underline decoration-line underline-offset-4 hover:text-primary">Full disclaimer</a>
				</p>
			</div>
		</section>

		<ArticleTOC items={articleTocItems} />

		<section id="family-example" class="container-shell scroll-mt-24 pb-section" aria-labelledby="family-example-title">
			<div class="max-w-3xl">
				<p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">One family, one decision</p>
				<h2 id="family-example-title" class="mt-3 text-3xl font-semibold tracking-[-0.04em] text-primary sm:text-4xl">
					{familyExample.title}
				</h2>
				<p class="mt-2 text-lg font-medium text-secondary">{familyExample.subtitle}</p>
				<p class="mt-4 text-base leading-7 text-secondary">{familyExample.intro}</p>
			</div>
			<div class="mt-8 max-w-3xl space-y-6">
				{familyExample.story.map((item) => (
					<article class="soft-card rounded-[1.5rem] p-5">
						<h3 class="text-xl font-semibold tracking-[-0.03em] text-primary">{item.heading}</h3>
						<p class="mt-3 text-base leading-7 text-secondary" set:html={item.body} />
					</article>
				))}
				<p class="text-base leading-7 text-secondary" set:html={familyExample.close} />
			</div>
		</section>

		<section id="decision-guide" class="container-shell scroll-mt-24 py-section" aria-labelledby="decision-guide-title">
			<div class="max-w-3xl">
				<p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">Equal-time decision framework</p>
				<h2 id="decision-guide-title" class="mt-3 text-3xl font-semibold tracking-[-0.04em] text-primary sm:text-4xl">
					{decisionGuide.title}
				</h2>
				<p class="mt-4 text-base leading-7 text-secondary">{decisionGuide.intro}</p>
			</div>
			<div class="mt-8 max-w-3xl space-y-5">
				{decisionGuide.choices.map((choice) => (
					<article id={choice.id} class="soft-card scroll-mt-24 rounded-[1.5rem] p-5">
						<h3 class="text-xl font-semibold tracking-[-0.03em] text-primary">{choice.heading}</h3>
						<ul class="mt-3 space-y-2 text-sm leading-6 text-secondary">
							{choice.signals.map((signal) => (
								<li class="flex gap-2">
									<span class="text-accent" aria-hidden="true">→</span>
									{signal}
								</li>
							))}
						</ul>
						<p class="mt-4 text-base leading-7 text-secondary" set:html={choice.body} />
					</article>
				))}
				<p class="text-base leading-7 text-secondary" set:html={decisionGuide.close} />
			</div>
		</section>

		<section id="when-not-5050" class="container-shell scroll-mt-24 py-section" aria-labelledby="when-not-5050-title">
			<div class="max-w-3xl">
				<p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">Beyond equal time</p>
				<h2 id="when-not-5050-title" class="mt-3 text-3xl font-semibold tracking-[-0.04em] text-primary sm:text-4xl">
					{whenNot5050.title}
				</h2>
				<p class="mt-4 text-base leading-7 text-secondary">{whenNot5050.intro}</p>
			</div>
			<div class="mt-8 max-w-3xl space-y-6">
				{whenNot5050.points.map((point) => (
					<article>
						<h3 class="text-lg font-semibold text-primary">{point.heading}</h3>
						<p class="mt-3 text-base leading-7 text-secondary" set:html={point.body} />
					</article>
				))}
			</div>
		</section>

		<section id="overnight-check" class="container-shell scroll-mt-24 py-section" aria-labelledby="overnight-check-title">
			<div class="max-w-3xl">
				<p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">Overnight math</p>
				<h2 id="overnight-check-title" class="mt-3 text-3xl font-semibold tracking-[-0.04em] text-primary sm:text-4xl">
					{overnightCheck.title}
				</h2>
				<p class="mt-4 text-base leading-7 text-secondary" set:html={overnightCheck.body} />
			</div>
		</section>

		<section id="builder-help" class="container-shell scroll-mt-24 py-section" aria-labelledby="builder-help-title">
			<div class="max-w-3xl">
				<p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">Generator</p>
				<h2 id="builder-help-title" class="mt-3 text-3xl font-semibold tracking-[-0.04em] text-primary sm:text-4xl">
					{builderHelp.title}
				</h2>
				<p class="mt-4 text-base leading-7 text-secondary" set:html={builderHelp.intro} />
				<ul class="mt-4 space-y-2 text-sm leading-6 text-secondary">
					{builderHelp.features.map((feature) => (
						<li class="flex gap-2">
							<span class="text-accent" aria-hidden="true">→</span>
							{feature}
						</li>
					))}
				</ul>
				<div class="mt-6">
					<CtaButton href="#schedule-generator-panel" variant="primary" size="large">
						{builderHelp.cta}
					</CtaButton>
				</div>
			</div>
		</section>

		<FAQ
			items={faqItems}
			title={faqSection.title}
			description={faqSection.description}
		/>
		<BackToGeneratorCta />
	</main>
	<Footer />
</BaseLayout>
