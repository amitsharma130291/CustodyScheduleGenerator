---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import FAQ from '../components/FAQ.astro';
import CtaButton from '../components/CtaButton.astro';
import ArticleTOC from '../components/ArticleTOC.astro';
import ScheduleHeroCalendarGlance from '../components/schedules/ScheduleHeroCalendarGlance.astro';
import ScheduleHeroGeneratorPanel from '../components/schedules/ScheduleHeroGeneratorPanel.astro';
import { generateSchedule } from '../lib/schedules/generateSchedule';
import { getDefaultStartDate } from '../lib/schedules/format';
import { getCanonicalUrl } from '../lib/seo/metadata';
import {
	buildArticleSchema,
	buildBreadcrumbSchema,
	buildFAQSchema,
	buildWebPageSchema,
} from '../lib/seo/schema';
import {
	articleTocItems,
	builderHelp,
	calendarGlance,
	editorialReview,
	faqItems,
	faqSection,
	hero,
	heroTrustSignals,
	kindergartenProblems,
	meta,
	moveBeyond,
	planLanguage,
	quickFacts,
	tradeOff,
	weekFeels,
	whyStart,
} from '../data/twoTwoThreeCustodySchedule';

const canonical = '/2-2-3-custody-schedule/';
const canonicalUrl = getCanonicalUrl(canonical);
const startDate = getDefaultStartDate();
const generatedSchedule = generateSchedule({
	scheduleId: '223',
	startDate,
	parentNames: { parentA: 'Parent A', parentB: 'Parent B' },
});

const breadcrumbs = [
	{ name: 'Home', url: getCanonicalUrl('/') },
	{ name: '50/50 Custody Schedule', url: getCanonicalUrl('/50-50-custody-schedule/') },
	{ name: '2-2-3 Custody Schedule', url: canonicalUrl },
];

const schema = [
	buildWebPageSchema({ name: meta.title, description: meta.description, url: canonicalUrl }),
	buildArticleSchema({
		headline: hero.headline,
		description: meta.description,
		url: canonicalUrl,
		datePublished: meta.datePublished,
		dateModified: meta.dateModified,
		authorName: editorialReview.reviewer,
	}),
	buildFAQSchema(faqItems),
	buildBreadcrumbSchema(breadcrumbs),
	{
		'@context': 'https://schema.org',
		'@type': 'WebApplication',
		name: '2-2-3 Custody Schedule Calendar Generator',
		description: meta.description,
		url: canonicalUrl,
		inLanguage: 'en-US',
		areaServed: 'US',
		applicationCategory: 'LegalApplication',
		operatingSystem: 'Web',
		offers: {
			'@type': 'Offer',
			price: '0',
			priceCurrency: 'USD',
		},
	},
	{
		'@context': 'https://schema.org',
		'@type': 'HowTo',
		name: 'How to create a 2-2-3 Custody Schedule',
		description: 'Use the custody calendar generator to preview, compare, and export a 2-2-3 parenting schedule.',
		inLanguage: 'en-US',
		totalTime: 'PT5M',
		step: [
			{
				'@type': 'HowToStep',
				name: 'Choose the 2-2-3 schedule type',
				text: 'Select 2-2-3 Custody Schedule in the generator.',
			},
			{
				'@type': 'HowToStep',
				name: 'Pick a start date',
				text: 'Align the first exchange with daycare or school dismissal.',
			},
			{
				'@type': 'HowToStep',
				name: 'Review overnight percentages',
				text: 'Check the monthly calendar and generated annual average before exporting or printing.',
			},
		],
	},
];
---

<BaseLayout title={meta.title} description={meta.description} canonical={canonical}>
	<JsonLd slot="head" data={schema} />
	<Navbar />
	<Breadcrumbs items={breadcrumbs} />
	<main>
		<section
			class="container-shell grid grid-cols-1 gap-5 py-4 sm:py-5 lg:grid-cols-[minmax(0,0.88fr)_minmax(704px,1.12fr)] lg:items-start lg:gap-7 lg:py-6 xl:w-[min(100%,1360px)]"
			id="schedule-generator"
		>
			<div class="order-1 min-w-0 lg:col-start-1 lg:row-start-1 lg:pt-1">
				<p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">2-2-3 calendar generator</p>
				<h1 class="mt-2.5 max-w-3xl text-4xl font-semibold leading-[0.98] tracking-[-0.055em] text-primary sm:text-5xl">
					{hero.headline}
				</h1>
				{hero.intro.map((paragraph) => (
					<p class="mt-3 max-w-2xl text-base leading-7 text-secondary">{paragraph}</p>
				))}

				<dl class="mt-4 grid gap-2 sm:grid-cols-3">
					{quickFacts.items.map((fact) => (
						<div class="rounded-[1rem] bg-surface/70 px-3 py-2.5 shadow-[inset_0_0_0_1px_var(--border-subtle)]">
							<dt class="text-[10px] font-semibold uppercase tracking-[0.12em] text-muted">{fact.label}</dt>
							<dd class="mt-1 text-xs font-semibold leading-5 text-primary">{fact.value}</dd>
						</div>
					))}
				</dl>

				<div class="mt-4 max-w-2xl rounded-2xl bg-page/70 p-3 text-xs leading-5 text-secondary shadow-[inset_0_0_0_1px_var(--border-subtle)] lg:hidden">
					<p>
						<strong class="text-primary">Last reviewed: {editorialReview.lastReviewed}</strong>
						<br />
						Reviewed by:{' '}
						<a href={editorialReview.reviewerHref} class="font-semibold text-accent underline decoration-line underline-offset-4 hover:text-primary">
							{editorialReview.reviewer}
						</a>
					</p>
					<p class="mt-2 text-muted">Educational use only. Not legal advice.</p>
				</div>
			</div>

			<ScheduleHeroGeneratorPanel
				selectedScheduleId="223"
				generatedSchedule={generatedSchedule}
				heroTrustSignals={heroTrustSignals}
			/>

			<div class="order-3 min-w-0 lg:col-start-1 lg:row-start-2">
				<ScheduleHeroCalendarGlance calendarGlance={calendarGlance} />
				<p class="mt-3 text-xs leading-5 text-muted">
					Not legal advice.
					<a href="/disclaimer/" class="ml-1 font-semibold text-secondary underline decoration-line underline-offset-4 hover:text-primary">Read disclaimer</a>
				</p>
			</div>
		</section>

		<section id="editorial-review" class="container-shell pb-5">
			<div class="max-w-3xl rounded-2xl bg-page/70 p-4 text-sm leading-6 text-secondary shadow-[inset_0_0_0_1px_var(--border-subtle)]">
				<p>
					<strong class="text-primary">Last reviewed: {editorialReview.lastReviewed}</strong>
					<br />
					Reviewed by:{' '}
					<a href={editorialReview.reviewerHref} class="font-semibold text-accent underline decoration-line underline-offset-4 hover:text-primary">
						{editorialReview.reviewer}
					</a>
				</p>
				<p class="mt-2">{editorialReview.body}</p>
			</div>
		</section>

		<ArticleTOC items={articleTocItems} />

		<section id="why-start" class="container-shell scroll-mt-24 pb-section" aria-labelledby="why-start-title">
			<div class="max-w-3xl">
				<p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">Frequent contact</p>
				<h2 id="why-start-title" class="mt-3 text-3xl font-semibold tracking-[-0.04em] text-primary sm:text-4xl">
					{whyStart.title}
				</h2>
				<p class="mt-4 text-base leading-7 text-secondary" set:html={whyStart.intro} />
			</div>
			<div class="mt-8 max-w-3xl space-y-6">
				{whyStart.points.map((item) => (
					<article>
						<h3 class="text-xl font-semibold tracking-[-0.03em] text-primary">{item.heading}</h3>
						<p class="mt-3 text-base leading-7 text-secondary" set:html={item.body} />
					</article>
				))}
				<p class="text-base leading-7 text-secondary" set:html={whyStart.close} />
			</div>
		</section>

		<section id="week-feels" class="container-shell scroll-mt-24 py-section" aria-labelledby="week-feels-title">
			<div class="max-w-3xl">
				<p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">Lucas, age four</p>
				<h2 id="week-feels-title" class="mt-3 text-3xl font-semibold tracking-[-0.04em] text-primary sm:text-4xl">
					{weekFeels.title}
				</h2>
				<p class="mt-2 text-lg font-medium text-secondary">{weekFeels.subtitle}</p>
				<p class="mt-4 text-base leading-7 text-secondary">{weekFeels.intro}</p>
			</div>
			<div class="mt-8 max-w-3xl space-y-8">
				<div>
					<p class="text-xs font-semibold uppercase tracking-[0.14em] text-accent">{weekFeels.weekOneLabel}</p>
					<div class="mt-4 space-y-6">
						{weekFeels.days.map((item) => (
							<article class="soft-card rounded-[1.5rem] p-5">
								<p class="text-xs font-semibold uppercase tracking-[0.14em] text-muted">{item.day}</p>
								<h3 class="mt-2 text-xl font-semibold tracking-[-0.03em] text-primary">{item.heading}</h3>
								<p class="mt-3 text-base leading-7 text-secondary">{item.body}</p>
							</article>
						))}
					</div>
				</div>
				<div>
					<p class="text-xs font-semibold uppercase tracking-[0.14em] text-accent">{weekFeels.weekTwoLabel}</p>
					<div class="mt-4 space-y-6">
						{weekFeels.weekTwoDays.map((item) => (
							<article class="soft-card rounded-[1.5rem] p-5">
								<p class="text-xs font-semibold uppercase tracking-[0.14em] text-muted">{item.day}</p>
								<h3 class="mt-2 text-xl font-semibold tracking-[-0.03em] text-primary">{item.heading}</h3>
								<p class="mt-3 text-base leading-7 text-secondary">{item.body}</p>
							</article>
						))}
					</div>
				</div>
				<p class="text-base leading-7 text-secondary" set:html={weekFeels.close} />
			</div>
		</section>

		<section id="trade-off" class="container-shell scroll-mt-24 py-section" aria-labelledby="trade-off-title">
			<div class="max-w-3xl">
				<p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">Exchange load</p>
				<h2 id="trade-off-title" class="mt-3 text-3xl font-semibold tracking-[-0.04em] text-primary sm:text-4xl">
					{tradeOff.title}
				</h2>
				<p class="mt-4 text-base leading-7 text-secondary">{tradeOff.intro}</p>
			</div>
			<div class="mt-8 max-w-3xl space-y-6">
				{tradeOff.points.map((item) => (
					<article>
						<h3 class="text-xl font-semibold tracking-[-0.03em] text-primary">{item.heading}</h3>
						<p class="mt-3 text-base leading-7 text-secondary" set:html={item.body} />
					</article>
				))}
				<p class="text-base leading-7 text-secondary" set:html={tradeOff.close} />
			</div>
		</section>

		<section id="move-beyond" class="container-shell scroll-mt-24 py-section" aria-labelledby="move-beyond-title">
			<div class="max-w-3xl">
				<p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">Schedule shifts</p>
				<h2 id="move-beyond-title" class="mt-3 text-3xl font-semibold tracking-[-0.04em] text-primary sm:text-4xl">
					{moveBeyond.title}
				</h2>
				<p class="mt-4 text-base leading-7 text-secondary">{moveBeyond.intro}</p>
			</div>
			<div class="mt-8 max-w-3xl space-y-6">
				{moveBeyond.scenarios.map((item) => (
					<article class="soft-card rounded-[1.5rem] p-5">
						<h3 class="text-lg font-semibold text-primary">{item.heading}</h3>
						<p class="mt-3 text-base leading-7 text-secondary" set:html={item.body} />
					</article>
				))}
				<p class="text-base leading-7 text-secondary">{moveBeyond.close}</p>
			</div>
		</section>

		<section id="kindergarten" class="container-shell scroll-mt-24 py-section" aria-labelledby="kindergarten-title">
			<div class="max-w-3xl">
				<p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">Kindergarten transition</p>
				<h2 id="kindergarten-title" class="mt-3 text-3xl font-semibold tracking-[-0.04em] text-primary sm:text-4xl">
					{kindergartenProblems.title}
				</h2>
				<p class="mt-4 text-base leading-7 text-secondary">{kindergartenProblems.intro}</p>
			</div>
			<div class="mt-8 max-w-3xl space-y-4">
				{kindergartenProblems.items.map((item) => (
					<article class="soft-card rounded-[1.25rem] p-4">
						<h3 class="text-lg font-semibold text-primary">{item.title}</h3>
						<p class="mt-3 text-sm leading-6 text-secondary" set:html={item.body} />
					</article>
				))}
			</div>
		</section>

		<section id="plan-language" class="container-shell scroll-mt-24 py-section" aria-labelledby="plan-language-title">
			<div class="max-w-3xl">
				<p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">Written plan language</p>
				<h2 id="plan-language-title" class="mt-3 text-3xl font-semibold tracking-[-0.04em] text-primary sm:text-4xl">
					{planLanguage.title}
				</h2>
				<p class="mt-4 text-sm leading-6 text-muted">{planLanguage.disclaimer}</p>
				<p class="mt-2 text-sm leading-6 text-secondary">{planLanguage.adaptationNote}</p>
				<p class="mt-4 text-base leading-7 text-secondary">{planLanguage.intro}</p>
				<p class="mt-3 text-base leading-7 text-secondary">{planLanguage.whyItHelps}</p>
			</div>
			<div class="mt-6 max-w-3xl">
				<blockquote class="soft-card rounded-[1.5rem] border-l-4 border-accent p-5 text-sm leading-7 text-secondary">
					{planLanguage.clause}
				</blockquote>
				<ul class="mt-4 space-y-2 text-sm leading-6 text-secondary">
					{planLanguage.notes.map((note) => (
						<li class="flex gap-2">
							<span class="text-accent" aria-hidden="true">→</span>
							{note}
						</li>
					))}
				</ul>
				<p class="mt-4 text-sm leading-6 text-secondary">
					Organize exchanges, holidays, and change rules in the{' '}
					<a href="/parenting-plan-template/" class="font-semibold text-accent underline decoration-line underline-offset-4 hover:text-primary">parenting plan template</a>.
				</p>
			</div>
		</section>

		<section id="builder-help" class="container-shell scroll-mt-24 py-section" aria-labelledby="builder-help-title">
			<div class="max-w-3xl">
				<p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">Pattern testing</p>
				<h2 id="builder-help-title" class="mt-3 text-3xl font-semibold tracking-[-0.04em] text-primary sm:text-4xl">
					{builderHelp.title}
				</h2>
				<p class="mt-4 text-base leading-7 text-secondary" set:html={builderHelp.intro} />
				<ul class="mt-4 space-y-2 text-sm leading-6 text-secondary">
					{builderHelp.features.map((feature) => (
						<li class="flex gap-2">
							<span class="text-accent" aria-hidden="true">→</span>
							{feature}
						</li>
					))}
				</ul>
				<p class="mt-4 text-sm leading-6 text-secondary">
					Verify overnight totals with the{' '}
					<a href="/custody-percentage-calculator/" class="font-semibold text-accent underline decoration-line underline-offset-4 hover:text-primary">custody percentage calculator</a>.
				</p>
				<div class="mt-6">
					<CtaButton href="#schedule-generator-panel" variant="primary" size="large">
						{builderHelp.cta}
					</CtaButton>
				</div>
			</div>
		</section>

		<FAQ
			items={faqItems}
			title={faqSection.title}
			description={faqSection.description}
		/>
	</main>
	<Footer />
</BaseLayout>
