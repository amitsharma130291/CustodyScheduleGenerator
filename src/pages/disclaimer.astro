---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import { getCanonicalUrl } from '../lib/seo/metadata';
import { buildBreadcrumbSchema, buildWebPageSchema } from '../lib/seo/schema';

const title = 'CustodyBuilder Disclaimer and Tool Limits | CustodyBuilder';
const description =
	'Read the CustodyBuilder disclaimer for custody schedule estimates, parenting time calendars, educational planning tools, legal limits, and review.';
const canonical = '/disclaimer';
const canonicalUrl = getCanonicalUrl(canonical);
const breadcrumbs = [
	{ name: 'Home', url: getCanonicalUrl('/') },
	{ name: 'Legal', url: getCanonicalUrl('/disclaimer') },
	{ name: 'Disclaimer', url: canonicalUrl },
];
const schema = [
	buildBreadcrumbSchema(breadcrumbs),
	buildWebPageSchema({ name: title, description, url: canonicalUrl }),
];
---

<BaseLayout title={title} description={description} canonical={canonical} robots="noindex, follow">
	<JsonLd slot="head" data={schema} />
	<Navbar />
	<Breadcrumbs items={breadcrumbs} />
	<main>
		<section class="container-shell py-12 lg:py-16">
			<div class="mx-auto max-w-3xl">
				<a href="/" class="text-sm font-medium text-muted transition-colors duration-200 hover:text-primary">← Back to CustodyBuilder</a>
				<p class="mt-5 text-xs font-semibold uppercase tracking-[0.18em] text-muted">Legal</p>
				<h1 class="mt-4 text-5xl font-semibold leading-[0.98] tracking-[-0.055em] text-primary lg:text-6xl">
					Disclaimer
				</h1>
				<p class="mt-6 text-lg leading-8 text-secondary">
					CustodyBuilder helps parents and caregivers visualize custody schedules for educational and planning purposes only.
				</p>
			</div>

			<div class="premium-card mx-auto mt-8 grid max-w-3xl gap-6 rounded-[1.75rem] p-6 text-base leading-8 text-secondary sm:p-8">
				<section>
					<h2 class="text-2xl font-semibold tracking-[-0.04em] text-primary">Not Legal Advice</h2>
					<p class="mt-3">
						CustodyBuilder is an educational planning tool and does not provide legal advice. Information generated by the site should not be relied upon as a substitute for advice from a qualified family law attorney or other legal professional.
					</p>
				</section>

				<section>
					<h2 class="text-2xl font-semibold tracking-[-0.04em] text-primary">No Legal Agreement</h2>
					<p class="mt-3">
						Using CustodyBuilder does not create a court order, custody agreement, parenting plan, attorney-client relationship, or any legally enforceable document.
					</p>
				</section>

				<section>
					<h2 class="text-2xl font-semibold tracking-[-0.04em] text-primary">Schedule Estimates</h2>
					<p class="mt-3">
						Custody percentages and parenting-time calculations are estimates based primarily on overnight allocations. Real-world custody arrangements may be affected by school schedules, holidays, exchanges, vacations, court orders, and local laws.
					</p>
				</section>

				<section>
					<h2 class="text-2xl font-semibold tracking-[-0.04em] text-primary">Professional Review</h2>
					<p class="mt-3">
						Before submitting any parenting plan to a court, mediator, attorney, or co-parent, users should independently verify all schedule details and seek professional legal guidance when appropriate.
					</p>
				</section>
			</div>
		</section>
	</main>
	<Footer />
</BaseLayout>
