---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import { getCanonicalUrl } from '../lib/seo/metadata';
import { buildAboutPageSchema, buildBreadcrumbSchema } from '../lib/seo/schema';

const title = 'About CustodyBuilder | Custody Schedule Planning Tool';
const description =
	'Learn about CustodyBuilder and how it helps parents create custody schedules, parenting calendars, and printable planning tools.';
const canonical = '/about/';
const canonicalUrl = getCanonicalUrl(canonical);
const breadcrumbs = [
	{ name: 'Home', url: getCanonicalUrl('/') },
	{ name: 'About', url: canonicalUrl },
];
const schema = [
	buildBreadcrumbSchema(breadcrumbs),
	buildAboutPageSchema({ name: title, description, url: canonicalUrl }),
];
---

<BaseLayout title={title} description={description} canonical={canonical}>
	<JsonLd slot="head" data={schema} />
	<Navbar />
	<Breadcrumbs items={breadcrumbs} />
	<main>
		<section class="container-shell py-12 lg:py-16">
			<div class="mx-auto max-w-3xl">
				<a href="/" class="text-sm font-medium text-muted transition-colors duration-200 hover:text-primary">← Back to CustodyBuilder</a>
				<p class="mt-5 text-xs font-semibold uppercase tracking-[0.18em] text-muted">About</p>
				<h1 class="mt-4 text-5xl font-semibold leading-[0.98] tracking-[-0.055em] text-primary lg:text-6xl">
					About CustodyBuilder
				</h1>
				<p class="mt-6 text-lg leading-8 text-secondary">
					CustodyBuilder helps parents and caregivers create clearer custody schedules, parenting calendars, and printable planning tools.
				</p>
			</div>

			<div class="premium-card mx-auto mt-8 grid max-w-3xl gap-6 rounded-[1.75rem] p-6 text-base leading-8 text-secondary sm:p-8">
				<section>
					<h2 class="text-2xl font-semibold tracking-[-0.04em] text-primary">Why CustodyBuilder Was Created</h2>
					<p class="mt-3">
						Custody schedules can be hard to understand when they are described only in text. CustodyBuilder was created to help families see the practical calendar behind a proposed parenting-time arrangement before they print, share, or discuss it.
					</p>
				</section>

				<section>
					<h2 class="text-2xl font-semibold tracking-[-0.04em] text-primary">Who It Helps</h2>
					<p class="mt-3">
						The site is built for parents, caregivers, and families who want a clearer way to compare custody schedules, visualize parenting time, prepare for co-parent conversations, and organize schedule ideas before professional review.
					</p>
				</section>

				<section>
					<h2 class="text-2xl font-semibold tracking-[-0.04em] text-primary">Custody Schedule Planning</h2>
					<p class="mt-3">
						CustodyBuilder is designed to make parenting time easier to visualize. Parents and caregivers can compare common custody schedule patterns, enter basic schedule details, and see how those choices appear on a calendar before discussing a plan.
					</p>
				</section>

				<section>
					<h2 class="text-2xl font-semibold tracking-[-0.04em] text-primary">Editorial Standards</h2>
					<p class="mt-3">
						Content is written and reviewed by the CustodyBuilder Editorial Team for plain-English clarity, practical usefulness, and consistency with the site’s calendar tools. We avoid legal promises, do not present educational material as legal advice, and update pages when planning guidance, tool behavior, or internal resources change.
					</p>
				</section>

				<section>
					<h2 class="text-2xl font-semibold tracking-[-0.04em] text-primary">Fact-Checking Approach</h2>
					<p class="mt-3">
						Fact checks focus on schedule mechanics, parenting-time calculations, exchange patterns, printable calendar behavior, and internal links between related tools. Legal rules vary by state and case, so legal questions should be reviewed with a qualified family law professional.
					</p>
				</section>

				<section>
					<h2 class="text-2xl font-semibold tracking-[-0.04em] text-primary">Parenting Time Calendars</h2>
					<p class="mt-3">
						The tool helps turn a repeating custody schedule into a visible parenting time calendar. This makes it easier to review overnights, weekends, exchange days, and the practical rhythm of a proposed schedule.
					</p>
				</section>

				<section>
					<h2 class="text-2xl font-semibold tracking-[-0.04em] text-primary">Available Planning Tools</h2>
					<p class="mt-3">
						CustodyBuilder supports printable custody schedules, custody calendar templates, parenting plan templates, custody percentage calculators, parenting time calculators, and visitation planning tools.
					</p>
				</section>

				<section>
					<h2 class="text-2xl font-semibold tracking-[-0.04em] text-primary">Educational Planning Only</h2>
					<p class="mt-3">
						CustodyBuilder is for educational planning only and is not legal advice. It does not create a court order, legal agreement, attorney-client relationship, or substitute for professional legal guidance.
					</p>
				</section>

				<section>
					<h2 class="text-2xl font-semibold tracking-[-0.04em] text-primary">Commitment to Clarity and Usability</h2>
					<p class="mt-3">
						CustodyBuilder focuses on simple language, readable calendars, printable outputs, and clear internal links between related schedules and tools. The goal is to make planning easier to understand without making decisions for the family.
					</p>
				</section>

				<section>
					<h2 class="text-2xl font-semibold tracking-[-0.04em] text-primary">Contact and Corrections</h2>
					<p class="mt-3">
						Questions, corrections, or feedback about custody schedule content can be sent through the <a href="/contact/" class="text-accent underline decoration-line underline-offset-4 hover:text-primary">contact page</a>. Please do not send confidential legal details through the website.
					</p>
				</section>
			</div>
		</section>
	</main>
	<Footer />
</BaseLayout>
