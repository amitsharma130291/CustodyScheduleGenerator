---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import FAQ from '../components/FAQ.astro';
import CtaButton from '../components/CtaButton.astro';
import ScheduleHeroGeneratorPanel from '../components/schedules/ScheduleHeroGeneratorPanel.astro';
import ThreeFourFourThreeMonthRhythmGraphic from '../components/schedules/3443/ThreeFourFourThreeMonthRhythmGraphic.astro';
import ThreeFourFourThreePrintableSample from '../components/schedules/3443/ThreeFourFourThreePrintableSample.astro';
import ThreeFourFourThreeWeekendRotationGraphic from '../components/schedules/3443/ThreeFourFourThreeWeekendRotationGraphic.astro';
import { generateSchedule } from '../lib/schedules/generateSchedule';
import { getDefaultStartDate } from '../lib/schedules/format';
import { getCanonicalUrl } from '../lib/seo/metadata';
import {
	buildArticleSchema,
	buildBreadcrumbSchema,
	buildFAQSchema,
	buildWebPageSchema,
} from '../lib/seo/schema';
import {
	articleTocItems,
	beforeYouChoose,
	costOfRotation,
	editorialReview,
	faqItems,
	faqSection,
	hero,
	heroKeyStats,
	heroTrustSignals,
	meta,
	noPermanentWeekend,
	postContentCta,
	startsWorking,
	typicalMonth,
	weekendBalance,
	whenAnotherBetter,
} from '../data/threeFourFourThreeCustodySchedule';

const canonical = '/3-4-4-3-custody-schedule/';
const canonicalUrl = getCanonicalUrl(canonical);
const startDate = getDefaultStartDate();
const generatedSchedule = generateSchedule({
	scheduleId: '3443',
	startDate,
	parentNames: { parentA: 'Parent A', parentB: 'Parent B' },
});

const breadcrumbs = [
	{ name: 'Home', url: getCanonicalUrl('/') },
	{ name: '50/50 Custody Schedule', url: getCanonicalUrl('/50-50-custody-schedule/') },
	{ name: '3-4-4-3 Custody Schedule', url: canonicalUrl },
];

const schema = [
	buildWebPageSchema({ name: meta.title, description: meta.description, url: canonicalUrl }),
	buildArticleSchema({
		headline: hero.headline,
		description: meta.description,
		url: canonicalUrl,
		datePublished: meta.datePublished,
		dateModified: meta.dateModified,
		authorName: 'CustodyBuilder Editorial Team',
	}),
	buildFAQSchema(faqItems),
	buildBreadcrumbSchema(breadcrumbs),
	{
		'@context': 'https://schema.org',
		'@type': 'WebApplication',
		name: '3-4-4-3 Custody Schedule Calendar Generator',
		description: meta.description,
		url: canonicalUrl,
		inLanguage: 'en-US',
		areaServed: 'US',
		applicationCategory: 'LegalApplication',
		operatingSystem: 'Web',
		offers: {
			'@type': 'Offer',
			price: '0',
			priceCurrency: 'USD',
		},
	},
];
---

<BaseLayout title={meta.title} description={meta.description} canonical={canonical}>
	<JsonLd slot="head" data={schema} />
	<Navbar />
	<Breadcrumbs items={breadcrumbs} />
	<main class="tfft-page">
		<section
			class="container-shell grid grid-cols-1 gap-5 py-4 sm:py-5 lg:grid-cols-[minmax(0,0.88fr)_minmax(704px,1.12fr)] lg:items-start lg:gap-7 lg:py-6 xl:w-[min(100%,1360px)]"
			id="schedule-generator"
		>
			<div class="order-1 min-w-0 lg:col-start-1 lg:row-start-1 lg:pt-1">
				<h1 class="max-w-3xl text-4xl font-semibold leading-[0.98] tracking-[-0.055em] text-primary sm:text-5xl">
					{hero.headline}
				</h1>

				<dl class="mt-4 grid grid-cols-3 gap-2">
					{heroKeyStats.map((stat) => (
						<div class="rounded-[1rem] bg-accent/10 px-2 py-2.5 text-center shadow-[inset_0_0_0_1px_rgba(37,99,235,0.15)] sm:px-3">
							<dd class="text-lg font-bold tabular-nums tracking-tight text-accent sm:text-xl">{stat.value}</dd>
							<dt class="mt-0.5 text-[10px] font-semibold uppercase leading-4 tracking-[0.08em] text-secondary">{stat.label}</dt>
						</div>
					))}
				</dl>

				<p class="mt-3 max-w-2xl text-base leading-7 text-secondary" set:html={hero.intro} />

				<div class="mt-3 max-w-2xl text-xs leading-5 text-muted">
					<p class="font-semibold text-secondary">Reviewed for:</p>
					<ul class="mt-1 list-inside list-disc space-y-0.5">
						{editorialReview.reviewedFor.map((item) => (
							<li>{item}</li>
						))}
					</ul>
					<p class="mt-2">
						Reviewed by{' '}
						<a href={editorialReview.reviewerHref} class="font-semibold text-secondary underline decoration-line underline-offset-4 hover:text-primary">
							{editorialReview.reviewer}
						</a>
						{' · '}
						Methodology:{' '}
						<a href={editorialReview.methodologyHref} class="font-semibold text-secondary underline decoration-line underline-offset-4 hover:text-primary">
							{editorialReview.methodologyLabel}
						</a>
						{' · '}{editorialReview.disclaimer}
					</p>
				</div>
			</div>

			<ScheduleHeroGeneratorPanel
				selectedScheduleId="3443"
				generatedSchedule={generatedSchedule}
				heroTrustSignals={heroTrustSignals}
			/>

			<div class="order-3 min-w-0 lg:col-start-1 lg:row-start-2">
				<ThreeFourFourThreePrintableSample />
			</div>
		</section>

		<nav class="container-shell border-y border-line-subtle py-3" aria-label="On this page">
			<ul class="flex flex-wrap gap-x-4 gap-y-1 text-xs font-semibold text-secondary">
				{articleTocItems.map((item) => (
					<li><a href={`#${item.id}`} class="hover:text-accent">{item.label}</a></li>
				))}
			</ul>
		</nav>

		<aside id="before-you-choose" class="container-shell scroll-mt-24 py-5" aria-labelledby="before-you-choose-title">
			<div class="max-w-3xl rounded-[1rem] border border-accent/25 bg-accent/5 px-4 py-4 sm:px-5">
				<h2 id="before-you-choose-title" class="text-sm font-semibold tracking-[-0.02em] text-primary sm:text-base">
					{beforeYouChoose.title}
				</h2>
				<p class="mt-2 text-sm leading-6 text-secondary">
					Ask yourself one question: <span class="font-medium text-primary">{beforeYouChoose.question}</span>{' '}
					<span set:html={beforeYouChoose.body} />
				</p>
			</div>
		</aside>

		<section id="weekend-balance" class="container-shell scroll-mt-24 border-t border-line-subtle py-10 lg:py-12" aria-labelledby="weekend-balance-title">
			<h2 id="weekend-balance-title" class="max-w-3xl text-2xl font-semibold tracking-[-0.04em] text-primary sm:text-3xl">
				{weekendBalance.title}
			</h2>
			<p class="mt-3 max-w-3xl text-base leading-7 text-secondary" set:html={weekendBalance.intro} />
			<div class="mt-6 space-y-5 max-w-3xl">
				{weekendBalance.points.map((item) => (
					<article>
						<h3 class="text-lg font-semibold text-primary">{item.heading}</h3>
						<p class="mt-2 text-sm leading-6 text-secondary">{item.body}</p>
					</article>
				))}
			</div>
		</section>

		<section id="no-permanent-weekend" class="container-shell scroll-mt-24 border-t border-line-subtle py-10 lg:py-12" aria-labelledby="no-permanent-weekend-title">
			<div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_minmax(280px,400px)] lg:items-start">
				<div class="min-w-0">
					<h2 id="no-permanent-weekend-title" class="text-2xl font-semibold tracking-[-0.04em] text-primary sm:text-3xl">
						{noPermanentWeekend.title}
					</h2>
					<p class="mt-3 text-base leading-7 text-secondary" set:html={noPermanentWeekend.intro} />
					<div class="mt-6 grid gap-3 sm:grid-cols-2">
						{noPermanentWeekend.layers.map((item) => (
							<article class="rounded-xl bg-surface/60 p-4 shadow-[inset_0_0_0_1px_var(--border-subtle)]">
								<h3 class="text-base font-semibold text-primary">{item.heading}</h3>
								<p class="mt-2 text-sm leading-6 text-secondary">{item.body}</p>
							</article>
						))}
					</div>
				</div>
				<ThreeFourFourThreeWeekendRotationGraphic />
			</div>
		</section>

		<section id="typical-month" class="container-shell scroll-mt-24 border-t border-line-subtle py-10 lg:py-12" aria-labelledby="typical-month-title">
			<h2 id="typical-month-title" class="max-w-3xl text-2xl font-semibold tracking-[-0.04em] text-primary sm:text-3xl">
				{typicalMonth.title}
			</h2>
			<p class="mt-3 max-w-3xl text-base leading-7 text-secondary">{typicalMonth.intro}</p>
			<div class="mt-6 max-w-2xl">
				<ThreeFourFourThreeMonthRhythmGraphic />
			</div>
		</section>

		<section id="cost-of-rotation" class="container-shell scroll-mt-24 border-t border-line-subtle py-10 lg:py-12" aria-labelledby="cost-of-rotation-title">
			<h2 id="cost-of-rotation-title" class="max-w-3xl text-2xl font-semibold tracking-[-0.04em] text-primary sm:text-3xl">
				{costOfRotation.title}
			</h2>
			<p class="mt-3 max-w-3xl text-base leading-7 text-secondary">{costOfRotation.intro}</p>
			<p class="mt-4 max-w-3xl rounded-lg border border-line bg-surface/40 px-4 py-3 text-sm leading-6 text-secondary">
				{costOfRotation.example}
			</p>
			<div class="mt-6 max-w-3xl space-y-4">
				{costOfRotation.items.map((item) => (
					<article class="border-l-2 border-accent/30 pl-4">
						<h3 class="text-base font-semibold text-primary">{item.heading}</h3>
						<p class="mt-2 text-sm leading-6 text-secondary" set:html={item.body} />
					</article>
				))}
			</div>
		</section>

		<section id="starts-working" class="container-shell scroll-mt-24 border-t border-line-subtle py-10 lg:py-12" aria-labelledby="starts-working-title">
			<h2 id="starts-working-title" class="max-w-3xl text-2xl font-semibold tracking-[-0.04em] text-primary sm:text-3xl">
				{startsWorking.title}
			</h2>
			<p class="mt-3 max-w-3xl text-base leading-7 text-secondary" set:html={startsWorking.intro} />
			<ol class="mt-6 max-w-3xl space-y-4">
				{startsWorking.points.map((item, index) => (
					<li class="flex gap-4">
						<span class="grid h-7 w-7 shrink-0 place-items-center rounded-full bg-accent/15 text-xs font-bold text-accent">{index + 1}</span>
						<div>
							<h3 class="text-base font-semibold text-primary">{item.heading}</h3>
							<p class="mt-1 text-sm leading-6 text-secondary" set:html={item.body} />
						</div>
					</li>
				))}
			</ol>
		</section>

		<section id="when-another-better" class="container-shell scroll-mt-24 border-t border-line-subtle py-10 lg:py-12" aria-labelledby="when-another-better-title">
			<h2 id="when-another-better-title" class="max-w-3xl text-2xl font-semibold tracking-[-0.04em] text-primary sm:text-3xl">
				{whenAnotherBetter.title}
			</h2>
			<p class="mt-3 max-w-3xl text-base leading-7 text-secondary">{whenAnotherBetter.intro}</p>
			<div class="mt-6 grid gap-3 sm:grid-cols-2">
				{whenAnotherBetter.blocks.map((item) => (
					<article class="rounded-xl bg-surface/60 p-4 shadow-[inset_0_0_0_1px_var(--border-subtle)]">
						<h3 class="text-base font-semibold text-primary">{item.heading}</h3>
						<p class="mt-2 text-sm leading-6 text-secondary" set:html={item.body} />
					</article>
				))}
			</div>
		</section>

		<section id="convert-cta" class="container-shell scroll-mt-24 border-t border-line-subtle py-10 lg:py-12" aria-labelledby="convert-cta-title">
			<div class="max-w-2xl rounded-[1.25rem] border border-line bg-surface/40 p-6 sm:p-7">
				<h2 id="convert-cta-title" class="text-2xl font-semibold tracking-[-0.04em] text-primary sm:text-[1.65rem]">
					{postContentCta.heading}
				</h2>
				<p class="mt-3 text-sm leading-6 text-secondary sm:text-base sm:leading-7">{postContentCta.body}</p>
				<div class="mt-5 flex flex-col gap-3 sm:flex-row sm:items-center sm:gap-5">
					<CtaButton href={postContentCta.primaryHref} variant="primary" size="large">
						{postContentCta.primaryLabel}
					</CtaButton>
					<a
						href={postContentCta.secondaryHref}
						class="text-sm font-semibold text-accent underline decoration-line underline-offset-4 hover:text-primary"
					>
						{postContentCta.secondaryLabel}
					</a>
				</div>
			</div>
		</section>

		<FAQ items={faqItems} title={faqSection.title} description={faqSection.description} />
	</main>
	<Footer />
</BaseLayout>
