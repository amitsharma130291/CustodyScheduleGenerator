---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import BackToGeneratorCta from '../components/BackToGeneratorCta.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import FAQ from '../components/FAQ.astro';
import GeneratorPanel from '../components/tool/GeneratorPanel.astro';
import CalendarPreview from '../components/tool/CalendarPreview.astro';
import { generateSchedule } from '../lib/schedules/generateSchedule';
import { getDefaultStartDate } from '../lib/schedules/format';
import { getCanonicalUrl } from '../lib/seo/metadata';
import {
	buildArticleSchema,
	buildBreadcrumbSchema,
	buildFAQSchema,
	buildWebPageSchema,
} from '../lib/seo/schema';
import {
	buildCta,
	editorialReview,
	examples,
	faqItems,
	faqSection,
	hero,
	keyTakeaways,
	meta,
	mistakes,
	orientation,
	relatedLinks,
} from '../data/sampleParentingPlan';

const canonical = '/sample-parenting-plan/';
const canonicalUrl = getCanonicalUrl(canonical);
const startDate = getDefaultStartDate();

const generatedSchedule = generateSchedule({
	scheduleId: '223',
	startDate,
	parentNames: { parentA: 'Parent A', parentB: 'Parent B' },
});

const breadcrumbs = [
	{ name: 'Home', url: getCanonicalUrl('/') },
	{ name: 'Sample Parenting Plan', url: canonicalUrl },
];

const schema = [
	buildWebPageSchema({ name: meta.title, description: meta.description, url: canonicalUrl }),
	buildArticleSchema({
		headline: meta.title,
		description: meta.description,
		url: canonicalUrl,
		datePublished: meta.datePublished,
		dateModified: meta.dateModified,
		authorName: editorialReview.reviewer,
	}),
	buildFAQSchema(faqItems),
	buildBreadcrumbSchema(breadcrumbs),
];
---

<BaseLayout title={meta.title} description={meta.description} canonical={canonical} ogType="article">
	<JsonLd slot="head" data={schema} />
	<Navbar />
	<Breadcrumbs items={breadcrumbs} />
	<main class="overflow-x-clip">

		<!-- Hero -->
		<section class="container-shell py-8 lg:max-w-5xl lg:py-12" id="overview">
			<h1 class="max-w-3xl text-[1.7rem] font-semibold leading-[1.06] tracking-[-0.05em] text-primary sm:text-4xl lg:text-5xl">
				{hero.headline}
			</h1>

			<ul class="mt-4 flex flex-wrap gap-2 text-xs font-semibold text-secondary">
				{hero.trustChips.map((chip) => (
					<li class="rounded-full bg-surface/70 px-3 py-1.5 shadow-[inset_0_0_0_1px_var(--border-subtle)]">{chip}</li>
				))}
			</ul>

			<p class="mt-5 max-w-2xl text-base leading-7 text-secondary">{hero.intro}</p>
			<p class="mt-3 max-w-2xl text-sm leading-6 text-secondary">
				Want the blank version to start your own? Use the {' '}
				<a href="/parenting-plan-template/" class="font-semibold text-accent underline decoration-line underline-offset-4 hover:text-primary">parenting plan template</a>. These pages are the filled-in examples that show you what a finished plan looks like in practice.
			</p>

			<div class="mt-6 max-w-2xl text-xs leading-5 text-muted">
				<p class="font-semibold text-secondary">Reviewed for:</p>
				<ul class="mt-1 list-inside list-disc">{editorialReview.reviewedFor.map((i) => <li>{i}</li>)}</ul>
				<p class="mt-2">
					Reviewed by <a href={editorialReview.reviewerHref} class="font-semibold text-secondary underline">{editorialReview.reviewer}</a>
					{' · '}<a href={editorialReview.methodologyHref} class="font-semibold text-secondary underline">{editorialReview.methodologyLabel}</a>
					{' · '}<span class="font-semibold text-secondary">{editorialReview.lastUpdatedLabel}</span>
					{' · '}{editorialReview.disclaimer}
				</p>
			</div>

			<div class="mt-6 flex flex-wrap gap-3">
				<a href="/custody-schedule-generator/" class="inline-flex rounded-full bg-accent px-5 py-2.5 text-sm font-semibold text-white shadow-sm hover:opacity-90" style="color: #ffffff">Build your parenting-time schedule &rarr;</a>
				<a href="/parenting-plan-template/" class="inline-flex rounded-full bg-surface px-5 py-2.5 text-sm font-semibold text-accent shadow-[inset_0_0_0_1px_var(--border-subtle)] hover:text-primary">Start a blank template</a>
			</div>

			<p class="mt-4 max-w-2xl text-sm leading-6 text-muted">
				Prefer to jump straight to the interactive schedule builder?
				<a href="#tool" class="ml-1 font-semibold text-secondary underline decoration-line underline-offset-4 hover:text-accent">Skip to the builder &darr;</a>
			</p>

			<p class="mt-5 max-w-2xl text-xs leading-5 text-muted">
				Educational information only. Not legal advice. Every family below is fictional and illustrative.
				<a href="/disclaimer/" class="ml-1 font-semibold text-secondary underline decoration-line underline-offset-4 hover:text-primary">Read disclaimer</a>
			</p>
		</section>

		<!-- Key takeaways (skimmer summary, above the fold) -->
		<section id="takeaways" class="container-shell scroll-mt-24 pb-2 lg:max-w-5xl" aria-label="Key takeaways">
			<div class="max-w-3xl rounded-[1.5rem] border border-line bg-accent/10 p-5 sm:p-6">
				<h2 class="text-sm font-semibold uppercase tracking-[0.08em] text-accent">{keyTakeaways.title}</h2>
				<ul class="mt-3 space-y-2 text-sm leading-6 text-secondary">
					{keyTakeaways.points.map((point) => (
						<li class="flex gap-2"><span class="shrink-0 text-accent" aria-hidden="true">&rarr;</span>{point}</li>
					))}
				</ul>
			</div>
		</section>

		<!-- On-this-page nav -->
		<nav class="container-shell border-y border-line-subtle py-3 lg:max-w-5xl" aria-label="On this page">
			<ul class="flex flex-wrap gap-x-4 gap-y-1 text-xs font-semibold text-secondary">
				<li><a href="#takeaways" class="hover:text-accent">Key takeaways</a></li>
				<li><a href="#orientation" class="hover:text-accent">What a plan includes</a></li>
				<li><a href="#example-amicable-5050" class="hover:text-accent">1. Amicable 50/50</a></li>
				<li><a href="#example-high-conflict" class="hover:text-accent">2. High-conflict</a></li>
				<li><a href="#example-long-distance" class="hover:text-accent">3. Long-distance</a></li>
				<li><a href="#example-primary-eow-midweek" class="hover:text-accent">4. Primary + EOW</a></li>
				<li><a href="#example-infant-step-up" class="hover:text-accent">5. Infant step-up</a></li>
				<li><a href="#mistakes" class="hover:text-accent">Common mistakes</a></li>
				<li><a href="#tool" class="hover:text-accent">Build the schedule</a></li>
				<li><a href="#build" class="hover:text-accent">Build your own</a></li>
				<li><a href="#faq" class="hover:text-accent">FAQ</a></li>
			</ul>
		</nav>

		<!-- Section: Orientation (what a plan includes) -->
		<section id="orientation" class="container-shell scroll-mt-24 border-t border-line-subtle py-10 lg:max-w-5xl lg:py-12">
			<h2 class="text-2xl font-semibold text-primary sm:text-3xl">{orientation.title}</h2>
			<p class="mt-3 max-w-3xl text-secondary">{orientation.intro}</p>

			<div class="mt-6 grid gap-4 max-w-3xl sm:grid-cols-2">
				{orientation.sections.map((sec) => (
					<div class="rounded-[1.25rem] bg-surface/70 p-5 shadow-[inset_0_0_0_1px_var(--border-subtle)]">
						<p class="font-semibold text-primary">{sec.label}</p>
						<p class="mt-2 text-sm leading-6 text-secondary">
							{sec.body}
							{sec.link && (
								<span> <a href={sec.link.href} class="font-semibold text-accent underline decoration-line underline-offset-4 hover:text-primary">{sec.link.label}</a>.</span>
							)}
						</p>
					</div>
				))}
			</div>

			<div class="mt-5 max-w-3xl rounded-2xl bg-accent/10 px-4 py-3 text-sm leading-6 text-secondary">
				{orientation.howToRead}
			</div>
		</section>

		<!-- The five worked example plans -->
		{examples.map((ex) => (
			<section id={`example-${ex.id}`} class="container-shell scroll-mt-24 border-t border-line-subtle py-10 lg:max-w-5xl lg:py-12">
				<h2 class="text-2xl font-semibold text-primary sm:text-3xl">{ex.heading}</h2>
				<p class="mt-2 text-xs font-semibold uppercase tracking-[0.08em] text-accent">{ex.typeChip}</p>
				<p class="mt-3 max-w-3xl text-secondary">{ex.situation}</p>

				<p class="mt-3 max-w-3xl text-sm text-secondary">
					This plan follows the {' '}
					<a href={ex.scheduleLink.href} class="font-semibold text-accent underline decoration-line underline-offset-4 hover:text-primary">{ex.scheduleLink.label}</a>
					{ex.altScheduleLink && (
						<span>. For related detail, see the {' '}
							<a href={ex.altScheduleLink.href} class="font-semibold text-accent underline decoration-line underline-offset-4 hover:text-primary">{ex.altScheduleLink.label}</a>
						</span>
					)}. The mechanics live on that page; this example just uses the pattern.
				</p>

				<div class="mt-6 max-w-3xl overflow-hidden rounded-[1.5rem] ring-1 ring-line-subtle">
					<dl class="divide-y divide-line-subtle">
						{ex.sections.map((sec) => (
							<div class="grid gap-1 px-5 py-4 sm:grid-cols-[200px_1fr] sm:gap-4">
								<dt class="text-sm font-semibold text-primary">{sec.label}</dt>
								<dd class="text-sm leading-6 text-secondary">{sec.body}</dd>
							</div>
						))}
					</dl>
				</div>

				<div class="mt-5 max-w-3xl rounded-2xl bg-accent/10 px-4 py-4">
					<h3 class="text-sm font-semibold text-primary">Why it is written this way</h3>
					<ul class="mt-2 space-y-2 text-sm leading-6 text-secondary">
						{ex.annotations.map((note) => (
							<li class="flex gap-2"><span class="shrink-0 text-accent" aria-hidden="true">&rarr;</span>{note}</li>
						))}
					</ul>
				</div>

				<p class="mt-4 max-w-3xl text-xs leading-5 text-muted">
					Illustrative example only. The family is fictional, requirements vary by state, and any plan should be reviewed locally before filing.
				</p>
			</section>
		))}

		<!-- Tool teaser callout (peak desire, right after Example 5) -->
		<section class="container-shell scroll-mt-24 border-t border-line-subtle py-8 lg:max-w-5xl" aria-label="Build your schedule">
			<div class="flex max-w-3xl flex-col gap-3 rounded-[1.5rem] border border-line bg-accent/10 p-5 sm:flex-row sm:items-center sm:justify-between sm:p-6">
				<p class="text-base font-semibold text-primary">Ready to make the schedule section for your own plan?</p>
				<a href="#tool" class="inline-flex shrink-0 rounded-full bg-accent px-5 py-2.5 text-sm font-semibold text-white shadow-sm hover:opacity-90" style="color: #ffffff">Build it free &darr;</a>
			</div>
		</section>

		<!-- Section: Common mistakes -->
		<section id="mistakes" class="container-shell scroll-mt-24 border-t border-line-subtle py-10 lg:max-w-5xl lg:py-12">
			<h2 class="text-2xl font-semibold text-primary sm:text-3xl">{mistakes.title}</h2>
			<p class="mt-3 max-w-3xl text-secondary">{mistakes.intro}</p>

			<div class="mt-6 max-w-3xl space-y-4">
				{mistakes.items.map((item) => (
					<div class="rounded-[1.25rem] border border-line bg-surface/40 p-5">
						<p class="font-semibold text-primary">{item.heading}</p>
						<p class="mt-2 text-sm leading-6 text-secondary">{item.body}</p>
					</div>
				))}
			</div>
		</section>

		<!-- Section: Build the schedule section of your plan (interactive tool) -->
		<section id="tool" class="container-shell scroll-mt-24 border-t border-line-subtle py-10 lg:max-w-5xl lg:py-12">
			<h2 class="text-2xl font-semibold text-primary sm:text-3xl">Build the schedule section of your plan</h2>
			<p class="mt-3 max-w-3xl text-secondary">
				Each sample plan above pairs a written agreement with a dated schedule exhibit. Use the builder to turn any of those patterns
				into a dated, shareable calendar you can attach to your own plan: the same schedule section, generated for your family.
				Adjust the start date and parent labels and the preview updates live.
			</p>

			<div class="mt-6">
				<div class="grid gap-5 lg:grid-cols-[minmax(0,0.9fr)_minmax(0,1.1fr)] lg:items-start lg:gap-8">
					<div class="min-w-0 lg:pt-2">
						<p class="text-sm leading-6 text-secondary">
							Pick a pattern, set a start date, add parent labels, and preview a dated calendar you can share and adjust. Once the
							weekly rotation looks right, add holidays and summer, then download a PDF for your plan packet.
						</p>
						<ul class="mt-4 space-y-2 text-sm leading-6 text-secondary">
							<li class="flex gap-2"><span class="shrink-0 text-accent" aria-hidden="true">&rarr;</span>One colour per parent, so the rotation is easy to read at a glance.</li>
							<li class="flex gap-2"><span class="shrink-0 text-accent" aria-hidden="true">&rarr;</span>Change dates and labels above to match your own family.</li>
							<li class="flex gap-2"><span class="shrink-0 text-accent" aria-hidden="true">&rarr;</span>Download the calendar as a PDF to attach to your written plan.</li>
						</ul>
					</div>

					<div class="min-w-0">
						<div class="premium-card relative overflow-visible rounded-[1.75rem] border-line p-3 sm:p-4">
							<div class="rounded-[1.4rem] bg-surface-elevated shadow-[inset_0_1px_0_rgba(255,255,255,0.07)] p-1">
								<div class="grid grid-cols-1 items-start gap-4 xl:grid-cols-[minmax(320px,1fr)_240px]">
									<div class="min-w-0">
										<GeneratorPanel selectedScheduleId="223" compact />
									</div>
									<div class="min-w-0 xl:w-[240px] xl:min-w-[240px]">
										<p class="mb-2 text-[10px] font-semibold uppercase tracking-[0.12em] text-muted">Illustrative schedule: adjust dates and parents above to update this calendar</p>
										<CalendarPreview schedule={generatedSchedule} embedded />
									</div>
								</div>
							</div>
						</div>
						<p class="mt-3 text-xs leading-5 text-muted">
							Educational estimate only. Not legal advice.
							<a href="/disclaimer/" class="ml-1 font-semibold text-secondary underline decoration-line underline-offset-4 hover:text-primary">Read disclaimer</a>
						</p>
					</div>
				</div>
			</div>
		</section>

		<!-- Section: Build your own (CTA block) -->
		<section id="build" class="container-shell scroll-mt-24 border-t border-line-subtle py-10 lg:max-w-5xl lg:py-12">
			<h2 class="text-2xl font-semibold text-primary sm:text-3xl">{buildCta.title}</h2>
			<p class="mt-3 max-w-3xl text-secondary">{buildCta.body}</p>
			<div class="mt-5 flex flex-wrap gap-3">
				<a href="/custody-schedule-generator/" class="inline-flex rounded-full bg-accent px-5 py-2.5 text-sm font-semibold text-white shadow-sm hover:opacity-90" style="color: #ffffff">{buildCta.generatorLabel} &rarr;</a>
				<a href={buildCta.templateHref} class="inline-flex rounded-full bg-surface px-5 py-2.5 text-sm font-semibold text-accent shadow-[inset_0_0_0_1px_var(--border-subtle)] hover:text-primary">{buildCta.templateLabel}</a>
				<a href="/custodial-schedule/" class="inline-flex rounded-full bg-surface px-5 py-2.5 text-sm font-semibold text-accent shadow-[inset_0_0_0_1px_var(--border-subtle)] hover:text-primary">Browse schedule types</a>
			</div>
		</section>

		<!-- Related links -->
		<section class="container-shell scroll-mt-24 border-t border-line-subtle py-10 lg:max-w-5xl lg:py-12">
			<h2 class="text-xl font-semibold text-primary">Related tools and guides</h2>
			<ul class="mt-4 grid gap-2 sm:grid-cols-2">
				{relatedLinks.map((link) => (
					<li>
						<a href={link.href} class="text-sm font-semibold text-accent underline decoration-line underline-offset-4 hover:text-primary">{link.label}</a>
					</li>
				))}
			</ul>
		</section>

		<!-- FAQ -->
		<FAQ items={faqItems} title={faqSection.title} description={faqSection.description} />

		<!-- Legal Disclaimer -->
		<section class="container-shell py-6 lg:max-w-5xl" aria-label="Legal disclaimer">
			<div class="rounded-2xl bg-page/70 p-4 text-xs leading-5 text-muted shadow-[inset_0_0_0_1px_var(--border-subtle)]">
				<p class="font-semibold text-secondary">Educational information only. Not legal advice.</p>
				<p class="mt-1">
					These sample parenting plans are general, educational examples of how families plan parenting time. Every family shown is fictional, and each plan is illustrative rather than a template to file as-is. This page is not legal advice and does not create an attorney-client relationship. Family law varies by state, and the terms, presumptions, and rules that apply to any case depend on the specific court and each family's circumstances. Read your actual court order and consult a qualified family law attorney in your state for advice specific to your situation.
					<a href="/disclaimer/" class="ml-1 font-semibold text-secondary underline decoration-line underline-offset-4 hover:text-primary">Read the full disclaimer</a>.
				</p>
			</div>
		</section>

		<!-- Bottom CTA -->
		<BackToGeneratorCta
			headline="Build your parenting-time schedule"
			body="Pick the example closest to your situation, then generate a dated calendar you can share and attach. Set the start date, preview months, and download a PDF."
			href="/custody-schedule-generator/"
			label="Build your schedule &rarr;"
		/>

	</main>
	<Footer />
</BaseLayout>
