---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import FAQ from '../components/FAQ.astro';
import CtaButton from '../components/CtaButton.astro';
import ExchangeCountComparisonGraphic from '../components/schedules/50-50-custody-schedule-for-school-age-children/ExchangeCountComparisonGraphic.astro';
import HomeworkMovementChartGraphic from '../components/schedules/50-50-custody-schedule-for-school-age-children/HomeworkMovementChartGraphic.astro';
import SchoolNightOwnershipMatrixGraphic from '../components/schedules/50-50-custody-schedule-for-school-age-children/SchoolNightOwnershipMatrixGraphic.astro';
import { getCanonicalUrl } from '../lib/seo/metadata';
import {
	buildArticleSchema,
	buildBreadcrumbSchema,
	buildFAQSchema,
	buildWebPageSchema,
} from '../lib/seo/schema';
import {
	meta,
	transitionRedirect,
	scheduleComparisonCards,
	exchangeCountComparison,
	homeworkMovement,
	moveFrom223,
	patternMistakes,
	builderFeatures,
	faqItems,
	faqSection,
} from '../data/fiftyFiftyCustodyScheduleForSchoolAgeChildren';

const title = meta.title;
const description = meta.description;
const canonical = '/50-50-custody-schedule-for-school-age-children/';
const canonicalUrl = getCanonicalUrl(canonical);
const datePublished = '2026-07-01';
const dateModified = '2026-06-24';

const breadcrumbs = [
	{ name: 'Home', url: getCanonicalUrl('/') },
	{ name: '50/50 Custody Schedule', url: getCanonicalUrl('/50-50-custody-schedule/') },
	{ name: '50/50 Schedule for School-Age Children', url: canonicalUrl },
];

const schema = [
	buildWebPageSchema({ name: title, description, url: canonicalUrl }),
	buildArticleSchema({
		headline: '50/50 Custody Schedule for School-Age Children',
		description,
		url: canonicalUrl,
		datePublished,
		dateModified,
		authorName: 'CustodyBuilder Editorial Team',
	}),
	buildFAQSchema(faqItems),
	buildBreadcrumbSchema(breadcrumbs),
];
---

<BaseLayout title={title} description={description} canonical={canonical}>
	<JsonLd slot="head" data={schema} />
	<Navbar />
	<Breadcrumbs items={breadcrumbs} />
	<main>
		<section class="container-shell py-section lg:py-section-loose">
			<div class="max-w-3xl">
				<p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">Equal-time school-year rotations</p>
				<h1 class="mt-4 text-4xl font-semibold leading-[1.02] tracking-[-0.05em] text-primary sm:text-5xl lg:text-6xl">
					50/50 Custody Schedule for School-Age Children
				</h1>
				<p class="mt-2 text-sm leading-6 text-muted">
					Created by <a href="/about/" class="font-semibold text-secondary underline decoration-line underline-offset-4 hover:text-primary">CustodyBuilder Editorial Team</a>
					<span aria-hidden="true"> • </span>Last reviewed: June 2026
					<span aria-hidden="true"> • </span><a href="/disclaimer/" class="font-semibold text-secondary underline decoration-line underline-offset-4 hover:text-primary">Not legal advice</a>
				</p>
				<p class="mt-5 text-lg leading-8 text-secondary">
					Equal time for school-age children is a calendar geometry problem: block length, exchanges per fortnight, and which parent owns which school night. This page compares 2-2-3, 2-2-5-5, 5-2-2-5, and week-on/week-off — not kindergarten entry logistics.
				</p>
				<p class="mt-4 text-base leading-7 text-secondary" set:html={transitionRedirect.body} />
				<div class="mt-8 flex flex-col gap-3 sm:flex-row">
					<CtaButton href="/custody-schedule-generator/" variant="primary" size="large">
						Print a school-age 50/50 calendar
					</CtaButton>
					<CtaButton href="/best-50-50-custody-schedule/" variant="secondary" size="large">
						Compare all 50/50 patterns
					</CtaButton>
				</div>
			</div>
		</section>

		<section id="pattern-comparison" class="container-shell scroll-mt-24 pb-section" aria-labelledby="pattern-comparison-title">
			<div class="max-w-3xl">
				<p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">Pattern comparison</p>
				<h2 id="pattern-comparison-title" class="mt-3 text-3xl font-semibold tracking-[-0.04em] text-primary sm:text-4xl">
					Four Equal-Time Rotations for School-Age 50/50
				</h2>
				<p class="mt-3 text-base leading-7 text-secondary">
					Same overnight split (~182 each). Different maximum block length, school-night handoffs, and homework ownership.
				</p>
			</div>
			<div class="mt-6 grid gap-4 md:grid-cols-2 xl:grid-cols-4">
				{scheduleComparisonCards.map((card) => (
					<article class="soft-card flex h-full flex-col rounded-[1.5rem] p-5">
						<h3 class="text-lg font-semibold tracking-[-0.03em] text-primary">
							<a href={card.href} class="text-accent underline decoration-line underline-offset-4 hover:text-primary">{card.schedule}</a>
						</h3>
						<div class="mt-3 flex-1 space-y-4 text-sm leading-6 text-secondary">
							<div>
								<p class="font-semibold text-primary">Block mechanics</p>
								<ul class="mt-2 list-disc space-y-1 pl-4">
									{card.whyChoose.map((item) => <li>{item}</li>)}
								</ul>
							</div>
							<div>
								<p class="font-semibold text-primary">Calendar trade-offs</p>
								<ul class="mt-2 list-disc space-y-1 pl-4">
									{card.challenges.map((item) => <li>{item}</li>)}
								</ul>
							</div>
						</div>
					</article>
				))}
			</div>
			<p class="mt-6 text-sm leading-6 text-secondary">
				<a href="/50-50-custody-schedule-examples/" class="font-semibold text-accent underline decoration-line underline-offset-4 hover:text-primary">See two-week calendar examples →</a>
			</p>
		</section>

		<section id="exchange-count" class="container-shell scroll-mt-24 py-section" aria-labelledby="exchange-count-title">
			<div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_minmax(280px,360px)] lg:items-start">
				<div class="min-w-0">
					<h2 id="exchange-count-title" class="text-3xl font-semibold tracking-[-0.04em] text-primary sm:text-4xl">
						{exchangeCountComparison.title}
					</h2>
					<p class="mt-3 text-base leading-7 text-secondary">{exchangeCountComparison.intro}</p>
					<div class="mt-6 overflow-x-auto rounded-[1.5rem] border border-line bg-surface shadow-[0_18px_44px_rgba(15,23,42,0.06)]">
						<table class="min-w-[640px] w-full text-left text-sm">
							<thead class="bg-surface-elevated text-xs uppercase tracking-[0.16em] text-muted">
								<tr>
									<th class="px-4 py-3">Pattern</th>
									<th class="px-4 py-3">Max block</th>
									<th class="px-4 py-3">Exchanges / fortnight</th>
									<th class="px-4 py-3">School-night handoffs</th>
								</tr>
							</thead>
							<tbody class="divide-y divide-line text-secondary">
								{exchangeCountComparison.rows.map((row) => (
									<tr>
										<td class="px-4 py-4 font-semibold text-primary">{row.pattern}</td>
										<td class="px-4 py-4">{row.maxBlock}</td>
										<td class="px-4 py-4">{row.exchangesPerFortnight}</td>
										<td class="px-4 py-4">{row.schoolNightHandoffs}</td>
									</tr>
								))}
							</tbody>
						</table>
					</div>
					<p class="mt-4 text-sm leading-6 text-secondary">{exchangeCountComparison.closing}</p>
				</div>
				<div class="space-y-4 lg:sticky lg:top-24">
					<ExchangeCountComparisonGraphic />
					<SchoolNightOwnershipMatrixGraphic />
				</div>
			</div>
		</section>

		<section id="homework-movement" class="container-shell scroll-mt-24 py-section" aria-labelledby="homework-movement-title">
			<div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_minmax(280px,360px)] lg:items-start">
				<div class="min-w-0">
					<h2 id="homework-movement-title" class="text-3xl font-semibold tracking-[-0.04em] text-primary sm:text-4xl">
						{homeworkMovement.title}
					</h2>
					<p class="mt-3 text-base leading-7 text-secondary">{homeworkMovement.intro}</p>
					{homeworkMovement.points.map((point) => (
						<div class="mt-6">
							<h3 class="text-lg font-semibold tracking-[-0.03em] text-primary">{point.heading}</h3>
							<p class="mt-2 text-base leading-7 text-secondary">{point.body}</p>
						</div>
					))}
					<p class="mt-6 text-sm leading-6 text-secondary" set:html={homeworkMovement.closing} />
				</div>
				<HomeworkMovementChartGraphic />
			</div>
		</section>

		<section id="move-from-223" class="container-shell scroll-mt-24 py-section" aria-labelledby="move-from-223-title">
			<div class="max-w-3xl">
				<h2 id="move-from-223-title" class="text-3xl font-semibold tracking-[-0.04em] text-primary sm:text-4xl">
					{moveFrom223.title}
				</h2>
				{moveFrom223.paragraphs.map((paragraph) => (
					<p class="mt-3 text-base leading-7 text-secondary" set:html={paragraph} />
				))}
				<p class="mt-4 text-sm leading-6 text-secondary" set:html={moveFrom223.compareNote} />
			</div>
		</section>

		<section id="pattern-mistakes" class="container-shell scroll-mt-24 py-section" aria-labelledby="pattern-mistakes-title">
			<div class="max-w-3xl">
				<h2 id="pattern-mistakes-title" class="text-3xl font-semibold tracking-[-0.04em] text-primary sm:text-4xl">
					Common 50/50 Pattern Mistakes for School-Age Children
				</h2>
				<p class="mt-3 text-base leading-7 text-secondary">
					Calendar errors — not parenting style — that show up on school-age equal-time plans.
				</p>
			</div>
			<div class="mt-6 grid gap-4 md:grid-cols-2">
				{patternMistakes.map((item) => (
					<article class="soft-card rounded-[1.5rem] p-5">
						<h3 class="text-base font-semibold text-primary">{item.mistake}</h3>
						<p class="mt-2 text-sm leading-6 text-secondary">{item.detail}</p>
					</article>
				))}
			</div>
		</section>

		<section id="custodybuilder-help" class="container-shell scroll-mt-24 py-section" aria-labelledby="custodybuilder-help-title">
			<div class="premium-card rounded-[2rem] p-3">
				<div class="rounded-[1.7rem] bg-surface-elevated/80 p-6 sm:p-8 lg:p-10">
					<h2 id="custodybuilder-help-title" class="text-3xl font-semibold tracking-[-0.04em] text-primary sm:text-4xl">
						Print and Compare School-Age 50/50 Calendars
					</h2>
					<p class="mt-4 max-w-2xl text-base leading-7 text-secondary">
						Test block length, school-week exchanges, and homework-night ownership with real start dates before you adopt a pattern in a parenting plan.
					</p>
					<ul class="mt-4 max-w-2xl list-disc space-y-2 pl-5 text-sm leading-7 text-secondary">
						{builderFeatures.map((feature) => <li>{feature}</li>)}
					</ul>
					<div class="mt-6 flex flex-col gap-3 sm:flex-row">
						<CtaButton href="/custody-schedule-generator/" variant="primary" size="large">
							Open schedule generator
						</CtaButton>
						<CtaButton href="/50-50-custody-schedule/" variant="secondary" size="large">
							50/50 custody schedule hub
						</CtaButton>
					</div>
				</div>
			</div>
		</section>

		<section id="ymyl-disclaimer" class="container-shell scroll-mt-24 py-section" aria-labelledby="ymyl-disclaimer-title">
			<div class="soft-card max-w-3xl rounded-[1.5rem] p-5 sm:p-6">
				<h2 id="ymyl-disclaimer-title" class="text-xl font-semibold tracking-[-0.03em] text-primary sm:text-2xl">
					Educational Planning Information, Not Legal Advice
				</h2>
				<p class="mt-3 text-sm leading-7 text-secondary">
					This page compares equal-time rotation mechanics for school-age children. It is not medical advice or <a href="/disclaimer/" class="font-semibold text-accent underline decoration-line underline-offset-4 hover:text-primary">legal advice</a>. Court orders and safety concerns override any pattern described here.
				</p>
			</div>
		</section>

		<FAQ
			items={faqItems}
			title={faqSection.title}
			description={faqSection.description}
		/>
	</main>
	<Footer />
</BaseLayout>
