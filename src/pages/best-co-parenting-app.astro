---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import BackToGeneratorCta from '../components/BackToGeneratorCta.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import FAQ from '../components/FAQ.astro';
import { getCanonicalUrl } from '../lib/seo/metadata';
import {
	buildArticleSchema,
	buildBreadcrumbSchema,
	buildFAQSchema,
	buildItemListSchema,
	buildWebPageSchema,
} from '../lib/seo/schema';
import {
	bySituation,
	comparison,
	custodyBuilderFit,
	editorialDisclosure,
	editorialReview,
	faqItems,
	faqSection,
	hero,
	howToChoose,
	itemListApps,
	meta,
	relatedLinks,
	reviews,
	trademarkNotice,
} from '../data/bestCoparentingApp';

const canonical = '/best-co-parenting-app/';
const canonicalUrl = getCanonicalUrl(canonical);

const breadcrumbs = [
	{ name: 'Home', url: getCanonicalUrl('/') },
	{ name: 'Best Co-Parenting App', url: canonicalUrl },
];

const schema = [
	buildWebPageSchema({ name: meta.title, description: meta.description, url: canonicalUrl }),
	buildArticleSchema({
		headline: meta.title,
		description: meta.description,
		url: canonicalUrl,
		datePublished: meta.datePublished,
		dateModified: meta.dateModified,
		authorName: editorialReview.reviewer,
	}),
	buildItemListSchema({
		name: 'Co-parenting apps compared',
		description: 'The co-parenting apps compared on this page, in no ranked order.',
		url: canonicalUrl,
		items: itemListApps,
	}),
	buildFAQSchema(faqItems),
	buildBreadcrumbSchema(breadcrumbs),
];
---

<BaseLayout title={meta.title} description={meta.description} canonical={canonical} ogType="article">
	<JsonLd slot="head" data={schema} />
	<Navbar />
	<Breadcrumbs items={breadcrumbs} />
	<main class="overflow-x-clip">

		<!-- Hero -->
		<section class="container-shell py-8 lg:max-w-5xl lg:py-12" id="overview">
			<h1 class="max-w-3xl text-[1.7rem] font-semibold leading-[1.06] tracking-[-0.05em] text-primary sm:text-4xl lg:text-5xl">
				{hero.headline}
			</h1>

			<ul class="mt-4 flex flex-wrap gap-2 text-xs font-semibold text-secondary">
				{hero.trustChips.map((chip) => (
					<li class="rounded-full bg-surface/70 px-3 py-1.5 shadow-[inset_0_0_0_1px_var(--border-subtle)]">{chip}</li>
				))}
			</ul>

			<p class="mt-5 max-w-2xl text-base leading-7 text-secondary">{hero.intro}</p>

			<div class="mt-4 max-w-2xl rounded-2xl bg-accent/10 px-4 py-3 text-sm leading-6 text-secondary">
				{hero.disclosure}
			</div>

			<div class="mt-6 max-w-2xl text-xs leading-5 text-muted">
				<p class="font-semibold text-secondary">Reviewed for:</p>
				<ul class="mt-1 list-inside list-disc">{editorialReview.reviewedFor.map((i) => <li>{i}</li>)}</ul>
				<p class="mt-2">
					Reviewed by <a href={editorialReview.reviewerHref} class="font-semibold text-secondary underline">{editorialReview.reviewer}</a>
					{' · '}<a href={editorialReview.methodologyHref} class="font-semibold text-secondary underline">{editorialReview.methodologyLabel}</a>
					{' · '}<span class="font-semibold text-secondary">{editorialReview.lastUpdatedLabel}</span>
					{' · '}{editorialReview.disclaimer}
				</p>
			</div>

			<div class="mt-6 flex flex-wrap gap-3">
				<a href="/custody-schedule-generator/" class="inline-flex rounded-full bg-accent px-5 py-2.5 text-sm font-semibold text-white shadow-sm hover:opacity-90" style="color: #ffffff">Build your custody schedule free &rarr;</a>
				<a href="/custodial-schedule/" class="inline-flex rounded-full bg-surface px-5 py-2.5 text-sm font-semibold text-accent shadow-[inset_0_0_0_1px_var(--border-subtle)] hover:text-primary">See schedule types</a>
			</div>

			<p class="mt-5 max-w-2xl text-xs leading-5 text-muted">
				Educational information only. Not legal advice.
				<a href="/disclaimer/" class="ml-1 font-semibold text-secondary underline decoration-line underline-offset-4 hover:text-primary">Read disclaimer</a>
			</p>
		</section>

		<!-- On-this-page nav -->
		<nav class="container-shell border-y border-line-subtle py-3 lg:max-w-5xl" aria-label="On this page">
			<ul class="flex flex-wrap gap-x-4 gap-y-1 text-xs font-semibold text-secondary">
				<li><a href="#glance" class="hover:text-accent">At a glance</a></li>
				<li><a href="#reviews" class="hover:text-accent">App reviews</a></li>
				<li><a href="#by-situation" class="hover:text-accent">Best by situation</a></li>
				<li><a href="#custodybuilder" class="hover:text-accent">Where CustodyBuilder fits</a></li>
				<li><a href="#choose" class="hover:text-accent">How to choose</a></li>
				<li><a href="#faq" class="hover:text-accent">FAQ</a></li>
			</ul>
		</nav>

		<!-- Section: Comparison at a glance -->
		<section id="glance" class="container-shell scroll-mt-24 border-t border-line-subtle py-10 lg:max-w-5xl lg:py-12">
			<h2 class="text-2xl font-semibold text-primary sm:text-3xl">{comparison.title}</h2>
			<p class="mt-3 max-w-3xl text-secondary">{comparison.intro}</p>

			<div class="mt-6 overflow-x-auto rounded-[1.5rem] ring-1 ring-line-subtle">
				<table class="w-full min-w-[820px] text-left text-sm">
					<thead class="bg-surface-elevated text-primary">
						<tr>
							{comparison.columns.map((col) => (
								<th class="px-4 py-3 font-semibold">{col}</th>
							))}
						</tr>
					</thead>
					<tbody class="divide-y divide-line-subtle text-secondary">
						{comparison.rows.map((row) => (
							<tr>
								<td class="px-4 py-3 font-medium text-primary whitespace-nowrap">{row.app}</td>
								<td class="px-4 py-3">{row.records}</td>
								<td class="px-4 py-3">{row.tone}</td>
								<td class="px-4 py-3">{row.expense}</td>
								<td class="px-4 py-3">{row.pricing}</td>
								<td class="px-4 py-3">{row.billing}</td>
							</tr>
						))}
					</tbody>
				</table>
			</div>

			<p class="mt-4 max-w-3xl rounded-2xl bg-surface/70 px-4 py-3 text-sm leading-6 text-secondary shadow-[inset_0_0_0_1px_var(--border-subtle)]">
				{comparison.caveat}
			</p>

			<p class="mt-4 max-w-3xl rounded-2xl bg-accent/10 px-4 py-3 text-sm leading-6 text-secondary">
				{editorialDisclosure}
			</p>

			<p class="mt-4 max-w-3xl text-sm leading-6 text-secondary">{comparison.note}</p>

			<p class="mt-4 max-w-3xl text-xs leading-5 text-muted">{trademarkNotice}</p>
		</section>

		<!-- Section: App reviews -->
		<section id="reviews" class="container-shell scroll-mt-24 border-t border-line-subtle py-10 lg:max-w-5xl lg:py-12">
			<h2 class="text-2xl font-semibold text-primary sm:text-3xl">{reviews.title}</h2>
			<p class="mt-3 max-w-3xl text-secondary">{reviews.intro}</p>

			<div class="mt-6 max-w-3xl space-y-4">
				{reviews.apps.map((app) => (
					<article id={app.id} class="soft-card rounded-[1.5rem] p-5">
						<h3 class="text-lg font-semibold text-primary">{app.name}</h3>
						<p class="mt-1 text-xs font-semibold text-accent">{app.bestFor}</p>
						<p class="mt-3 text-sm leading-6 text-secondary"><span class="font-semibold text-primary">Strengths:</span> {app.strength}</p>
					</article>
				))}
			</div>

			<p class="mt-6 max-w-3xl text-sm leading-6 text-secondary">{reviews.coparentlyNote}</p>
		</section>

		<!-- Section: Best by situation -->
		<section id="by-situation" class="container-shell scroll-mt-24 border-t border-line-subtle py-10 lg:max-w-5xl lg:py-12">
			<h2 class="text-2xl font-semibold text-primary sm:text-3xl">{bySituation.title}</h2>
			<p class="mt-3 max-w-3xl text-secondary">{bySituation.intro}</p>

			<div class="mt-6 grid gap-4 max-w-3xl sm:grid-cols-2">
				{bySituation.cases.map((item) => (
					<div class="rounded-[1.25rem] bg-surface/70 p-5 shadow-[inset_0_0_0_1px_var(--border-subtle)]">
						<p class="text-xs font-semibold uppercase tracking-[0.06em] text-muted">{item.need}</p>
						<p class="mt-1 font-semibold text-primary">{item.pick}</p>
						<p class="mt-2 text-sm leading-6 text-secondary">{item.why}</p>
					</div>
				))}
			</div>

			<p class="mt-6 max-w-3xl text-sm leading-6 text-secondary">
				Not sure what your schedule should even look like yet? Start by drafting one with the{' '}
				<a href="/custody-schedule-generator/" class="font-semibold text-accent underline decoration-line underline-offset-4 hover:text-primary">free custody schedule generator</a>, browse patterns on the{' '}
				<a href="/custodial-schedule/" class="font-semibold text-accent underline decoration-line underline-offset-4 hover:text-primary">schedule-types hub</a>, or estimate a split with the{' '}
				<a href="/custody-percentage-calculator/" class="font-semibold text-accent underline decoration-line underline-offset-4 hover:text-primary">custody percentage calculator</a>.
			</p>
		</section>

		<!-- Section: Where CustodyBuilder fits -->
		<section id="custodybuilder" class="container-shell scroll-mt-24 border-t border-line-subtle py-10 lg:max-w-5xl lg:py-12">
			<h2 class="text-2xl font-semibold text-primary sm:text-3xl">{custodyBuilderFit.title}</h2>
			<p class="mt-3 max-w-3xl text-secondary">{custodyBuilderFit.intro}</p>

			<div class="mt-6 grid gap-4 max-w-3xl sm:grid-cols-2">
				<div class="rounded-[1.25rem] border border-line bg-surface/40 p-5">
					<p class="font-semibold text-primary">What CustodyBuilder is</p>
					<ul class="mt-2 space-y-2 text-sm leading-6 text-secondary">
						{custodyBuilderFit.isList.map((point) => (
							<li class="flex gap-2"><span class="shrink-0 text-accent" aria-hidden="true">&rarr;</span>{point}</li>
						))}
					</ul>
				</div>
				<div class="rounded-[1.25rem] border border-line bg-surface/40 p-5">
					<p class="font-semibold text-primary">What CustodyBuilder is not</p>
					<ul class="mt-2 space-y-2 text-sm leading-6 text-secondary">
						{custodyBuilderFit.isNotList.map((point) => (
							<li class="flex gap-2"><span class="shrink-0 text-muted" aria-hidden="true">&times;</span>{point}</li>
						))}
					</ul>
				</div>
			</div>

			<div class="mt-5 max-w-3xl rounded-2xl bg-accent/10 px-4 py-3 text-sm leading-6 text-secondary">
				{custodyBuilderFit.handoff}
			</div>

			<p class="mt-5 max-w-3xl text-sm leading-6 text-secondary">{custodyBuilderFit.bestFor}</p>

			<p class="mt-5 max-w-3xl text-sm leading-6 text-secondary">
				When you are ready to draft the schedule itself, see{' '}
				<a href="/sample-parenting-plan/" class="font-semibold text-accent underline decoration-line underline-offset-4 hover:text-primary">sample parenting plans</a>, read up on{' '}
				<a href="/legal-custody-vs-physical-custody/" class="font-semibold text-accent underline decoration-line underline-offset-4 hover:text-primary">legal versus physical custody</a>, or plan time off with the{' '}
				<a href="/holiday-custody-schedule/" class="font-semibold text-accent underline decoration-line underline-offset-4 hover:text-primary">holiday custody schedule</a> guide.
			</p>
		</section>

		<!-- Section: How to choose -->
		<section id="choose" class="container-shell scroll-mt-24 border-t border-line-subtle py-10 lg:max-w-5xl lg:py-12">
			<h2 class="text-2xl font-semibold text-primary sm:text-3xl">{howToChoose.title}</h2>
			<p class="mt-3 max-w-3xl text-secondary">{howToChoose.intro}</p>

			<ol class="mt-6 max-w-3xl space-y-4">
				{howToChoose.steps.map((step, index) => (
					<li class="rounded-[1.25rem] bg-surface/70 p-5 shadow-[inset_0_0_0_1px_var(--border-subtle)]">
						<p class="font-semibold text-primary"><span class="text-accent">{index + 1}.</span> {step.heading}</p>
						<p class="mt-2 text-sm leading-6 text-secondary">{step.body}</p>
					</li>
				))}
			</ol>
		</section>

		<!-- Related links -->
		<section class="container-shell scroll-mt-24 border-t border-line-subtle py-10 lg:max-w-5xl lg:py-12">
			<h2 class="text-xl font-semibold text-primary">Related tools and guides</h2>
			<ul class="mt-4 grid gap-2 sm:grid-cols-2">
				{relatedLinks.map((link) => (
					<li>
						<a href={link.href} class="text-sm font-semibold text-accent underline decoration-line underline-offset-4 hover:text-primary">{link.label}</a>
					</li>
				))}
			</ul>
		</section>

		<!-- FAQ -->
		<FAQ items={faqItems} title={faqSection.title} description={faqSection.description} />

		<!-- Legal Disclaimer -->
		<section class="container-shell py-6 lg:max-w-5xl" aria-label="Legal disclaimer">
			<div class="rounded-2xl bg-page/70 p-4 text-xs leading-5 text-muted shadow-[inset_0_0_0_1px_var(--border-subtle)]">
				<p class="font-semibold text-secondary">Educational information only. Not legal advice.</p>
				<p class="mt-1">
					This page gives general, educational information comparing co-parenting apps. It is not legal advice and does not create an attorney-client relationship. The comparisons and assessments here are the author's editorial opinion, based on publicly available information as of July 2026, and are for general informational purposes only. App features and pricing were checked in July 2026 and change often, so verify the current details on each app's own site before you buy. What a court accepts as an admissible record varies by state and by case: always read your actual court order and consult a qualified family law attorney in your state for advice specific to your situation.
					<a href="/disclaimer/" class="ml-1 font-semibold text-secondary underline decoration-line underline-offset-4 hover:text-primary">Read the full disclaimer</a>.
				</p>
				<p class="mt-2">{trademarkNotice}</p>
			</div>
		</section>

		<!-- Bottom CTA -->
		<BackToGeneratorCta
			headline="Build your custody schedule free"
			body="Whichever app you choose, start with a clear schedule. Pick a pattern, set a start date, preview months, and download a PDF you can share."
			href="/custody-schedule-generator/"
			label="Build your schedule &rarr;"
		/>

	</main>
	<Footer />
</BaseLayout>
