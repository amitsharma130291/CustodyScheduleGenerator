---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import FAQ from '../components/FAQ.astro';
import VisitationLogCalculator from '../components/tool/VisitationLogCalculator.astro';
import LoggedVisitsTimelineGraphic from '../components/tools/visitation-calculator/LoggedVisitsTimelineGraphic.astro';
import ActualVsPlannedGraphic from '../components/tools/visitation-calculator/ActualVsPlannedGraphic.astro';
import VisitationHistoryGraphGraphic from '../components/tools/visitation-calculator/VisitationHistoryGraphGraphic.astro';
import { getCanonicalUrl } from '../lib/seo/metadata';
import {
	buildArticleSchema,
	buildBreadcrumbSchema,
	buildFAQSchema,
	buildSoftwareApplicationSchema,
	buildWebPageSchema,
} from '../lib/seo/schema';
import {
	actualVsPlanned,
	articleTocItems,
	editorialReview,
	faqItems,
	faqSection,
	hero,
	heroKeyStats,
	loggingVisits,
	meta,
	missedVisits,
	relatedReading,
} from '../data/visitationCalculatorPage';

const canonical = '/visitation-calculator/';
const canonicalUrl = getCanonicalUrl(canonical);
const breadcrumbs = [
	{ name: 'Home', url: getCanonicalUrl('/') },
	{ name: 'Visitation Calculator', url: canonicalUrl },
];
const schema = [
	buildWebPageSchema({ name: meta.title, description: meta.description, url: canonicalUrl }),
	buildArticleSchema({
		headline: hero.headline,
		description: meta.description,
		url: canonicalUrl,
		datePublished: meta.datePublished,
		dateModified: meta.dateModified,
		authorName: editorialReview.reviewer,
	}),
	buildFAQSchema(faqItems),
	buildBreadcrumbSchema(breadcrumbs),
	{
		...buildSoftwareApplicationSchema({
			name: 'Visitation Log Calculator',
			description: meta.description,
			url: canonicalUrl,
			applicationCategory: 'LegalApplication',
		}),
		operatingSystem: 'Web',
		offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
	},
];
---

<BaseLayout title={meta.title} description={meta.description} canonical={canonical}>
	<JsonLd slot="head" data={schema} />
	<Navbar />
	<Breadcrumbs items={breadcrumbs} />
	<main>
		<section class="container-shell grid grid-cols-1 gap-5 py-4 sm:py-5 lg:grid-cols-[minmax(0,0.88fr)_minmax(420px,1fr)] lg:items-start lg:gap-7 lg:py-6">
			<div class="min-w-0 lg:pt-1">
				<h1 class="max-w-3xl text-4xl font-semibold leading-[0.98] tracking-[-0.055em] text-primary sm:text-5xl">{hero.headline}</h1>
				<dl class="mt-4 grid grid-cols-3 gap-2">
					{heroKeyStats.map((s) => (
						<div class="rounded-[1rem] bg-accent/10 px-2 py-2.5 text-center sm:px-3">
							<dd class="text-lg font-bold text-accent sm:text-xl">{s.value}</dd>
							<dt class="mt-0.5 text-[10px] font-semibold uppercase text-secondary">{s.label}</dt>
						</div>
					))}
				</dl>
				<p class="mt-3 max-w-2xl text-base leading-7 text-secondary">{hero.intro}</p>
				<p class="mt-3 max-w-2xl text-sm leading-6 text-secondary" set:html={hero.boundary} />
				<div class="mt-3 max-w-2xl text-xs leading-5 text-muted">
					<p class="font-semibold text-secondary">Reviewed for:</p>
					<ul class="mt-1 list-inside list-disc">{editorialReview.reviewedFor.map((i) => <li>{i}</li>)}</ul>
					<p class="mt-2">
						Reviewed by <a href={editorialReview.reviewerHref} class="font-semibold text-secondary underline">{editorialReview.reviewer}</a>
						{' · '}<a href={editorialReview.methodologyHref} class="font-semibold text-secondary underline">{editorialReview.methodologyLabel}</a>
						{' · '}{editorialReview.disclaimer}
					</p>
				</div>
			</div>
			<VisitationLogCalculator />
		</section>

		<nav class="container-shell border-y border-line-subtle py-3" aria-label="On this page">
			<ul class="flex flex-wrap gap-x-4 gap-y-1 text-xs font-semibold text-secondary">
				{articleTocItems.map((i) => <li><a href={`#${i.id}`} class="hover:text-accent">{i.label}</a></li>)}
			</ul>
		</nav>

		<section id="logging-visits" class="container-shell scroll-mt-24 py-10 lg:py-12">
			<div class="grid gap-8 lg:grid-cols-[1fr_360px]">
				<div>
					<h2 class="text-2xl font-semibold text-primary sm:text-3xl">{loggingVisits.title}</h2>
					<p class="mt-3 text-secondary">{loggingVisits.intro}</p>
					<ol class="mt-6 list-decimal space-y-4 pl-5">
						{loggingVisits.steps.map((s) => (
							<li class="text-secondary"><h3 class="font-semibold text-primary">{s.heading}</h3><p class="mt-2 text-sm">{s.body}</p></li>
						))}
					</ol>
				</div>
				<LoggedVisitsTimelineGraphic />
			</div>
		</section>

		<section id="actual-vs-planned" class="container-shell scroll-mt-24 border-t border-line-subtle py-10 lg:py-12">
			<div class="grid gap-8 lg:grid-cols-[1fr_360px]">
				<div>
					<h2 class="text-2xl font-semibold text-primary sm:text-3xl">{actualVsPlanned.title}</h2>
					<p class="mt-3 text-secondary">{actualVsPlanned.intro}</p>
					<ul class="mt-6 space-y-4">
						{actualVsPlanned.points.map((p) => (
							<li class="border-l-2 border-accent/30 pl-4"><h3 class="font-semibold text-primary">{p.heading}</h3><p class="mt-2 text-sm text-secondary">{p.body}</p></li>
						))}
					</ul>
					<p class="mt-4 text-sm text-secondary" set:html={actualVsPlanned.closing} />
				</div>
				<ActualVsPlannedGraphic />
			</div>
		</section>

		<section id="missed-visits" class="container-shell scroll-mt-24 border-t border-line-subtle py-10 lg:py-12">
			<div class="grid gap-8 lg:grid-cols-[1fr_360px]">
				<div>
					<h2 class="text-2xl font-semibold text-primary sm:text-3xl">{missedVisits.title}</h2>
					<p class="mt-3 text-secondary">{missedVisits.intro}</p>
					<ul class="mt-6 space-y-4">
						{missedVisits.points.map((p) => (
							<li class="text-sm text-secondary" set:html={`<strong class="text-primary">${p.heading}</strong> — ${p.body}`} />
						))}
					</ul>
				</div>
				<VisitationHistoryGraphGraphic />
			</div>
		</section>

		<section id="related-reading" class="container-shell scroll-mt-24 border-t border-line-subtle py-10 lg:py-12">
			<h2 class="text-2xl font-semibold text-primary sm:text-3xl">{relatedReading.title}</h2>
			<div class="mt-4 max-w-3xl space-y-3 text-secondary">
				{relatedReading.paragraphs.map((p) => <p set:html={p} />)}
			</div>
		</section>

		<FAQ items={faqItems} title={faqSection.title} description={faqSection.description} />
	</main>
	<Footer />
</BaseLayout>
