---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import PercentageCalculatorCard from '../components/tool/PercentageCalculatorCard.astro';
import { getCanonicalUrl } from '../lib/seo/metadata';
import {
	buildBreadcrumbSchema,
	buildFAQSchema,
	buildWebPageSchema,
} from '../lib/seo/schema';
import { calculateCustodyPercentage, formatCustodyPercentage } from '../lib/calculators/custodyPercentage';

const title = 'Visitation Calculator | Estimate Parenting Time & Overnights';
const description =
	'Calculate visitation time, overnight counts, and parenting time percentages for custody and visitation schedules.';
const canonical = '/visitation-calculator/';
const canonicalUrl = getCanonicalUrl(canonical);
const commonExamples = [
	{ split: '50/50', parentAOvernights: 182, parentBOvernights: 183 },
	{ split: '60/40', parentAOvernights: 219, parentBOvernights: 146 },
	{ split: '70/30', parentAOvernights: 256, parentBOvernights: 109 },
	{ split: '80/20', parentAOvernights: 292, parentBOvernights: 73 },
].map((example) => ({
	...example,
	result: calculateCustodyPercentage({
		parentAOvernights: example.parentAOvernights,
		parentBOvernights: example.parentBOvernights,
	}),
}));
const faq = [
	{
		question: 'What is a visitation calculator?',
		answer:
			'A visitation calculator estimates each parent’s parenting time percentage from overnight counts, helping families compare visitation schedules and custody arrangements.',
	},
	{
		question: 'How is visitation percentage calculated?',
		answer:
			'Visitation percentage is usually calculated by dividing a parent’s overnights by total overnights, then multiplying by 100.',
	},
	{
		question: 'Is visitation the same as custody?',
		answer:
			'The terms are related but not always identical. Custody can refer to legal decision-making and physical care, while visitation often describes scheduled parenting time for a parent.',
	},
	{
		question: 'How many overnights equal 50/50 visitation?',
		answer:
			'In a 365-day year, 50/50 visitation is usually about 182 or 183 overnights for each parent.',
	},
	{
		question: 'Can visitation percentages vary by year?',
		answer:
			'Yes. Holidays, school calendars, leap years, and custom parenting plans can shift the final percentage from year to year.',
	},
	{
		question: 'Do courts use overnight counts?',
		answer:
			'Courts and child support guidelines often use overnight counts when estimating physical custody, visitation, or parenting time percentages, though rules vary by jurisdiction.',
	},
];
const breadcrumbs = [
	{ name: 'Home', url: getCanonicalUrl('/') },
	{ name: 'Calculators', url: getCanonicalUrl('/calculators/') },
	{ name: 'Visitation Calculator', url: canonicalUrl },
];
const schema = [
	buildFAQSchema(faq),
	buildBreadcrumbSchema(breadcrumbs),
	buildWebPageSchema({ name: title, description, url: canonicalUrl }),
];
---

<BaseLayout title={title} description={description} canonical={canonical}>
	<JsonLd slot="head" data={schema} />
	<Navbar />
	<Breadcrumbs items={breadcrumbs} />
	<main>
		<section class="container-shell grid gap-8 py-12 lg:grid-cols-[0.9fr_1.1fr] lg:items-start lg:py-16">
			<div>
				<p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">Parenting time calculator</p>
				<h1 class="mt-4 max-w-3xl text-5xl font-semibold leading-[0.98] tracking-[-0.055em] text-primary lg:text-6xl">
					Visitation Calculator
				</h1>
				<p class="mt-6 max-w-2xl text-lg leading-8 text-secondary">
					Estimate visitation percentages and parenting time from overnight counts. Enter the number of overnights each parent receives to calculate visitation percentages and total parenting time.
				</p>
				<div class="mt-8 flex flex-col gap-3 sm:flex-row">
					<a href="#calculator" class="btn-primary inline-flex h-13 w-full items-center justify-center whitespace-nowrap rounded-full px-8 text-base font-semibold transition-all duration-200 ease-out hover:-translate-y-px hover:shadow-[0_10px_30px_rgba(94,106,210,0.14)] active:translate-y-0 sm:w-auto">
						Calculate Visitation
					</a>
					<a href="/custody-percentage-calculator/" class="btn-secondary inline-flex h-13 w-full items-center justify-center whitespace-nowrap rounded-full px-8 text-base font-semibold transition-all duration-200 ease-out hover:-translate-y-px hover:shadow-[0_10px_24px_rgba(0,0,0,0.12)] active:translate-y-0 sm:w-auto">
						Compare Custody Percentage
					</a>
				</div>
			</div>

			<PercentageCalculatorCard
				mode="visitation"
				heading="Calculate visitation percentage"
				ariaLabel="Visitation percentage results"
			/>
		</section>

		<section class="container-shell grid gap-8 py-12 lg:grid-cols-[0.72fr_1.28fr] lg:py-16">
			<aside class="soft-card h-fit rounded-[1.5rem] p-6">
				<p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">On this page</p>
				<ul class="mt-4 space-y-3 text-sm text-secondary">
					<li><a href="#calculator" class="hover:text-primary">Calculator</a></li>
					<li><a href="#examples" class="hover:text-primary">Examples</a></li>
					<li><a href="#how-it-works" class="hover:text-primary">How it works</a></li>
					<li><a href="#faq" class="hover:text-primary">FAQ</a></li>
					<li><a href="#related" class="hover:text-primary">Related tools</a></li>
				</ul>
			</aside>
			<div class="grid gap-10">
				<section id="examples" class="grid gap-5">
					<div>
						<p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">Examples</p>
						<h2 class="mt-2 text-3xl font-semibold tracking-[-0.04em] text-primary">Common visitation percentage examples</h2>
					</div>
					<div class="grid gap-4 sm:grid-cols-2">
						{commonExamples.map((example) => (
							<article class="soft-card rounded-[1.5rem] p-5">
								<h3 class="text-lg font-semibold tracking-[-0.03em] text-primary">{example.split}</h3>
								<div class="mt-4 grid grid-cols-2 gap-3">
									<div class="rounded-2xl bg-page/55 p-3 shadow-[inset_0_0_0_1px_var(--border-subtle)]">
										<p class="text-xs font-medium text-secondary">Parent A</p>
										<p class="mt-1 text-xl font-semibold tracking-[-0.04em] text-accent">{formatCustodyPercentage(example.result.parentAPercentage)}</p>
										<p class="mt-1 text-xs text-muted">{example.parentAOvernights} overnights</p>
									</div>
									<div class="rounded-2xl bg-page/55 p-3 shadow-[inset_0_0_0_1px_var(--border-subtle)]">
										<p class="text-xs font-medium text-secondary">Parent B</p>
										<p class="mt-1 text-xl font-semibold tracking-[-0.04em] text-parent-b">{formatCustodyPercentage(example.result.parentBPercentage)}</p>
										<p class="mt-1 text-xs text-muted">{example.parentBOvernights} overnights</p>
									</div>
								</div>
							</article>
						))}
					</div>
				</section>

				<section id="how-it-works" class="grid gap-4">
					<h2 class="text-3xl font-semibold tracking-[-0.04em] text-primary">How visitation percentage is calculated</h2>
					<p class="text-base leading-8 text-secondary">
						Visitation percentage is commonly estimated from overnight counts. The basic formula is: Visitation Percentage = (Parent Overnights ÷ Total Overnights) × 100.
					</p>
					<p class="text-base leading-8 text-secondary">
						Courts often use overnight counts when estimating parenting time percentages because overnights are easier to document than partial-day exchanges. This calculator is a planning tool, and local rules may treat holidays, school breaks, or partial days differently.
					</p>
				</section>

				<section class="grid gap-4">
					<h2 class="text-3xl font-semibold tracking-[-0.04em] text-primary">Visitation schedules and parenting time</h2>
					<p class="text-base leading-8 text-secondary">
						A visitation schedule explains when each parent has time with the child. A parenting plan may also cover exchanges, holidays, school breaks, transportation, and decision-making rules.
					</p>
					<p class="text-base leading-8 text-secondary">
						When comparing custody vs visitation terminology, custody may describe legal authority or physical care, while visitation often describes scheduled parenting time. In practice, many families still calculate both using overnight totals and parenting time percentages.
					</p>
				</section>

				<section id="faq" class="grid gap-5">
					<h2 class="text-3xl font-semibold tracking-[-0.04em] text-primary">FAQ</h2>
					<div class="premium-card divide-y divide-line-subtle overflow-hidden rounded-[1.5rem]">
						{faq.map((item) => (
							<details class="group p-5 transition-colors duration-200 open:bg-surface-elevated/70 hover:bg-surface-hover/60">
								<summary class="flex cursor-pointer list-none items-center justify-between gap-6 text-left text-base font-semibold tracking-[-0.02em] text-primary">
									{item.question}
									<span class="grid h-7 w-7 shrink-0 place-items-center rounded-full bg-surface/80 text-muted shadow-[inset_0_0_0_1px_var(--border-subtle)] transition-transform duration-200 group-open:rotate-45">+</span>
								</summary>
								<p class="mt-4 text-sm leading-6 text-secondary">{item.answer}</p>
							</details>
						))}
					</div>
				</section>

				<section id="related" class="grid gap-5">
					<h2 class="text-3xl font-semibold tracking-[-0.04em] text-primary">Related tools</h2>
					<div class="grid gap-4 md:grid-cols-3">
						<a href="/custody-percentage-calculator/" class="soft-card rounded-[1.5rem] p-5">
							<h3 class="text-lg font-semibold tracking-[-0.03em] text-primary">Custody Percentage Calculator</h3>
							<p class="mt-2 text-sm leading-6 text-secondary">Calculate custody percentages from overnight counts.</p>
						</a>
						<a href="/50-50-custody-schedule/" class="soft-card rounded-[1.5rem] p-5">
							<h3 class="text-lg font-semibold tracking-[-0.03em] text-primary">50/50 Custody Schedule</h3>
							<p class="mt-2 text-sm leading-6 text-secondary">Compare common equal parenting schedules.</p>
						</a>
						<a href="/2-2-3-custody-schedule/" class="soft-card rounded-[1.5rem] p-5">
							<h3 class="text-lg font-semibold tracking-[-0.03em] text-primary">2-2-3 Custody Schedule</h3>
							<p class="mt-2 text-sm leading-6 text-secondary">Preview a frequent-contact 50/50 schedule.</p>
						</a>
						<a href="/2-2-5-5-custody-schedule/" class="soft-card rounded-[1.5rem] p-5">
							<h3 class="text-lg font-semibold tracking-[-0.03em] text-primary">2-2-5-5 Custody Schedule</h3>
							<p class="mt-2 text-sm leading-6 text-secondary">See a consistent weekday rotation.</p>
						</a>
						<a href="/5-2-2-5-custody-schedule/" class="soft-card rounded-[1.5rem] p-5">
							<h3 class="text-lg font-semibold tracking-[-0.03em] text-primary">5-2-2-5 Custody Schedule</h3>
							<p class="mt-2 text-sm leading-6 text-secondary">Compare another common 50/50 schedule pattern.</p>
						</a>
						<a href="/custody-calendar-template/" class="soft-card rounded-[1.5rem] p-5">
							<h3 class="text-lg font-semibold tracking-[-0.03em] text-primary">Custody Calendar Template</h3>
							<p class="mt-2 text-sm leading-6 text-secondary">Start from a printable calendar format.</p>
						</a>
					</div>
				</section>
			</div>
		</section>
	</main>
	<Footer />
</BaseLayout>
