---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import FAQ from '../components/FAQ.astro';
import PercentageCalculatorCard from '../components/tool/PercentageCalculatorCard.astro';
import OvernightPieGraphic from '../components/tools/custody-percentage-calculator/OvernightPieGraphic.astro';
import AnnualCalculationGraphic from '../components/tools/custody-percentage-calculator/AnnualCalculationGraphic.astro';
import PercentageLadderGraphic from '../components/tools/custody-percentage-calculator/PercentageLadderGraphic.astro';
import { getCanonicalUrl } from '../lib/seo/metadata';
import {
	buildArticleSchema,
	buildBreadcrumbSchema,
	buildFAQSchema,
	buildSoftwareApplicationSchema,
	buildWebPageSchema,
} from '../lib/seo/schema';
import {
	annualTotals,
	articleTocItems,
	editorialReview,
	faqItems,
	faqSection,
	hero,
	heroKeyStats,
	howCalculated,
	meta,
	percentageLadder,
	relatedReading,
} from '../data/custodyPercentageCalculatorPage';

const canonical = '/custody-percentage-calculator/';
const canonicalUrl = getCanonicalUrl(canonical);
const breadcrumbs = [
	{ name: 'Home', url: getCanonicalUrl('/') },
	{ name: 'Custody Percentage Calculator', url: canonicalUrl },
];
const schema = [
	buildWebPageSchema({ name: meta.title, description: meta.description, url: canonicalUrl }),
	buildArticleSchema({
		headline: hero.headline,
		description: meta.description,
		url: canonicalUrl,
		datePublished: meta.datePublished,
		dateModified: meta.dateModified,
		authorName: editorialReview.reviewer,
	}),
	buildFAQSchema(faqItems),
	buildBreadcrumbSchema(breadcrumbs),
	{
		...buildSoftwareApplicationSchema({
			name: 'Custody Percentage Calculator',
			description: meta.description,
			url: canonicalUrl,
			applicationCategory: 'LegalApplication',
		}),
		operatingSystem: 'Web',
		offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
	},
];
---

<BaseLayout title={meta.title} description={meta.description} canonical={canonical}>
	<JsonLd slot="head" data={schema} />
	<Navbar />
	<Breadcrumbs items={breadcrumbs} />
	<main>
		<section class="container-shell grid grid-cols-1 gap-5 py-4 sm:py-5 lg:grid-cols-[minmax(0,0.88fr)_minmax(420px,1fr)] lg:items-start lg:gap-7 lg:py-6">
			<div class="min-w-0 lg:pt-1">
				<h1 class="max-w-3xl text-4xl font-semibold leading-[0.98] tracking-[-0.055em] text-primary sm:text-5xl">{hero.headline}</h1>
				<dl class="mt-4 grid grid-cols-3 gap-2">
					{heroKeyStats.map((s) => (
						<div class="rounded-[1rem] bg-accent/10 px-2 py-2.5 text-center sm:px-3">
							<dd class="text-lg font-bold text-accent sm:text-xl">{s.value}</dd>
							<dt class="mt-0.5 text-[10px] font-semibold uppercase text-secondary">{s.label}</dt>
						</div>
					))}
				</dl>
				<p class="mt-3 max-w-2xl text-base leading-7 text-secondary">{hero.intro}</p>
				<p class="mt-3 max-w-2xl text-sm leading-6 text-secondary" set:html={hero.boundary} />
				<div class="mt-3 max-w-2xl text-xs leading-5 text-muted">
					<p class="font-semibold text-secondary">Reviewed for:</p>
					<ul class="mt-1 list-inside list-disc">{editorialReview.reviewedFor.map((i) => <li>{i}</li>)}</ul>
					<p class="mt-2">
						Reviewed by <a href={editorialReview.reviewerHref} class="font-semibold text-secondary underline">{editorialReview.reviewer}</a>
						{' · '}<a href={editorialReview.methodologyHref} class="font-semibold text-secondary underline">{editorialReview.methodologyLabel}</a>
						{' · '}{editorialReview.disclaimer}
					</p>
				</div>
			</div>
			<PercentageCalculatorCard heading="Calculate custody percentage" ariaLabel="Custody percentage results" />
		</section>

		<nav class="container-shell border-y border-line-subtle py-3" aria-label="On this page">
			<ul class="flex flex-wrap gap-x-4 gap-y-1 text-xs font-semibold text-secondary">
				{articleTocItems.map((i) => <li><a href={`#${i.id}`} class="hover:text-accent">{i.label}</a></li>)}
			</ul>
		</nav>

		<section id="how-calculated" class="container-shell scroll-mt-24 py-10 lg:py-12">
			<div class="grid gap-8 lg:grid-cols-[1fr_360px]">
				<div>
					<h2 class="text-2xl font-semibold text-primary sm:text-3xl">{howCalculated.title}</h2>
					<p class="mt-3 text-secondary">{howCalculated.intro}</p>
					<p class="mt-4 rounded-lg bg-surface/50 p-3 font-mono text-sm text-primary ring-1 ring-line-subtle">{howCalculated.formula}</p>
					<ol class="mt-6 list-decimal space-y-4 pl-5">
						{howCalculated.steps.map((s) => (
							<li class="text-secondary"><h3 class="font-semibold text-primary">{s.heading}</h3><p class="mt-2 text-sm">{s.body}</p></li>
						))}
					</ol>
					<p class="mt-4 text-sm text-secondary" set:html={howCalculated.closing} />
				</div>
				<AnnualCalculationGraphic />
			</div>
		</section>

		<section id="annual-totals" class="container-shell scroll-mt-24 border-t border-line-subtle py-10 lg:py-12">
			<div class="grid gap-8 lg:grid-cols-[1fr_360px]">
				<div>
					<h2 class="text-2xl font-semibold text-primary sm:text-3xl">{annualTotals.title}</h2>
					<p class="mt-3 text-secondary">{annualTotals.intro}</p>
					<div class="mt-6 overflow-x-auto rounded-[1.25rem] ring-1 ring-line-subtle">
						<table class="w-full min-w-[320px] text-left text-sm">
							<thead class="bg-surface-elevated text-xs uppercase text-muted">
								<tr><th class="px-4 py-3">Split</th><th class="px-4 py-3">Parent A</th><th class="px-4 py-3">Parent B</th><th class="px-4 py-3">Note</th></tr>
							</thead>
							<tbody class="divide-y divide-line-subtle text-secondary">
								{annualTotals.rows.map((r) => (
									<tr><td class="px-4 py-3 font-semibold text-primary">{r.split}</td><td class="px-4 py-3">{r.parentA}</td><td class="px-4 py-3">{r.parentB}</td><td class="px-4 py-3 text-xs">{r.note}</td></tr>
								))}
							</tbody>
						</table>
					</div>
				</div>
				<OvernightPieGraphic />
			</div>
		</section>

		<section id="percentage-ladder" class="container-shell scroll-mt-24 border-t border-line-subtle py-10 lg:py-12">
			<div class="grid gap-8 lg:grid-cols-[1fr_360px]">
				<div>
					<h2 class="text-2xl font-semibold text-primary sm:text-3xl">{percentageLadder.title}</h2>
					<p class="mt-3 text-secondary">{percentageLadder.intro}</p>
					<ul class="mt-6 space-y-4">
						{percentageLadder.bands.map((b) => (
							<li class="border-l-2 border-accent/30 pl-4">
								<h3 class="font-semibold text-primary">{b.range} — {b.label}</h3>
								<p class="mt-2 text-sm text-secondary" set:html={b.body} />
							</li>
						))}
					</ul>
				</div>
				<PercentageLadderGraphic />
			</div>
		</section>

		<section id="related-reading" class="container-shell scroll-mt-24 border-t border-line-subtle py-10 lg:py-12">
			<h2 class="text-2xl font-semibold text-primary sm:text-3xl">{relatedReading.title}</h2>
			<div class="mt-4 max-w-3xl space-y-3 text-secondary">
				{relatedReading.paragraphs.map((p) => <p set:html={p} />)}
			</div>
		</section>

		<FAQ items={faqItems} title={faqSection.title} description={faqSection.description} />
	</main>
	<Footer />
</BaseLayout>
