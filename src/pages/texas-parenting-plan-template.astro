			const day = date.getDate();
			if (isFar) {
				return (month === 5 && day >= 15) || (month === 6 && day <= 27);
			}
			return month === 6 && day >= 1 && day <= 30;
		}

		function isSummerPreviewMonth(month, isFar) {
			if (isFar) return month === 5 || month === 6;
			return month === 6;
		}

		function getSummerBlockLabel(isFar) {
			return isFar ? 'June 15â€“July 27' : 'July 1â€“30';
		}

		function shouldApplySeasonalToAnnual(snapshot) {
			// Weekend and 50/50 annual totals use the base repeating pattern only.
			// Seasonal layers still appear in month preview when viewing relevant months.
			return snapshot.scheduleType !== 'weekend' && snapshot.scheduleType !== 'fifty';
		}

		function usesTexasHolidayRules(snapshot) {
			return snapshot.holidays === HOLIDAY_TEXAS_OPTION || snapshot.holidays === HOLIDAY_ALTERNATING_OPTION;
		}

		function usesSummerRules(snapshot) {
			return snapshot.summerPossession === SUMMER_RULES_OPTION;
		}

		function parseStartDate(snapshot) {
			const start = new Date(`${snapshot.startDate}T00:00:00`);
			return Number.isNaN(start.getTime()) ? new Date() : start;
		}

		function daysBetween(startDate, date) {
			return Math.floor((date.getTime() - startDate.getTime()) / 86400000);
		}

		function getNthFriday(year, month, n) {
			const daysInMonth = new Date(year, month + 1, 0).getDate();
			let count = 0;
			for (let day = 1; day <= daysInMonth; day += 1) {
				if (new Date(year, month, day).getDay() === 5) {
					count += 1;
					if (count === n) return day;
				}
			}
			return null;
		}

		function getFridayOnOrAfter(date) {
			const result = new Date(date.getFullYear(), date.getMonth(), date.getDate());
			const offset = (5 - result.getDay() + 7) % 7;
			result.setDate(result.getDate() + offset);
			return result;
		}

		function getFridayOfWeek(date) {
			const result = new Date(date.getFullYear(), date.getMonth(), date.getDate());
			const offset = (result.getDay() + 2) % 7;
			result.setDate(result.getDate() - offset);
			return result;
		}

		function isSpoPossessionDay(date) {
			const year = date.getFullYear();
			const month = date.getMonth();
			const day = date.getDate();
			const dayOfWeek = date.getDay();
			for (const nth of [1, 3, 5]) {
				const friday = getNthFriday(year, month, nth);
				if (!friday) continue;
				const sunday = friday + 2;
				if (day >= friday && day <= sunday) {
					return { friday, sunday, dayOfWeek };
				}
			}
			return null;
		}

		function isMondayAfterSpoWeekend(date) {
			if (date.getDay() !== 1) return false;
			const sunday = new Date(date.getFullYear(), date.getMonth(), date.getDate() - 1);
			return isSpoPossessionDay(sunday);
		}

		function isThursdayBeforeSpoWeekend(date) {
			if (date.getDay() !== 4) return false;
			const friday = new Date(date.getFullYear(), date.getMonth(), date.getDate() + 1);
			return isSpoPossessionDay(friday) !== null;
		}

		function isAlternatingWeekendNight(date, startDate) {
			const dayOfWeek = date.getDay();
			if (dayOfWeek !== 5 && dayOfWeek !== 6) return false;
			const startFriday = getFridayOnOrAfter(startDate);
			const weekFriday = getFridayOfWeek(date);
			const weeksApart = Math.round((weekFriday.getTime() - startFriday.getTime()) / (7 * 86400000));
			return weeksApart >= 0 && weeksApart % 2 === 0;
		}

		function getBaseOvernightOwner(date, snapshot) {
			// Base schedule layer: counts overnights only (not same-day visits).
			// Standard SPO nearby: Fri/Sat possession weekends + Thu before 1st/3rd/5th weekends.
			// Expanded SPO nearby: Friâ€“Sun possession weekends + school-year Thu + Mon school return.
			// Long-distance: weekend Fri/Sat blocks only (no midweek Thu).
			const scheduleType = snapshot.scheduleType;
			const isFar = snapshot.distance === 'far';
			const startDate = parseStartDate(snapshot);
			if (daysBetween(startDate, date) < 0) return 'inactive';

			const dayOfWeek = date.getDay();

			if (scheduleType === 'fifty') {
				const cycleDay = daysBetween(startDate, date) % 14;
				return [2, 3, 7, 8, 11, 12, 13].includes(cycleDay) ? 'b' : 'a';
			}

			if (scheduleType === 'weekend') {
				return isAlternatingWeekendNight(date, startDate) ? 'b' : 'a';
			}

			const possession = isSpoPossessionDay(date);
			if (possession) {
				if (scheduleType === 'expanded' || scheduleType === 'custom') {
					if (dayOfWeek === 5 || dayOfWeek === 6 || dayOfWeek === 0) return 'b';
					return 'a';
				}
				if (isFar) {
					if (dayOfWeek === 5 || dayOfWeek === 6) return 'b';
					return 'a';
				}
				if (scheduleType === 'spo') {
					if (dayOfWeek === 5 || dayOfWeek === 6) return 'b';
					return 'a';
				}
				if (dayOfWeek === 5 || dayOfWeek === 6 || dayOfWeek === 0) return 'b';
				return 'a';
			}

			if (!isFar && scheduleType === 'expanded') {
				if (dayOfWeek === 4 && isSchoolYearMonth(date.getMonth())) return 'b';
				if (dayOfWeek === 1 && isMondayAfterSpoWeekend(date)) return 'b';
			}

			if (!isFar && scheduleType === 'spo' && isThursdayBeforeSpoWeekend(date)) {
				return 'b';
			}

			return 'a';
		}

		function getThanksgivingThursday(year) {
			const first = new Date(year, 10, 1);
			const offset = (4 - first.getDay() + 7) % 7;
			return 1 + offset + 21;
		}

		function getSpringBreakStart(year) {
			const march1 = new Date(year, 2, 1);
			const firstMonday = 1 + ((8 - march1.getDay()) % 7);
			return firstMonday + 7;
		}

		function applySimplifiedSummer(owner, date, snapshot, notes, previewMonthIndex, forAnnual) {
			if (!usesSummerRules(snapshot)) return owner;
			const isFar = isFarDistance(snapshot);
			if (!isSimplifiedSummerBlock(date, isFar)) return owner;
			if (!forAnnual && !isSummerPreviewMonth(previewMonthIndex, isFar)) return owner;
			if (notes && !notes.includes('summer-applied')) notes.push('summer-applied');
			return owner === 'inactive' ? 'inactive' : 'b';
		}

		function applyTexasHolidayOverride(owner, date, snapshot, notes, previewMonthIndex) {
			if (!usesTexasHolidayRules(snapshot)) return owner;
			if (!isHolidayMonth(previewMonthIndex)) return owner;

			const year = date.getFullYear();
			const month = date.getMonth();
			const day = date.getDate();
			const evenYear = year % 2 === 0;
			let holidayOwner = null;

			if (month === 10) {
				const thanksgiving = getThanksgivingThursday(year);
				if (day >= thanksgiving && day <= thanksgiving + 3) {
					holidayOwner = evenYear ? 'b' : 'a';
				}
			}

			if (month === 11 && day >= 24 && day <= 26) {
				holidayOwner = evenYear ? 'b' : 'a';
			}

			if (month === 2) {
				const springStart = getSpringBreakStart(year);
				if (day >= springStart && day <= springStart + 6) {
					holidayOwner = evenYear ? 'b' : 'a';
				}
			}

			if (holidayOwner) {
				if (notes && !notes.includes('holiday-applied')) notes.push('holiday-applied');
				return holidayOwner;
			}

			return owner;
		}

		/** Single source of truth for overnight ownership across preview, annual totals, and print. */
		function resolveOvernightOwner(date, snapshot, options = {}) {
			const {
				previewMonthIndex = date.getMonth(),
				forAnnual = false,
				notes = null,
				applySeasonal = true,
			} = options;

			let owner = getBaseOvernightOwner(date, snapshot);
			if (!applySeasonal) return owner;

			const includeSeasonalInAnnual = forAnnual && shouldApplySeasonalToAnnual(snapshot);
			const includeSeasonalInPreview = !forAnnual;

			if (includeSeasonalInAnnual || includeSeasonalInPreview) {
				owner = applySimplifiedSummer(owner, date, snapshot, notes, previewMonthIndex, forAnnual);
				owner = applyTexasHolidayOverride(owner, date, snapshot, notes, previewMonthIndex);
			}

			return owner;
		}

		function buildRuleNotes(snapshot, previewMonthIndex, runtimeNotes) {
			const notes = [];
			const isFar = isFarDistance(snapshot);
			const scheduleType = snapshot.scheduleType;

			if (isFar && (scheduleType === 'spo' || scheduleType === 'expanded' || scheduleType === 'custom')) {
				notes.push('Long-distance rule applied');
			}
			if (snapshot.summerPossession === SUMMER_CUSTOM_OPTION) {
				notes.push('Custom summer plan selected. Add dates in notes or final plan.');
			} else if (runtimeNotes.includes('summer-applied')) {
				notes.push(`Simplified summer possession estimate applied (${getSummerBlockLabel(isFar)}).`);
			} else if (usesSummerRules(snapshot) && !isSummerPreviewMonth(previewMonthIndex, isFar)) {
				notes.push('Summer possession applies when viewing summer months.');
			}
			if (snapshot.holidays === HOLIDAY_CUSTOM_OPTION) {
				notes.push('Custom holiday plan selected. Add holiday dates in notes or final plan.');
			} else if (runtimeNotes.includes('holiday-applied')) {
				notes.push('Texas holiday override applied');
			}
			return notes;
		}

		function calculateAnnualOvernights(snapshot) {
			const startDate = parseStartDate(snapshot);
			const applySeasonal = shouldApplySeasonalToAnnual(snapshot);
			let bDays = 0;
			for (let offset = 0; offset < 365; offset += 1) {
				const date = new Date(startDate.getTime() + offset * 86400000);
				const owner = resolveOvernightOwner(date, snapshot, {
					forAnnual: true,
					applySeasonal,
					previewMonthIndex: date.getMonth(),
				});
				if (owner === 'b') bDays += 1;
			}
			const aDays = 365 - bDays;
			const bPercent = Math.round((bDays / 365) * 100);
			const aPercent = 100 - bPercent;
			return { aDays, bDays, aPercent, bPercent };
		}

		function buildCalendarState(snapshot) {
			const { year, month } = getPreviewMonth(snapshot);
			const daysInMonth = new Date(year, month + 1, 0).getDate();
			const runtimeNotes = [];
			const owners = {};

			for (let day = 1; day <= daysInMonth; day += 1) {
				const date = new Date(year, month, day);
				owners[day] = resolveOvernightOwner(date, snapshot, {
					previewMonthIndex: month,
					forAnnual: false,
					notes: runtimeNotes,
				});
			}

			const annual = calculateAnnualOvernights(snapshot);
			const notes = buildRuleNotes(snapshot, month, runtimeNotes);
			const preset = presets[snapshot.scheduleType] ?? presets.spo;

			return { year, month, daysInMonth, owners, notes, annual, preset, monthLabel: formatMonthYear(year, month) };
		}

		function createCalendarDayCell(owner, dayLabel) {
			const cell = document.createElement('span');
			if (!dayLabel) {
				cell.className = spacerDayClasses;
				return cell;
			}
			cell.className = owner === 'b' ? parentBClasses : owner === 'a' ? parentAClasses : inactiveDayClasses;
			const label = document.createElement('span');
			label.className = 'leading-none';
			label.textContent = dayLabel;
			cell.append(label);
			return cell;
		}

		function renderCalendarGrid(container, state) {
			if (!container) return;
			const { year, month, daysInMonth, owners } = state;
			const firstOfMonth = new Date(year, month, 1);
			const mondayFirstOffset = (firstOfMonth.getDay() + 6) % 7;
			const cells = [];

			for (let i = 0; i < mondayFirstOffset; i += 1) {
				cells.push(createCalendarDayCell('spacer', ''));
			}

			for (let day = 1; day <= daysInMonth; day += 1) {
				const owner = owners[day] ?? 'inactive';
				cells.push(createCalendarDayCell(owner, String(day)));
			}

			while (cells.length % 7 !== 0) {
				cells.push(createCalendarDayCell('spacer', ''));
			}

			container.replaceChildren(...cells);
		}

		function renderPrintCalendarGrid(state) {
			const printCalendar = document.querySelector('[data-print-calendar-grid]');
			if (!printCalendar) return;
			const { year, month, daysInMonth, owners } = state;
			const firstOfMonth = new Date(year, month, 1);
			const mondayFirstOffset = (firstOfMonth.getDay() + 6) % 7;
			const cells = ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'].map((label) => {
				const cell = document.createElement('span');
				cell.className = 'print-weekday';
				cell.textContent = label;
				return cell;
			});

			for (let i = 0; i < mondayFirstOffset; i += 1) {
				const cell = document.createElement('span');
				cell.className = 'print-inactive';
				cell.textContent = '';
				cells.push(cell);
			}

			for (let day = 1; day <= daysInMonth; day += 1) {
				const owner = owners[day] ?? 'inactive';
				const cell = document.createElement('span');
				cell.textContent = String(day);
				cell.classList.add(owner === 'b' ? 'print-parent-b' : owner === 'a' ? 'print-parent-a' : 'print-inactive');
				cells.push(cell);
			}

			printCalendar.replaceChildren(...cells);
		}

		function renderCalendarNotes(container, notes) {
			if (!container) return;
			container.replaceChildren();
			notes.forEach((note) => {
				const item = document.createElement('li');
				item.className = calendarNoteClasses;
				item.textContent = note;
				container.append(item);
			});
		}

		function renderRuleNotesText(notes) {
			const target = document.querySelector('[data-print-rule-notes]');
			if (!target) return;
			target.replaceChildren(notes.length ? `Applied rules: ${notes.join(' · ')}` : '');
		}

		function updateParentingTimeUI(snapshot, state, selectors) {
			const parentA = snapshot.parentA || 'Parent A';
			const parentB = snapshot.parentB || 'Parent B';
			const { annual } = state;

			setText(selectors.parentALabel, parentA);
			setText(selectors.parentBLabel, parentB);
			setText(selectors.parentAPercent, `${annual.aPercent}%`);
			setText(selectors.parentBPercent, `${annual.bPercent}%`);
			setText(selectors.parentADays, `${annual.aDays} annual overnights est.`);
			setText(selectors.parentBDays, `${annual.bDays} annual overnights est.`);

			const parentABar = document.querySelector(selectors.parentABar);
			const parentBBar = document.querySelector(selectors.parentBBar);
			if (parentABar instanceof HTMLElement) parentABar.style.width = `${annual.aPercent}%`;
			if (parentBBar instanceof HTMLElement) parentBBar.style.width = `${annual.bPercent}%`;
		}

		function getSelectedScheduleType() {
			const selected = tool?.querySelector('input[name="scheduleType"]:checked');
			return selected instanceof HTMLInputElement ? selected.value : 'spo';
		}

		function getFieldValue(name, fallback = '') {
			const field = document.querySelector(`[name="${name}"]`);
			if (field instanceof HTMLInputElement || field instanceof HTMLSelectElement || field instanceof HTMLTextAreaElement) {
				return field.value.trim() || fallback;
			}
			return fallback;
		}

		function collectFormState() {
			const startDate = getFieldValue('startDate', getLocalDateString());
			const preview = getPreviewMonth({ startDate });
			return {
				scheduleType: getSelectedScheduleType(),
				parentA: getFieldValue('parentA', 'Parent A'),
				parentB: getFieldValue('parentB', 'Parent B'),
				childAge: getFieldValue('childAge', '8'),
				distance: getFieldValue('distance', 'near'),
				startDate,
				summerPossession: getFieldValue('summerPossession', SUMMER_RULES_OPTION),
				holidays: getFieldValue('holidays', HOLIDAY_TEXAS_OPTION),
				pdfOptions: getFieldValue('pdfOptions', 'Calendar and parenting plan outline'),
				notes: getFieldValue('notes', 'No notes added.'),
				previewYear: preview.year,
				previewMonth: preview.month,
			};
		}

		function setFieldValue(name, value) {
			const field = document.querySelector(`[name="${name}"]`);
			if (typeof value !== 'string') return;
			if (field instanceof HTMLInputElement || field instanceof HTMLSelectElement || field instanceof HTMLTextAreaElement) {
				field.value = value;
			}
		}

		function saveProgress() {
			try {
				window.localStorage.setItem(storageKey, JSON.stringify(collectFormState()));
			} catch {
				// Storage can be unavailable in private browsing or hardened browser settings.
			}
		}

		function loadSavedProgress() {
			try {
				const saved = window.localStorage.getItem(storageKey);
				if (!saved) return;
				const parsed = JSON.parse(saved);
				if (!parsed || typeof parsed !== 'object') return;
				const scheduleOption = tool?.querySelector(`input[name="scheduleType"][value="${parsed.scheduleType}"]`);
				if (scheduleOption instanceof HTMLInputElement) scheduleOption.checked = true;
				setFieldValue('parentA', parsed.parentA);
				setFieldValue('parentB', parsed.parentB);
				setFieldValue('childAge', parsed.childAge);
				setFieldValue('distance', parsed.distance);
				setFieldValue('startDate', parsed.startDate);
				setFieldValue('summerPossession', parsed.summerPossession);
				setFieldValue('holidays', parsed.holidays);
				setFieldValue('notes', parsed.notes);
				setFieldValue('pdfOptions', parsed.pdfOptions);
				if (typeof parsed.previewYear === 'number' && typeof parsed.previewMonth === 'number') {
					previewYear = parsed.previewYear;
					previewMonth = parsed.previewMonth;
				}
			} catch {
				// Ignore malformed saved state and continue with defaults.
			}
		}

		function selectBuilderSchedule(scheduleType, shouldScroll = true) {
			const option = tool?.querySelector(`input[name="scheduleType"][value="${scheduleType}"]`);
			if (!(option instanceof HTMLInputElement)) return;
			option.checked = true;
			updateTool();
			saveProgress();
			trackTexasBuilderStarted();
			trackTexasScheduleSelected(scheduleType);
			trackTexasCalendarGenerated(collectFormState());
			if (shouldScroll) tool?.scrollIntoView({ behavior: 'smooth', block: 'start' });
		}

		function getFitValue(selector, fallback) {
			const field = document.querySelector(selector);
			return field instanceof HTMLSelectElement ? field.value : fallback;
		}

		function getScheduleFitRecommendation() {
			const distance = getFitValue('[data-fit-distance]', 'near');
			const age = getFitValue('[data-fit-age]', 'school');
			const conflict = getFitValue('[data-fit-conflict]', 'cooperative');

			if (distance === 'far') {
				return {
					scheduleType: 'weekend',
					primary: 'Every Other Weekend',
					secondary: 'Secondary option: Standard SPO with longer blocks',
					why: 'Long-distance plans often work better with fewer exchanges, longer possession blocks, and careful summer and school-calendar planning.',
				};
			}

			if (conflict === 'high') {
				return {
					scheduleType: 'spo',
					primary: 'Standard Possession Order',
					secondary: 'Secondary option: clearer structured schedule',
					why: 'Higher-conflict situations usually benefit from clearer exchange times, fewer ambiguous terms, and a schedule parents can follow consistently.',
				};
			}

			if (conflict === 'moderate') {
				return {
					scheduleType: 'expanded',
					primary: 'Expanded Standard Possession Order',
					secondary: 'Secondary option: Standard SPO',
					why: 'Moderate-conflict families may compare expanded weekday time against a more structured Standard SPO calendar.',
				};
			}

			if (age === 'under5') {
				return {
					scheduleType: 'spo',
					primary: 'Standard Possession Order',
					secondary: 'Secondary option: shorter recurring schedule',
					why: 'Younger children may need predictable routines and shorter gaps between visits, so parents often compare Standard SPO with a custom recurring pattern.',
				};
			}

			if (age === 'teen') {
				return {
					scheduleType: 'fifty',
					primary: '50/50 Schedule',
					secondary: 'Secondary option: week-on/week-off style',
					why: 'Cooperative parents with teens may be able to support equal parenting time when school, activities, and transportation are predictable.',
				};
			}

			return {
				scheduleType: 'expanded',
				primary: 'Expanded Standard Possession Order',
				secondary: 'Secondary option: 50/50 Schedule',
				why: 'Nearby cooperative co-parents may be able to support more weekday time while still keeping the schedule structured.',
			};
		}

		function saveScheduleFitAnswers() {
			try {
				window.localStorage.setItem(
					fitStorageKey,
					JSON.stringify({
						distance: getFitValue('[data-fit-distance]', 'near'),
						age: getFitValue('[data-fit-age]', 'school'),
						conflict: getFitValue('[data-fit-conflict]', 'cooperative'),
					})
				);
			} catch {
				// Schedule-fit answers are optional and browser-local only.
			}
		}

		function loadScheduleFitAnswers() {
			try {
				const saved = window.localStorage.getItem(fitStorageKey);
				if (!saved) return;
				const parsed = JSON.parse(saved);
				if (!parsed || typeof parsed !== 'object') return;
				const distance = document.querySelector('[data-fit-distance]');
				const age = document.querySelector('[data-fit-age]');
				const conflict = document.querySelector('[data-fit-conflict]');
				if (distance instanceof HTMLSelectElement && typeof parsed.distance === 'string') distance.value = parsed.distance;
				if (age instanceof HTMLSelectElement && typeof parsed.age === 'string') age.value = parsed.age;
				if (conflict instanceof HTMLSelectElement && typeof parsed.conflict === 'string') conflict.value = parsed.conflict;
