---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import FAQ from '../components/FAQ.astro';
import CtaButton from '../components/CtaButton.astro';
import TexasParentingFlowGraphic from '../components/schedules/texas-parenting-plan-template/TexasParentingFlowGraphic.astro';
import SpoInteractionGraphic from '../components/schedules/texas-parenting-plan-template/SpoInteractionGraphic.astro';
import TexasFilingSequenceGraphic from '../components/schedules/texas-parenting-plan-template/TexasFilingSequenceGraphic.astro';
import { getCanonicalUrl } from '../lib/seo/metadata';
import {
	buildArticleSchema,
	buildBreadcrumbSchema,
	buildFAQSchema,
	buildSoftwareApplicationSchema,
	buildWebPageSchema,
} from '../lib/seo/schema';
import {
	articleTocItems,
	distanceRules,
	editorialReview,
	faqItems,
	faqSection,
	filingSequence,
	genericRouting,
	hero,
	heroKeyStats,
	meta,
	officialResources,
	spoInteraction,
	summerNotice,
	texasFlow,
} from '../data/texasParentingPlanTemplate';

const title = meta.title;
const description = meta.description;
const canonical = '/texas-parenting-plan-template/';
const canonicalUrl = getCanonicalUrl(canonical);
const datePublished = meta.datePublished;
const dateModified = meta.dateModified;

const breadcrumbs = [
	{ name: 'Home', url: getCanonicalUrl('/') },
	{ name: 'Templates', url: getCanonicalUrl('/parenting-plan-template/') },
	{ name: 'Texas Parenting Plan Template', url: canonicalUrl },
];

const schema = [
	buildWebPageSchema({ name: title, description, url: canonicalUrl }),
	buildArticleSchema({
		headline: hero.headline,
		description,
		url: canonicalUrl,
		datePublished,
		dateModified,
		authorName: editorialReview.reviewer,
	}),
	buildFAQSchema(faqItems),
	buildBreadcrumbSchema(breadcrumbs),
	{
		...buildSoftwareApplicationSchema({
			name: 'Texas Parenting Plan Generator',
			description,
			url: canonicalUrl,
			applicationCategory: 'LegalApplication',
		}),
		operatingSystem: 'Web',
		offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
	},
];
---

<BaseLayout title={meta.title} description={meta.description} canonical={canonical}>
	<JsonLd slot="head" data={schema} />
	<Navbar />
	<Breadcrumbs items={breadcrumbs} />
	<main class="overflow-x-clip">
		<section class="container-shell grid gap-3 py-4 sm:gap-4 sm:py-5 lg:grid-cols-[minmax(0,0.68fr)_minmax(0,1fr)] lg:items-start lg:gap-8 lg:py-10" id="plan-builder">
			<div class="min-w-0 lg:pt-4">
				<h1 class="max-w-4xl text-[1.65rem] font-semibold leading-[1.03] tracking-[-0.055em] text-primary sm:text-5xl lg:text-6xl">{hero.headline}</h1>
				<dl class="mt-4 grid max-w-xl grid-cols-3 gap-2">{heroKeyStats.map((s) => (<div class="rounded-[1rem] bg-accent/10 px-2 py-2.5 text-center sm:px-3"><dd class="text-lg font-bold text-accent sm:text-xl">{s.value}</dd><dt class="mt-0.5 text-[10px] font-semibold uppercase text-secondary">{s.label}</dt></div>))}</dl>
				<p class="mt-3 max-w-xl text-sm leading-6 text-secondary sm:text-base sm:leading-7">{hero.intro}</p>
				<p class="mt-3 max-w-xl text-sm leading-6 text-secondary" set:html={hero.boundary} />
				<div class="mt-3 max-w-xl text-xs leading-5 text-muted">
					<p class="font-semibold text-secondary">Reviewed for:</p>
					<ul class="mt-1 list-inside list-disc">{editorialReview.reviewedFor.map((i) => <li>{i}</li>)}</ul>
					<p class="mt-2">Reviewed by <a href={editorialReview.reviewerHref} class="font-semibold text-secondary underline">{editorialReview.reviewer}</a> · <a href={editorialReview.methodologyHref} class="font-semibold text-secondary underline">{editorialReview.methodologyLabel}</a> · Updated {meta.dateModified} · {editorialReview.disclaimer}</p>
				</div>
			</div>

			<section class="premium-card relative min-w-0 max-w-full overflow-visible rounded-[1.5rem] border-line p-3 sm:rounded-[2rem] sm:p-4" data-texas-plan-tool>
				<div class="absolute inset-x-10 top-0 h-px bg-gradient-to-r from-transparent via-white/30 to-transparent" aria-hidden="true"></div>
				<div class="min-w-0 max-w-full rounded-[1.25rem] bg-surface-elevated shadow-[inset_0_1px_0_rgba(255,255,255,0.07)] sm:rounded-[1.6rem]">
					<div class="grid gap-3 p-3 sm:p-4" data-texas-plan-form>
						<div class="grid gap-2">
							<div class="flex items-center justify-between gap-3">
								<h2 class="text-lg font-semibold tracking-[-0.04em] text-primary">Build your Texas parenting plan</h2>
								<span class="rounded-full bg-accent/10 px-3 py-1 text-[11px] font-semibold text-accent" data-schedule-chip>Texas SPO</span>
							</div>
							<div class="grid grid-cols-2 gap-2 lg:grid-cols-4" aria-label="Choose schedule">
								{[
									['spo', 'Standard SPO', '30% est.', 'Often used when one parent has the primary residence.'],
									['expanded', 'Expanded SPO', '42% est.', 'More parenting time when homes and school routines are close enough.'],
									['fifty', '50/50 Schedule', '50% est.', 'Best when parents live nearby and can share school transportation.'],
									['weekend', 'Every Other Weekend', '25% est.', 'Simpler option when fewer exchanges or longer distance is needed.'],
								].map(([value, label, help, description], index) => (
									<label class="texas-schedule-option min-w-0 cursor-pointer rounded-2xl bg-surface/80 p-2.5 text-center shadow-[inset_0_0_0_1px_var(--border-subtle)] transition-all duration-200 hover:-translate-y-0.5 hover:bg-surface-hover hover:shadow-[0_10px_24px_rgba(15,23,42,0.06)]">
										<input class="sr-only" type="radio" name="scheduleType" value={value} checked={index === 0} />
										<span class="block text-xs font-semibold leading-4 text-primary sm:text-sm">{label}</span>
										<span class="mt-1 block text-[11px] leading-4 text-muted">{help}</span>
										<span class="mt-1 block text-[10px] leading-4 text-muted">{description}</span>
									</label>
								))}
							</div>
						</div>

						<div class="grid min-w-0 gap-3 rounded-[1.15rem] bg-page/55 p-3 shadow-[inset_0_0_0_1px_var(--border-subtle)]" aria-live="polite">
							<div class="grid min-w-0 gap-3 md:grid-cols-[minmax(0,1fr)_minmax(190px,220px)]">
								<div class="min-w-0 rounded-[1rem] bg-surface/80 p-3 shadow-[inset_0_0_0_1px_var(--border-subtle)]">
									<div class="flex items-start justify-between gap-3">
										<div>
											<p class="text-[11px] font-semibold uppercase tracking-[0.16em] text-muted">Calendar preview</p>
											<h3 class="mt-1 text-lg font-semibold tracking-[-0.04em] text-primary" data-preview-title>Standard Possession Order</h3>
										</div>
										<p class="mt-3 text-xs leading-5 text-muted">
											Parenting time can affect planning conversations. You can also estimate support with the <a href="/texas-child-support-calculator/" class="font-semibold text-accent underline decoration-line underline-offset-4 hover:text-primary">Texas child support calculator</a>.
										</p>
									</div>
									<div class="texas-month-nav mt-3 flex items-center justify-between gap-2">
										<button type="button" class="texas-month-nav-btn" data-calendar-prev aria-label="Previous month">â€¹</button>
										<p class="min-w-0 truncate text-center text-xs font-semibold tracking-[-0.02em] text-primary" data-calendar-month-label>June 2026</p>
										<button type="button" class="texas-month-nav-btn" data-calendar-next aria-label="Next month">â€º</button>
									</div>
									<div class="texas-calendar-legend mt-2 flex flex-wrap items-center gap-x-3 gap-y-1 text-[11px] text-secondary">
										<span class="inline-flex items-center gap-1.5"><i class="h-2 w-2 shrink-0 rounded-full bg-accent" aria-hidden="true"></i><span data-calendar-legend-parent-a>Parent A</span></span>
										<span class="inline-flex items-center gap-1.5"><i class="h-2 w-2 shrink-0 rounded-full bg-parent-b" aria-hidden="true"></i><span data-calendar-legend-parent-b>Parent B</span></span>
									</div>
									<div class="mt-2.5 grid min-w-0 grid-cols-7 gap-1 text-center text-[10px] font-semibold uppercase tracking-[0.08em] text-muted sm:gap-1.5 sm:text-[11px]" aria-hidden="true">
										<span>Mon</span><span>Tue</span><span>Wed</span><span>Thu</span><span>Fri</span><span>Sat</span><span>Sun</span>
									</div>
									<div class="texas-calendar-grid mt-2 grid min-w-0 grid-cols-7 gap-1 sm:gap-1.5" data-demo-calendar>
										{Array.from({ length: 35 }, (_, index) => {
											const day = index + 1;
											const parentB = [5, 6, 7, 12, 13, 14, 19, 20, 21].includes(day);
											const isDay = index < 31;
											return (
												<span class:list={[
													isDay ? 'calendar-day-cell texas-calendar-day' : 'texas-calendar-spacer',
													isDay && (parentB ? 'texas-calendar-day-b' : 'texas-calendar-day-a'),
												]} data-calendar-day={day}>
													{isDay ? <span class="leading-none">{day}</span> : null}
												</span>
											);
										})}
									</div>
									<ul class="texas-preview-notes mt-1.5 grid max-w-full gap-0.5" data-tool-calendar-notes></ul>
								</div>
								<div class="grid min-w-0 gap-3">
									<div class="rounded-[1rem] bg-surface/80 p-3 shadow-[inset_0_0_0_1px_var(--border-subtle)]">
										<p class="text-[11px] font-semibold uppercase tracking-[0.16em] text-muted">Parenting time estimate</p>
										<div class="mt-2.5 grid gap-2.5">
											<div>
												<div class="flex items-center justify-between gap-2 text-xs font-medium text-secondary">
													<span class="inline-flex min-w-0 items-center gap-1.5 truncate"><i class="h-2 w-2 shrink-0 rounded-full bg-accent" aria-hidden="true"></i><span data-parent-a-label>Parent A</span></span>
													<span class="shrink-0 font-semibold text-primary" data-parent-a-percent>70%</span>
												</div>
												<div class="mt-1.5 h-2 overflow-hidden rounded-full bg-page/80 shadow-[inset_0_0_0_1px_var(--border-subtle)]"><span class="block h-full rounded-full bg-accent" style="width: 70%" data-parent-a-bar></span></div>
												<p class="mt-1 text-[10px] leading-none text-muted" data-parent-a-days>256 annual overnights est.</p>
											</div>
											<div>
												<div class="flex items-center justify-between gap-2 text-xs font-medium text-secondary">
													<span class="inline-flex min-w-0 items-center gap-1.5 truncate"><i class="h-2 w-2 shrink-0 rounded-full bg-parent-b" aria-hidden="true"></i><span data-parent-b-label>Parent B</span></span>
													<span class="shrink-0 font-semibold text-primary" data-parent-b-percent>30%</span>
												</div>
												<div class="mt-1.5 h-2 overflow-hidden rounded-full bg-page/80 shadow-[inset_0_0_0_1px_var(--border-subtle)]"><span class="block h-full rounded-full bg-parent-b" style="width: 30%" data-parent-b-bar></span></div>
												<p class="mt-1 text-[10px] leading-none text-muted" data-parent-b-days>109 annual overnights est.</p>
											</div>
										</div>
									</div>
									<div class="grid min-w-0 gap-2">
										<button type="button" class="btn-primary h-11 w-full max-w-full whitespace-nowrap px-4 text-sm font-semibold" data-customize-plan>Customize Plan</button>
										<p class="mt-2 text-center text-xs font-medium leading-5 text-muted">Free â€¢ Printable calendar â€¢ No account required</p>
									</div>
								</div>
							</div>
						</div>
					</div>
				</div>
			</section>
		</section>

		<section id="customize-plan" class="container-shell py-4 scroll-mt-24 sm:py-6 lg:max-w-5xl" data-customize-section>
			<div class="premium-card grid gap-4 rounded-[1.75rem] p-5">
				<div>
					<p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">Next step</p>
					<h2 class="mt-2 text-3xl font-semibold tracking-[-0.04em] text-primary">Customize your Texas parenting plan</h2>
					<p class="mt-3 text-sm leading-6 text-secondary">Add family details, summer and holiday options, and notes before generating a printable planning document.</p>
					<p class="mt-2 text-xs font-semibold text-secondary"><span class="text-parent-b" aria-hidden="true">âœ“</span> Changes save automatically in this browser.</p>
				</div>
				<div class="grid gap-5 lg:grid-cols-[minmax(0,1.45fr)_minmax(300px,0.9fr)] lg:items-start">
					<div class="grid min-w-0 gap-4">
						<div class="grid gap-3 sm:grid-cols-2 sm:items-start" data-plan-details>
							<label class="grid gap-2">
								<span class="text-sm font-medium text-secondary">Parent A</span>
								<input name="parentA" value="Parent A" data-first-custom-input class="texas-plan-control w-full rounded-2xl bg-surface px-4 text-sm text-primary shadow-[inset_0_0_0_1px_var(--border-subtle)] transition-all duration-200 ease-out hover:bg-surface-hover focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent" />
							</label>
							<label class="grid gap-2">
								<span class="text-sm font-medium text-secondary">Parent B</span>
								<input name="parentB" value="Parent B" class="texas-plan-control w-full rounded-2xl bg-surface px-4 text-sm text-primary shadow-[inset_0_0_0_1px_var(--border-subtle)] transition-all duration-200 ease-out hover:bg-surface-hover focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent" />
							</label>
							<label class="grid gap-2">
								<span class="text-sm font-medium text-secondary">Child age</span>
								<input name="childAge" type="number" min="0" max="18" value="8" class="texas-plan-control w-full rounded-2xl bg-surface px-4 text-sm text-primary shadow-[inset_0_0_0_1px_var(--border-subtle)] transition-all duration-200 ease-out hover:bg-surface-hover focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent" />
							</label>
							<label class="grid gap-2">
								<span class="text-sm font-medium text-secondary">Distance between parents</span>
								<select name="distance" class="texas-plan-control w-full rounded-2xl bg-surface px-4 text-sm text-primary shadow-[inset_0_0_0_1px_var(--border-subtle)] transition-all duration-200 ease-out hover:bg-surface-hover focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent">
									<option value="near">100 miles or less</option>
									<option value="far">More than 100 miles</option>
								</select>
							</label>
							<label class="grid gap-2">
								<span class="text-sm font-medium text-secondary">Start date</span>
								<input name="startDate" type="date" class="texas-plan-control w-full rounded-2xl bg-surface px-4 text-sm text-primary shadow-[inset_0_0_0_1px_var(--border-subtle)] transition-all duration-200 ease-out hover:bg-surface-hover focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent" />
							</label>
							<label class="grid gap-2">
								<span class="text-sm font-medium text-secondary">Summer possession</span>
								<select name="summerPossession" class="texas-plan-control w-full rounded-2xl bg-surface px-4 text-sm text-primary shadow-[inset_0_0_0_1px_var(--border-subtle)] transition-all duration-200 ease-out hover:bg-surface-hover focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent">
									<option>Use Texas summer possession rules</option>
									<option>Custom summer dates</option>
									<option>Decide later</option>
								</select>
							</label>
							<label class="grid gap-2">
								<span class="text-sm font-medium text-secondary">Holidays</span>
								<select name="holidays" class="texas-plan-control w-full rounded-2xl bg-surface px-4 text-sm text-primary shadow-[inset_0_0_0_1px_var(--border-subtle)] transition-all duration-200 ease-out hover:bg-surface-hover focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent">
									<option>Texas holiday schedule</option>
									<option>Alternating holidays</option>
									<option>Custom holiday plan</option>
								</select>
							</label>
							<label class="grid gap-2">
								<span class="text-sm font-medium text-secondary">Printable PDF options</span>
								<select name="pdfOptions" class="texas-plan-control w-full rounded-2xl bg-surface px-4 text-sm text-primary shadow-[inset_0_0_0_1px_var(--border-subtle)] transition-all duration-200 ease-out hover:bg-surface-hover focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent">
									<option>Calendar and parenting plan outline</option>
									<option>Calendar only</option>
									<option>Parenting plan outline only</option>
								</select>
							</label>
							<label class="grid gap-2 sm:col-span-2">
								<span class="text-sm font-medium text-secondary">Notes</span>
								<textarea name="notes" rows="3" placeholder="Add exchange details, school pickup notes, or planning questions." class="w-full rounded-2xl bg-surface px-4 py-2.5 text-sm text-primary shadow-[inset_0_0_0_1px_var(--border-subtle)] transition-all duration-200 ease-out hover:bg-surface-hover focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"></textarea>
							</label>
						</div>
						<p class="texas-distance-notice hidden rounded-xl px-3 py-2 text-xs leading-5 text-secondary" data-distance-notice role="note">
							<span class="font-semibold text-primary">Long-distance rule applied:</span> fewer midweek exchanges and longer possession blocks may be used.
						</p>
						<div class="grid gap-2 sm:flex sm:flex-wrap sm:items-center" data-plan-actions>
							<button type="button" class="btn-primary h-11 w-full px-5 text-sm font-semibold sm:w-auto" data-print-plan>Print / Save PDF</button>
							<CtaButton href="#filing-sequence" variant="secondary" size="small" class="h-11 w-full justify-center sm:w-auto">Filing sequence</CtaButton>
						</div>
					</div>
					<aside class="soft-card grid gap-4 rounded-[1.5rem] p-4 lg:sticky lg:top-24" data-custom-preview>
						<div class="flex items-start justify-between gap-3">
							<div>
								<p class="text-xs font-semibold uppercase tracking-[0.16em] text-muted">Live preview</p>
								<h3 class="mt-1 text-xl font-semibold tracking-[-0.04em] text-primary" data-custom-preview-title>Standard Possession Order</h3>
							</div>
							<span class="shrink-0 rounded-full bg-surface px-3 py-1 text-[11px] font-semibold text-secondary shadow-[inset_0_0_0_1px_var(--border-subtle)]"><span class="text-parent-b" aria-hidden="true">âœ“</span> Auto-updated</span>
						</div>
						<div>
							<p class="text-xs font-semibold text-muted">Start date</p>
							<p class="mt-1 text-sm font-semibold text-primary" data-custom-preview-start>Not selected</p>
						</div>
						<div class="min-w-0" data-texas-calendar-preview>
							<div class="texas-month-nav flex items-center justify-between gap-2">
								<button type="button" class="texas-month-nav-btn" data-calendar-prev aria-label="Previous month">â€¹</button>
								<p class="min-w-0 truncate text-center text-xs font-semibold tracking-[-0.02em] text-primary" data-calendar-month-label>June 2026</p>
								<button type="button" class="texas-month-nav-btn" data-calendar-next aria-label="Next month">â€º</button>
							</div>
							<div class="texas-calendar-legend mt-2 flex flex-wrap items-center gap-x-3 gap-y-1 text-[11px] text-secondary">
								<span class="inline-flex items-center gap-1.5"><i class="h-2 w-2 shrink-0 rounded-full bg-accent" aria-hidden="true"></i><span data-calendar-legend-parent-a>Parent A</span></span>
								<span class="inline-flex items-center gap-1.5"><i class="h-2 w-2 shrink-0 rounded-full bg-parent-b" aria-hidden="true"></i><span data-calendar-legend-parent-b>Parent B</span></span>
							</div>
							<div class="mt-2.5 grid min-w-0 grid-cols-7 gap-1 text-center text-[10px] font-semibold uppercase tracking-[0.08em] text-muted sm:gap-1.5 sm:text-[11px]" aria-hidden="true">
								<span>Mon</span><span>Tue</span><span>Wed</span><span>Thu</span><span>Fri</span><span>Sat</span><span>Sun</span>
							</div>
							<div class="texas-calendar-grid mt-2 grid min-w-0 grid-cols-7 gap-1 sm:gap-1.5" data-custom-preview-calendar></div>
							<ul class="texas-preview-notes mt-1.5 grid max-w-full gap-0.5" data-custom-preview-notes></ul>
						</div>
						<div class="grid gap-2.5 rounded-[1rem] bg-surface/80 p-3 shadow-[inset_0_0_0_1px_var(--border-subtle)]">
							<p class="text-[11px] font-semibold uppercase tracking-[0.16em] text-muted">Parenting time estimate</p>
							<div>
								<div class="flex items-center justify-between gap-2 text-xs font-medium text-secondary">
									<span class="inline-flex min-w-0 items-center gap-1.5 truncate"><i class="h-2 w-2 shrink-0 rounded-full bg-accent" aria-hidden="true"></i><span data-custom-parent-a-label>Parent A</span></span>
									<span class="shrink-0 font-semibold text-primary" data-custom-parent-a-percent>70%</span>
								</div>
								<div class="mt-1.5 h-2 overflow-hidden rounded-full bg-page/80 shadow-[inset_0_0_0_1px_var(--border-subtle)]"><span class="block h-full rounded-full bg-accent" style="width: 70%" data-custom-parent-a-bar></span></div>
								<p class="mt-1 text-[10px] leading-none text-muted" data-custom-parent-a-days>256 annual overnights est.</p>
							</div>
							<div>
								<div class="flex items-center justify-between gap-2 text-xs font-medium text-secondary">
									<span class="inline-flex min-w-0 items-center gap-1.5 truncate"><i class="h-2 w-2 shrink-0 rounded-full bg-parent-b" aria-hidden="true"></i><span data-custom-parent-b-label>Parent B</span></span>
									<span class="shrink-0 font-semibold text-primary" data-custom-parent-b-percent>30%</span>
								</div>
								<div class="mt-1.5 h-2 overflow-hidden rounded-full bg-page/80 shadow-[inset_0_0_0_1px_var(--border-subtle)]"><span class="block h-full rounded-full bg-parent-b" style="width: 30%" data-custom-parent-b-bar></span></div>
								<p class="mt-1 text-[10px] leading-none text-muted" data-custom-parent-b-days>109 annual overnights est.</p>
							</div>
						</div>
