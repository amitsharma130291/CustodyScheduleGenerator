---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import CtaButton from '../components/CtaButton.astro';
import { getCanonicalUrl } from '../lib/seo/metadata';
import {
	buildBreadcrumbSchema,
	buildFAQSchema,
	buildSoftwareApplicationSchema,
	buildWebPageSchema,
} from '../lib/seo/schema';

const title = 'Texas Parenting Plan Template & Standard Possession Order Calendar';
const description =
	'Create a free Texas parenting plan template online. Generate a Standard Possession Order calendar, customize visitation schedules, calculate parenting time, and export a printable PDF.';
const canonical = '/texas-parenting-plan-template/';
const canonicalUrl = getCanonicalUrl(canonical);
const datePublished = '2026-06-17';
const dateModified = '2026-06-17';

const breadcrumbs = [
	{ name: 'Home', url: getCanonicalUrl('/') },
	{ name: 'Templates', url: getCanonicalUrl('/parenting-plan-template/') },
	{ name: 'Texas Parenting Plan Template', url: canonicalUrl },
];

const toc = [
	{ href: '#plan-builder', label: 'Builder' },
	{ href: '#schedule-comparison', label: 'Compare' },
	{ href: '#standard-possession-order', label: 'SPO' },
	{ href: '#texas-spo-calendar', label: 'Calendar' },
	{ href: '#summer-visitation', label: 'Summer' },
	{ href: '#parenting-plan-pdf', label: 'PDF' },
	{ href: '#faq', label: 'FAQ' },
];

const popularScheduleLinks = [
	{ href: '#standard-possession-order', label: 'Standard SPO' },
	{ href: '#expanded-spo', label: 'Expanded SPO' },
	{ href: '#schedule-comparison', label: '50/50 Schedule' },
	{ href: '#schedule-comparison', label: 'Every Other Weekend' },
	{ href: '#summer-visitation', label: 'Summer Visitation' },
	{ href: '#plan-builder', label: 'Parenting Plan Builder' },
	{ href: '#faq', label: 'FAQ' },
];

const statsCards = [
	{ label: 'Most common default schedule', value: 'Standard Possession Order', note: 'The usual starting point for many Texas possession schedules and custody orders.' },
	{ label: 'Typical SPO parenting time', value: 'About 25-35%', note: 'Regular SPO often gives the non-primary parent structured weekends, some weekday time, holidays, and summer possession.' },
	{ label: 'Expanded SPO estimate', value: 'About 40-45%', note: 'Expanded possession can add school-night and school-exchange time when homes are close enough.' },
	{ label: 'Most balanced schedule', value: '50/50 parenting time', note: 'Equal parenting time usually requires stronger logistics, nearby homes, and reliable school routines.' },
];

const custodyComparisonBars = [
	{ key: 'spo', title: 'Standard Possession Order', shortTitle: 'Standard SPO', percent: '30%', value: 30, bestFor: ['Structured weekends', 'Texas default-style schedule', 'Holiday and summer planning'], href: '#plan-builder', cta: 'Generate Texas Parenting Plan' },
	{ key: 'expanded', title: 'Expanded Standard Possession Order', shortTitle: 'Expanded SPO', percent: '42%', value: 42, bestFor: ['More weekday time', 'Nearby homes', 'Fewer Sunday exchanges'], href: '#expanded-spo', cta: 'Compare schedules' },
	{ key: 'fifty', title: '50/50 Schedule', shortTitle: '50/50 Schedule', percent: '50%', value: 50, bestFor: ['Equal parenting time', 'Reliable school routines', 'High cooperation'], href: '/50-50-custody-schedule/', cta: 'Compare schedules' },
	{ key: 'weekend', title: 'Every Other Weekend', shortTitle: 'Every Other Weekend', percent: '25%', value: 25, bestFor: ['Fewer exchanges', 'Simpler weekends', 'Long-distance friendly'], href: '/every-other-weekend-custody-schedule/', cta: 'Compare schedules' },
];

const practicalExamples = [
	{
		title: 'Parents living near the same school',
		copy: 'If both parents live close to the child’s school, a 50/50 or 2-2-5-5 style schedule may be easier to manage because transportation and school-night routines stay predictable.',
	},
	{
		title: 'Parents living more than 100 miles apart',
		copy: 'If parents live far apart, fewer exchanges and longer possession blocks may be more realistic than frequent midweek exchanges. The plan should account for travel time, school calendars, and summer possession.',
	},
	{
		title: 'Younger child with frequent transitions',
		copy: 'For younger children, some parents prefer shorter gaps between visits so the child sees both parents regularly. The calendar preview can help compare whether Standard SPO, Expanded SPO, or a custom schedule feels manageable.',
	},
];

const officialResources = [
	{ title: 'Texas Attorney General parenting time and child support resources', href: 'https://www.texasattorneygeneral.gov/child-support' },
	{ title: 'Texas Law Help custody and visitation resources', href: 'https://texaslawhelp.org/family-divorce-children' },
	{ title: 'Texas Family Code Chapter 153', href: 'https://statutes.capitol.texas.gov/Docs/FA/htm/FA.153.htm' },
	{ title: 'Texas courts forms and rules', href: 'https://www.txcourts.gov/rules-forms/forms/' },
];

const relatedTexasTools = [
	{
		title: 'Texas Child Support Calculator',
		href: '/texas-child-support-calculator/',
		description: 'Estimate child support using Texas guideline-style inputs.',
	},
	{
		title: 'Texas Custody Schedule Calculator',
		href: '/custody-schedule-generator/',
		description: 'Compare parenting schedules, overnights, and calendar patterns.',
	},
	{
		title: 'Texas Parenting Plan Calendar',
		href: '/texas-parenting-plan-template/#plan-builder',
		description: 'Create a printable Texas possession calendar for SPO, expanded SPO, holidays, and summer visitation.',
	},
	{
		title: 'Custody Percentage Calculator',
		href: '/custody-percentage-calculator/',
		description: 'Calculate parenting time percentages and estimated annual overnights.',
	},
];

const decisionPrompts = [
	'Parents live under 100 miles apart',
	'Parents live more than 100 miles apart',
	'Need predictable school weeks',
	'Want equal parenting time',
	'Need fewer exchanges',
];

const decisionResults = [
	{ title: 'Standard SPO', note: 'Best starting point when parents want a familiar Texas standard possession order calendar.', href: '#standard-possession-order' },
	{ title: 'Expanded SPO', note: 'Often fits nearby homes that can handle school exchanges and more weekday contact.', href: '#expanded-spo' },
	{ title: '50/50 Schedule', note: 'Worth comparing when both homes can support school, activities, and transportation.', href: '/50-50-custody-schedule/' },
	{ title: 'Custom Schedule', note: 'Useful when distance, work schedules, or child needs make standard patterns unrealistic.', href: '#plan-builder' },
];

const exampleScenarios = [
	{ situation: 'Parents live 20 miles apart', recommended: 'Expanded Standard Possession Order', why: 'Frequent school-week contact may work without the complexity of exact equal parenting time.', href: '#plan-builder' },
	{ situation: 'Parents live 120 miles apart', recommended: 'Long-distance possession schedule', why: 'Fewer exchanges and longer blocks may work better than frequent school-week handoffs.', href: '#summer-visitation' },
	{ situation: 'Parents live near the same school', recommended: '50/50 or 2-2-5-5 schedule', why: 'School transportation is easier and both homes can support weekday routines.', href: '/50-50-custody-schedule/' },
];

const spoComparisonRows = [
	{ feature: 'Weekends', regular: 'Usually first, third, and fifth weekends beginning Friday evening and ending Sunday evening.', expanded: 'Usually first, third, and fifth weekends beginning after school Friday and ending when school resumes Monday.' },
	{ feature: 'Weekday visits', regular: 'Commonly one weekday evening during the school term.', expanded: 'Often includes an overnight weekday period during the school term when the order allows expanded time.' },
	{ feature: 'Holiday schedule', regular: 'Major holidays alternate or are assigned separately from the regular Texas visitation schedule.', expanded: 'Holiday rules usually stay separate, but expanded weekends can change how transitions feel around school days.' },
	{ feature: 'Summer possession', regular: 'Summer possession is handled separately and can create longer blocks than the school-year weekend schedule.', expanded: 'Summer rules may be similar, but families often use expanded possession to make the regular year feel less weekend-only.' },
	{ feature: 'Exchange times', regular: 'Often evening pickup and Sunday return unless the order says otherwise.', expanded: 'Often tied to school dismissal and school return, which can reduce parent-to-parent exchanges.' },
];

const summerRows = [
	{ distance: '100 miles or less', typical: 'The non-primary parent often receives an extended summer possession period, with notice and election rules depending on the order.', planning: 'Plan the selected summer dates, transportation, notice deadline, and whether the regular weekend schedule pauses or resumes.' },
	{ distance: 'More than 100 miles', typical: 'Long-distance schedules may allow a longer summer block and different spring break or holiday possession rules.', planning: 'Use a Texas custody calendar to map travel time, school dates, notice deadlines, and make-up time before finalizing the plan.' },
	{ distance: 'Holiday conflicts', typical: 'Holidays can override summer possession or require special exchange rules.', planning: 'Write whether holiday time replaces summer time, interrupts it, or is added before/after the summer block.' },
];

const expandedCards = [
	{ title: 'More school-routine time', description: 'Expanded Standard Possession Order Texas schedules can give the non-primary parent more ordinary school mornings, homework nights, and weekday routines than regular SPO.', href: '#plan-builder' },
	{ title: 'Fewer Sunday-night handoffs', description: 'When exchanges happen through school, parents may avoid late Sunday returns and reduce direct handoff friction.', href: '#texas-spo-calendar' },
	{ title: 'Closer to shared parenting', description: 'Expanded possession is not automatically 50/50, but it can feel less like a weekend-only Texas visitation schedule.', href: '/50-50-custody-schedule/' },
	{ title: 'Better for nearby homes', description: 'Expanded possession usually works best when both homes can support school transportation, supplies, activities, and bedtime.', href: '#standard-possession-order' },
];

const scheduleCards = [
	{ title: 'Standard Possession Order', href: '#plan-builder', bestFor: 'Families using a familiar Texas possession schedule with structured weekends, holidays, and summer rules.', cta: 'Generate Texas Parenting Plan' },
	{ title: 'Expanded Standard Possession', href: '#schedule-comparison', bestFor: 'Parents who want more school-routine time and fewer Sunday exchanges when homes are nearby.', cta: 'Compare schedules' },
	{ title: '50/50 Schedule', href: '/50-50-custody-schedule/', bestFor: 'Families comparing equal parenting time schedules such as 2-2-3, 2-2-5-5, and week-on/week-off.', cta: 'Compare schedules' },
	{ title: 'Every Other Weekend Schedule', href: '/every-other-weekend-custody-schedule/', bestFor: 'Parents comparing a simpler alternating weekend visitation pattern against Texas SPO terms.', cta: 'Compare schedules' },
];

const agreementOutline = [
	{ section: 'Parent information', detail: 'Full legal names, contact details, preferred communication method, and emergency contact expectations.' },
	{ section: 'Child information', detail: 'Child names, birthdates, school, medical needs, activity commitments, and any special routines that affect possession.' },
	{ section: 'Weekly schedule', detail: 'Regular Texas custody schedule, start date, pickup time, return time, school-year rules, and how the calendar repeats.' },
	{ section: 'Holidays', detail: 'Thanksgiving, winter break, spring break, birthdays, Mother\'s Day, Father\'s Day, religious holidays, and long weekends.' },
	{ section: 'Summer possession', detail: 'Summer dates, notice deadlines, travel rules, conflicts with holidays, and whether regular weekends continue.' },
	{ section: 'Transportation', detail: 'Pickup parent, drop-off parent, exchange location, late-arrival rules, school exchanges, and travel costs.' },
	{ section: 'Communication rules', detail: 'Parent-to-parent messages, child calls, emergency updates, shared calendar expectations, and response times.' },
	{ section: 'Decision making', detail: 'Medical decisions, school decisions, extracurricular activities, religious decisions, records access, and notice requirements.' },
];

const faq = [
	{ question: 'What is the Standard Possession Order in Texas?', answer: 'The Standard Possession Order, often called SPO, is a common Texas possession schedule that describes regular weekend possession, weekday visits, holidays, and summer possession for the non-primary parent. The exact terms depend on the order and facts of the case.' },
	{ question: 'Is the Standard Possession Order 50/50?', answer: 'No. A regular Texas Standard Possession Order is not usually a 50/50 custody schedule. It normally gives one parent primary weekday time and gives the other parent scheduled weekends, some weekday time, holidays, and summer possession.' },
	{ question: 'What is expanded Standard Possession?', answer: 'Expanded Standard Possession generally gives the non-primary parent more time than regular SPO, often by extending weekend possession around school dismissal and school return and sometimes adding overnight weekday time.' },
	{ question: 'How many days does a parent get in Texas custody?', answer: 'Many parents ask this because they want to know how much time they will actually have with their child. The answer depends on the schedule, holidays, summer possession, distance between homes, and whether the plan uses regular SPO, expanded SPO, 50/50, or a custom schedule. Use the calendar above to estimate annual overnights.' },
	{ question: 'How does summer visitation work in Texas?', answer: 'Texas summer visitation can include an extended summer possession period, notice deadlines, and different rules when parents live more than 100 miles apart. Holidays and travel can affect the exact dates.' },
	{ question: 'Can parents create their own parenting plan?', answer: 'Yes. Parents can often agree to a custom parenting plan if it serves the child and is approved as required. A template can help organize the schedule, holidays, transportation, and decision-making terms before legal review.' },
	{ question: 'Do Texas parenting plans have to follow SPO?', answer: 'Not always. SPO is a common starting point, but parents may use expanded possession, 50/50, every other weekend, or custom arrangements when appropriate and allowed. Local legal guidance is important before relying on any plan.' },
	{ question: 'What happens if parents live more than 100 miles apart?', answer: 'Texas possession schedules can change when parents live more than 100 miles apart. Long-distance plans may use different weekend, spring break, holiday, and summer possession rules to account for travel.' },
	{ question: 'Can I modify a Texas custody agreement?', answer: 'A Texas custody agreement may be modified through the proper legal process when requirements are met. This page can help plan calendar changes, but it is not legal advice or a substitute for court-approved modification guidance.' },
	{ question: 'How do I create a Texas parenting plan?', answer: 'Start by choosing the regular possession schedule, adding holidays and summer possession, defining exchange logistics, listing decision-making rules, and generating a printable calendar. Then review the plan with a qualified professional if it will be used legally.' },
	{ question: 'What should be included in a Texas parenting plan template?', answer: 'A useful Texas parenting plan template should cover the weekly schedule, holidays, summer possession, exchange locations, transportation, communication rules, school and medical decisions, and how parents handle changes. The goal is to make the calendar and written plan specific enough that both parents understand the same routine.' },
	{ question: 'What is a Texas custody calendar?', answer: 'A Texas custody calendar turns plan language into actual dates. Instead of only reading phrases like Standard Possession Order or alternating holidays, parents can see weekends, school breaks, summer possession, and estimated overnights on a visual calendar.' },
	{ question: 'Can I download a Texas parenting plan PDF?', answer: 'Yes. After you choose a schedule and add details, you can print or save the Texas parenting plan preview as a PDF from your browser. It is designed for planning, discussion, mediation prep, or professional review, not as a guaranteed court form.' },
	{ question: 'What is the difference between a Texas parenting plan and a custody agreement?', answer: 'A parenting plan usually describes schedules, decision-making, exchanges, holidays, communication, and parenting responsibilities. A custody agreement may include those terms as part of a broader legal arrangement or court order.' },
	{ question: 'Does a Texas parenting plan include child support?', answer: 'A parenting plan may reference support responsibilities, but child support is usually calculated separately under Texas rules. Use the Texas child support calculator for planning estimates and get qualified guidance for legal questions.' },
	{ question: 'Does parenting time affect child support in Texas?', answer: 'Parenting time may be part of the overall custody and support discussion, but Texas child support also depends on income, number of children, medical support, and other details. Use our Texas child support calculator for an estimate.' },
	{ question: 'Can this replace a lawyer or court form?', answer: 'No. This tool helps you organize a schedule, calendar, and printable planning outline. It does not provide legal advice, replace an attorney, create a court order, or guarantee that a court will accept a plan.' },
];

const schema = [
	buildFAQSchema(faq),
	buildBreadcrumbSchema(breadcrumbs),
	{
		...buildWebPageSchema({ name: title, description, url: canonicalUrl }),
		dateModified,
		lastReviewed: dateModified,
		isAccessibleForFree: true,
	},
	{
		...buildSoftwareApplicationSchema({
			name: 'Texas Parenting Plan Generator',
			description: 'Create a Texas parenting plan, Standard Possession Order calendar, visitation schedule, parenting time estimate, and printable planning document.',
			url: canonicalUrl,
			applicationCategory: 'LegalApplication',
		}),
		operatingSystem: 'Web',
		offers: {
			'@type': 'Offer',
			price: '0',
			priceCurrency: 'USD',
		},
		isAccessibleForFree: true,
		dateModified,
	},
	{
		'@context': 'https://schema.org',
		'@type': 'HowTo',
		name: 'How to create a Texas parenting plan online',
		description: 'Use CustodyBuilder to choose a Texas custody schedule, preview a calendar, add family details, review parenting time, and print or save a parenting plan.',
		totalTime: 'PT5M',
		step: [
			{ '@type': 'HowToStep', name: 'Choose a Texas custody schedule.', text: 'Select Standard SPO, Expanded SPO, 50/50 Schedule, or Every Other Weekend.' },
			{ '@type': 'HowToStep', name: 'Preview the calendar.', text: 'Review the generated Texas custody calendar and schedule pattern.' },
			{ '@type': 'HowToStep', name: 'Add parent and child details.', text: 'Enter parent names, child age, distance, start date, summer possession, holidays, and notes.' },
			{ '@type': 'HowToStep', name: 'Review parenting time.', text: 'Check estimated parenting time percentages and annual overnight estimates.' },
			{ '@type': 'HowToStep', name: 'Print or save the parenting plan.', text: 'Use Print / Save PDF to open the print dialog and print or save as PDF.' },
		],
	},
	{
		'@context': 'https://schema.org',
		'@type': 'Article',
		headline: 'Texas Parenting Plan Template, Calendar & Free Generator',
		description,
		url: canonicalUrl,
		mainEntityOfPage: canonicalUrl,
		inLanguage: 'en-US',
		datePublished,
		dateModified,
		author: {
			'@type': 'Organization',
			name: 'CustodyBuilder Editorial Team',
			url: getCanonicalUrl('/about/'),
		},
		publisher: {
			'@type': 'Organization',
			name: 'CustodyBuilder',
			url: getCanonicalUrl('/'),
			logo: {
				'@type': 'ImageObject',
				url: 'https://custodybuilder.com/logo/custodybuilder-icon-light.svg',
			},
		},
		about: [
			'Texas parenting plan template',
			'Standard Possession Order Texas',
			'Texas custody calendar',
			'Texas visitation schedule',
			'Texas summer visitation schedule',
		],
		isAccessibleForFree: true,
	},
];
---

<BaseLayout title={title} description={description} canonical={canonical} ogTitle="Texas Parenting Plan Template Generator" ogDescription="Create a Texas parenting plan, Standard Possession Order calendar, summer visitation schedule, and printable PDF.">
	<JsonLd slot="head" data={schema} />
	<Navbar />
	<Breadcrumbs items={breadcrumbs} />
	<main class="overflow-x-clip">
		<section class="container-shell grid gap-3 py-4 sm:gap-4 sm:py-5 lg:grid-cols-[minmax(0,0.68fr)_minmax(0,1fr)] lg:items-start lg:gap-8 lg:py-10" id="plan-builder">
			<div class="min-w-0 lg:pt-4">
				<p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">Texas custody planning tool</p>
				<h1 class="mt-2 max-w-4xl text-[1.65rem] font-semibold leading-[1.03] tracking-[-0.055em] text-primary sm:mt-3 sm:text-5xl lg:text-6xl">
					<span class="sm:hidden">Texas Parenting Plan Template & Calendar</span>
					<span class="hidden sm:inline">Texas Parenting Plan Template, Calendar & Free Generator</span>
				</h1>
				<p class="mt-3 max-w-xl text-sm leading-6 text-secondary sm:mt-4 sm:text-base sm:leading-7">
					<span class="sm:hidden">Free generator for Texas SPO, 50/50 schedules, parenting time, and printable PDF.</span>
					<span class="hidden sm:inline">Create a Texas parenting plan in minutes. Choose a schedule, preview the calendar, and estimate parenting time before adding details.</span>
				</p>
				<p class="mt-2 text-xs leading-5 text-muted sm:mt-3">Educational planning tool. Not legal advice.</p>
				<div class="mt-3 inline-flex max-w-xl flex-col gap-1 rounded-2xl bg-surface/80 px-4 py-3 text-xs leading-5 text-secondary shadow-[inset_0_0_0_1px_var(--border-subtle)]">
					<p><span class="font-semibold text-primary">Reviewed by CustodyBuilder Editorial Team</span></p>
					<p>Last updated: June 17, 2026</p>
					<p>Updated for Texas parenting plan, Standard Possession Order, and custody calendar planning.</p>
					<p>Updated when Texas schedule guidance, tool logic, or page examples change.</p>
				</div>
			</div>

			<section class="premium-card relative min-w-0 max-w-full overflow-visible rounded-[1.5rem] border-line p-3 sm:rounded-[2rem] sm:p-4" data-texas-plan-tool>
				<div class="absolute inset-x-10 top-0 h-px bg-gradient-to-r from-transparent via-white/30 to-transparent" aria-hidden="true"></div>
				<div class="min-w-0 max-w-full rounded-[1.25rem] bg-surface-elevated shadow-[inset_0_1px_0_rgba(255,255,255,0.07)] sm:rounded-[1.6rem]">
					<div class="grid gap-3 p-3 sm:p-4" data-texas-plan-form>
						<div class="grid gap-2">
							<div class="flex items-center justify-between gap-3">
								<h2 class="text-lg font-semibold tracking-[-0.04em] text-primary">Build your Texas parenting plan</h2>
								<span class="rounded-full bg-accent/10 px-3 py-1 text-[11px] font-semibold text-accent" data-schedule-chip>Texas SPO</span>
							</div>
							<div class="grid grid-cols-2 gap-2 lg:grid-cols-4" aria-label="Choose schedule">
								{[
									['spo', 'Standard SPO', '30% est.', 'Often used when one parent has the primary residence.'],
									['expanded', 'Expanded SPO', '42% est.', 'More parenting time when homes and school routines are close enough.'],
									['fifty', '50/50 Schedule', '50% est.', 'Best when parents live nearby and can share school transportation.'],
									['weekend', 'Every Other Weekend', '25% est.', 'Simpler option when fewer exchanges or longer distance is needed.'],
								].map(([value, label, help, description], index) => (
									<label class="texas-schedule-option min-w-0 cursor-pointer rounded-2xl bg-surface/80 p-2.5 text-center shadow-[inset_0_0_0_1px_var(--border-subtle)] transition-all duration-200 hover:-translate-y-0.5 hover:bg-surface-hover hover:shadow-[0_10px_24px_rgba(15,23,42,0.06)]">
										<input class="sr-only" type="radio" name="scheduleType" value={value} checked={index === 0} />
										<span class="block text-xs font-semibold leading-4 text-primary sm:text-sm">{label}</span>
										<span class="mt-1 block text-[11px] leading-4 text-muted">{help}</span>
										<span class="mt-1 block text-[10px] leading-4 text-muted">{description}</span>
									</label>
								))}
							</div>
						</div>

						<div class="grid min-w-0 gap-3 rounded-[1.15rem] bg-page/55 p-3 shadow-[inset_0_0_0_1px_var(--border-subtle)]" aria-live="polite">
							<div class="grid min-w-0 gap-3 md:grid-cols-[minmax(0,1fr)_minmax(190px,220px)]">
								<div class="min-w-0 rounded-[1rem] bg-surface/80 p-3 shadow-[inset_0_0_0_1px_var(--border-subtle)]">
									<div class="flex items-start justify-between gap-3">
										<div>
											<p class="text-[11px] font-semibold uppercase tracking-[0.16em] text-muted">Calendar preview</p>
											<h3 class="mt-1 text-lg font-semibold tracking-[-0.04em] text-primary" data-preview-title>Standard Possession Order</h3>
										</div>
										<p class="mt-3 text-xs leading-5 text-muted">
											Parenting time can affect planning conversations. You can also estimate support with the <a href="/texas-child-support-calculator/" class="font-semibold text-accent underline decoration-line underline-offset-4 hover:text-primary">Texas child support calculator</a>.
										</p>
									</div>
									<div class="texas-month-nav mt-3 flex items-center justify-between gap-2">
										<button type="button" class="texas-month-nav-btn" data-calendar-prev aria-label="Previous month">‹</button>
										<p class="min-w-0 truncate text-center text-xs font-semibold tracking-[-0.02em] text-primary" data-calendar-month-label>June 2026</p>
										<button type="button" class="texas-month-nav-btn" data-calendar-next aria-label="Next month">›</button>
									</div>
									<div class="texas-calendar-legend mt-2 flex flex-wrap items-center gap-x-3 gap-y-1 text-[11px] text-secondary">
										<span class="inline-flex items-center gap-1.5"><i class="h-2 w-2 shrink-0 rounded-full bg-accent" aria-hidden="true"></i><span data-calendar-legend-parent-a>Parent A</span></span>
										<span class="inline-flex items-center gap-1.5"><i class="h-2 w-2 shrink-0 rounded-full bg-parent-b" aria-hidden="true"></i><span data-calendar-legend-parent-b>Parent B</span></span>
									</div>
									<div class="mt-2.5 grid min-w-0 grid-cols-7 gap-1 text-center text-[10px] font-semibold uppercase tracking-[0.08em] text-muted sm:gap-1.5 sm:text-[11px]" aria-hidden="true">
										<span>Mon</span><span>Tue</span><span>Wed</span><span>Thu</span><span>Fri</span><span>Sat</span><span>Sun</span>
									</div>
									<div class="texas-calendar-grid mt-2 grid min-w-0 grid-cols-7 gap-1 sm:gap-1.5" data-demo-calendar>
										{Array.from({ length: 35 }, (_, index) => {
											const day = index + 1;
											const parentB = [5, 6, 7, 12, 13, 14, 19, 20, 21].includes(day);
											const isDay = index < 31;
											return (
												<span class:list={[
													isDay ? 'calendar-day-cell texas-calendar-day' : 'texas-calendar-spacer',
													isDay && (parentB ? 'texas-calendar-day-b' : 'texas-calendar-day-a'),
												]} data-calendar-day={day}>
													{isDay ? <span class="leading-none">{day}</span> : null}
												</span>
											);
										})}
									</div>
									<ul class="texas-preview-notes mt-1.5 grid max-w-full gap-0.5" data-tool-calendar-notes></ul>
								</div>
								<div class="grid min-w-0 gap-3">
