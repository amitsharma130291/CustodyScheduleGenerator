		</section>

		<section class="container-shell py-section">
			<div class="premium-card rounded-[2rem] p-6 lg:p-8">
				<h2 class="text-4xl font-semibold leading-[1.05] tracking-[-0.045em] text-primary">Helpful Custody Planning Tools</h2>
				<div class="mt-6 grid gap-4 md:grid-cols-2 xl:grid-cols-3">
					{tools.map((tool) => (
						<a href={tool.href} class="soft-card group rounded-[1.5rem] p-5 transition-all duration-200 hover:-translate-y-0.5 hover:border-accent/40">
							<h3 class="text-lg font-semibold tracking-[-0.03em] text-primary">{tool.title}</h3>
							<p class="mt-2 text-sm leading-6 text-secondary">{tool.description}</p>
							<span class="mt-4 inline-flex text-sm font-semibold text-accent underline decoration-line underline-offset-4 group-hover:text-primary">Open tool</span>
						</a>
					))}
				</div>
			</div>
		</section>

		<section id="faq" class="container-shell py-10 lg:py-12">
			<div class="max-w-3xl">
				<p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">FAQ</p>
				<h2 class="mt-3 text-4xl font-semibold leading-[1.05] tracking-[-0.045em] text-primary">Questions About Custody Schedules for 5-Year-Olds</h2>
			</div>
			<div class="mt-6 grid gap-3">
				{faqItems.map((item) => (
					<details class="soft-card group rounded-[1.35rem] p-5">
						<summary class="cursor-pointer list-none text-base font-semibold text-primary">{item.question}</summary>
						<p class="mt-3 text-sm leading-7 text-secondary">{item.answer}</p>
					</details>
				))}
			</div>
		</section>
	</main>
	<Footer />
</BaseLayout>
