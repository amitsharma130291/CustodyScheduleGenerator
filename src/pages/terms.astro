---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import { getCanonicalUrl } from '../lib/seo/metadata';
import { buildBreadcrumbSchema, buildWebPageSchema } from '../lib/seo/schema';

const title = 'Terms and Conditions | CustodyBuilder';
const description =
	'Read the terms and conditions governing the use of CustodyBuilder and its custody schedule planning tools.';
const canonical = '/terms/';
const canonicalUrl = getCanonicalUrl(canonical);
const breadcrumbs = [
	{ name: 'Home', url: getCanonicalUrl('/') },
	{ name: 'Legal', url: getCanonicalUrl('/disclaimer/') },
	{ name: 'Terms and Conditions', url: canonicalUrl },
];
const sections = [
	{
		title: 'Acceptance of Terms',
		body: 'By using CustodyBuilder, you agree to these terms and conditions. If you do not agree, you should not use the website or its planning tools.',
	},
	{
		title: 'Use of the Website',
		body: 'CustodyBuilder may be used to create, preview, print, and compare custody schedules, parenting calendars, templates, and calculator outputs for personal planning purposes.',
	},
	{
		title: 'Educational Purpose',
		body: 'The website is provided for educational and informational planning. It is intended to help users understand schedule patterns and prepare for more informed parenting-time discussions.',
	},
	{
		title: 'No Legal Advice',
		body: 'CustodyBuilder does not provide legal advice. Information, templates, schedules, calendars, percentages, and examples generated by the website should not be treated as legal guidance.',
	},
	{
		title: 'No Attorney-Client Relationship',
		body: 'Using CustodyBuilder does not create an attorney-client relationship, legal representation, mediation relationship, or professional advisory relationship.',
	},
	{
		title: 'User Responsibility',
		body: 'You are responsible for reviewing all generated schedules, calculations, dates, and planning materials before using them in any discussion, filing, agreement, or decision-making process.',
	},
	{
		title: 'Accuracy of Information',
		body: 'CustodyBuilder aims to provide useful planning outputs, but custody schedules may be affected by local rules, court orders, holidays, school calendars, and personal circumstances.',
	},
	{
		title: 'Third-Party Links',
		body: 'The website may link to other resources for convenience. CustodyBuilder is not responsible for the content, accuracy, availability, or practices of third-party websites.',
	},
	{
		title: 'Limitation of Liability',
		body: 'CustodyBuilder is provided as-is. To the fullest extent permitted by law, CustodyBuilder is not liable for losses, disputes, errors, or decisions arising from use of the website.',
	},
	{
		title: 'Intellectual Property',
		body: 'The CustodyBuilder name, design, content, templates, and planning tools are protected by applicable intellectual property rights and may not be copied or redistributed without permission.',
	},
	{
		title: 'Changes to These Terms',
		body: 'These terms may be updated as CustodyBuilder evolves. Continued use of the website after changes means you accept the updated terms.',
	},
];
const schema = [
	buildBreadcrumbSchema(breadcrumbs),
	buildWebPageSchema({ name: title, description, url: canonicalUrl }),
];
---

<BaseLayout title={title} description={description} canonical={canonical} robots="noindex, follow">
	<JsonLd slot="head" data={schema} />
	<Navbar />
	<Breadcrumbs items={breadcrumbs} />
	<main>
		<section class="container-shell py-12 lg:py-16">
			<div class="mx-auto max-w-3xl">
				<a href="/" class="text-sm font-medium text-muted transition-colors duration-200 hover:text-primary">← Back to CustodyBuilder</a>
				<p class="mt-5 text-xs font-semibold uppercase tracking-[0.18em] text-muted">Legal</p>
				<h1 class="mt-4 text-5xl font-semibold leading-[0.98] tracking-[-0.055em] text-primary lg:text-6xl">
					Terms and Conditions
				</h1>
				<p class="mt-6 text-lg leading-8 text-secondary">
					These terms govern use of CustodyBuilder and its custody schedule planning tools.
				</p>
			</div>

			<div class="premium-card mx-auto mt-8 grid max-w-3xl gap-6 rounded-[1.75rem] p-6 text-base leading-8 text-secondary sm:p-8">
				{sections.map((section) => (
					<section>
						<h2 class="text-2xl font-semibold tracking-[-0.04em] text-primary">{section.title}</h2>
						<p class="mt-3">{section.body}</p>
					</section>
				))}
			</div>
		</section>
	</main>
	<Footer />
</BaseLayout>
