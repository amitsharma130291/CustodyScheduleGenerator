---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import FAQ from '../components/FAQ.astro';
import CtaButton from '../components/CtaButton.astro';
import ScheduleHeroGeneratorPanel from '../components/schedules/ScheduleHeroGeneratorPanel.astro';
import HolidayOverrideStackGraphic from '../components/schedules/holiday-custody-schedule/HolidayOverrideStackGraphic.astro';
import WinterBreakSplitTimelineGraphic from '../components/schedules/holiday-custody-schedule/WinterBreakSplitTimelineGraphic.astro';
import HolidayConflictResolverGraphic from '../components/schedules/holiday-custody-schedule/HolidayConflictResolverGraphic.astro';
import { generateSchedule } from '../lib/schedules/generateSchedule';
import { getDefaultStartDate } from '../lib/schedules/format';
import { getCanonicalUrl } from '../lib/seo/metadata';
import {
	buildArticleSchema,
	buildBreadcrumbSchema,
	buildFAQSchema,
	buildWebPageSchema,
} from '../lib/seo/schema';
import {
	articleTocItems,
	buildCalendar,
	clauses,
	editorialReview,
	faqItems,
	faqSection,
	hero,
	heroKeyStats,
	heroTrustSignals,
	holidaysToName,
	meta,
	orderOfOperations,
	postContentCta,
	visitationRouting,
	whatBreaks,
	whyOverride,
} from '../data/holidayCustodySchedule';

const canonical = '/holiday-custody-schedule/';
const canonicalUrl = getCanonicalUrl(canonical);
const currentYear = new Date().getFullYear();
const startDate = getDefaultStartDate();
const generatedSchedule = generateSchedule({
	scheduleId: '2-2-5-5',
	startDate,
	parentNames: { parentA: 'Parent A', parentB: 'Parent B' },
});

const supportedCountries = [
	{ label: 'United States', value: 'US' },
	{ label: 'Canada', value: 'CA' },
	{ label: 'United Kingdom', value: 'GB' },
	{ label: 'Australia', value: 'AU' },
] as const;

const breadcrumbs = [
	{ name: 'Home', url: getCanonicalUrl('/') },
	{ name: 'Holiday Custody Schedule', url: canonicalUrl },
];

const schema = [
	buildWebPageSchema({ name: meta.title, description: meta.description, url: canonicalUrl }),
	buildArticleSchema({
		headline: hero.headline,
		description: meta.description,
		url: canonicalUrl,
		datePublished: meta.datePublished,
		dateModified: meta.dateModified,
		authorName: editorialReview.reviewer,
	}),
	buildFAQSchema(faqItems),
	buildBreadcrumbSchema(breadcrumbs),
	{
		'@context': 'https://schema.org',
		'@type': 'WebApplication',
		name: 'Holiday Override Calendar Generator',
		description: meta.description,
		url: canonicalUrl,
		inLanguage: 'en-US',
		areaServed: 'US',
		applicationCategory: 'LegalApplication',
		operatingSystem: 'Web',
		offers: {
			'@type': 'Offer',
			price: '0',
			priceCurrency: 'USD',
		},
	},
];
---

<BaseLayout title={meta.title} description={meta.description} canonical={canonical}>
	<JsonLd slot="head" data={schema} />
	<Navbar />
	<Breadcrumbs items={breadcrumbs} />
	<main class="holiday-custody-page">
		<section
			class="container-shell grid grid-cols-1 gap-5 py-4 sm:py-5 lg:grid-cols-[minmax(0,0.88fr)_minmax(704px,1.12fr)] lg:items-start lg:gap-7 lg:py-6 xl:w-[min(100%,1360px)]"
			id="schedule-generator"
		>
			<div class="order-1 min-w-0 lg:col-start-1 lg:row-start-1 lg:pt-1">
				<h1 class="max-w-3xl text-4xl font-semibold leading-[0.98] tracking-[-0.055em] text-primary sm:text-5xl">
					{hero.headline}
				</h1>

				<dl class="mt-4 grid grid-cols-3 gap-2">
					{heroKeyStats.map((stat) => (
						<div class="rounded-[1rem] bg-accent/10 px-2 py-2.5 text-center shadow-[inset_0_0_0_1px_rgba(37,99,235,0.15)] sm:px-3">
							<dd class="text-lg font-bold tabular-nums tracking-tight text-accent sm:text-xl">{stat.value}</dd>
							<dt class="mt-0.5 text-[10px] font-semibold uppercase leading-4 tracking-[0.08em] text-secondary">{stat.label}</dt>
						</div>
					))}
				</dl>

				<p class="mt-3 max-w-2xl text-base leading-7 text-secondary">{hero.intro}</p>
				<p class="mt-3 max-w-2xl text-sm leading-6 text-secondary" set:html={hero.boundary} />

				<div class="mt-3 max-w-2xl text-xs leading-5 text-muted">
					<p class="font-semibold text-secondary">Reviewed for:</p>
					<ul class="mt-1 list-inside list-disc space-y-0.5">
						{editorialReview.reviewedFor.map((item) => (
							<li>{item}</li>
						))}
					</ul>
					<p class="mt-2">
						Reviewed by{' '}
						<a href={editorialReview.reviewerHref} class="font-semibold text-secondary underline decoration-line underline-offset-4 hover:text-primary">
							{editorialReview.reviewer}
						</a>
						{' · '}
						Methodology:{' '}
						<a href={editorialReview.methodologyHref} class="font-semibold text-secondary underline decoration-line underline-offset-4 hover:text-primary">
							{editorialReview.methodologyLabel}
						</a>
						{' · '}{editorialReview.disclaimer}
					</p>
				</div>
			</div>

			<ScheduleHeroGeneratorPanel
				selectedScheduleId="2-2-5-5"
				generatedSchedule={generatedSchedule}
				heroTrustSignals={heroTrustSignals}
			/>
		</section>

		<nav class="container-shell border-y border-line-subtle py-3" aria-label="On this page">
			<ul class="flex flex-wrap gap-x-4 gap-y-1 text-xs font-semibold text-secondary">
				{articleTocItems.map((item) => (
					<li><a href={`#${item.id}`} class="hover:text-accent">{item.label}</a></li>
				))}
			</ul>
		</nav>

		<section id="why-override" class="container-shell scroll-mt-24 py-10 lg:py-12" aria-labelledby="why-override-title">
			<h2 id="why-override-title" class="max-w-3xl text-2xl font-semibold tracking-[-0.04em] text-primary sm:text-3xl">
				{whyOverride.title}
			</h2>
			<p class="mt-3 max-w-3xl text-base leading-7 text-secondary">{whyOverride.intro}</p>
			<p class="mt-3 max-w-3xl text-base leading-7 text-secondary">{whyOverride.body}</p>
		</section>

		<section id="order-of-operations" class="container-shell scroll-mt-24 border-t border-line-subtle py-10 lg:py-12" aria-labelledby="order-of-operations-title">
			<div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_minmax(280px,360px)] lg:items-start">
				<div class="min-w-0">
					<h2 id="order-of-operations-title" class="text-2xl font-semibold tracking-[-0.04em] text-primary sm:text-3xl">
						{orderOfOperations.title}
					</h2>
					<p class="mt-3 text-base leading-7 text-secondary">{orderOfOperations.intro}</p>
					<ol class="mt-6 space-y-5">
						{orderOfOperations.steps.map((step) => (
							<li class="border-l-2 border-accent/30 pl-4">
								<h3 class="text-base font-semibold text-primary">{step.heading}</h3>
								<p class="mt-2 text-sm leading-6 text-secondary">{step.body}</p>
							</li>
						))}
					</ol>
				</div>
				<HolidayOverrideStackGraphic />
			</div>
		</section>

		<section id="what-breaks" class="container-shell scroll-mt-24 border-t border-line-subtle py-10 lg:py-12" aria-labelledby="what-breaks-title">
			<div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_minmax(280px,360px)] lg:items-start">
				<div class="min-w-0">
					<h2 id="what-breaks-title" class="text-2xl font-semibold tracking-[-0.04em] text-primary sm:text-3xl">
						{whatBreaks.title}
					</h2>
					<p class="mt-3 text-base leading-7 text-secondary">{whatBreaks.intro}</p>
					<ul class="mt-6 space-y-4">
						{whatBreaks.breakdowns.map((item) => (
							<li class="rounded-[1rem] bg-surface/50 p-4 ring-1 ring-line-subtle">
								<h3 class="text-base font-semibold text-primary">{item.heading}</h3>
								<p class="mt-2 text-sm leading-6 text-secondary">{item.body}</p>
							</li>
						))}
					</ul>
				</div>
				<HolidayConflictResolverGraphic />
			</div>
		</section>

		<section id="holidays-to-name" class="container-shell scroll-mt-24 border-t border-line-subtle py-10 lg:py-12" aria-labelledby="holidays-to-name-title">
			<div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_minmax(280px,360px)] lg:items-start">
				<div class="min-w-0">
					<h2 id="holidays-to-name-title" class="text-2xl font-semibold tracking-[-0.04em] text-primary sm:text-3xl">
						{holidaysToName.title}
					</h2>
					<p class="mt-3 text-base leading-7 text-secondary">{holidaysToName.intro}</p>
					<ul class="mt-6 space-y-3">
						{holidaysToName.holidays.map((holiday) => (
							<li class="border-l-2 border-accent/30 pl-4">
								<h3 class="text-base font-semibold text-primary">{holiday.name}</h3>
								<p class="mt-1 text-sm leading-6 text-secondary">{holiday.detail}</p>
							</li>
						))}
					</ul>
				</div>
				<WinterBreakSplitTimelineGraphic />
			</div>
		</section>

		<section id="clauses" class="container-shell scroll-mt-24 border-t border-line-subtle py-10 lg:py-12" aria-labelledby="clauses-title">
			<h2 id="clauses-title" class="max-w-3xl text-2xl font-semibold tracking-[-0.04em] text-primary sm:text-3xl">
				{clauses.title}
			</h2>
			<p class="mt-3 max-w-3xl text-base leading-7 text-secondary">{clauses.intro}</p>
			<ul class="mt-6 max-w-3xl space-y-4">
				{clauses.fields.map((field) => (
					<li class="border-l-2 border-accent/30 pl-4">
						<h3 class="text-base font-semibold text-primary">{field.heading}</h3>
						<p class="mt-2 text-sm leading-6 text-secondary">{field.body}</p>
					</li>
				))}
			</ul>
			<p class="mt-6 max-w-3xl text-sm leading-6 text-secondary" set:html={clauses.closing} />
		</section>

		<section id="visitation-routing" class="container-shell scroll-mt-24 border-t border-line-subtle py-10 lg:py-12" aria-labelledby="visitation-routing-title">
			<h2 id="visitation-routing-title" class="max-w-3xl text-2xl font-semibold tracking-[-0.04em] text-primary sm:text-3xl">
				{visitationRouting.title}
			</h2>
			<p class="mt-3 max-w-3xl text-base leading-7 text-secondary">{visitationRouting.intro}</p>
			<ul class="mt-6 max-w-3xl space-y-4">
				{visitationRouting.routes.map((route) => (
					<li class="rounded-[1rem] bg-surface/50 p-4 ring-1 ring-line-subtle">
						<h3 class="text-base font-semibold text-primary">{route.heading}</h3>
						<p class="mt-2 text-sm leading-6 text-secondary" set:html={route.body} />
					</li>
				))}
			</ul>
		</section>

		<section id="build-calendar" class="container-shell scroll-mt-24 border-t border-line-subtle py-10 lg:py-12" aria-labelledby="build-calendar-title">
			<h2 id="build-calendar-title" class="max-w-3xl text-2xl font-semibold tracking-[-0.04em] text-primary sm:text-3xl">
				{buildCalendar.title}
			</h2>
			<p class="mt-3 max-w-3xl text-base leading-7 text-secondary">{buildCalendar.body}</p>

			<div class="mt-8 premium-card rounded-[2rem] p-4 sm:p-5" data-holiday-planner>
				<div class="rounded-[1.5rem] bg-surface-elevated p-4 shadow-[inset_0_1px_0_rgba(255,255,255,0.07)] sm:p-5">
					<p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">Holiday override planner</p>
					<p class="mt-2 text-sm leading-6 text-secondary">Choose override type, year, and parent labels to preview a yearly holiday table on top of your base rotation.</p>

					<form class="mt-5 grid gap-4" data-holiday-custody-form>
						<div class="grid gap-4 sm:grid-cols-2">
							<label class="grid gap-1.5">
								<span class="text-sm font-medium text-secondary">Holiday schedule type</span>
								<select name="scheduleType" aria-label="Holiday schedule type" class="w-full min-w-0 rounded-2xl bg-page px-4 py-2 text-sm text-primary shadow-[inset_0_0_0_1px_var(--border-subtle)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent">
									<option value="alternating">Alternating holidays</option>
									<option value="split">Split holidays</option>
									<option value="fixed">Fixed parent holidays</option>
									<option value="school-break">School break schedule</option>
								</select>
							</label>
							<label class="grid gap-1.5">
								<span class="text-sm font-medium text-secondary">Year</span>
								<input name="year" type="number" min="2024" max="2100" step="1" value={currentYear} aria-label="Holiday schedule year" class="w-full min-w-0 rounded-2xl bg-page px-4 py-2 text-sm text-primary shadow-[inset_0_0_0_1px_var(--border-subtle)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent" />
							</label>
						</div>
						<div class="grid gap-4 sm:grid-cols-2">
							<label class="grid gap-1.5">
								<span class="text-sm font-medium text-secondary">Parent A name</span>
								<input name="parentAName" value="Parent A" aria-label="Parent A name" class="w-full min-w-0 rounded-2xl bg-page px-4 py-2 text-sm text-primary shadow-[inset_0_0_0_1px_var(--border-subtle)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent" />
							</label>
							<label class="grid gap-1.5">
								<span class="text-sm font-medium text-secondary">Parent B name</span>
								<input name="parentBName" value="Parent B" aria-label="Parent B name" class="w-full min-w-0 rounded-2xl bg-page px-4 py-2 text-sm text-primary shadow-[inset_0_0_0_1px_var(--border-subtle)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent" />
							</label>
						</div>
						<label class="grid gap-1.5">
							<span class="text-sm font-medium text-secondary">Region / country</span>
							<select name="country" aria-label="Region or country" class="w-full min-w-0 rounded-2xl bg-page px-4 py-2 text-sm text-primary shadow-[inset_0_0_0_1px_var(--border-subtle)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent">
								{supportedCountries.map((country) => (
									<option value={country.value}>{country.label}</option>
								))}
							</select>
						</label>
					</form>

					<div class="mt-4 rounded-2xl bg-page/55 p-4 shadow-[inset_0_0_0_1px_var(--border-subtle)]" data-holiday-print>
						<div class="flex flex-col gap-3 border-b border-line-subtle pb-3 sm:flex-row sm:items-center sm:justify-between">
							<div>
								<p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">Yearly override preview</p>
								<h3 class="mt-1 text-xl font-semibold tracking-[-0.04em] text-primary" data-holiday-preview-title>
									{currentYear} holiday override table
								</h3>
								<p class="mt-1 text-xs text-muted" data-holiday-preview-subtitle>United States · Alternating holidays</p>
							</div>
						</div>
						<div class="mt-4 overflow-x-auto">
							<table class="w-full min-w-[500px] border-collapse text-left text-sm">
								<thead class="text-xs uppercase tracking-[0.14em] text-muted">
									<tr class="border-b border-line-subtle">
										<th class="py-3 pr-4 font-semibold">Holiday</th>
										<th class="px-4 py-3 font-semibold">Date</th>
										<th class="px-4 py-3 font-semibold">Parenting time</th>
										<th class="hidden py-3 pl-4 font-semibold md:table-cell">Notes</th>
									</tr>
								</thead>
								<tbody class="divide-y divide-line-subtle text-secondary" data-holiday-custody-table></tbody>
							</table>
						</div>
					</div>

					<div class="mt-4 grid w-full min-w-0 grid-cols-1 gap-3 sm:grid-cols-2">
						<button type="button" class="btn-primary flex h-12 w-full min-w-0 items-center justify-center whitespace-nowrap rounded-full px-4 text-sm font-semibold" data-print-holiday-schedule>
							Print override table
						</button>
						<button type="button" class="btn-secondary flex h-12 w-full min-w-0 items-center justify-center whitespace-nowrap rounded-full px-4 text-sm font-semibold" data-copy-holiday-schedule>
							Copy override table
						</button>
					</div>
				</div>
			</div>
		</section>

		<section id="convert-cta" class="container-shell scroll-mt-24 border-t border-line-subtle py-10 lg:py-12" aria-labelledby="convert-cta-title">
			<div class="max-w-2xl rounded-[1.25rem] border border-line bg-surface/40 p-6 sm:p-7">
				<h2 id="convert-cta-title" class="text-2xl font-semibold tracking-[-0.04em] text-primary sm:text-[1.65rem]">
					{postContentCta.heading}
				</h2>
				<p class="mt-3 text-sm leading-6 text-secondary sm:text-base sm:leading-7">{postContentCta.body}</p>
				<div class="mt-5 flex flex-col gap-3 sm:flex-row sm:items-center sm:gap-5">
					<CtaButton href={postContentCta.primaryHref} variant="primary" size="large">
						{postContentCta.primaryLabel}
					</CtaButton>
					<a
						href={postContentCta.secondaryHref}
						class="text-sm font-semibold text-accent underline decoration-line underline-offset-4 hover:text-primary"
					>
						{postContentCta.secondaryLabel}
					</a>
				</div>
			</div>
		</section>

		<FAQ items={faqItems} title={faqSection.title} description={faqSection.description} />
	</main>
	<Footer />
</BaseLayout>

<script>
	const form = document.querySelector('[data-holiday-custody-form]');
	const tableBody = document.querySelector('[data-holiday-custody-table]');
	const previewTitle = document.querySelector('[data-holiday-preview-title]');
	const previewSubtitle = document.querySelector('[data-holiday-preview-subtitle]');
	const copyButton = document.querySelector('[data-copy-holiday-schedule]');
	const printButton = document.querySelector('[data-print-holiday-schedule]');
	const countrySelect = form?.querySelector('select[name="country"]');
	const supportedCountries = [
		{ label: 'United States', value: 'US' },
		{ label: 'Canada', value: 'CA' },
		{ label: 'United Kingdom', value: 'GB' },
		{ label: 'Australia', value: 'AU' },
	];
	const defaultCountry = 'US';

	function normalizeCountry(country) {
		return supportedCountries.some((c) => c.value === country) ? country : defaultCountry;
	}

	function getCountryLabel(country) {
		return supportedCountries.find((c) => c.value === normalizeCountry(country))?.label || 'United States';
	}

	function formatDate(date) {
		return date.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
	}

	function getNthWeekday(year, monthIndex, weekday, nth) {
		const date = new Date(year, monthIndex, 1);
		let count = 0;
		while (date.getMonth() === monthIndex) {
			if (date.getDay() === weekday) {
				count += 1;
				if (count === nth) return new Date(date);
			}
			date.setDate(date.getDate() + 1);
		}
		return new Date(year, monthIndex, 1);
	}

	function getLastWeekday(year, monthIndex, weekday) {
		const date = new Date(year, monthIndex + 1, 0);
		while (date.getDay() !== weekday) date.setDate(date.getDate() - 1);
		return date;
	}

	function getCountryHolidayLabels(country) {
		const labels = {
			US: { newYear: "New Year's Day", winterMondayOne: 'Martin Luther King Jr. Day', winterMondayTwo: 'Presidents’ Day', mayHoliday: 'Memorial Day', midYearHoliday: 'Independence Day', fallHoliday: 'Labor Day', thanksgiving: 'Thanksgiving', christmasEve: 'Christmas Eve', christmasDay: 'Christmas Day', newYearsEve: 'New Year’s Eve' },
			CA: { newYear: "New Year's Day", winterMondayOne: 'Family Day', winterMondayTwo: 'Victoria Day', mayHoliday: 'Civic holiday', midYearHoliday: 'Canada Day', fallHoliday: 'Labor Day', thanksgiving: 'Thanksgiving', christmasEve: 'Christmas Eve', christmasDay: 'Christmas Day', newYearsEve: 'New Year’s Eve' },
			GB: { newYear: "New Year's Day", winterMondayOne: 'Spring bank holiday', winterMondayTwo: 'Summer bank holiday', mayHoliday: 'Early May bank holiday', midYearHoliday: 'School summer break', fallHoliday: 'Autumn half-term', thanksgiving: 'Autumn school break', christmasEve: 'Christmas Eve', christmasDay: 'Christmas Day', newYearsEve: 'New Year’s Eve' },
			AU: { newYear: "New Year's Day", winterMondayOne: 'Australia Day', winterMondayTwo: 'Labor Day', mayHoliday: 'King’s Birthday', midYearHoliday: 'Winter school break', fallHoliday: 'Spring school break', thanksgiving: 'Term break', christmasEve: 'Christmas Eve', christmasDay: 'Christmas Day', newYearsEve: 'New Year’s Eve' },
		};
		return labels[normalizeCountry(country)] || labels.US;
	}

	function getHolidayRows(year, country) {
		const selectedCountry = normalizeCountry(country);
		const labels = getCountryHolidayLabels(selectedCountry);
		const isUS = selectedCountry === 'US';
		const variableDate = 'Date varies by location';
		return [
			{ name: labels.newYear, date: new Date(year, 0, 1), category: 'standard' },
			{ name: labels.winterMondayOne, date: isUS ? getNthWeekday(year, 0, 1, 3) : variableDate, category: 'standard' },
			{ name: labels.winterMondayTwo, date: isUS ? getNthWeekday(year, 1, 1, 3) : variableDate, category: 'standard' },
			{ name: 'Spring break', date: 'School calendar dates vary', category: 'spring-break' },
			{ name: 'Mother’s Day', date: getNthWeekday(year, 4, 0, 2), category: 'mother' },
			{ name: labels.mayHoliday, date: isUS ? getLastWeekday(year, 4, 1) : variableDate, category: 'standard' },
			{ name: 'Father’s Day', date: getNthWeekday(year, 5, 0, 3), category: 'father' },
			{ name: labels.midYearHoliday, date: isUS ? new Date(year, 6, 4) : variableDate, category: 'standard' },
			{ name: 'Child’s birthday', date: "Child’s actual birthday", category: 'child-birthday' },
			{ name: 'Parent A birthday', date: 'Parent A birthday', category: 'parent-a-birthday' },
			{ name: 'Parent B birthday', date: 'Parent B birthday', category: 'parent-b-birthday' },
			{ name: labels.fallHoliday, date: isUS ? getNthWeekday(year, 8, 1, 1) : variableDate, category: 'standard' },
			{ name: labels.thanksgiving, date: isUS ? getNthWeekday(year, 10, 4, 4) : variableDate, category: 'thanksgiving' },
			{ name: labels.christmasEve, date: new Date(year, 11, 24), category: 'christmas-eve' },
			{ name: labels.christmasDay, date: new Date(year, 11, 25), category: 'christmas-day' },
			{ name: 'Winter break', date: 'School calendar dates vary', category: 'winter-break' },
			{ name: labels.newYearsEve, date: new Date(year, 11, 31), category: 'standard' },
		];
	}

	function getAlternatingParent(index, year, parentA, parentB) {
		return (index + year) % 2 === 0 ? parentA : parentB;
	}

	function assignHoliday(row, index, { scheduleType, year, parentA, parentB }) {
		const isEvenYear = year % 2 === 0;
		if (scheduleType === 'split') {
			if (row.category === 'winter-break' || row.category === 'spring-break') return { parent: 'Split schedule', notes: `${parentA}: first half. ${parentB}: second half.` };
			if (row.category === 'christmas-eve' || row.category === 'christmas-day') return { parent: 'Split holiday', notes: 'Morning / afternoon or first half / second half.' };
			return { parent: 'Split holiday', notes: 'Morning / afternoon split. Add exchange time.' };
		}
		if (scheduleType === 'fixed') {
			if (row.category === 'mother') return { parent: parentA, notes: `${parentA} by default.` };
			if (row.category === 'father') return { parent: parentB, notes: `${parentB} by default.` };
			if (row.category === 'parent-a-birthday') return { parent: parentA, notes: `${parentA} birthday.` };
			if (row.category === 'parent-b-birthday') return { parent: parentB, notes: `${parentB} birthday.` };
			if (row.category === 'child-birthday') return { parent: getAlternatingParent(index, year, parentA, parentB), notes: 'Alternate or split birthday time.' };
			return { parent: getAlternatingParent(index, year, parentA, parentB), notes: 'Other holidays alternate yearly between parents.' };
		}
		if (scheduleType === 'school-break') {
			if (row.category === 'spring-break') return { parent: isEvenYear ? parentB : parentA, notes: 'Spring break alternates by year.' };
			if (row.category === 'winter-break') return { parent: 'Split schedule', notes: `${parentA}: first half. ${parentB}: second half.` };
			return { parent: getAlternatingParent(index, year, parentA, parentB), notes: 'Summer break should be planned separately.' };
		}
		if (row.category === 'thanksgiving') return { parent: isEvenYear ? parentB : parentA, notes: `${parentA} in odd-numbered years, ${parentB} in even-numbered years.` };
		if (row.category === 'christmas-day') return { parent: isEvenYear ? parentA : parentB, notes: `${parentB} in odd-numbered years, ${parentA} in even-numbered years.` };
		return { parent: getAlternatingParent(index, year, parentA, parentB), notes: 'Alternates yearly between parents.' };
	}

	function renderPlanner() {
		if (!(form instanceof HTMLFormElement) || !tableBody) return;
		const data = new FormData(form);
		const year = Number(data.get('year')) || new Date().getFullYear();
		const scheduleType = String(data.get('scheduleType') || 'alternating');
		const parentA = String(data.get('parentAName') || 'Parent A');
		const parentB = String(data.get('parentBName') || 'Parent B');
		const selectedCountry = normalizeCountry(String(data.get('country') || defaultCountry));
		if (countrySelect instanceof HTMLSelectElement) countrySelect.value = selectedCountry;
		const region = getCountryLabel(selectedCountry);
		const rows = getHolidayRows(year, selectedCountry).map((row, index) => ({
			...row,
			...assignHoliday(row, index, { scheduleType, year, parentA, parentB }),
		}));

		tableBody.textContent = '';
		rows.forEach((row) => {
			const tr = document.createElement('tr');
			[row.name, row.date instanceof Date ? formatDate(row.date) : row.date, row.parent, row.notes].forEach((text, i) => {
				const td = document.createElement('td');
				td.className = i === 0 ? 'py-3 pr-4 font-semibold text-primary' : i === 3 ? 'hidden py-3 pl-4 text-muted md:table-cell' : 'px-4 py-3';
				if (i === 2) td.className += ' font-medium text-primary';
				td.textContent = text;
				tr.appendChild(td);
			});
			tableBody.appendChild(tr);
		});

		const scheduleLabel = { alternating: 'Alternating holidays', split: 'Split holidays', fixed: 'Fixed parent holidays', 'school-break': 'School break schedule' }[scheduleType] || 'Alternating holidays';
		if (previewTitle) previewTitle.textContent = `${year} holiday override table`;
		if (previewSubtitle) previewSubtitle.textContent = `${region} · ${scheduleLabel}`;
	}

	function buildCopyText() {
		const rows = Array.from(document.querySelectorAll('[data-holiday-custody-table] tr')).map((row) =>
			Array.from(row.querySelectorAll('td')).map((cell) => cell.textContent?.trim() || '').join(' | ')
		);
		return ['Holiday Override Table', ...rows, '', 'Educational planning tool. Not legal advice.'].join('\n');
	}

	form?.addEventListener('input', renderPlanner);
	form?.addEventListener('change', renderPlanner);
	if (countrySelect instanceof HTMLSelectElement) {
		const params = new URLSearchParams(window.location.search);
		const countryFromUrl = params.get('country') || params.get('region');
		countrySelect.value = normalizeCountry(countryFromUrl || countrySelect.value);
	}
	printButton?.addEventListener('click', () => window.print());
	copyButton?.addEventListener('click', async () => {
		if (!(copyButton instanceof HTMLButtonElement)) return;
		const defaultLabel = copyButton.textContent || 'Copy override table';
		try {
			await navigator.clipboard.writeText(buildCopyText());
			copyButton.textContent = 'Copied';
			window.setTimeout(() => { copyButton.textContent = defaultLabel; }, 1800);
		} catch {
			copyButton.textContent = 'Copy failed';
			window.setTimeout(() => { copyButton.textContent = defaultLabel; }, 1800);
		}
	});
	renderPlanner();
</script>
