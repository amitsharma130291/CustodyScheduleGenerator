---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import { getCanonicalUrl } from '../lib/seo/metadata';
import {
	buildBreadcrumbSchema,
	buildFAQSchema,
	buildWebPageSchema,
} from '../lib/seo/schema';

const title = 'Holiday Custody Schedule Calendar | CustodyBuilder';
const description =
	'Create a holiday custody schedule for school breaks, birthdays, and special days. Preview, print, and share a parenting calendar for review.';
const canonical = '/holiday-custody-schedule';
const canonicalUrl = getCanonicalUrl(canonical);
const currentYear = new Date().getFullYear();
const supportedCountries = [
	{ label: 'United States', value: 'US' },
	{ label: 'Canada', value: 'CA' },
	{ label: 'United Kingdom', value: 'GB' },
	{ label: 'Australia', value: 'AU' },
] as const;
const faq = [
	{
		question: 'What is a holiday custody schedule?',
		answer:
			'A holiday custody schedule is a written parenting schedule for holidays, school breaks, long weekends, birthdays, and special days. It explains which parent has the child and when holiday parenting time begins and ends.',
	},
	{
		question: 'Does a holiday schedule override the regular custody schedule?',
		answer:
			'Holiday schedules often take priority over regular parenting schedules. If a holiday is assigned to one parent, that holiday arrangement may override the normal weekly custody schedule until the holiday period ends.',
	},
	{
		question: 'How do parents split Thanksgiving custody?',
		answer:
			'Parents often alternate Thanksgiving by odd- and even-numbered years, split the holiday weekend, or assign Thanksgiving Day to one parent and the rest of the school break to the other. A clear schedule should list exchange times, locations, and travel expectations.',
	},
	{
		question: 'How do parents split Christmas custody?',
		answer:
			'Christmas parenting time can be split by Christmas Eve and Christmas Day, by first half and second half of winter break, or by alternating years. The clearest schedules state when each block starts, when it ends, and how the regular parenting schedule resumes.',
	},
	{
		question: 'Who gets the child on Mother’s Day and Father’s Day?',
		answer:
			'Many holiday custody schedules assign Mother’s Day and Father’s Day to the corresponding parent, regardless of the regular parenting schedule. Families can customize these holidays based on parent labels, family structure, and written agreements.',
	},
	{
		question: 'How are school breaks handled in a custody schedule?',
		answer:
			'School breaks are often alternated, split into halves, or assigned separately from single-day holidays. Spring break may alternate by year, while winter break is often divided into first-half and second-half parenting time blocks.',
	},
	{
		question: 'Can parents customize a holiday custody schedule?',
		answer:
			'Yes. Parents can customize holiday names, exchange times, travel rules, school break divisions, birthday schedules, make-up parenting time, and whether each holiday overrides the regular parenting schedule.',
	},
	{
		question: 'Should exchange times be included in a holiday schedule?',
		answer:
			'Yes. Exchange times help prevent confusion, especially for split holidays, long weekends, winter break, and travel-heavy holidays. A useful schedule should include start time, end time, and pickup or drop-off location.',
	},
	{
		question: 'What happens if a holiday falls on the other parent’s regular day?',
		answer:
			'Many written schedules say holiday parenting time controls when a holiday falls on the other parent’s regular day. Some families add make-up parenting time or simply return to the regular parenting schedule after the holiday ends.',
	},
	{
		question: 'Is this holiday custody schedule legal advice?',
		answer:
			'No. Educational planning tool. Not legal advice. This tool does not replace a court order or advice from a qualified professional. Custody laws and court practices vary by location.',
	},
];
const breadcrumbs = [
	{ name: 'Home', url: getCanonicalUrl('/') },
	{ name: 'Holiday Custody Schedule', url: canonicalUrl },
];
const schema = [
	buildFAQSchema(faq),
	buildBreadcrumbSchema(breadcrumbs),
	buildWebPageSchema({ name: title, description, url: canonicalUrl }),
];
const holidayExamples = [
	{
		title: 'Alternating holidays',
		description: 'Parents alternate major holidays each year so both parents receive important holiday parenting time.',
	},
	{
		title: 'Split Christmas / winter break',
		description: 'Christmas Eve, Christmas Day, or winter break may be divided into two parenting periods.',
	},
	{
		title: 'Thanksgiving rotation',
		description: 'Parents alternate Thanksgiving by year or pair it with the surrounding holiday weekend.',
	},
	{
		title: 'Mother’s Day and Father’s Day',
		description: 'These holidays are often assigned to the matching parent regardless of the normal schedule.',
	},
	{
		title: 'Child birthday schedule',
		description: 'Parents may alternate birthdays, split the day, or provide a short visit for the other parent.',
	},
	{
		title: 'School break custody schedule',
		description: 'School breaks are often alternated or divided into separate parenting periods.',
	},
];
const checklistItems = [
	'Holiday name',
	'Start date and end date',
	'Exchange time',
	'Pickup/drop-off location',
	'Which parent has the child',
	'Whether the holiday overrides the normal schedule',
	'Travel rules',
	'Make-up parenting time',
	'School break rules',
];
const exampleRows = [
	{
		holiday: 'Thanksgiving',
		odd: 'Parent A',
		even: 'Parent B',
		notes: 'Exchange after school Wednesday or Thanksgiving morning.',
	},
	{
		holiday: 'Christmas Eve',
		odd: 'Parent B',
		even: 'Parent A',
		notes: 'Often paired with Christmas morning exchange.',
	},
	{
		holiday: 'Christmas Day',
		odd: 'Parent A',
		even: 'Parent B',
		notes: 'Can override the regular custody schedule.',
	},
	{
		holiday: 'Spring break',
		odd: 'Parent A',
		even: 'Parent B',
		notes: 'Use school calendar dates and clear travel rules.',
	},
];
const relatedTools = [
	{
		title: 'CustodyBuilder Schedule Generator',
		href: '/#generator',
		description: 'Create a regular parenting schedule and compare holiday exceptions.',
	},
	{
		title: '50/50 Custody Schedule',
		href: '/50-50-custody-schedule',
		description: 'Compare equal parenting time schedules and holiday overrides.',
	},
	{
		title: '60/40 Custody Schedule',
		href: '/60-40-custody-schedule',
		description: 'Preview 60/40 schedules and plan holiday parenting time around them.',
	},
	{
		title: '70/30 Custody Schedule',
		href: '/70-30-custody-schedule',
		description: 'Explore majority-time schedules and compare holiday arrangements.',
	},
	{
		title: '80/20 Custody Schedule',
		href: '/80-20-custody-schedule',
		description: 'Explore schedules where one parent has most parenting time and compare holiday arrangements.',
	},
	{
		title: 'Custody Calendar Template',
		href: '/custody-calendar-template',
		description: 'Map parenting time, holidays, and school breaks on a printable calendar.',
	},
	{
		title: 'Custody Schedule Template',
		href: '/custody-schedule-template',
		description: 'Document regular parenting time, holiday exceptions, and exchange details.',
	},
];
---

<BaseLayout title={title} description={description} canonical={canonical}>
	<JsonLd slot="head" data={schema} />
	<Navbar />
	<Breadcrumbs items={breadcrumbs} />
	<main>
		<section class="container-shell grid gap-8 py-12 lg:grid-cols-[0.9fr_1.1fr] lg:items-start lg:py-16">
			<div>
				<p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">Holiday custody schedule tool</p>
				<h1 class="mt-4 max-w-3xl text-5xl font-semibold leading-[0.98] tracking-[-0.055em] text-primary lg:text-6xl">
					Holiday Custody Schedule
				</h1>
				<p class="mt-6 max-w-2xl text-lg leading-8 text-secondary">
					A holiday custody schedule helps parents plan where children spend major holidays, school breaks, long weekends, and special days. Use this holiday custody schedule tool to preview common holiday parenting time arrangements, print a simple custody holiday calendar, and plan around your regular custody schedule.
				</p>
				<div class="mt-8 flex flex-col gap-3 sm:flex-row">
					<a href="#holiday-planner" class="btn-primary inline-flex h-13 w-full items-center justify-center whitespace-nowrap rounded-full px-8 text-base font-semibold transition-all duration-200 ease-out hover:-translate-y-px hover:shadow-[0_10px_30px_rgba(94,106,210,0.14)] active:translate-y-0 sm:w-auto">
						Build Holiday Schedule
					</a>
					<a href="#faq" class="btn-secondary inline-flex h-13 w-full items-center justify-center whitespace-nowrap rounded-full px-8 text-base font-semibold transition-all duration-200 ease-out hover:-translate-y-px hover:shadow-[0_10px_24px_rgba(0,0,0,0.12)] active:translate-y-0 sm:w-auto">
						Read FAQ
					</a>
				</div>
			</div>

			<section id="holiday-planner" class="premium-card rounded-[2rem] p-4 sm:p-5" data-holiday-planner>
				<div class="rounded-[1.5rem] bg-surface-elevated p-4 shadow-[inset_0_1px_0_rgba(255,255,255,0.07)] sm:p-5">
					<p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">Generator</p>
					<h2 class="mt-2 text-2xl font-semibold tracking-[-0.04em] text-primary">Build a holiday custody schedule</h2>
					<p class="mt-2 text-sm leading-6 text-secondary">Choose a holiday parenting schedule type, year, parent names, and region to preview a simple yearly holiday calendar.</p>

					<form class="mt-5 grid gap-4" data-holiday-custody-form>
						<div class="grid gap-4 sm:grid-cols-2">
							<label class="grid gap-1.5">
								<span class="text-sm font-medium text-secondary">Holiday schedule type</span>
								<select name="scheduleType" aria-label="Holiday schedule type" class="w-full min-w-0 rounded-2xl bg-page px-4 py-2 text-sm text-primary shadow-[inset_0_0_0_1px_var(--border-subtle)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent">
									<option value="alternating">Alternating holidays</option>
									<option value="split">Split holidays</option>
									<option value="fixed">Fixed parent holidays</option>
									<option value="school-break">School break schedule</option>
								</select>
							</label>
							<label class="grid gap-1.5">
								<span class="text-sm font-medium text-secondary">Year</span>
								<input name="year" type="number" min="2024" max="2100" step="1" value={currentYear} aria-label="Holiday schedule year" class="w-full min-w-0 rounded-2xl bg-page px-4 py-2 text-sm text-primary shadow-[inset_0_0_0_1px_var(--border-subtle)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent" />
							</label>
						</div>
						<div class="grid gap-4 sm:grid-cols-2">
							<label class="grid gap-1.5">
								<span class="text-sm font-medium text-secondary">Parent A name</span>
								<input name="parentAName" value="Parent A" aria-label="Parent A name" class="w-full min-w-0 rounded-2xl bg-page px-4 py-2 text-sm text-primary shadow-[inset_0_0_0_1px_var(--border-subtle)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent" />
							</label>
							<label class="grid gap-1.5">
								<span class="text-sm font-medium text-secondary">Parent B name</span>
								<input name="parentBName" value="Parent B" aria-label="Parent B name" class="w-full min-w-0 rounded-2xl bg-page px-4 py-2 text-sm text-primary shadow-[inset_0_0_0_1px_var(--border-subtle)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent" />
							</label>
						</div>
						<label class="grid gap-1.5">
							<span class="text-sm font-medium text-secondary">Region / country</span>
							<select name="country" aria-label="Region or country" class="w-full min-w-0 rounded-2xl bg-page px-4 py-2 text-sm text-primary shadow-[inset_0_0_0_1px_var(--border-subtle)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent">
								{supportedCountries.map((country) => (
									<option value={country.value}>{country.label}</option>
								))}
							</select>
							<span class="text-xs leading-5 text-muted">Select a supported country for the holiday preview.</span>
						</label>
					</form>

					<div class="mt-4 rounded-2xl bg-page/55 p-4 shadow-[inset_0_0_0_1px_var(--border-subtle)]" data-holiday-print>
						<div class="flex flex-col gap-3 border-b border-line-subtle pb-3 sm:flex-row sm:items-center sm:justify-between">
							<div>
								<p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">Yearly holiday preview</p>
								<h2 class="mt-1 text-xl font-semibold tracking-[-0.04em] text-primary" data-holiday-preview-title>
									{currentYear} holiday custody schedule
								</h2>
								<p class="mt-1 text-xs text-muted" data-holiday-preview-subtitle>United States · Alternating holidays</p>
							</div>
							<p class="rounded-full bg-surface/70 px-3 py-1.5 text-xs font-medium text-secondary shadow-[inset_0_0_0_1px_var(--border-subtle)]">
								Educational planning tool. Not legal advice.
							</p>
						</div>
						<div class="mt-4 overflow-x-auto">
							<table class="w-full min-w-[500px] border-collapse text-left text-sm">
								<thead class="text-xs uppercase tracking-[0.14em] text-muted">
									<tr class="border-b border-line-subtle">
										<th class="py-3 pr-4 font-semibold">Holiday</th>
										<th class="px-4 py-3 font-semibold">Date</th>
										<th class="px-4 py-3 font-semibold">Parenting time</th>
										<th class="hidden py-3 pl-4 font-semibold md:table-cell">Notes</th>
									</tr>
								</thead>
								<tbody class="divide-y divide-line-subtle text-secondary" data-holiday-custody-table></tbody>
							</table>
						</div>
					</div>

					<div class="mt-4 grid w-full min-w-0 grid-cols-1 gap-3 sm:grid-cols-2">
						<button type="button" class="btn-primary flex h-12 w-full min-w-0 items-center justify-center overflow-hidden text-ellipsis whitespace-nowrap rounded-full px-4 text-sm font-semibold transition-all duration-200 ease-out hover:-translate-y-px hover:shadow-[0_10px_30px_rgba(94,106,210,0.14)] active:translate-y-0 active:scale-[0.99] disabled:cursor-not-allowed disabled:opacity-70 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent" data-print-holiday-schedule>
							Print schedule
						</button>
						<button type="button" class="btn-secondary flex h-12 w-full min-w-0 items-center justify-center overflow-hidden text-ellipsis whitespace-nowrap rounded-full px-4 text-sm font-semibold transition-all duration-200 ease-out hover:-translate-y-px hover:shadow-[inset_0_0_0_1px_color-mix(in_srgb,var(--accent)_28%,var(--border-subtle)),0_10px_24px_rgba(0,0,0,0.12)] active:translate-y-0 active:scale-[0.99] disabled:cursor-not-allowed disabled:opacity-70 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent" data-copy-holiday-schedule>
							Copy schedule
						</button>
					</div>
					<p class="mt-4 text-xs leading-5 text-muted">Educational planning tool. Not legal advice.</p>
				</div>
			</section>
		</section>

		<section class="container-shell grid gap-8 py-12 lg:grid-cols-[0.72fr_1.28fr] lg:py-16">
			<aside class="soft-card h-fit rounded-[1.5rem] p-6">
				<p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">On this page</p>
				<ul class="mt-4 space-y-3 text-sm text-secondary">
					<li><a href="#holiday-planner" class="hover:text-primary">Holiday schedule tool</a></li>
					<li><a href="#how-it-works" class="hover:text-primary">How it works</a></li>
					<li><a href="#examples" class="hover:text-primary">Examples</a></li>
					<li><a href="#include" class="hover:text-primary">What to include</a></li>
					<li><a href="#sample" class="hover:text-primary">Sample table</a></li>
					<li><a href="#regular-vs-holiday" class="hover:text-primary">Holiday vs regular schedule</a></li>
					<li><a href="#faq" class="hover:text-primary">FAQ</a></li>
					<li><a href="#related" class="hover:text-primary">Related tools</a></li>
				</ul>
			</aside>

			<div class="grid gap-10">
				<section id="how-it-works" class="grid gap-4">
					<h2 class="text-3xl font-semibold tracking-[-0.04em] text-primary">How holiday custody schedules work</h2>
					<p class="text-base leading-8 text-secondary">
						Holiday schedules often take priority over regular parenting schedules. If a holiday is assigned to one parent, that holiday arrangement may override the normal weekly custody schedule for the holiday period.
					</p>
					<p class="text-base leading-8 text-secondary">
						This holiday custody schedule tool demonstrates common holiday parenting arrangements, including alternating holidays, split holidays, fixed-parent holidays, and school break schedules. Educational planning tool. Not legal advice. It does not replace court orders, professional guidance, or requirements in your location.
					</p>
				</section>

				<section id="examples" class="grid gap-5">
					<h2 class="text-3xl font-semibold tracking-[-0.04em] text-primary">Common holiday custody schedule examples</h2>
					<div class="grid gap-4 md:grid-cols-3">
						{holidayExamples.map((item) => (
							<article class="soft-card rounded-[1.5rem] p-5">
								<h3 class="text-lg font-semibold tracking-[-0.03em] text-primary">{item.title}</h3>
								<p class="mt-2 text-sm leading-6 text-secondary">{item.description}</p>
							</article>
						))}
					</div>
				</section>

				<section id="include" class="grid gap-5">
					<div>
						<h2 class="text-3xl font-semibold tracking-[-0.04em] text-primary">What to include in a holiday custody schedule</h2>
						<p class="mt-3 text-base leading-8 text-secondary">A clear custody holiday calendar should describe the holiday, the exact time period, and whether the holiday overrides the normal parenting schedule.</p>
					</div>
					<div class="grid gap-3 sm:grid-cols-2">
						{checklistItems.map((item) => (
							<div class="soft-card rounded-2xl p-4 text-sm font-medium text-secondary">{item}</div>
						))}
					</div>
				</section>

				<section id="sample" class="grid gap-5">
					<h2 class="text-3xl font-semibold tracking-[-0.04em] text-primary">Example holiday custody schedule</h2>
					<div class="premium-card overflow-x-auto rounded-[1.5rem]">
						<table class="w-full min-w-[760px] border-collapse text-left text-sm">
							<thead class="text-xs uppercase tracking-[0.14em] text-muted">
								<tr class="border-b border-line-subtle">
									<th class="px-5 py-4 font-semibold">Holiday</th>
									<th class="px-5 py-4 font-semibold">Odd-numbered years</th>
									<th class="px-5 py-4 font-semibold">Even-numbered years</th>
									<th class="px-5 py-4 font-semibold">Exchange notes</th>
								</tr>
							</thead>
							<tbody class="divide-y divide-line-subtle text-secondary">
								{exampleRows.map((row) => (
									<tr>
										<td class="px-5 py-4 font-semibold text-primary">{row.holiday}</td>
										<td class="px-5 py-4">{row.odd}</td>
										<td class="px-5 py-4">{row.even}</td>
										<td class="px-5 py-4">{row.notes}</td>
									</tr>
								))}
							</tbody>
						</table>
					</div>
				</section>

				<section id="regular-vs-holiday" class="grid gap-4">
					<h2 class="text-3xl font-semibold tracking-[-0.04em] text-primary">Holiday custody schedule vs regular custody schedule</h2>
					<p class="text-base leading-8 text-secondary">
						A regular custody schedule explains the weekly or monthly parenting time rotation. A holiday custody schedule explains exceptions for Thanksgiving custody schedules, Christmas custody schedules, school breaks, birthdays, and other special days.
					</p>
					<p class="text-base leading-8 text-secondary">
						Use a <a href="/custody-schedule-template" class="font-medium text-primary hover:text-accent">custody schedule template</a> for the regular rotation, then use a holiday custody schedule to list overrides and special exchange details.
					</p>
				</section>

				<section id="faq" class="grid gap-5">
					<h2 class="text-3xl font-semibold tracking-[-0.04em] text-primary">FAQ</h2>
					<div class="premium-card divide-y divide-line-subtle overflow-hidden rounded-[1.5rem]">
						{faq.map((item, index) => (
							<details open={index === 0} class="group p-5 transition-colors duration-200 open:bg-surface-elevated/70 hover:bg-surface-hover/60">
								<summary class="flex cursor-pointer list-none items-center justify-between gap-6 text-left text-base font-semibold tracking-[-0.02em] text-primary">
									{item.question}
									<span class="grid h-7 w-7 shrink-0 place-items-center rounded-full bg-surface/80 text-muted shadow-[inset_0_0_0_1px_var(--border-subtle)] transition-transform duration-200 group-open:rotate-45">+</span>
								</summary>
								<p class="mt-4 text-sm leading-6 text-secondary">{item.answer}</p>
							</details>
						))}
					</div>
				</section>

				<section id="related" class="grid gap-5">
					<h2 class="text-3xl font-semibold tracking-[-0.04em] text-primary">Related tools and schedules</h2>
					<div class="grid gap-4 md:grid-cols-2">
						{relatedTools.map((item) => (
							<a href={item.href} class="soft-card rounded-[1.5rem] p-5">
								<h3 class="text-lg font-semibold tracking-[-0.03em] text-primary">{item.title}</h3>
								<p class="mt-2 text-sm leading-6 text-secondary">{item.description}</p>
							</a>
						))}
					</div>
				</section>
			</div>
		</section>
	</main>
	<Footer />
</BaseLayout>

<script>
	const form = document.querySelector('[data-holiday-custody-form]');
	const tableBody = document.querySelector('[data-holiday-custody-table]');
	const previewTitle = document.querySelector('[data-holiday-preview-title]');
	const previewSubtitle = document.querySelector('[data-holiday-preview-subtitle]');
	const copyButton = document.querySelector('[data-copy-holiday-schedule]');
	const printButton = document.querySelector('[data-print-holiday-schedule]');
	const countrySelect = form?.querySelector('select[name="country"]');
	const supportedCountries = [
		{ label: 'United States', value: 'US' },
		{ label: 'Canada', value: 'CA' },
		{ label: 'United Kingdom', value: 'GB' },
		{ label: 'Australia', value: 'AU' },
	];
	const defaultCountry = 'US';

	function normalizeCountry(country) {
		return supportedCountries.some((supportedCountry) => supportedCountry.value === country) ? country : defaultCountry;
	}

	function getCountryLabel(country) {
		const selectedCountry = normalizeCountry(country);
		return supportedCountries.find((supportedCountry) => supportedCountry.value === selectedCountry)?.label || 'United States';
	}

	function formatDate(date) {
		return date.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
	}

	function getNthWeekday(year, monthIndex, weekday, nth) {
		const date = new Date(year, monthIndex, 1);
		let count = 0;
		while (date.getMonth() === monthIndex) {
			if (date.getDay() === weekday) {
				count += 1;
				if (count === nth) return new Date(date);
			}
			date.setDate(date.getDate() + 1);
		}
		return new Date(year, monthIndex, 1);
	}

	function getLastWeekday(year, monthIndex, weekday) {
		const date = new Date(year, monthIndex + 1, 0);
		while (date.getDay() !== weekday) {
			date.setDate(date.getDate() - 1);
		}
		return date;
	}

	function getCountryHolidayLabels(country) {
		const labels = {
			US: {
				newYear: "New Year's Day",
				winterMondayOne: 'Martin Luther King Jr. Day',
				winterMondayTwo: 'Presidents’ Day',
				mayHoliday: 'Memorial Day',
				midYearHoliday: 'Independence Day',
				fallHoliday: 'Labor Day',
				thanksgiving: 'Thanksgiving',
				christmasEve: 'Christmas Eve',
				christmasDay: 'Christmas Day',
				newYearsEve: 'New Year’s Eve',
			},
			CA: {
				newYear: "New Year's Day",
				winterMondayOne: 'Family Day',
				winterMondayTwo: 'Victoria Day',
				mayHoliday: 'Civic holiday',
				midYearHoliday: 'Canada Day',
				fallHoliday: 'Labor Day',
				thanksgiving: 'Thanksgiving',
				christmasEve: 'Christmas Eve',
				christmasDay: 'Christmas Day',
				newYearsEve: 'New Year’s Eve',
			},
			GB: {
				newYear: "New Year's Day",
				winterMondayOne: 'Spring bank holiday',
				winterMondayTwo: 'Summer bank holiday',
				mayHoliday: 'Early May bank holiday',
				midYearHoliday: 'School summer break',
				fallHoliday: 'Autumn half-term',
				thanksgiving: 'Autumn school break',
				christmasEve: 'Christmas Eve',
				christmasDay: 'Christmas Day',
				newYearsEve: 'New Year’s Eve',
			},
			AU: {
				newYear: "New Year's Day",
				winterMondayOne: 'Australia Day',
				winterMondayTwo: 'Labor Day',
				mayHoliday: 'King’s Birthday',
				midYearHoliday: 'Winter school break',
				fallHoliday: 'Spring school break',
				thanksgiving: 'Term break',
				christmasEve: 'Christmas Eve',
				christmasDay: 'Christmas Day',
				newYearsEve: 'New Year’s Eve',
			},
		};

		return labels[normalizeCountry(country)] || labels.US;
	}

	function getHolidayRows(year, country) {
		const selectedCountry = normalizeCountry(country);
		const labels = getCountryHolidayLabels(selectedCountry);
		const isUnitedStates = selectedCountry === 'US';
		const variableDate = 'Date varies by location';

		return [
			{ name: labels.newYear, date: new Date(year, 0, 1), category: 'standard' },
			{ name: labels.winterMondayOne, date: isUnitedStates ? getNthWeekday(year, 0, 1, 3) : variableDate, category: 'standard' },
			{ name: labels.winterMondayTwo, date: isUnitedStates ? getNthWeekday(year, 1, 1, 3) : variableDate, category: 'standard' },
			{ name: 'Spring break', date: 'School calendar dates vary', category: 'spring-break' },
			{ name: 'Mother’s Day', date: getNthWeekday(year, 4, 0, 2), category: 'mother' },
			{ name: labels.mayHoliday, date: isUnitedStates ? getLastWeekday(year, 4, 1) : variableDate, category: 'standard' },
			{ name: 'Father’s Day', date: getNthWeekday(year, 5, 0, 3), category: 'father' },
			{ name: labels.midYearHoliday, date: isUnitedStates ? new Date(year, 6, 4) : variableDate, category: 'standard' },
			{ name: 'Child’s birthday', date: "Child’s actual birthday", category: 'child-birthday' },
			{ name: 'Parent A birthday', date: 'Parent A birthday', category: 'parent-a-birthday' },
			{ name: 'Parent B birthday', date: 'Parent B birthday', category: 'parent-b-birthday' },
			{ name: labels.fallHoliday, date: isUnitedStates ? getNthWeekday(year, 8, 1, 1) : variableDate, category: 'standard' },
			{ name: labels.thanksgiving, date: isUnitedStates ? getNthWeekday(year, 10, 4, 4) : variableDate, category: 'thanksgiving' },
			{ name: labels.christmasEve, date: new Date(year, 11, 24), category: 'christmas-eve' },
			{ name: labels.christmasDay, date: new Date(year, 11, 25), category: 'christmas-day' },
			{ name: 'Winter break', date: 'School calendar dates vary', category: 'winter-break' },
			{ name: labels.newYearsEve, date: new Date(year, 11, 31), category: 'standard' },
		];
	}

	function getAlternatingParent(index, year, parentA, parentB) {
		return (index + year) % 2 === 0 ? parentA : parentB;
	}

	function assignHoliday(row, index, { scheduleType, year, parentA, parentB }) {
		const isEvenYear = year % 2 === 0;

		if (scheduleType === 'split') {
			if (row.category === 'winter-break') return { parent: 'Split schedule', notes: `${parentA}: first half. ${parentB}: second half.` };
			if (row.category === 'spring-break') return { parent: 'Split schedule', notes: `${parentA}: first half. ${parentB}: second half.` };
			if (row.category === 'christmas-eve' || row.category === 'christmas-day') return { parent: 'Split holiday', notes: 'Morning / afternoon or first half / second half.' };
			return { parent: 'Split holiday', notes: 'Morning / afternoon split. Add exchange time.' };
		}

		if (scheduleType === 'fixed') {
			if (row.category === 'mother') return { parent: parentA, notes: `${parentA} by default.` };
			if (row.category === 'father') return { parent: parentB, notes: `${parentB} by default.` };
			if (row.category === 'parent-a-birthday') return { parent: parentA, notes: `${parentA} birthday.` };
			if (row.category === 'parent-b-birthday') return { parent: parentB, notes: `${parentB} birthday.` };
			if (row.category === 'child-birthday') return { parent: getAlternatingParent(index, year, parentA, parentB), notes: 'Alternate or split birthday time.' };
			return { parent: getAlternatingParent(index, year, parentA, parentB), notes: 'Other holidays alternate yearly between parents.' };
		}

		if (scheduleType === 'school-break') {
			if (row.category === 'spring-break') return { parent: isEvenYear ? parentB : parentA, notes: 'Spring break alternates by year.' };
			if (row.category === 'winter-break') return { parent: 'Split schedule', notes: `${parentA}: first half. ${parentB}: second half.` };
			return { parent: getAlternatingParent(index, year, parentA, parentB), notes: 'Summer break should be planned separately.' };
		}

		if (row.category === 'thanksgiving') return { parent: isEvenYear ? parentB : parentA, notes: `${parentA} in odd-numbered years, ${parentB} in even-numbered years.` };
		if (row.category === 'christmas-day') return { parent: isEvenYear ? parentA : parentB, notes: `${parentB} in odd-numbered years, ${parentA} in even-numbered years.` };
		return { parent: getAlternatingParent(index, year, parentA, parentB), notes: 'Alternates yearly between parents.' };
	}

	function renderPlanner() {
		if (!(form instanceof HTMLFormElement) || !tableBody) return;

		const data = new FormData(form);
		const year = Number(data.get('year')) || new Date().getFullYear();
		const scheduleType = String(data.get('scheduleType') || 'alternating');
		const parentA = String(data.get('parentAName') || 'Parent A');
		const parentB = String(data.get('parentBName') || 'Parent B');
		const selectedCountry = normalizeCountry(String(data.get('country') || defaultCountry));
		if (countrySelect instanceof HTMLSelectElement) countrySelect.value = selectedCountry;
		const region = getCountryLabel(selectedCountry);
		const rows = getHolidayRows(year, selectedCountry).map((row, index) => ({
			...row,
			...assignHoliday(row, index, { scheduleType, year, parentA, parentB }),
		}));

		tableBody.textContent = '';
		rows.forEach((row) => {
			const tr = document.createElement('tr');
			const holidayCell = document.createElement('td');
			const dateCell = document.createElement('td');
			const parentCell = document.createElement('td');
			const notesCell = document.createElement('td');

			holidayCell.className = 'py-3 pr-4 font-semibold text-primary';
			dateCell.className = 'px-4 py-3';
			parentCell.className = 'px-4 py-3 font-medium text-primary';
			notesCell.className = 'hidden py-3 pl-4 text-muted md:table-cell';

			holidayCell.textContent = row.name;
			dateCell.textContent = row.date instanceof Date ? formatDate(row.date) : row.date;
			parentCell.textContent = row.parent;
			notesCell.textContent = row.notes;

			tr.append(holidayCell, dateCell, parentCell, notesCell);
			tableBody.appendChild(tr);
		});

		const scheduleLabel = {
			'alternating': 'Alternating holidays',
			'split': 'Split holidays',
			'fixed': 'Fixed parent holidays',
			'school-break': 'School break schedule',
		}[scheduleType] || 'Alternating holidays';

		if (previewTitle) previewTitle.textContent = `${year} holiday custody schedule`;
		if (previewSubtitle) previewSubtitle.textContent = `${region} · ${scheduleLabel}`;
	}

	function buildCopyText() {
		const rows = Array.from(document.querySelectorAll('[data-holiday-custody-table] tr')).map((row) =>
			Array.from(row.querySelectorAll('td')).map((cell) => cell.textContent?.trim() || '').join(' | ')
		);
		return ['Holiday Custody Schedule', ...rows, '', 'Educational planning tool. Not legal advice.'].join('\n');
	}

	form?.addEventListener('input', renderPlanner);
	form?.addEventListener('change', renderPlanner);
	if (countrySelect instanceof HTMLSelectElement) {
		const params = new URLSearchParams(window.location.search);
		const countryFromUrl = params.get('country') || params.get('region');
		countrySelect.value = normalizeCountry(countryFromUrl || countrySelect.value);
	}
	printButton?.addEventListener('click', () => window.print());
	copyButton?.addEventListener('click', async () => {
		if (!(copyButton instanceof HTMLButtonElement)) return;
		const defaultLabel = copyButton.textContent || 'Copy schedule';
		try {
			await navigator.clipboard.writeText(buildCopyText());
			copyButton.textContent = 'Copied';
			window.setTimeout(() => {
				copyButton.textContent = defaultLabel;
			}, 1800);
		} catch {
			copyButton.textContent = 'Copy failed';
			window.setTimeout(() => {
				copyButton.textContent = defaultLabel;
			}, 1800);
		}
	});
	renderPlanner();
</script>
