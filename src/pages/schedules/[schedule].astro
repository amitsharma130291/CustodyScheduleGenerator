---
import SchedulePageTemplate from '../../components/pages/SchedulePageTemplate.astro';
import { schedules } from '../../content/schedules';

export function getStaticPaths() {
	return schedules
		.filter((schedule) => !['5-2-2-5-custody-schedule', '2-2-5-5-custody-schedule', '80-20-custody-schedule', '70-30-custody-schedule', '60-40-custody-schedule', '50-50-custody-schedule'].includes(schedule.slug))
		.map((schedule) => ({
			params: { schedule: schedule.slug },
			props: {
				schedule: {
					...schedule,
					href: `/${schedule.slug}/`,
				},
			},
		}));
}

const { schedule } = Astro.props;
---

<SchedulePageTemplate schedule={schedule} />
