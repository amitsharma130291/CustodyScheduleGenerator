---
import SchedulePageTemplate from '../components/pages/SchedulePageTemplate.astro';
import { schedules } from '../content/schedules';

export function getStaticPaths() {
	return schedules.map((schedule) => ({
		params: { schedule: schedule.slug },
		props: { schedule },
	}));
}

const { schedule } = Astro.props;
---

<SchedulePageTemplate schedule={schedule} />
