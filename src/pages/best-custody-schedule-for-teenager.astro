---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import FAQ from '../components/FAQ.astro';
import CtaButton from '../components/CtaButton.astro';
import ScheduleHeroGeneratorPanel from '../components/schedules/ScheduleHeroGeneratorPanel.astro';
import DrivingAgeTimelineGraphic from '../components/schedules/best-custody-schedule-for-teenager/DrivingAgeTimelineGraphic.astro';
import TeenSchedulePressureMapGraphic from '../components/schedules/best-custody-schedule-for-teenager/TeenSchedulePressureMapGraphic.astro';
import IndependenceLadderGraphic from '../components/schedules/best-custody-schedule-for-teenager/IndependenceLadderGraphic.astro';
import { generateSchedule } from '../lib/schedules/generateSchedule';
import { getDefaultStartDate } from '../lib/schedules/format';
import { getCanonicalUrl } from '../lib/seo/metadata';
import {
	buildArticleSchema,
	buildBreadcrumbSchema,
	buildFAQSchema,
	buildWebPageSchema,
} from '../lib/seo/schema';
import {
	articleTocItems,
	calendarIndependence,
	differentGuide,
	editorialReview,
	faqItems,
	faqSection,
	hero,
	heroKeyStats,
	heroTrustSignals,
	jobsSports,
	meta,
	outgrowSchedule,
	parentingPlanFlexibility,
	postContentCta,
	revisitMoments,
	transportation,
} from '../data/bestCustodyScheduleForTeenager';

const canonical = '/best-custody-schedule-for-teenager/';
const canonicalUrl = getCanonicalUrl(canonical);
const startDate = getDefaultStartDate();
const generatedSchedule = generateSchedule({
	scheduleId: 'week-on-week-off',
	startDate,
	parentNames: { parentA: 'Parent A', parentB: 'Parent B' },
});

const breadcrumbs = [
	{ name: 'Home', url: getCanonicalUrl('/') },
	{ name: 'Custody Schedule By Age', url: getCanonicalUrl('/custody-schedule-by-age/') },
	{ name: 'Custody Schedule for a Teenager', url: canonicalUrl },
];

const schema = [
	buildWebPageSchema({ name: meta.title, description: meta.description, url: canonicalUrl }),
	buildArticleSchema({
		headline: hero.headline,
		description: meta.description,
		url: canonicalUrl,
		datePublished: meta.datePublished,
		dateModified: meta.dateModified,
		authorName: editorialReview.reviewer,
	}),
	buildFAQSchema(faqItems),
	buildBreadcrumbSchema(breadcrumbs),
	{
		'@context': 'https://schema.org',
		'@type': 'WebApplication',
		name: 'Teen Custody Schedule Calendar Generator',
		description: meta.description,
		url: canonicalUrl,
		inLanguage: 'en-US',
		areaServed: 'US',
		applicationCategory: 'LegalApplication',
		operatingSystem: 'Web',
		offers: {
			'@type': 'Offer',
			price: '0',
			priceCurrency: 'USD',
		},
	},
];
---

<BaseLayout title={meta.title} description={meta.description} canonical={canonical}>
	<JsonLd slot="head" data={schema} />
	<Navbar />
	<Breadcrumbs items={breadcrumbs} />
	<main class="teenager-page">
		<section
			class="container-shell grid grid-cols-1 gap-5 py-4 sm:py-5 lg:grid-cols-[minmax(0,0.88fr)_minmax(704px,1.12fr)] lg:items-start lg:gap-7 lg:py-6 xl:w-[min(100%,1360px)]"
			id="schedule-generator"
		>
			<div class="order-1 min-w-0 lg:col-start-1 lg:row-start-1 lg:pt-1">
				<h1 class="max-w-3xl text-4xl font-semibold leading-[0.98] tracking-[-0.055em] text-primary sm:text-5xl">
					{hero.headline}
				</h1>

				<dl class="mt-4 grid grid-cols-3 gap-2">
					{heroKeyStats.map((stat) => (
						<div class="rounded-[1rem] bg-accent/10 px-2 py-2.5 text-center shadow-[inset_0_0_0_1px_rgba(37,99,235,0.15)] sm:px-3">
							<dd class="text-lg font-bold tabular-nums tracking-tight text-accent sm:text-xl">{stat.value}</dd>
							<dt class="mt-0.5 text-[10px] font-semibold uppercase leading-4 tracking-[0.08em] text-secondary">{stat.label}</dt>
						</div>
					))}
				</dl>

				<p class="mt-3 max-w-2xl text-base leading-7 text-secondary">{hero.intro}</p>
				<p class="mt-3 max-w-2xl text-sm leading-6 text-secondary" set:html={hero.boundary} />

				<div class="mt-3 max-w-2xl text-xs leading-5 text-muted">
					<p class="font-semibold text-secondary">Reviewed for:</p>
					<ul class="mt-1 list-inside list-disc space-y-0.5">
						{editorialReview.reviewedFor.map((item) => (
							<li>{item}</li>
						))}
					</ul>
					<p class="mt-2">
						Reviewed by{' '}
						<a href={editorialReview.reviewerHref} class="font-semibold text-secondary underline decoration-line underline-offset-4 hover:text-primary">
							{editorialReview.reviewer}
						</a>
						{' · '}
						Methodology:{' '}
						<a href={editorialReview.methodologyHref} class="font-semibold text-secondary underline decoration-line underline-offset-4 hover:text-primary">
							{editorialReview.methodologyLabel}
						</a>
						{' · '}{editorialReview.disclaimer}
					</p>
				</div>
			</div>

			<ScheduleHeroGeneratorPanel
				selectedScheduleId="week-on-week-off"
				generatedSchedule={generatedSchedule}
				heroTrustSignals={heroTrustSignals}
			/>
		</section>

		<nav class="container-shell border-y border-line-subtle py-3" aria-label="On this page">
			<ul class="flex flex-wrap gap-x-4 gap-y-1 text-xs font-semibold text-secondary">
				{articleTocItems.map((item) => (
					<li><a href={`#${item.id}`} class="hover:text-accent">{item.label}</a></li>
				))}
			</ul>
		</nav>

		<section id="transportation" class="container-shell scroll-mt-24 py-10 lg:py-12" aria-labelledby="transportation-title">
			<div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_minmax(260px,320px)] lg:items-start">
				<div class="min-w-0">
					<h2 id="transportation-title" class="text-2xl font-semibold tracking-[-0.04em] text-primary sm:text-3xl">
						{transportation.title}
					</h2>
					<p class="mt-3 text-base leading-7 text-secondary">{transportation.intro}</p>
					<div class="mt-6 space-y-5">
						{transportation.points.map((item) => (
							<article>
								<h3 class="text-base font-semibold text-primary">{item.heading}</h3>
								<p class="mt-2 text-sm leading-6 text-secondary" set:html={item.body} />
							</article>
						))}
					</div>
				</div>
				<DrivingAgeTimelineGraphic />
			</div>
		</section>

		<section id="calendar-independence" class="container-shell scroll-mt-24 border-t border-line-subtle py-10 lg:py-12" aria-labelledby="calendar-independence-title">
			<div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_minmax(280px,360px)] lg:items-start">
				<div class="min-w-0">
					<h2 id="calendar-independence-title" class="text-2xl font-semibold tracking-[-0.04em] text-primary sm:text-3xl">
						{calendarIndependence.title}
					</h2>
					<p class="mt-3 text-base leading-7 text-secondary">{calendarIndependence.intro}</p>
					<div class="mt-6 space-y-5">
						{calendarIndependence.observations.map((item) => (
							<article class="border-l-2 border-accent/30 pl-4">
								<h3 class="text-base font-semibold text-primary">{item.heading}</h3>
								<p class="mt-2 text-sm leading-6 text-secondary" set:html={item.body} />
							</article>
						))}
					</div>
				</div>
				<IndependenceLadderGraphic />
			</div>
		</section>

		<section id="jobs-sports" class="container-shell scroll-mt-24 border-t border-line-subtle py-10 lg:py-12" aria-labelledby="jobs-sports-title">
			<div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_minmax(280px,360px)] lg:items-start">
				<div class="min-w-0">
					<h2 id="jobs-sports-title" class="text-2xl font-semibold tracking-[-0.04em] text-primary sm:text-3xl">
						{jobsSports.title}
					</h2>
					<p class="mt-3 text-base leading-7 text-secondary">{jobsSports.intro}</p>
					<ul class="mt-6 space-y-5">
						{jobsSports.pressures.map((item) => (
							<li>
								<h3 class="text-base font-semibold text-primary">{item.heading}</h3>
								<p class="mt-2 text-sm leading-6 text-secondary">{item.body}</p>
							</li>
						))}
					</ul>
				</div>
				<TeenSchedulePressureMapGraphic />
			</div>
		</section>

		<section id="revisit-moments" class="container-shell scroll-mt-24 border-t border-line-subtle py-10 lg:py-12" aria-labelledby="revisit-moments-title">
			<h2 id="revisit-moments-title" class="max-w-3xl text-2xl font-semibold tracking-[-0.04em] text-primary sm:text-3xl">
				{revisitMoments.title}
			</h2>
			<p class="mt-3 max-w-3xl text-base leading-7 text-secondary">{revisitMoments.intro}</p>
			<ol class="mt-6 max-w-3xl space-y-0">
				{revisitMoments.moments.map((item, index) => (
					<li class="relative flex gap-4 pb-6 last:pb-0">
						{index < revisitMoments.moments.length - 1 && (
							<span class="absolute left-[0.6875rem] top-8 h-[calc(100%-1.5rem)] w-px bg-line" aria-hidden="true"></span>
						)}
						<span class="relative z-10 flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-accent/15 text-xs font-bold text-accent ring-1 ring-accent/30">
							{index + 1}
						</span>
						<article class="min-w-0 pt-0.5">
							<h3 class="text-base font-semibold text-primary">{item.heading}</h3>
							<p class="mt-2 text-sm leading-6 text-secondary" set:html={item.body} />
						</article>
					</li>
				))}
			</ol>
		</section>

		<section id="parenting-plan" class="container-shell scroll-mt-24 border-t border-line-subtle py-10 lg:py-12" aria-labelledby="parenting-plan-title">
			<h2 id="parenting-plan-title" class="max-w-3xl text-2xl font-semibold tracking-[-0.04em] text-primary sm:text-3xl">
				{parentingPlanFlexibility.title}
			</h2>
			<p class="mt-3 max-w-3xl text-base leading-7 text-secondary">{parentingPlanFlexibility.intro}</p>
			<ul class="mt-6 max-w-3xl space-y-5">
				{parentingPlanFlexibility.clauses.map((item) => (
					<li class="border-l-2 border-line pl-4">
						<h3 class="text-base font-semibold text-primary">{item.heading}</h3>
						<p class="mt-2 text-sm leading-6 text-secondary" set:html={item.body} />
					</li>
				))}
			</ul>
			<p class="mt-6 max-w-3xl text-sm leading-6 text-secondary" set:html={parentingPlanFlexibility.closing} />
		</section>

		<section id="outgrow" class="container-shell scroll-mt-24 border-t border-line-subtle py-10 lg:py-12" aria-labelledby="outgrow-title">
			<h2 id="outgrow-title" class="max-w-3xl text-2xl font-semibold tracking-[-0.04em] text-primary sm:text-3xl">
				{outgrowSchedule.title}
			</h2>
			<p class="mt-3 max-w-3xl text-base leading-7 text-secondary">{outgrowSchedule.intro}</p>
			<div class="mt-6 max-w-3xl space-y-5">
				{outgrowSchedule.points.map((item) => (
					<article>
						<h3 class="text-base font-semibold text-primary">{item.heading}</h3>
						<p class="mt-2 text-sm leading-6 text-secondary" set:html={item.body} />
					</article>
				))}
			</div>
		</section>

		<section id="different-guide" class="container-shell scroll-mt-24 border-t border-line-subtle py-10 lg:py-12" aria-labelledby="different-guide-title">
			<h2 id="different-guide-title" class="max-w-3xl text-2xl font-semibold tracking-[-0.04em] text-primary sm:text-3xl">
				{differentGuide.title}
			</h2>
			<div class="mt-6 max-w-3xl space-y-4 text-base leading-7 text-secondary">
				{differentGuide.paragraphs.map((paragraph) => (
					<p set:html={paragraph} />
				))}
			</div>
		</section>

		<section id="convert-cta" class="container-shell scroll-mt-24 border-t border-line-subtle py-10 lg:py-12" aria-labelledby="convert-cta-title">
			<div class="max-w-2xl rounded-[1.25rem] border border-line bg-surface/40 p-6 sm:p-7">
				<h2 id="convert-cta-title" class="text-2xl font-semibold tracking-[-0.04em] text-primary sm:text-[1.65rem]">
					{postContentCta.heading}
				</h2>
				<p class="mt-3 text-sm leading-6 text-secondary sm:text-base sm:leading-7">{postContentCta.body}</p>
				<div class="mt-5 flex flex-col gap-3 sm:flex-row sm:items-center sm:gap-5">
					<CtaButton href={postContentCta.primaryHref} variant="primary" size="large">
						{postContentCta.primaryLabel}
					</CtaButton>
					<a
						href={postContentCta.secondaryHref}
						class="text-sm font-semibold text-accent underline decoration-line underline-offset-4 hover:text-primary"
					>
						{postContentCta.secondaryLabel}
					</a>
				</div>
			</div>
		</section>

		<FAQ items={faqItems} title={faqSection.title} description={faqSection.description} />
	</main>
	<Footer />
</BaseLayout>
