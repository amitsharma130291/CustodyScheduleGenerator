---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import { getCanonicalUrl } from '../lib/seo/metadata';
import { buildBreadcrumbSchema, buildWebPageSchema } from '../lib/seo/schema';

const title = 'Contact CustodyBuilder | Custody Planning Tools';
const description =
	'Contact CustodyBuilder about custody schedule planning tools, printable parenting calendars, and site feedback.';
const canonical = '/contact/';
const canonicalUrl = getCanonicalUrl(canonical);
const breadcrumbs = [
	{ name: 'Home', url: getCanonicalUrl('/') },
	{ name: 'Contact', url: canonicalUrl },
];
const schema = [
	buildBreadcrumbSchema(breadcrumbs),
	buildWebPageSchema({ name: title, description, url: canonicalUrl }),
];
---

<BaseLayout title={title} description={description} canonical={canonical}>
	<JsonLd slot="head" data={schema} />
	<Navbar />
	<Breadcrumbs items={breadcrumbs} />
	<main>
		<section class="container-shell py-12 lg:py-16">
			<div class="mx-auto max-w-3xl">
				<a href="/" class="text-sm font-medium text-muted transition-colors duration-200 hover:text-primary">← Back to CustodyBuilder</a>
				<p class="mt-5 text-xs font-semibold uppercase tracking-[0.18em] text-muted">Contact</p>
				<h1 class="mt-4 text-5xl font-semibold leading-[0.98] tracking-[-0.055em] text-primary lg:text-6xl">
					Contact CustodyBuilder
				</h1>
				<p class="mt-6 text-lg leading-8 text-secondary">
					Have feedback about the custody schedule generator or a question about using CustodyBuilder planning tools? Send a note to <a href="mailto:hello@custodybuilder.com" class="font-semibold text-accent underline decoration-line underline-offset-4">hello@custodybuilder.com</a>.
				</p>
			</div>

			<div class="premium-card mx-auto mt-8 grid max-w-3xl gap-6 rounded-[1.75rem] p-6 text-base leading-8 text-secondary sm:p-8">
				<section>
					<h2 class="text-2xl font-semibold tracking-[-0.04em] text-primary">What to Include</h2>
					<p class="mt-3">
						If you are reporting a site issue, include the page URL, what you expected to happen, and what happened instead. For feature ideas, describe the custody planning task you were trying to complete.
					</p>
				</section>

				<section>
					<h2 class="text-2xl font-semibold tracking-[-0.04em] text-primary">Planning Tools Only</h2>
					<p class="mt-3">
						CustodyBuilder provides planning tools and educational information only. It does not provide legal advice, review individual cases, create court orders, or replace guidance from a qualified family law professional.
					</p>
				</section>
			</div>
		</section>
	</main>
	<Footer />
</BaseLayout>
