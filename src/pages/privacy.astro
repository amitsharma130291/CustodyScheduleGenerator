---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import { getCanonicalUrl } from '../lib/seo/metadata';
import { buildBreadcrumbSchema, buildWebPageSchema } from '../lib/seo/schema';

const title = 'Privacy Policy for CustodyBuilder Tools | CustodyBuilder';
const description =
	'Read the CustodyBuilder privacy policy for custody schedule tools, calendar templates, local schedule data, analytics use, privacy, and updates.';
const canonical = '/privacy/';
const canonicalUrl = getCanonicalUrl(canonical);
const breadcrumbs = [
	{ name: 'Home', url: getCanonicalUrl('/') },
	{ name: 'Legal', url: getCanonicalUrl('/disclaimer/') },
	{ name: 'Privacy Policy', url: canonicalUrl },
];
const schema = [
	buildBreadcrumbSchema(breadcrumbs),
	buildWebPageSchema({ name: title, description, url: canonicalUrl }),
];
---

<BaseLayout title={title} description={description} canonical={canonical} robots="noindex, follow">
	<JsonLd slot="head" data={schema} />
	<Navbar />
	<Breadcrumbs items={breadcrumbs} />
	<main>
		<section class="container-shell py-12 lg:py-16">
			<div class="mx-auto max-w-3xl">
				<a href="/" class="text-sm font-medium text-muted transition-colors duration-200 hover:text-primary">← Back to CustodyBuilder</a>
				<p class="mt-5 text-xs font-semibold uppercase tracking-[0.18em] text-muted">Legal</p>
				<h1 class="mt-4 text-5xl font-semibold leading-[0.98] tracking-[-0.055em] text-primary lg:text-6xl">
					Privacy Policy
				</h1>
				<p class="mt-6 text-lg leading-8 text-secondary">
					CustodyBuilder is an educational planning tool for creating custody schedules, parenting time calendars, and printable planning materials.
				</p>
			</div>

			<p class="mx-auto mt-4 max-w-3xl text-sm text-muted">Last updated: 3 July 2026</p>

			<div class="premium-card mx-auto mt-8 grid max-w-3xl gap-6 rounded-[1.75rem] p-6 text-base leading-8 text-secondary sm:p-8">
				<section>
					<h2 class="text-2xl font-semibold tracking-[-0.04em] text-primary">Overview</h2>
					<p class="mt-3">
						CustodyBuilder is a free, browser-based tool for building custody schedules and parenting time calendars. This policy explains what data we collect, the cookies we use, and the third parties involved. We keep collection to a minimum: the schedules you build stay in your browser, and the only third-party service we run is website analytics.
					</p>
				</section>

				<section>
					<h2 class="text-2xl font-semibold tracking-[-0.04em] text-primary">Analytics and Cookies We Use</h2>
					<p class="mt-3">
						CustodyBuilder uses <strong>Google Analytics 4</strong> (measurement ID <code>G-ZEM3ECSRZH</code>) to understand how visitors use the site so we can improve it. Google Analytics sets cookies (for example <code>_ga</code> and <code>_ga_*</code>) and processes information such as the pages you view, approximate location (derived from your IP address, which Google does not report to us in full), device and browser type, referring page, and how you interact with the tools.
					</p>
					<p class="mt-3">
						Analytics is loaded through Google Consent Mode. When you first visit, analytics cookies are set to <strong>denied</strong> by default and no analytics cookies are stored until you choose <em>Accept</em> in our cookie banner. If you decline, Google Analytics does not store cookies on your device. You can change your mind at any time by clearing this site's data in your browser, which will show the banner again.
					</p>
					<p class="mt-3">
						Google acts as our data processor for analytics. Your use of Google Analytics is also governed by Google's terms. To learn how Google uses data from sites that use its services, see
						<a href="https://policies.google.com/privacy" class="font-semibold text-accent underline decoration-line underline-offset-4 hover:text-primary" rel="noopener noreferrer" target="_blank">Google's Privacy Policy</a>
						and
						<a href="https://policies.google.com/technologies/partner-sites" class="font-semibold text-accent underline decoration-line underline-offset-4 hover:text-primary" rel="noopener noreferrer" target="_blank">How Google uses information from sites that use its services</a>.
					</p>
				</section>

				<section>
					<h2 class="text-2xl font-semibold tracking-[-0.04em] text-primary">Advertising</h2>
					<p class="mt-3">
						CustodyBuilder does not currently show ads. If we introduce advertising in the future, third-party vendors, including Google, may use cookies to serve ads based on your prior visits to this or other websites. Any advertising we add will be disclosed here and gated behind the same consent choice described above. You can review and control how Google personalises ads to you at
						<a href="https://policies.google.com/technologies/ads" class="font-semibold text-accent underline decoration-line underline-offset-4 hover:text-primary" rel="noopener noreferrer" target="_blank">Google Ads Settings and ad technologies</a>.
					</p>
				</section>

				<section>
					<h2 class="text-2xl font-semibold tracking-[-0.04em] text-primary">Schedule Data You Enter</h2>
					<p class="mt-3">
						The schedules, dates, and parent labels you enter are processed <strong>in your browser</strong> to generate calendars, overnight percentages, print views, and PDF exports. We do not send this information to a server or store it on our systems. Some values, such as your theme preference and your cookie choice, are saved in your browser's local storage, and schedule details may be encoded into share links (URL parameters) if you choose to copy or share a calendar.
					</p>
				</section>

				<section>
					<h2 class="text-2xl font-semibold tracking-[-0.04em] text-primary">Your Choices</h2>
					<p class="mt-3">
						You can decline analytics cookies from the banner, block or delete cookies in your browser settings, and use browser or Google tools to opt out of Google Analytics. Declining does not affect your ability to build schedules or export PDFs, as those features run entirely in your browser.
					</p>
				</section>

				<section>
					<h2 class="text-2xl font-semibold tracking-[-0.04em] text-primary">Personal Information</h2>
					<p class="mt-3">
						We do not sell personal information, and we do not ask you to create an account or submit personal details to use the tools.
					</p>
				</section>

				<section>
					<h2 class="text-2xl font-semibold tracking-[-0.04em] text-primary">Contact and Updates</h2>
					<p class="mt-3">
						If you have questions about this policy, please reach us through our
						<a href="/contact/" class="font-semibold text-accent underline decoration-line underline-offset-4 hover:text-primary">contact page</a>.
						We may update this privacy policy as CustodyBuilder evolves; when we do, we will revise the "Last updated" date above.
					</p>
				</section>
			</div>
		</section>
	</main>
	<Footer />
</BaseLayout>
