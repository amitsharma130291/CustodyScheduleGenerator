---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import FAQ from '../components/FAQ.astro';
import CtaButton from '../components/CtaButton.astro';
import ArticleTOC from '../components/ArticleTOC.astro';
import GeneratorPanel from '../components/tool/GeneratorPanel.astro';
import CalendarPreview from '../components/tool/CalendarPreview.astro';
import ExportActions from '../components/tool/ExportActions.astro';
import { generateSchedule } from '../lib/schedules/generateSchedule';
import { getDefaultStartDate } from '../lib/schedules/format';
import { getCanonicalUrl } from '../lib/seo/metadata';
import {
	buildArticleSchema,
	buildBreadcrumbSchema,
	buildFAQSchema,
	buildWebPageSchema,
} from '../lib/seo/schema';
import {
	articleTocItems,
	builderHelp,
	calendarGlance,
	editorialReview,
	faqItems,
	hero,
	heroTrustSignals,
	meta,
	mistakes,
	planLanguage,
	primaryHomeLoad,
	thirtyPercentNotVisitor,
	transitions,
	weekInFamily,
} from '../data/seventyThirtyCustodySchedule';

const canonical = '/70-30-custody-schedule/';
const canonicalUrl = getCanonicalUrl(canonical);
const startDate = getDefaultStartDate();
const generatedSchedule = generateSchedule({
	scheduleId: '70-30',
	startDate,
	parentNames: { parentA: 'Parent A', parentB: 'Parent B' },
});

const breadcrumbs = [
	{ name: 'Home', url: getCanonicalUrl('/') },
	{ name: 'Schedules', url: getCanonicalUrl('/custody-schedule-generator/') },
	{ name: '70/30 Custody Schedule', url: canonicalUrl },
];

const schema = [
	buildWebPageSchema({ name: meta.title, description: meta.description, url: canonicalUrl }),
	buildArticleSchema({
		headline: hero.headline,
		description: meta.description,
		url: canonicalUrl,
		datePublished: meta.datePublished,
		dateModified: meta.dateModified,
		authorName: editorialReview.reviewer,
	}),
	buildFAQSchema(faqItems),
	buildBreadcrumbSchema(breadcrumbs),
	{
		'@context': 'https://schema.org',
		'@type': 'WebApplication',
		name: '70/30 Custody Schedule Calendar Generator',
		description: meta.description,
		url: canonicalUrl,
		inLanguage: 'en-US',
		areaServed: 'US',
		applicationCategory: 'LegalApplication',
		operatingSystem: 'Web',
		offers: {
			'@type': 'Offer',
			price: '0',
			priceCurrency: 'USD',
		},
	},
	{
		'@context': 'https://schema.org',
		'@type': 'HowTo',
		name: 'How to create a 70/30 Custody Schedule',
		description: 'Use the custody calendar generator to preview, compare, and export a 70/30 parenting schedule.',
		inLanguage: 'en-US',
		totalTime: 'PT5M',
		step: [
			{
				'@type': 'HowToStep',
				name: 'Choose the 70/30 schedule type',
				text: 'Select 70/30 Custody Schedule in the generator.',
			},
			{
				'@type': 'HowToStep',
				name: 'Pick a pattern and start date',
				text: 'Compare every weekend, alternating weekends plus a weekday overnight, and monthly weekend rules.',
			},
			{
				'@type': 'HowToStep',
				name: 'Review overnight percentages',
				text: 'Check the monthly calendar and generated annual average before exporting or printing.',
			},
		],
	},
];
---

<BaseLayout title={meta.title} description={meta.description} canonical={canonical}>
	<JsonLd slot="head" data={schema} />
	<Navbar />
	<Breadcrumbs items={breadcrumbs} />
	<main>
		<section
			class="container-shell grid grid-cols-1 gap-5 py-4 sm:py-5 lg:grid-cols-[minmax(0,0.88fr)_minmax(704px,1.12fr)] lg:items-start lg:gap-7 lg:py-6 xl:w-[min(100%,1360px)]"
			id="schedule-generator"
		>
			<div class="order-1 min-w-0 lg:col-start-1 lg:row-start-1 lg:pt-1">
				<p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">70/30 calendar generator</p>
				<h1 class="mt-2.5 max-w-3xl text-4xl font-semibold leading-[0.98] tracking-[-0.055em] text-primary sm:text-5xl">
					{hero.headline}
				</h1>
				{hero.intro.map((paragraph) => (
					<p class="mt-3 max-w-2xl text-base leading-7 text-secondary">{paragraph}</p>
				))}
			</div>

			<div class="order-2 min-w-0 lg:col-start-2 lg:row-span-2 lg:row-start-1 lg:justify-self-end" id="schedule-generator-panel">
				<div class="premium-card relative overflow-visible rounded-[1.75rem] border-line p-3 sm:rounded-[2rem] sm:p-4">
					<div class="hero-generator-inner rounded-[1.25rem] bg-surface-elevated p-0 shadow-[inset_0_1px_0_rgba(255,255,255,0.07)] sm:rounded-[1.5rem]">
						<div class="hero-generator-grid generator-shell grid grid-cols-1 items-start gap-4 xl:grid-cols-[minmax(360px,1fr)_240px]">
							<div class="generator-form-panel min-w-0">
								<GeneratorPanel selectedScheduleId="70-30" compact />
							</div>
							<div class="hero-calendar-column calendar-preview-panel grid w-full min-w-0 gap-2 xl:w-[240px] xl:min-w-[240px]">
								<CalendarPreview schedule={generatedSchedule}>
									<ExportActions slot="actions" />
								</CalendarPreview>
							</div>
						</div>
					</div>
					<div class="mt-3 flex flex-wrap gap-2 text-xs font-semibold text-secondary" aria-label="CustodyBuilder trust signals">
						{heroTrustSignals.map((signal) => (
							<span class="inline-flex items-center gap-1.5 rounded-full bg-surface/70 px-3 py-1.5 shadow-[inset_0_0_0_1px_var(--border-subtle)]">
								<span class="text-parent-b" aria-hidden="true">✓</span>
								{signal}
							</span>
						))}
					</div>
				</div>
			</div>

			<div class="order-3 min-w-0 lg:col-start-1 lg:row-start-2">
				<section id="calendar-glance" class="soft-card scroll-mt-24 rounded-[1.25rem] p-4" aria-labelledby="calendar-glance-title">
					<div class="flex flex-wrap items-baseline justify-between gap-2">
						<h2 id="calendar-glance-title" class="text-sm font-semibold tracking-[-0.03em] text-primary">
							{calendarGlance.title}
						</h2>
						<p class="text-xs font-semibold text-accent">{calendarGlance.overnightSplit}</p>
					</div>
					<div class="mt-3 overflow-x-auto">
						{calendarGlance.weeks.map((week, weekIndex) => (
							<div>
								<p class="mb-2 text-[11px] font-semibold uppercase tracking-[0.12em] text-muted">{calendarGlance.weekLabels[weekIndex]}</p>
								<table class="w-full min-w-[280px] border-collapse text-center text-sm">
									<thead>
										<tr>
											{calendarGlance.dayLabels.map((day) => (
												<th class="px-1 py-1.5 text-[10px] font-semibold uppercase tracking-[0.1em] text-muted">{day}</th>
											))}
										</tr>
									</thead>
									<tbody>
										<tr>
											{week.map((parent) => (
												<td class="px-1 py-1.5">
													<span
														class:list={[
															'inline-flex h-7 w-7 items-center justify-center rounded-md text-[11px] font-bold',
															parent === 'A'
																? 'bg-accent/15 text-accent'
																: 'bg-surface/80 text-secondary shadow-[inset_0_0_0_1px_var(--border-subtle)]',
														]}
													>
														{parent}
													</span>
												</td>
											))}
										</tr>
									</tbody>
								</table>
							</div>
						))}
					</div>
					<p class="mt-3 text-xs leading-5 text-secondary" set:html={calendarGlance.notes[0]} />
					<div class="mt-3 flex flex-wrap gap-3 text-[11px] font-medium text-muted">
						<span><span class="font-semibold text-accent">A</span> = primary home</span>
						<span><span class="font-semibold text-secondary">B</span> = 30% parent block</span>
					</div>
				</section>

				<p class="mt-3 text-xs leading-5 text-muted">
					Not legal advice.
					<a href="/disclaimer/" class="ml-1 font-semibold text-secondary underline decoration-line underline-offset-4 hover:text-primary">Read disclaimer</a>
				</p>
			</div>
		</section>

		<section id="editorial-review" class="container-shell pb-5">
			<div class="max-w-3xl rounded-2xl bg-page/70 p-4 text-sm leading-6 text-secondary shadow-[inset_0_0_0_1px_var(--border-subtle)]">
				<p>
					<strong class="text-primary">Last reviewed: {editorialReview.lastReviewed}</strong>
					<br />
					Reviewed by:{' '}
					<a href={editorialReview.reviewerHref} class="font-semibold text-accent underline decoration-line underline-offset-4 hover:text-primary">
						{editorialReview.reviewer}
					</a>
				</p>
				<p class="mt-2">{editorialReview.body}</p>
			</div>
		</section>

		<ArticleTOC items={articleTocItems} />

		<section id="week-in-family" class="container-shell scroll-mt-24 pb-section" aria-labelledby="week-in-family-title">
			<div class="max-w-3xl">
				<p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">Real-life 70/30</p>
				<h2 id="week-in-family-title" class="mt-3 text-3xl font-semibold tracking-[-0.04em] text-primary sm:text-4xl">
					{weekInFamily.title}
				</h2>
				<p class="mt-2 text-lg font-medium text-secondary">{weekInFamily.subtitle}</p>
				<p class="mt-4 text-base leading-7 text-secondary">{weekInFamily.intro}</p>
			</div>
			<div class="mt-8 max-w-3xl space-y-6">
				{weekInFamily.days.map((item) => (
					<article class="soft-card rounded-[1.5rem] p-5">
						<p class="text-xs font-semibold uppercase tracking-[0.14em] text-accent">{item.day}</p>
						<h3 class="mt-2 text-xl font-semibold tracking-[-0.03em] text-primary">{item.heading}</h3>
						<p class="mt-3 text-base leading-7 text-secondary">{item.body}</p>
					</article>
				))}
				<p class="mt-4 text-base leading-7 text-secondary" set:html={weekInFamily.close} />
			</div>
		</section>

		<section id="thirty-percent-not-visitor" class="container-shell scroll-mt-24 py-section" aria-labelledby="thirty-percent-not-visitor-title">
			<div class="max-w-3xl">
				<p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">30% parent connection</p>
				<h2 id="thirty-percent-not-visitor-title" class="mt-3 text-3xl font-semibold tracking-[-0.04em] text-primary sm:text-4xl">
					{thirtyPercentNotVisitor.title}
				</h2>
				<p class="mt-4 text-base leading-7 text-secondary">{thirtyPercentNotVisitor.intro}</p>
			</div>
			<div class="mt-8 max-w-3xl space-y-6">
				{thirtyPercentNotVisitor.problems.map((item) => (
					<article>
						<h3 class="text-xl font-semibold tracking-[-0.03em] text-primary">{item.problem}</h3>
						<p class="mt-3 text-base leading-7 text-secondary">{item.body}</p>
					</article>
				))}
				<div class="soft-card rounded-[1.5rem] p-5">
					<p class="text-sm font-semibold text-primary">Practical fixes</p>
					<ul class="mt-3 space-y-2 text-sm leading-6 text-secondary">
						{thirtyPercentNotVisitor.solutions.map((solution) => (
							<li class="flex gap-2">
								<span class="text-accent" aria-hidden="true">→</span>
								{solution}
							</li>
						))}
					</ul>
				</div>
				<p class="text-base leading-7 text-secondary" set:html={thirtyPercentNotVisitor.close} />
			</div>
		</section>

		<section id="primary-home-load" class="container-shell scroll-mt-24 py-section" aria-labelledby="primary-home-load-title">
			<div class="max-w-3xl">
				<p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">Primary-home parent</p>
				<h2 id="primary-home-load-title" class="mt-3 text-3xl font-semibold tracking-[-0.04em] text-primary sm:text-4xl">
					{primaryHomeLoad.title}
				</h2>
				<p class="mt-4 text-base leading-7 text-secondary">{primaryHomeLoad.intro}</p>
			</div>
			<div class="mt-8 max-w-3xl space-y-6">
				{primaryHomeLoad.tasks.map((task) => (
					<article>
						<h3 class="text-xl font-semibold tracking-[-0.03em] text-primary">{task.heading}</h3>
						<p class="mt-3 text-base leading-7 text-secondary">{task.body}</p>
					</article>
				))}
				<div class="soft-card rounded-[1.5rem] p-5">
					<p class="text-sm font-semibold text-primary">Systems that prevent resentment</p>
					<ul class="mt-3 space-y-2 text-sm leading-6 text-secondary">
						{primaryHomeLoad.systems.map((item) => (
							<li class="flex gap-2">
								<span class="text-accent" aria-hidden="true">•</span>
								{item}
							</li>
						))}
					</ul>
				</div>
				<p class="text-base leading-7 text-secondary">{primaryHomeLoad.close}</p>
			</div>
		</section>

		<section id="transitions" class="container-shell scroll-mt-24 py-section" aria-labelledby="transitions-title">
			<div class="max-w-3xl">
				<p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">Schedule changes</p>
				<h2 id="transitions-title" class="mt-3 text-3xl font-semibold tracking-[-0.04em] text-primary sm:text-4xl">
					{transitions.title}
				</h2>
				<p class="mt-4 text-base leading-7 text-secondary">{transitions.intro}</p>
			</div>
			<div class="mt-8 max-w-3xl space-y-6">
				{transitions.scenarios.map((scenario) => (
					<article class="soft-card rounded-[1.5rem] p-5">
						<p class="text-xs font-semibold uppercase tracking-[0.14em] text-muted">{scenario.direction}</p>
						<h3 class="mt-2 text-lg font-semibold text-primary">{scenario.heading}</h3>
						<p class="mt-3 text-base leading-7 text-secondary" set:html={scenario.body} />
					</article>
				))}
				<p class="text-base leading-7 text-secondary">{transitions.close}</p>
			</div>
		</section>

		<section id="mistakes" class="container-shell scroll-mt-24 py-section" aria-labelledby="mistakes-title">
			<div class="max-w-3xl">
				<p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">70/30 pitfalls</p>
				<h2 id="mistakes-title" class="mt-3 text-3xl font-semibold tracking-[-0.04em] text-primary sm:text-4xl">
					{mistakes.title}
				</h2>
				<p class="mt-4 text-base leading-7 text-secondary" set:html={mistakes.intro} />
			</div>
			<div class="mt-8 max-w-3xl space-y-4">
				{mistakes.items.map((item) => (
					<article class="soft-card rounded-[1.25rem] p-4">
						<h3 class="text-lg font-semibold text-primary">{item.title}</h3>
						<p class="mt-3 text-sm leading-6 text-secondary">{item.stakes}</p>
						<p class="mt-3 text-sm leading-6 text-secondary">
							<span class="font-semibold text-accent">What to write instead:</span> {item.fix}
						</p>
					</article>
				))}
			</div>
		</section>

		<section id="plan-language" class="container-shell scroll-mt-24 py-section" aria-labelledby="plan-language-title">
			<div class="max-w-3xl">
				<p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">Parenting plan draft</p>
				<h2 id="plan-language-title" class="mt-3 text-3xl font-semibold tracking-[-0.04em] text-primary sm:text-4xl">
					{planLanguage.title}
				</h2>
				<p class="mt-4 text-sm leading-6 text-muted">{planLanguage.disclaimer}</p>
				<p class="mt-4 text-base leading-7 text-secondary">{planLanguage.intro}</p>
				<p class="mt-3 text-base leading-7 text-secondary">{planLanguage.whyItHelps}</p>
			</div>
			<div class="mt-6 max-w-3xl">
				<blockquote class="soft-card rounded-[1.5rem] border-l-4 border-accent p-5 text-sm leading-7 text-secondary">
					{planLanguage.clause}
				</blockquote>
				<ul class="mt-4 space-y-2 text-sm leading-6 text-secondary">
					{planLanguage.notes.map((note) => (
						<li class="flex gap-2">
							<span class="text-accent" aria-hidden="true">→</span>
							{note}
						</li>
					))}
				</ul>
				<p class="mt-4 text-sm leading-6 text-secondary">
					Organize exchanges, holidays, and change rules in the{' '}
					<a href="/parenting-plan-template/" class="font-semibold text-accent underline decoration-line underline-offset-4 hover:text-primary">parenting plan template</a>.
				</p>
			</div>
		</section>

		<section id="builder-help" class="container-shell scroll-mt-24 py-section" aria-labelledby="builder-help-title">
			<div class="max-w-3xl">
				<p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">Plan with CustodyBuilder</p>
				<h2 id="builder-help-title" class="mt-3 text-3xl font-semibold tracking-[-0.04em] text-primary sm:text-4xl">
					{builderHelp.title}
				</h2>
				<p class="mt-4 text-base leading-7 text-secondary" set:html={builderHelp.intro} />
				<ul class="mt-4 space-y-2 text-sm leading-6 text-secondary">
					{builderHelp.features.map((feature) => (
						<li class="flex gap-2">
							<span class="text-accent" aria-hidden="true">→</span>
							{feature}
						</li>
					))}
				</ul>
				<p class="mt-4 text-sm leading-6 text-secondary">
					Verify overnight totals with the{' '}
					<a href="/custody-percentage-calculator/" class="font-semibold text-accent underline decoration-line underline-offset-4 hover:text-primary">custody percentage calculator</a>.
				</p>
				<div class="mt-6">
					<CtaButton href="#schedule-generator-panel" variant="primary" size="large">
						{builderHelp.cta}
					</CtaButton>
				</div>
			</div>
		</section>

		<section id="faq" class="container-shell scroll-mt-24 pb-section" aria-labelledby="faq-title">
			<div class="max-w-3xl">
				<h2 id="faq-title" class="text-3xl font-semibold tracking-[-0.04em] text-primary">70/30 Custody Schedule FAQ</h2>
				<div class="mt-6">
					<FAQ items={faqItems} />
				</div>
			</div>
		</section>
	</main>
	<Footer />
</BaseLayout>
