---
import Footer from '../components/Footer.astro';
import Navbar from '../components/Navbar.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCanonicalUrl } from '../lib/seo/metadata';
import { buildBreadcrumbSchema, buildWebPageSchema } from '../lib/seo/schema';

const title = 'Schedule Comparison Tool';
const description = 'A custody schedule comparison tool is coming soon to help compare 50/50, 60/40, 70/30, alternating weekend, holiday, and custom parenting schedules.';
const canonical = '/schedule-comparison-tool/';
const canonicalUrl = getCanonicalUrl(canonical);
const schema = [
	buildBreadcrumbSchema([
		{ name: 'Home', url: getCanonicalUrl('/') },
		{ name: 'Tools', url: getCanonicalUrl('/#tools') },
		{ name: title, url: canonicalUrl },
	]),
	{
		...buildWebPageSchema({ name: title, description, url: canonicalUrl }),
		isAccessibleForFree: true,
	},
];
---

<BaseLayout title={`${title} | CustodyBuilder`} description={description} canonical={canonical}>
	<JsonLd slot="head" data={schema} />
	<Navbar />
	<main class="container-shell py-14 lg:py-20">
		<section class="premium-card rounded-[2rem] p-3">
			<div class="rounded-[1.7rem] bg-surface-elevated/80 p-6 sm:p-8 lg:p-10">
				<p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">Coming soon</p>
				<h1 class="mt-4 max-w-3xl text-4xl font-semibold leading-[1.02] tracking-[-0.05em] text-primary sm:text-5xl">
					{title}
				</h1>
				<div class="mt-4 grid max-w-3xl gap-4 text-base leading-7 text-secondary">
					<p>
						This custody schedule comparison tool is coming soon. For now, parents comparing equal-time schedules can review
						{' '}<a href="/2-2-3-custody-schedule/" class="text-accent underline decoration-line underline-offset-4 hover:text-primary">2-2-3</a>,
						{' '}<a href="/2-2-5-5-custody-schedule/" class="text-accent underline decoration-line underline-offset-4 hover:text-primary">2-2-5-5</a>,
						{' '}<a href="/5-2-2-5-custody-schedule/" class="text-accent underline decoration-line underline-offset-4 hover:text-primary">5-2-2-5</a>, and
						{' '}<a href="/3-4-4-3-custody-schedule/" class="text-accent underline decoration-line underline-offset-4 hover:text-primary">3-4-4-3 custody schedules</a> before choosing a calendar pattern.
					</p>
					<p>
						If equal time is not realistic, compare a
						{' '}<a href="/60-40-custody-schedule/" class="text-accent underline decoration-line underline-offset-4 hover:text-primary">60/40 custody schedule</a> or
						{' '}<a href="/70-30-custody-schedule/" class="text-accent underline decoration-line underline-offset-4 hover:text-primary">70/30 custody schedule</a> to understand how a primary-home arrangement may change exchanges, school routines, transportation, and parenting-time percentages.
					</p>
				</div>
				<div class="mt-7 flex flex-col gap-3 sm:flex-row">
					<a href="/#tools" class="btn-primary inline-flex h-12 items-center justify-center rounded-full px-6 text-sm font-semibold">
						Explore Available Tools
					</a>
					<a href="/custody-schedule-generator/" class="btn-secondary inline-flex h-12 items-center justify-center rounded-full px-6 text-sm font-semibold">
						Open Schedule Generator
					</a>
				</div>
			</div>
		</section>
	</main>
	<Footer />
</BaseLayout>
