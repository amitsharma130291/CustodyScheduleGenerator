---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import { getCanonicalUrl } from '../lib/seo/metadata';
import { buildArticleSchema, buildBreadcrumbSchema, buildWebPageSchema } from '../lib/seo/schema';
import {
	calendarGeneration,
	corrections,
	guideReview,
	hero,
	meta,
	percentageCalculation,
	reviewStandards,
	templateStructure,
	texasLimits,
	whatWeDoNot,
} from '../data/howCustodybuilderWorksPage';

const canonical = '/how-custodybuilder-works/';
const canonicalUrl = getCanonicalUrl(canonical);
const breadcrumbs = [
	{ name: 'Home', url: getCanonicalUrl('/') },
	{ name: 'How CustodyBuilder Works', url: canonicalUrl },
];
const schema = [
	buildWebPageSchema({ name: meta.title, description: meta.description, url: canonicalUrl }),
	buildArticleSchema({
		headline: hero.headline,
		description: meta.description,
		url: canonicalUrl,
		datePublished: meta.datePublished,
		dateModified: meta.dateModified,
		authorName: 'CustodyBuilder Editorial Team',
	}),
	buildBreadcrumbSchema(breadcrumbs),
];
---

<BaseLayout title={meta.title} description={meta.description} canonical={canonical}>
	<JsonLd slot="head" data={schema} />
	<Navbar />
	<Breadcrumbs items={breadcrumbs} />
	<main>
		<section class="container-shell py-10 lg:py-14">
			<div class="max-w-3xl">
				<h1 class="text-4xl font-semibold leading-[0.98] tracking-[-0.055em] text-primary sm:text-5xl">{hero.headline}</h1>
				<p class="mt-5 text-lg leading-8 text-secondary">{hero.intro}</p>
				<p class="mt-4 text-sm text-muted">
					Reviewed by <a href="/about/" class="font-semibold text-secondary underline">CustodyBuilder Editorial Team</a>
					{' · '}Updated {meta.dateModified}
				</p>
			</div>
		</section>

		<section id="calendar-generation" class="container-shell scroll-mt-24 border-t border-line-subtle py-10 lg:py-12">
			<h2 class="text-2xl font-semibold text-primary sm:text-3xl">{calendarGeneration.title}</h2>
			<p class="mt-3 max-w-3xl text-secondary">{calendarGeneration.intro}</p>
			<ol class="mt-6 max-w-3xl list-decimal space-y-4 pl-5">
				{calendarGeneration.steps.map((s) => (
					<li class="text-secondary"><h3 class="font-semibold text-primary">{s.heading}</h3><p class="mt-2 text-sm">{s.body}</p></li>
				))}
			</ol>
			<p class="mt-5"><a href={calendarGeneration.link.href} class="font-semibold text-accent underline">{calendarGeneration.link.label}</a></p>
		</section>

		<section id="percentage-calculation" class="container-shell scroll-mt-24 border-t border-line-subtle py-10 lg:py-12">
			<h2 class="text-2xl font-semibold text-primary sm:text-3xl">{percentageCalculation.title}</h2>
			<p class="mt-3 max-w-3xl text-secondary">{percentageCalculation.intro}</p>
			<p class="mt-4 max-w-3xl rounded-lg bg-surface/50 p-3 font-mono text-sm text-primary ring-1 ring-line-subtle">{percentageCalculation.formula}</p>
			<ul class="mt-6 max-w-3xl list-disc space-y-2 pl-5 text-sm text-secondary">
				{percentageCalculation.points.map((p) => <li>{p}</li>)}
			</ul>
			<p class="mt-5"><a href={percentageCalculation.link.href} class="font-semibold text-accent underline">{percentageCalculation.link.label}</a></p>
		</section>

		<section id="guide-review" class="container-shell scroll-mt-24 border-t border-line-subtle py-10 lg:py-12">
			<h2 class="text-2xl font-semibold text-primary sm:text-3xl">{guideReview.title}</h2>
			<p class="mt-3 max-w-3xl text-secondary">{guideReview.intro}</p>
			<ul class="mt-6 max-w-3xl list-disc space-y-2 pl-5 text-sm text-secondary">
				{guideReview.checklist.map((item) => <li>{item}</li>)}
			</ul>
		</section>

		<section id="template-structure" class="container-shell scroll-mt-24 border-t border-line-subtle py-10 lg:py-12">
			<h2 class="text-2xl font-semibold text-primary sm:text-3xl">{templateStructure.title}</h2>
			<p class="mt-3 max-w-3xl text-secondary">{templateStructure.intro}</p>
			<ul class="mt-6 max-w-3xl space-y-4">
				{templateStructure.pages.map((p) => (
					<li class="border-l-2 border-accent/30 pl-4">
						<h3 class="font-semibold text-primary"><a href={p.href} class="hover:text-accent">{p.heading}</a></h3>
						<p class="mt-2 text-sm text-secondary">{p.body}</p>
					</li>
				))}
			</ul>
		</section>

		<section id="texas-limits" class="container-shell scroll-mt-24 border-t border-line-subtle py-10 lg:py-12">
			<h2 class="text-2xl font-semibold text-primary sm:text-3xl">{texasLimits.title}</h2>
			<p class="mt-3 max-w-3xl text-secondary">{texasLimits.intro}</p>
			<ul class="mt-6 max-w-3xl list-disc space-y-2 pl-5 text-sm text-secondary">
				{texasLimits.points.map((p) => <li>{p}</li>)}
			</ul>
			<ul class="mt-4 flex flex-wrap gap-4">
				{texasLimits.links.map((l) => <li><a href={l.href} class="text-sm font-semibold text-accent underline">{l.label}</a></li>)}
			</ul>
		</section>

		<section id="limitations" class="container-shell scroll-mt-24 border-t border-line-subtle py-10 lg:py-12">
			<h2 class="text-2xl font-semibold text-primary sm:text-3xl">{whatWeDoNot.title}</h2>
			<ul class="mt-6 max-w-3xl list-disc space-y-2 pl-5 text-sm text-secondary">
				{whatWeDoNot.items.map((item) => <li>{item}</li>)}
			</ul>
		</section>

		<section id="corrections" class="container-shell scroll-mt-24 border-t border-line-subtle py-10 lg:py-12">
			<h2 class="text-2xl font-semibold text-primary sm:text-3xl">{corrections.title}</h2>
			<p class="mt-3 max-w-3xl text-secondary">{corrections.intro}</p>
			<ol class="mt-6 max-w-3xl list-decimal space-y-2 pl-5 text-sm text-secondary">
				{corrections.process.map((step) => <li>{step}</li>)}
			</ol>
			<p class="mt-5"><a href={corrections.link.href} class="font-semibold text-accent underline">{corrections.link.label}</a></p>
		</section>

		<section id="review-standards" class="container-shell scroll-mt-24 border-t border-line-subtle py-10 lg:py-12">
			<h2 class="text-2xl font-semibold text-primary sm:text-3xl">{reviewStandards.title}</h2>
			<ul class="mt-6 max-w-3xl list-disc space-y-2 pl-5 text-sm text-secondary">
				{reviewStandards.items.map((item) => <li>{item}</li>)}
			</ul>
			<ul class="mt-5 flex flex-wrap gap-4">
				{reviewStandards.links.map((l) => <li><a href={l.href} class="text-sm font-semibold text-accent underline">{l.label}</a></li>)}
			</ul>
		</section>
	</main>
	<Footer />
</BaseLayout>
