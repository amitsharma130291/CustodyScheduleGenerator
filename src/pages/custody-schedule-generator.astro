---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import BackToGeneratorCta from '../components/BackToGeneratorCta.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import FAQ from '../components/FAQ.astro';
import CalendarPreview from '../components/tool/CalendarPreview.astro';
import ExportActions from '../components/tool/ExportActions.astro';
import GeneratorPanel from '../components/tool/GeneratorPanel.astro';
import CalendarConstructionGraphic from '../components/tools/custody-schedule-generator/CalendarConstructionGraphic.astro';
import GeneratorRotationBuilderGraphic from '../components/tools/custody-schedule-generator/GeneratorRotationBuilderGraphic.astro';
import GeneratorHolidayOverlayGraphic from '../components/tools/custody-schedule-generator/GeneratorHolidayOverlayGraphic.astro';
import { generateSchedule } from '../lib/schedules/generateSchedule';
import { getDefaultStartDate } from '../lib/schedules/format';
import { getCanonicalUrl } from '../lib/seo/metadata';
import {
	buildArticleSchema,
	buildBreadcrumbSchema,
	buildFAQSchema,
	buildOrganizationSchema,
	buildSoftwareApplicationSchema,
	buildWebPageSchema,
} from '../lib/seo/schema';
import {
	articleTocItems,
	calendarConstruction,
	editorialReview,
	faqItems,
	faqSection,
	hero,
	heroKeyStats,
	heroTrustSignals,
	holidayOverlay,
	interpretResults,
	meta,
	relatedReading,
	rotationBuilder,
} from '../data/custodyScheduleGenerator';

const canonical = '/custody-schedule-generator/';
const canonicalUrl = getCanonicalUrl(canonical);
const startDate = getDefaultStartDate();
const schedule = generateSchedule({ scheduleId: '223', startDate });

const breadcrumbs = [
	{ name: 'Home', url: getCanonicalUrl('/') },
	{ name: 'Custody Schedule Generator', url: canonicalUrl },
];

const schema = [
	buildWebPageSchema({ name: meta.title, description: meta.description, url: canonicalUrl }),
	buildArticleSchema({
		headline: hero.headline,
		description: meta.description,
		url: canonicalUrl,
		datePublished: meta.datePublished,
		dateModified: meta.dateModified,
		authorName: editorialReview.reviewer,
	}),
	buildFAQSchema(faqItems),
	buildBreadcrumbSchema(breadcrumbs),
	buildOrganizationSchema({ name: 'CustodyBuilder', url: getCanonicalUrl('/') }),
	{
		...buildSoftwareApplicationSchema({
			name: 'Custody Schedule Generator',
			description: meta.description,
			url: canonicalUrl,
			applicationCategory: 'LegalApplication',
		}),
		operatingSystem: 'Web',
		offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
	},
];
---

<BaseLayout title={meta.title} description={meta.description} canonical={canonical}>
	<JsonLd slot="head" data={schema} />
	<Navbar />
	<Breadcrumbs items={breadcrumbs} />
	<main>
		<section class="atmosphere container-shell grid items-start gap-5 py-4 scroll-mt-24 sm:gap-6 sm:py-6 lg:grid-cols-[minmax(0,0.42fr)_minmax(0,1fr)] lg:gap-8">
			<div class="relative z-10 min-w-0 lg:pt-2">
				<h1 class="max-w-3xl text-4xl font-semibold leading-[0.98] tracking-[-0.055em] text-primary sm:text-5xl">{hero.headline}</h1>
				<dl class="mt-4 grid grid-cols-3 gap-2">
					{heroKeyStats.map((s) => (
						<div class="rounded-[1rem] bg-accent/10 px-2 py-2.5 text-center sm:px-3">
							<dd class="text-lg font-bold text-accent sm:text-xl">{s.value}</dd>
							<dt class="mt-0.5 text-[10px] font-semibold uppercase text-secondary">{s.label}</dt>
						</div>
					))}
				</dl>
				<p class="mt-3 max-w-xl text-base leading-7 text-secondary">{hero.intro}</p>
				<p class="mt-3 max-w-xl text-sm leading-6 text-secondary" set:html={hero.boundary} />
				<div class="mt-3 max-w-xl text-xs leading-5 text-muted">
					<p class="font-semibold text-secondary">Reviewed for:</p>
					<ul class="mt-1 list-inside list-disc">{editorialReview.reviewedFor.map((i) => <li>{i}</li>)}</ul>
					<p class="mt-2">
						Reviewed by <a href={editorialReview.reviewerHref} class="font-semibold text-secondary underline">{editorialReview.reviewer}</a>
						{' · '}<a href={editorialReview.methodologyHref} class="font-semibold text-secondary underline">{editorialReview.methodologyLabel}</a>
						{' · '}{editorialReview.disclaimer}
					</p>
				</div>
				<ul class="mt-3 flex flex-wrap gap-2 text-xs font-semibold text-secondary">
					{heroTrustSignals.map((s) => (
						<li class="rounded-full bg-surface/70 px-3 py-1.5 shadow-[inset_0_0_0_1px_var(--border-subtle)]">{s}</li>
					))}
				</ul>
			</div>

			<div id="generator" class="hero-generator-shell relative min-w-0 scroll-mt-24">
				<div class="premium-card relative overflow-visible rounded-[1.75rem] border-line p-3 sm:p-4">
					<div class="rounded-[1.4rem] bg-surface-elevated shadow-[inset_0_1px_0_rgba(255,255,255,0.07)]">
						<div class="hero-generator-grid">
							<GeneratorPanel selectedScheduleId="223" compact />
							<div class="hero-calendar-column grid gap-3 p-3">
								<CalendarPreview schedule={schedule}>
									<ExportActions slot="actions" />
								</CalendarPreview>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<nav class="container-shell border-y border-line-subtle py-3" aria-label="On this page">
			<ul class="flex flex-wrap gap-x-4 gap-y-1 text-xs font-semibold text-secondary">
				{articleTocItems.map((i) => <li><a href={`#${i.id}`} class="hover:text-accent">{i.label}</a></li>)}
			</ul>
		</nav>

		<section id="calendar-construction" class="container-shell scroll-mt-24 py-10 lg:py-12">
			<div class="grid gap-8 lg:grid-cols-[1fr_360px]">
				<div>
					<h2 class="text-2xl font-semibold text-primary sm:text-3xl">{calendarConstruction.title}</h2>
					<p class="mt-3 text-secondary">{calendarConstruction.intro}</p>
					<ol class="mt-6 list-decimal space-y-4 pl-5">
						{calendarConstruction.steps.map((s) => (
							<li class="text-secondary"><h3 class="font-semibold text-primary">{s.heading}</h3><p class="mt-2 text-sm">{s.body}</p></li>
						))}
					</ol>
				</div>
				<CalendarConstructionGraphic />
			</div>
		</section>

		<section id="rotation-builder" class="container-shell scroll-mt-24 border-t border-line-subtle py-10 lg:py-12">
			<div class="grid gap-8 lg:grid-cols-[1fr_360px]">
				<div>
					<h2 class="text-2xl font-semibold text-primary sm:text-3xl">{rotationBuilder.title}</h2>
					<p class="mt-3 text-secondary">{rotationBuilder.intro}</p>
					<ul class="mt-6 space-y-4">
						{rotationBuilder.points.map((p) => (
							<li class="border-l-2 border-accent/30 pl-4"><h3 class="font-semibold text-primary">{p.heading}</h3><p class="mt-2 text-sm text-secondary">{p.body}</p></li>
						))}
					</ul>
				</div>
				<GeneratorRotationBuilderGraphic />
			</div>
		</section>

		<section id="holiday-overlay" class="container-shell scroll-mt-24 border-t border-line-subtle py-10 lg:py-12">
			<div class="grid gap-8 lg:grid-cols-[1fr_360px]">
				<div>
					<h2 class="text-2xl font-semibold text-primary sm:text-3xl">{holidayOverlay.title}</h2>
					<p class="mt-3 text-secondary">{holidayOverlay.intro}</p>
					<ul class="mt-6 space-y-4">
						{holidayOverlay.points.map((p) => (
							<li class="text-sm text-secondary" set:html={`<strong class="text-primary">${p.heading}</strong> — ${p.body}`} />
						))}
					</ul>
				</div>
				<GeneratorHolidayOverlayGraphic />
			</div>
		</section>

		<section id="interpret-results" class="container-shell scroll-mt-24 border-t border-line-subtle py-10 lg:py-12">
			<h2 class="text-2xl font-semibold text-primary sm:text-3xl">{interpretResults.title}</h2>
			<p class="mt-3 max-w-3xl text-secondary">{interpretResults.intro}</p>
			<ul class="mt-6 max-w-3xl space-y-4">
				{interpretResults.questions.map((q) => (
					<li class="border-l-2 border-accent/30 pl-4"><h3 class="font-semibold text-primary">{q.heading}</h3><p class="mt-2 text-sm text-secondary">{q.body}</p></li>
				))}
			</ul>
			<p class="mt-6 max-w-3xl text-sm text-secondary" set:html={interpretResults.closing} />
		</section>

		<section id="related-reading" class="container-shell scroll-mt-24 border-t border-line-subtle py-10 lg:py-12">
			<h2 class="text-2xl font-semibold text-primary sm:text-3xl">{relatedReading.title}</h2>
			<div class="mt-4 max-w-3xl space-y-3 text-secondary">
				{relatedReading.paragraphs.map((p) => <p set:html={p} />)}
			</div>
		</section>

		<FAQ items={faqItems} title={faqSection.title} description={faqSection.description} />
		<BackToGeneratorCta
			headline="Back to the schedule builder"
			body="Use the generator above to build a dated exchange calendar — set the rotation, add parent names, preview months, and download a PDF."
			href="#generator"
			label="Build your schedule ↑"
		/>
	</main>
	<Footer />
</BaseLayout>
