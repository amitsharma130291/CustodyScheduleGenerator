---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import FAQ from '../components/FAQ.astro';
import CtaButton from '../components/CtaButton.astro';
import ScheduleHeroGeneratorPanel from '../components/schedules/ScheduleHeroGeneratorPanel.astro';
import FiftyFiftyEliminationFunnelGraphic from '../components/schedules/best-50-50-custody-schedule/FiftyFiftyEliminationFunnelGraphic.astro';
import FiftyFiftyConflictDayComparisonGraphic from '../components/schedules/best-50-50-custody-schedule/FiftyFiftyConflictDayComparisonGraphic.astro';
import FiftyFiftyNonNegotiablesGraphic from '../components/schedules/best-50-50-custody-schedule/FiftyFiftyNonNegotiablesGraphic.astro';
import { generateSchedule } from '../lib/schedules/generateSchedule';
import { getDefaultStartDate } from '../lib/schedules/format';
import { getCanonicalUrl } from '../lib/seo/metadata';
import {
	buildArticleSchema,
	buildBreadcrumbSchema,
	buildFAQSchema,
	buildWebPageSchema,
} from '../lib/seo/schema';
import {
	articleTocItems,
	bothFail,
	breakTie,
	conflictDays,
	editorialReview,
	faqItems,
	faqSection,
	hero,
	heroKeyStats,
	heroTrustSignals,
	meta,
	methodology,
	nonNegotiables,
	postContentCta,
	printBoth,
	twoSurvive,
} from '../data/bestFiftyFiftyCustodySchedule';

const canonical = '/best-50-50-custody-schedule/';
const canonicalUrl = getCanonicalUrl(canonical);
const startDate = getDefaultStartDate();
const generatedSchedule = generateSchedule({
	scheduleId: '2-2-5-5',
	startDate,
	parentNames: { parentA: 'Parent A', parentB: 'Parent B' },
});

const breadcrumbs = [
	{ name: 'Home', url: getCanonicalUrl('/') },
	{ name: '50/50 Custody Schedule', url: getCanonicalUrl('/50-50-custody-schedule/') },
	{ name: 'Two-Schedule Elimination Guide', url: canonicalUrl },
];

const schema = [
	buildWebPageSchema({ name: meta.title, description: meta.description, url: canonicalUrl }),
	buildArticleSchema({
		headline: hero.headline,
		description: meta.description,
		url: canonicalUrl,
		datePublished: meta.datePublished,
		dateModified: meta.dateModified,
		authorName: editorialReview.reviewer,
	}),
	buildFAQSchema(faqItems),
	buildBreadcrumbSchema(breadcrumbs),
	{
		'@context': 'https://schema.org',
		'@type': 'WebApplication',
		name: '50/50 Finalist Calendar Generator',
		description: meta.description,
		url: canonicalUrl,
		inLanguage: 'en-US',
		areaServed: 'US',
		applicationCategory: 'LegalApplication',
		operatingSystem: 'Web',
		offers: {
			'@type': 'Offer',
			price: '0',
			priceCurrency: 'USD',
		},
	},
];
---

<BaseLayout title={meta.title} description={meta.description} canonical={canonical}>
	<JsonLd slot="head" data={schema} />
	<Navbar />
	<Breadcrumbs items={breadcrumbs} />
	<main class="best-fifty-fifty-page">
		<section
			class="container-shell grid grid-cols-1 gap-5 py-4 sm:py-5 lg:grid-cols-[minmax(0,0.88fr)_minmax(704px,1.12fr)] lg:items-start lg:gap-7 lg:py-6 xl:w-[min(100%,1360px)]"
			id="schedule-generator"
		>
			<div class="order-1 min-w-0 lg:col-start-1 lg:row-start-1 lg:pt-1">
				<h1 class="max-w-3xl text-4xl font-semibold leading-[0.98] tracking-[-0.055em] text-primary sm:text-5xl">
					{hero.headline}
				</h1>

				<dl class="mt-4 grid grid-cols-3 gap-2">
					{heroKeyStats.map((stat) => (
						<div class="rounded-[1rem] bg-accent/10 px-2 py-2.5 text-center shadow-[inset_0_0_0_1px_rgba(37,99,235,0.15)] sm:px-3">
							<dd class="text-lg font-bold tabular-nums tracking-tight text-accent sm:text-xl">{stat.value}</dd>
							<dt class="mt-0.5 text-[10px] font-semibold uppercase leading-4 tracking-[0.08em] text-secondary">{stat.label}</dt>
						</div>
					))}
				</dl>

				<p class="mt-3 max-w-2xl text-base leading-7 text-secondary">{hero.intro}</p>
				<p class="mt-3 max-w-2xl text-sm leading-6 text-secondary" set:html={hero.boundary} />

				<div class="mt-3 max-w-2xl text-xs leading-5 text-muted">
					<p class="font-semibold text-secondary">Reviewed for:</p>
					<ul class="mt-1 list-inside list-disc space-y-0.5">
						{editorialReview.reviewedFor.map((item) => (
							<li>{item}</li>
						))}
					</ul>
					<p class="mt-2">
						Reviewed by{' '}
						<a href={editorialReview.reviewerHref} class="font-semibold text-secondary underline decoration-line underline-offset-4 hover:text-primary">
							{editorialReview.reviewer}
						</a>
						{' · '}
						Methodology:{' '}
						<a href={editorialReview.methodologyHref} class="font-semibold text-secondary underline decoration-line underline-offset-4 hover:text-primary">
							{editorialReview.methodologyLabel}
						</a>
						{' · '}{editorialReview.disclaimer}
					</p>
				</div>
			</div>

			<ScheduleHeroGeneratorPanel
				selectedScheduleId="2-2-5-5"
				generatedSchedule={generatedSchedule}
				heroTrustSignals={heroTrustSignals}
			/>
		</section>

		<nav class="container-shell border-y border-line-subtle py-3" aria-label="On this page">
			<ul class="flex flex-wrap gap-x-4 gap-y-1 text-xs font-semibold text-secondary">
				{articleTocItems.map((item) => (
					<li><a href={`#${item.id}`} class="hover:text-accent">{item.label}</a></li>
				))}
			</ul>
		</nav>

		<section id="two-survive" class="container-shell scroll-mt-24 py-10 lg:py-12" aria-labelledby="two-survive-title">
			<div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_minmax(280px,360px)] lg:items-start">
				<div class="min-w-0">
					<h2 id="two-survive-title" class="text-2xl font-semibold tracking-[-0.04em] text-primary sm:text-3xl">
						{twoSurvive.title}
					</h2>
					<p class="mt-3 text-base leading-7 text-secondary">{twoSurvive.intro}</p>
					<ul class="mt-6 space-y-5">
						{twoSurvive.pairs.map((pair) => (
							<li class="rounded-[1rem] bg-surface/50 p-4 ring-1 ring-line-subtle">
								<h3 class="text-base font-semibold text-primary">{pair.heading}</h3>
								<p class="mt-2 text-sm leading-6 text-secondary">{pair.body}</p>
								<p class="mt-3 flex flex-wrap gap-x-4 gap-y-1 text-sm font-semibold">
									{pair.links.map((link) => (
										<a href={link.href} class="text-accent underline decoration-line underline-offset-4 hover:text-primary">
											{link.label}
										</a>
									))}
								</p>
							</li>
						))}
					</ul>
				</div>
				<FiftyFiftyEliminationFunnelGraphic />
			</div>
		</section>

		<section id="non-negotiables" class="container-shell scroll-mt-24 border-t border-line-subtle py-10 lg:py-12" aria-labelledby="non-negotiables-title">
			<div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_minmax(280px,360px)] lg:items-start">
				<div class="min-w-0">
					<h2 id="non-negotiables-title" class="text-2xl font-semibold tracking-[-0.04em] text-primary sm:text-3xl">
						{nonNegotiables.title}
					</h2>
					<p class="mt-3 text-base leading-7 text-secondary">{nonNegotiables.intro}</p>
					<ul class="mt-6 space-y-4">
						{nonNegotiables.items.map((item) => (
							<li class="border-l-2 border-accent/30 pl-4">
								<h3 class="text-base font-semibold text-primary">{item.heading}</h3>
								<p class="mt-2 text-sm leading-6 text-secondary">{item.body}</p>
							</li>
						))}
					</ul>
				</div>
				<FiftyFiftyNonNegotiablesGraphic />
			</div>
		</section>

		<section id="print-both" class="container-shell scroll-mt-24 border-t border-line-subtle py-10 lg:py-12" aria-labelledby="print-both-title">
			<h2 id="print-both-title" class="max-w-3xl text-2xl font-semibold tracking-[-0.04em] text-primary sm:text-3xl">
				{printBoth.title}
			</h2>
			<p class="mt-3 max-w-3xl text-base leading-7 text-secondary">{printBoth.intro}</p>
			<ol class="mt-6 max-w-3xl list-decimal space-y-2 pl-5 text-sm leading-6 text-secondary">
				{printBoth.steps.map((step) => (
					<li>{step}</li>
				))}
			</ol>
			<p class="mt-6 max-w-3xl text-sm leading-6 text-secondary" set:html={printBoth.closing} />
		</section>

		<section id="conflict-days" class="container-shell scroll-mt-24 border-t border-line-subtle py-10 lg:py-12" aria-labelledby="conflict-days-title">
			<div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_minmax(280px,360px)] lg:items-start">
				<div class="min-w-0">
					<h2 id="conflict-days-title" class="text-2xl font-semibold tracking-[-0.04em] text-primary sm:text-3xl">
						{conflictDays.title}
					</h2>
					<p class="mt-3 text-base leading-7 text-secondary">{conflictDays.intro}</p>
					<ul class="mt-6 space-y-4">
						{conflictDays.markers.map((marker) => (
							<li class="border-l-2 border-rose-500/30 pl-4">
								<h3 class="text-base font-semibold text-primary">{marker.heading}</h3>
								<p class="mt-2 text-sm leading-6 text-secondary" set:html={marker.body} />
							</li>
						))}
					</ul>
					<p class="mt-6 text-sm leading-6 text-secondary">{conflictDays.threshold}</p>
				</div>
				<FiftyFiftyConflictDayComparisonGraphic />
			</div>
		</section>

		<section id="break-tie" class="container-shell scroll-mt-24 border-t border-line-subtle py-10 lg:py-12" aria-labelledby="break-tie-title">
			<h2 id="break-tie-title" class="max-w-3xl text-2xl font-semibold tracking-[-0.04em] text-primary sm:text-3xl">
				{breakTie.title}
			</h2>
			<p class="mt-3 max-w-3xl text-base leading-7 text-secondary">{breakTie.intro}</p>
			<div class="mt-6 max-w-3xl space-y-5">
				{breakTie.steps.map((step) => (
					<article class="rounded-[1rem] bg-surface/50 p-4 ring-1 ring-line-subtle">
						<h3 class="text-base font-semibold text-primary">{step.heading}</h3>
						<p class="mt-2 text-sm leading-6 text-secondary" set:html={step.body} />
					</article>
				))}
			</div>
		</section>

		<section id="both-fail" class="container-shell scroll-mt-24 border-t border-line-subtle py-10 lg:py-12" aria-labelledby="both-fail-title">
			<h2 id="both-fail-title" class="max-w-3xl text-2xl font-semibold tracking-[-0.04em] text-primary sm:text-3xl">
				{bothFail.title}
			</h2>
			<p class="mt-3 max-w-3xl text-base leading-7 text-secondary">{bothFail.intro}</p>
			<ul class="mt-6 max-w-3xl space-y-4">
				{bothFail.outcomes.map((outcome) => (
					<li class="border-l-2 border-accent/30 pl-4">
						<h3 class="text-base font-semibold text-primary">{outcome.heading}</h3>
						<p class="mt-2 text-sm leading-6 text-secondary" set:html={outcome.body} />
					</li>
				))}
			</ul>
		</section>

		<section id="methodology" class="container-shell scroll-mt-24 border-t border-line-subtle py-10 lg:py-12" aria-labelledby="methodology-title">
			<h2 id="methodology-title" class="max-w-3xl text-2xl font-semibold tracking-[-0.04em] text-primary sm:text-3xl">
				{methodology.title}
			</h2>
			{methodology.paragraphs.map((paragraph) => (
				<p class="mt-3 max-w-3xl text-base leading-7 text-secondary">{paragraph}</p>
			))}
		</section>

		<section id="convert-cta" class="container-shell scroll-mt-24 border-t border-line-subtle py-10 lg:py-12" aria-labelledby="convert-cta-title">
			<div class="max-w-2xl rounded-[1.25rem] border border-line bg-surface/40 p-6 sm:p-7">
				<h2 id="convert-cta-title" class="text-2xl font-semibold tracking-[-0.04em] text-primary sm:text-[1.65rem]">
					{postContentCta.heading}
				</h2>
				<p class="mt-3 text-sm leading-6 text-secondary sm:text-base sm:leading-7">{postContentCta.body}</p>
				<div class="mt-5 flex flex-col gap-3 sm:flex-row sm:items-center sm:gap-5">
					<CtaButton href={postContentCta.primaryHref} variant="primary" size="large">
						{postContentCta.primaryLabel}
					</CtaButton>
					<a
						href={postContentCta.secondaryHref}
						class="text-sm font-semibold text-accent underline decoration-line underline-offset-4 hover:text-primary"
					>
						{postContentCta.secondaryLabel}
					</a>
				</div>
			</div>
		</section>

		<FAQ items={faqItems} title={faqSection.title} description={faqSection.description} />
	</main>
	<Footer />
</BaseLayout>
