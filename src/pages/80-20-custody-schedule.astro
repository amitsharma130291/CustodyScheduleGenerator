---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import FAQ from '../components/FAQ.astro';
import CtaButton from '../components/CtaButton.astro';
import ArticleTOC from '../components/ArticleTOC.astro';
import GeneratorPanel from '../components/tool/GeneratorPanel.astro';
import CalendarPreview from '../components/tool/CalendarPreview.astro';
import ExportActions from '../components/tool/ExportActions.astro';
import { generateSchedule } from '../lib/schedules/generateSchedule';
import { getDefaultStartDate } from '../lib/schedules/format';
import { getCanonicalUrl } from '../lib/seo/metadata';
import {
	buildArticleSchema,
	buildBreadcrumbSchema,
	buildFAQSchema,
	buildWebPageSchema,
} from '../lib/seo/schema';
import {
	articleTocItems,
	builderHelp,
	calendarGlance,
	commonPatterns,
	faqItems,
	hero,
	meta,
	overnightCount,
	primaryHomeWorkload,
	risksMistakes,
	twentyPercentParent,
	quickFacts,
	vsOtherSplits,
	whatItLooksLike,
	whenItWorks,
} from '../data/eightyTwentyCustodySchedule';

const canonical = '/80-20-custody-schedule/';
const canonicalUrl = getCanonicalUrl(canonical);
const startDate = getDefaultStartDate();
const generatedSchedule = generateSchedule({
	scheduleId: '80-20',
	startDate,
	parentNames: { parentA: 'Parent A', parentB: 'Parent B' },
});

const breadcrumbs = [
	{ name: 'Home', url: getCanonicalUrl('/') },
	{ name: 'Schedules', url: getCanonicalUrl('/custody-schedule-generator/') },
	{ name: '80/20 Custody Schedule', url: canonicalUrl },
];

const schema = [
	buildWebPageSchema({ name: meta.title, description: meta.description, url: canonicalUrl }),
	buildArticleSchema({
		headline: hero.headline,
		description: meta.description,
		url: canonicalUrl,
		datePublished: meta.datePublished,
		dateModified: meta.dateModified,
		authorName: 'CustodyBuilder Editorial Team',
	}),
	buildFAQSchema(faqItems),
	buildBreadcrumbSchema(breadcrumbs),
	{
		'@context': 'https://schema.org',
		'@type': 'WebApplication',
		name: '80/20 Custody Schedule Calendar Generator',
		description: meta.description,
		url: canonicalUrl,
		inLanguage: 'en-US',
		areaServed: 'US',
		applicationCategory: 'LegalApplication',
		operatingSystem: 'Web',
		offers: {
			'@type': 'Offer',
			price: '0',
			priceCurrency: 'USD',
		},
	},
	{
		'@context': 'https://schema.org',
		'@type': 'HowTo',
		name: 'How to create an 80/20 Custody Schedule',
		description: 'Use the custody calendar generator to preview, compare, and export an 80/20 parenting schedule.',
		inLanguage: 'en-US',
		totalTime: 'PT5M',
		step: [
			{
				'@type': 'HowToStep',
				name: 'Choose the 80/20 schedule type',
				text: 'Select 80/20 Custody Schedule in the generator.',
			},
			{
				'@type': 'HowToStep',
				name: 'Pick a pattern and start date',
				text: 'Compare every other weekend, monthly weekend rules, added weekday overnights, or long-distance blocks.',
			},
			{
				'@type': 'HowToStep',
				name: 'Review overnight percentages',
				text: 'Check the monthly calendar and generated annual average before exporting or printing.',
			},
		],
	},
];
---

<BaseLayout title={meta.title} description={meta.description} canonical={canonical}>
	<JsonLd slot="head" data={schema} />
	<Navbar />
	<Breadcrumbs items={breadcrumbs} />
	<main>
		<section
			class="container-shell schedule-hero-section grid gap-10 py-12 xl:grid-cols-[minmax(0,1fr)_minmax(704px,720px)] xl:items-start xl:justify-center xl:gap-8 xl:py-16"
			id="schedule-generator"
		>
			<div class="min-w-0 max-w-[820px]">
				<p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">Primary-home schedule</p>
				<h1 class="mt-4 text-4xl font-semibold leading-[1.02] tracking-[-0.05em] text-primary sm:text-5xl lg:text-6xl">
					{hero.headline}
				</h1>
				<p class="mt-5 text-lg leading-8 text-secondary">{hero.opening}</p>
				<p class="mt-4 text-base leading-7 text-secondary">{hero.connection}</p>

				<div class="mt-6 soft-card rounded-[1.5rem] p-5">
					<p class="text-xs font-semibold uppercase tracking-[0.16em] text-muted">{quickFacts.title}</p>
					<dl class="mt-3 grid gap-3 sm:grid-cols-2">
						{quickFacts.items.map((fact) => (
							<div class="rounded-[1rem] bg-surface/70 p-3 shadow-[inset_0_0_0_1px_var(--border-subtle)]">
								<dt class="text-xs font-semibold uppercase tracking-[0.12em] text-muted">{fact.label}</dt>
								<dd class="mt-1 text-sm font-semibold leading-6 text-primary">{fact.value}</dd>
							</div>
						))}
					</dl>
				</div>

				<p class="mt-4 text-sm leading-6 text-muted">
					Not legal advice.
					<a href="/disclaimer/" class="ml-1 font-semibold text-secondary underline decoration-line underline-offset-4 hover:text-primary">Read disclaimer</a>
				</p>

				<div class="mt-6 xl:hidden">
					<CtaButton href="#schedule-generator-panel" variant="primary" size="large">
						Build an 80/20 custody calendar
					</CtaButton>
				</div>
			</div>

			<div class="hero-generator-shell relative w-full min-w-0 xl:sticky xl:top-24 xl:min-w-[704px] xl:max-w-[720px] xl:justify-self-end">
				<div class="grid gap-5">
					<section id="calendar-glance" class="soft-card scroll-mt-24 rounded-[1.5rem] p-5" aria-labelledby="calendar-glance-title">
						<h2 id="calendar-glance-title" class="text-lg font-semibold tracking-[-0.03em] text-primary">
							{calendarGlance.title}
						</h2>
						<div class="mt-4 overflow-x-auto">
							{calendarGlance.weeks.map((week, weekIndex) => (
								<div class:list={[weekIndex > 0 && 'mt-4']}>
									<p class="mb-2 text-xs font-semibold uppercase tracking-[0.14em] text-muted">{calendarGlance.weekLabels[weekIndex]}</p>
									<table class="w-full min-w-[320px] border-collapse text-center text-sm">
										<thead>
											<tr>
												{calendarGlance.dayLabels.map((day) => (
													<th class="px-1 py-2 text-xs font-semibold uppercase tracking-[0.1em] text-muted">{day}</th>
												))}
											</tr>
										</thead>
										<tbody>
											<tr>
												{week.map((parent) => (
													<td class="px-1 py-2">
														<span
															class:list={[
																'inline-flex h-8 w-8 items-center justify-center rounded-lg text-xs font-bold',
																parent === 'A'
																	? 'bg-accent/15 text-accent'
																	: 'bg-surface/80 text-secondary shadow-[inset_0_0_0_1px_var(--border-subtle)]',
															]}
														>
															{parent}
														</span>
													</td>
												))}
											</tr>
										</tbody>
									</table>
								</div>
							))}
						</div>
						<div class="mt-4 space-y-2">
							{calendarGlance.notes.map((note) => (
								<p class="text-xs leading-5 text-secondary">{note}</p>
							))}
						</div>
					</section>

					<div id="schedule-generator-panel" class="premium-card relative overflow-visible rounded-[1.75rem] border-line p-4 sm:rounded-[2.25rem] sm:p-5">
						<p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">80/20 calendar</p>
						<p class="mt-2 text-sm leading-6 text-secondary">
							Set a start date, pick an 80/20 pattern, and compare overnight percentages on your month.
						</p>
						<div class="hero-generator-inner mt-4 rounded-[1.4rem] bg-surface-elevated p-0 shadow-[inset_0_1px_0_rgba(255,255,255,0.07)] sm:rounded-[1.8rem]">
							<div class="hero-generator-grid generator-shell grid grid-cols-1 items-start gap-6 xl:grid-cols-[minmax(380px,1fr)_260px]">
								<div class="generator-form-panel min-w-0">
									<GeneratorPanel selectedScheduleId="80-20" compact />
								</div>
								<div class="hero-calendar-column calendar-preview-panel grid w-full min-w-0 gap-3 xl:w-[260px] xl:min-w-[260px]">
									<CalendarPreview schedule={generatedSchedule}>
										<ExportActions slot="actions" />
									</CalendarPreview>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<ArticleTOC items={articleTocItems} />

		<section id="what-it-looks-like" class="container-shell scroll-mt-24 pb-section" aria-labelledby="what-it-looks-like-title">
			<div class="max-w-3xl">
				<p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">Real-life 80/20</p>
				<h2 id="what-it-looks-like-title" class="mt-3 text-3xl font-semibold tracking-[-0.04em] text-primary sm:text-4xl">
					{whatItLooksLike.title}
				</h2>
				<p class="mt-4 text-base leading-7 text-secondary">{whatItLooksLike.intro}</p>
			</div>
			<div class="mt-8 max-w-3xl space-y-6">
				{whatItLooksLike.details.map((item) => (
					<article>
						<h3 class="text-xl font-semibold tracking-[-0.03em] text-primary">{item.heading}</h3>
						<p class="mt-3 text-base leading-7 text-secondary">{item.body}</p>
					</article>
				))}
				<p class="text-base leading-7 text-secondary">{whatItLooksLike.close}</p>
			</div>
		</section>

		<section id="overnight-count" class="container-shell scroll-mt-24 py-section" aria-labelledby="overnight-count-title">
			<div class="max-w-3xl">
				<p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">Overnight math</p>
				<h2 id="overnight-count-title" class="mt-3 text-3xl font-semibold tracking-[-0.04em] text-primary sm:text-4xl">
					{overnightCount.title}
				</h2>
				<p class="mt-4 text-base leading-7 text-secondary">{overnightCount.intro}</p>
			</div>
			<div class="mt-8 max-w-3xl space-y-4">
				{overnightCount.points.map((point) => (
					<article class="soft-card rounded-[1.25rem] p-4">
						<p class="text-sm font-semibold text-accent">{point.label}</p>
						<p class="mt-2 text-sm leading-6 text-secondary">{point.body}</p>
					</article>
				))}
				<p class="text-sm leading-6 text-secondary" set:html={overnightCount.calculatorNote} />
			</div>
		</section>

		<section id="common-patterns" class="container-shell scroll-mt-24 py-section" aria-labelledby="common-patterns-title">
			<div class="max-w-3xl">
				<p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">80/20 patterns</p>
				<h2 id="common-patterns-title" class="mt-3 text-3xl font-semibold tracking-[-0.04em] text-primary sm:text-4xl">
					{commonPatterns.title}
				</h2>
				<p class="mt-4 text-base leading-7 text-secondary">{commonPatterns.intro}</p>
			</div>
			<div class="mt-8 max-w-3xl space-y-6">
				{commonPatterns.patterns.map((pattern) => (
					<article class="soft-card rounded-[1.5rem] p-5">
						<h3 class="text-lg font-semibold text-primary">{pattern.title}</h3>
						<p class="mt-3 text-sm leading-6 text-secondary">
							<span class="font-semibold text-primary">Looks like:</span> {pattern.looksLike}
						</p>
						<p class="mt-2 text-sm leading-6 text-secondary">
							<span class="font-semibold text-primary">When families use it:</span> {pattern.whenUsed}
						</p>
						<p class="mt-2 text-sm leading-6 text-secondary">
							<span class="font-semibold text-accent">Watch for:</span>{' '}
							<span set:html={pattern.watchFor} />
						</p>
					</article>
				))}
			</div>
		</section>

		<section id="twenty-percent-parent" class="container-shell scroll-mt-24 py-section" aria-labelledby="twenty-percent-parent-title">
			<div class="max-w-3xl">
				<p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">20% parent connection</p>
				<h2 id="twenty-percent-parent-title" class="mt-3 text-3xl font-semibold tracking-[-0.04em] text-primary sm:text-4xl">
					{twentyPercentParent.title}
				</h2>
				<p class="mt-4 text-base leading-7 text-secondary">{twentyPercentParent.intro}</p>
			</div>
			<div class="mt-8 max-w-3xl space-y-6">
				{twentyPercentParent.challenges.map((item) => (
					<article class="soft-card rounded-[1.5rem] p-5">
						<h3 class="text-lg font-semibold text-primary">{item.problem}</h3>
						<p class="mt-3 text-sm leading-6 text-secondary">{item.body}</p>
					</article>
				))}
				<div>
					<p class="text-sm font-semibold text-primary">Practical fixes</p>
					<ul class="mt-3 space-y-2 text-sm leading-6 text-secondary">
						{twentyPercentParent.solutions.map((solution) => (
							<li class="flex gap-2">
								<span class="text-accent" aria-hidden="true">→</span>
								{solution}
							</li>
						))}
					</ul>
				</div>
				<p class="text-base leading-7 text-secondary">{twentyPercentParent.close}</p>
			</div>
		</section>

		<section id="primary-home-workload" class="container-shell scroll-mt-24 py-section" aria-labelledby="primary-home-workload-title">
			<div class="max-w-3xl">
				<p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">Primary-home parent</p>
				<h2 id="primary-home-workload-title" class="mt-3 text-3xl font-semibold tracking-[-0.04em] text-primary sm:text-4xl">
					{primaryHomeWorkload.title}
				</h2>
				<p class="mt-4 text-base leading-7 text-secondary">{primaryHomeWorkload.intro}</p>
			</div>
			<div class="mt-8 max-w-3xl space-y-6">
				{primaryHomeWorkload.tasks.map((task) => (
					<article>
						<h3 class="text-xl font-semibold tracking-[-0.03em] text-primary">{task.heading}</h3>
						<p class="mt-3 text-base leading-7 text-secondary">{task.body}</p>
					</article>
				))}
				<div class="soft-card rounded-[1.5rem] p-5">
					<p class="text-sm font-semibold text-primary">Split duties the plan can assign to Parent B</p>
					<ul class="mt-3 space-y-2 text-sm leading-6 text-secondary">
						{primaryHomeWorkload.sharedDuties.map((duty) => (
							<li class="flex gap-2">
								<span class="text-accent" aria-hidden="true">•</span>
								{duty}
							</li>
						))}
					</ul>
				</div>
				<p class="text-base leading-7 text-secondary">{primaryHomeWorkload.close}</p>
			</div>
		</section>

		<section id="vs-other-splits" class="container-shell scroll-mt-24 py-section" aria-labelledby="vs-other-splits-title">
			<div class="max-w-3xl">
				<p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">Compare splits</p>
				<h2 id="vs-other-splits-title" class="mt-3 text-3xl font-semibold tracking-[-0.04em] text-primary sm:text-4xl">
					{vsOtherSplits.title}
				</h2>
				<p class="mt-4 text-base leading-7 text-secondary">{vsOtherSplits.intro}</p>
			</div>
			<div class="mt-8 max-w-3xl space-y-4">
				{vsOtherSplits.rows.map((row) => (
					<article class="soft-card rounded-[1.25rem] p-4">
						<p class="text-sm font-semibold text-accent">
							{row.href ? (
								<a href={row.href} class="underline decoration-line underline-offset-4 hover:text-primary">{row.split}</a>
							) : (
								row.split
							)}
						</p>
						<p class="mt-2 text-sm leading-6 text-secondary">{row.fits}</p>
					</article>
				))}
				<p class="text-base leading-7 text-secondary">{vsOtherSplits.close}</p>
			</div>
		</section>

		<section id="when-it-works" class="container-shell scroll-mt-24 py-section" aria-labelledby="when-it-works-title">
			<div class="max-w-3xl">
				<p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">When 80/20 fits</p>
				<h2 id="when-it-works-title" class="mt-3 text-3xl font-semibold tracking-[-0.04em] text-primary sm:text-4xl">
					{whenItWorks.title}
				</h2>
			</div>
			<div class="mt-8 max-w-3xl space-y-6">
				{whenItWorks.situations.map((item) => (
					<article>
						<h3 class="text-xl font-semibold tracking-[-0.03em] text-primary">{item.heading}</h3>
						<p class="mt-3 text-base leading-7 text-secondary">{item.body}</p>
					</article>
				))}
			</div>
		</section>

		<section id="risks-mistakes" class="container-shell scroll-mt-24 py-section" aria-labelledby="risks-mistakes-title">
			<div class="max-w-3xl">
				<p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">80/20 pitfalls</p>
				<h2 id="risks-mistakes-title" class="mt-3 text-3xl font-semibold tracking-[-0.04em] text-primary sm:text-4xl">
					{risksMistakes.title}
				</h2>
				<p class="mt-4 text-base leading-7 text-secondary">{risksMistakes.intro}</p>
			</div>
			<div class="mt-8 max-w-3xl space-y-6">
				{risksMistakes.problems.map((item) => (
					<article class="soft-card rounded-[1.5rem] p-5">
						<h3 class="text-lg font-semibold text-primary">{item.problem}</h3>
						<p class="mt-3 text-sm leading-6 text-secondary">
							<span class="font-semibold text-accent">Fix:</span>{' '}
							<span set:html={item.solution} />
						</p>
					</article>
				))}
			</div>
		</section>

		<section id="builder-help" class="container-shell scroll-mt-24 py-section" aria-labelledby="builder-help-title">
			<div class="max-w-3xl">
				<p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">Plan with CustodyBuilder</p>
				<h2 id="builder-help-title" class="mt-3 text-3xl font-semibold tracking-[-0.04em] text-primary sm:text-4xl">
					{builderHelp.title}
				</h2>
				<p class="mt-4 text-base leading-7 text-secondary">{builderHelp.intro}</p>
				<ul class="mt-4 space-y-2 text-sm leading-6 text-secondary">
					{builderHelp.features.map((feature) => (
						<li class="flex gap-2">
							<span class="text-accent" aria-hidden="true">→</span>
							{feature}
						</li>
					))}
				</ul>
				<div class="mt-6">
					<CtaButton href="#schedule-generator-panel" variant="primary" size="large">
						{builderHelp.cta}
					</CtaButton>
				</div>
			</div>
		</section>

		<section id="faq" class="container-shell scroll-mt-24 pb-section" aria-labelledby="faq-title">
			<div class="max-w-3xl">
				<h2 id="faq-title" class="text-3xl font-semibold tracking-[-0.04em] text-primary">80/20 Custody Schedule FAQ</h2>
				<div class="mt-6">
					<FAQ items={faqItems} />
				</div>
			</div>
		</section>
	</main>
	<Footer />
</BaseLayout>
