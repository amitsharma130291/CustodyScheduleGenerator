---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import FAQ from '../components/FAQ.astro';
import CtaButton from '../components/CtaButton.astro';
import ScheduleHeroGeneratorPanel from '../components/schedules/ScheduleHeroGeneratorPanel.astro';
import VisitationGapGraphic from '../components/schedules/holiday-visitation-schedule/VisitationGapGraphic.astro';
import HolidayAccessTimelineGraphic from '../components/schedules/holiday-visitation-schedule/HolidayAccessTimelineGraphic.astro';
import LimitedTimeParentHolidayMapGraphic from '../components/schedules/holiday-visitation-schedule/LimitedTimeParentHolidayMapGraphic.astro';
import { generateSchedule } from '../lib/schedules/generateSchedule';
import { getDefaultStartDate } from '../lib/schedules/format';
import { getCanonicalUrl } from '../lib/seo/metadata';
import {
	buildArticleSchema,
	buildBreadcrumbSchema,
	buildFAQSchema,
	buildWebPageSchema,
} from '../lib/seo/schema';
import {
	articleTocItems,
	baseChange,
	buildCalendar,
	conflicts,
	editorialReview,
	faqItems,
	faqSection,
	gapProblem,
	hero,
	heroKeyStats,
	heroTrustSignals,
	meta,
	needsInWriting,
	notSame,
	postContentCta,
	replaceWeekend,
} from '../data/holidayVisitationSchedule';

const canonical = '/holiday-visitation-schedule/';
const canonicalUrl = getCanonicalUrl(canonical);
const currentYear = new Date().getFullYear();
const startDate = getDefaultStartDate();
const generatedSchedule = generateSchedule({
	scheduleId: 'every-other-weekend',
	startDate,
	parentNames: { parentA: 'Parent A', parentB: 'Parent B' },
});

const initialHolidays = [
	{ name: "New Year's Day", date: `January 1, ${currentYear}`, parent: 'Parent B' },
	{ name: 'Spring Break', date: `March 17, ${currentYear}`, parent: 'Parent B' },
	{ name: 'Memorial Day', date: `May 26, ${currentYear}`, parent: 'Parent B' },
	{ name: 'July 4th', date: `July 4, ${currentYear}`, parent: 'Parent B' },
	{ name: 'Labor Day', date: `September 1, ${currentYear}`, parent: 'Parent B' },
	{ name: 'Thanksgiving', date: `November 27, ${currentYear}`, parent: 'Parent B' },
	{ name: 'Christmas Eve', date: `December 24, ${currentYear}`, parent: 'Parent B' },
	{ name: 'Christmas Day', date: `December 25, ${currentYear}`, parent: 'Parent B' },
];

const breadcrumbs = [
	{ name: 'Home', url: getCanonicalUrl('/') },
	{ name: 'Holiday Visitation Schedule', url: canonicalUrl },
];

const schema = [
	buildWebPageSchema({ name: meta.title, description: meta.description, url: canonicalUrl }),
	buildArticleSchema({
		headline: hero.headline,
		description: meta.description,
		url: canonicalUrl,
		datePublished: meta.datePublished,
		dateModified: meta.dateModified,
		authorName: editorialReview.reviewer,
	}),
	buildFAQSchema(faqItems),
	buildBreadcrumbSchema(breadcrumbs),
	{
		'@context': 'https://schema.org',
		'@type': 'WebApplication',
		name: 'Holiday Visitation Calendar Generator',
		description: meta.description,
		url: canonicalUrl,
		inLanguage: 'en-US',
		areaServed: 'US',
		applicationCategory: 'LegalApplication',
		operatingSystem: 'Web',
		offers: {
			'@type': 'Offer',
			price: '0',
			priceCurrency: 'USD',
		},
	},
];
---

<BaseLayout title={meta.title} description={meta.description} canonical={canonical}>
	<JsonLd slot="head" data={schema} />
	<Navbar />
	<Breadcrumbs items={breadcrumbs} />
	<main class="holiday-visitation-page">
		<section
			class="container-shell grid grid-cols-1 gap-5 py-4 sm:py-5 lg:grid-cols-[minmax(0,0.88fr)_minmax(704px,1.12fr)] lg:items-start lg:gap-7 lg:py-6 xl:w-[min(100%,1360px)]"
			id="schedule-generator"
		>
			<div class="order-1 min-w-0 lg:col-start-1 lg:row-start-1 lg:pt-1">
				<h1 class="max-w-3xl text-4xl font-semibold leading-[0.98] tracking-[-0.055em] text-primary sm:text-5xl">
					{hero.headline}
				</h1>

				<dl class="mt-4 grid grid-cols-3 gap-2">
					{heroKeyStats.map((stat) => (
						<div class="rounded-[1rem] bg-accent/10 px-2 py-2.5 text-center shadow-[inset_0_0_0_1px_rgba(37,99,235,0.15)] sm:px-3">
							<dd class="text-lg font-bold tabular-nums tracking-tight text-accent sm:text-xl">{stat.value}</dd>
							<dt class="mt-0.5 text-[10px] font-semibold uppercase leading-4 tracking-[0.08em] text-secondary">{stat.label}</dt>
						</div>
					))}
				</dl>

				<p class="mt-3 max-w-2xl text-base leading-7 text-secondary">{hero.intro}</p>
				<p class="mt-3 max-w-2xl text-sm leading-6 text-secondary" set:html={hero.boundary} />

				<div class="mt-3 max-w-2xl text-xs leading-5 text-muted">
					<p class="font-semibold text-secondary">Reviewed for:</p>
					<ul class="mt-1 list-inside list-disc space-y-0.5">
						{editorialReview.reviewedFor.map((item) => (
							<li>{item}</li>
						))}
					</ul>
					<p class="mt-2">
						Reviewed by{' '}
						<a href={editorialReview.reviewerHref} class="font-semibold text-secondary underline decoration-line underline-offset-4 hover:text-primary">
							{editorialReview.reviewer}
						</a>
						{' · '}
						Methodology:{' '}
						<a href={editorialReview.methodologyHref} class="font-semibold text-secondary underline decoration-line underline-offset-4 hover:text-primary">
							{editorialReview.methodologyLabel}
						</a>
						{' · '}{editorialReview.disclaimer}
					</p>
				</div>
			</div>

			<ScheduleHeroGeneratorPanel
				selectedScheduleId="every-other-weekend"
				generatedSchedule={generatedSchedule}
				heroTrustSignals={heroTrustSignals}
			/>
		</section>

		<nav class="container-shell border-y border-line-subtle py-3" aria-label="On this page">
			<ul class="flex flex-wrap gap-x-4 gap-y-1 text-xs font-semibold text-secondary">
				{articleTocItems.map((item) => (
					<li><a href={`#${item.id}`} class="hover:text-accent">{item.label}</a></li>
				))}
			</ul>
		</nav>

		<section id="not-same" class="container-shell scroll-mt-24 py-10 lg:py-12" aria-labelledby="not-same-title">
			<h2 id="not-same-title" class="max-w-3xl text-2xl font-semibold tracking-[-0.04em] text-primary sm:text-3xl">
				{notSame.title}
			</h2>
			<p class="mt-3 max-w-3xl text-base leading-7 text-secondary">{notSame.intro}</p>
			<ul class="mt-6 max-w-3xl space-y-4">
				{notSame.points.map((point) => (
					<li class="rounded-[1rem] bg-surface/50 p-4 ring-1 ring-line-subtle">
						<h3 class="text-base font-semibold text-primary">{point.heading}</h3>
						<p class="mt-2 text-sm leading-6 text-secondary">{point.body}</p>
					</li>
				))}
			</ul>
		</section>

		<section id="gap-problem" class="container-shell scroll-mt-24 border-t border-line-subtle py-10 lg:py-12" aria-labelledby="gap-problem-title">
			<div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_minmax(280px,360px)] lg:items-start">
				<div class="min-w-0">
					<h2 id="gap-problem-title" class="text-2xl font-semibold tracking-[-0.04em] text-primary sm:text-3xl">
						{gapProblem.title}
					</h2>
					<p class="mt-3 text-base leading-7 text-secondary">{gapProblem.intro}</p>
					<ul class="mt-6 space-y-4">
						{gapProblem.examples.map((ex) => (
							<li class="border-l-2 border-accent/30 pl-4">
								<h3 class="text-base font-semibold text-primary">{ex.heading}</h3>
								<p class="mt-2 text-sm leading-6 text-secondary">{ex.body}</p>
							</li>
						))}
					</ul>
				</div>
				<VisitationGapGraphic />
			</div>
		</section>

		<section id="needs-in-writing" class="container-shell scroll-mt-24 border-t border-line-subtle py-10 lg:py-12" aria-labelledby="needs-in-writing-title">
			<div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_minmax(280px,360px)] lg:items-start">
				<div class="min-w-0">
					<h2 id="needs-in-writing-title" class="text-2xl font-semibold tracking-[-0.04em] text-primary sm:text-3xl">
						{needsInWriting.title}
					</h2>
					<p class="mt-3 text-base leading-7 text-secondary">{needsInWriting.intro}</p>
					<ul class="mt-6 space-y-4">
						{needsInWriting.items.map((item) => (
							<li class="border-l-2 border-accent/30 pl-4">
								<h3 class="text-base font-semibold text-primary">{item.heading}</h3>
								<p class="mt-2 text-sm leading-6 text-secondary">{item.body}</p>
							</li>
						))}
					</ul>
				</div>
				<LimitedTimeParentHolidayMapGraphic />
			</div>
		</section>

		<section id="conflicts" class="container-shell scroll-mt-24 border-t border-line-subtle py-10 lg:py-12" aria-labelledby="conflicts-title">
			<h2 id="conflicts-title" class="max-w-3xl text-2xl font-semibold tracking-[-0.04em] text-primary sm:text-3xl">
				{conflicts.title}
			</h2>
			<p class="mt-3 max-w-3xl text-base leading-7 text-secondary">{conflicts.intro}</p>
			<ul class="mt-6 max-w-3xl space-y-4">
				{conflicts.scenarios.map((scenario) => (
					<li class="rounded-[1rem] bg-surface/50 p-4 ring-1 ring-line-subtle">
						<h3 class="text-base font-semibold text-primary">{scenario.heading}</h3>
						<p class="mt-2 text-sm leading-6 text-secondary">{scenario.body}</p>
					</li>
				))}
			</ul>
		</section>

		<section id="replace-weekend" class="container-shell scroll-mt-24 border-t border-line-subtle py-10 lg:py-12" aria-labelledby="replace-weekend-title">
			<div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_minmax(280px,360px)] lg:items-start">
				<div class="min-w-0">
					<h2 id="replace-weekend-title" class="text-2xl font-semibold tracking-[-0.04em] text-primary sm:text-3xl">
						{replaceWeekend.title}
					</h2>
					<p class="mt-3 text-base leading-7 text-secondary">{replaceWeekend.intro}</p>
					<ul class="mt-6 space-y-4">
						{replaceWeekend.rules.map((rule) => (
							<li class="border-l-2 border-accent/30 pl-4">
								<h3 class="text-base font-semibold text-primary">{rule.heading}</h3>
								<p class="mt-2 text-sm leading-6 text-secondary">{rule.body}</p>
							</li>
						))}
					</ul>
				</div>
				<HolidayAccessTimelineGraphic />
			</div>
		</section>

		<section id="base-change" class="container-shell scroll-mt-24 border-t border-line-subtle py-10 lg:py-12" aria-labelledby="base-change-title">
			<h2 id="base-change-title" class="max-w-3xl text-2xl font-semibold tracking-[-0.04em] text-primary sm:text-3xl">
				{baseChange.title}
			</h2>
			<p class="mt-3 max-w-3xl text-base leading-7 text-secondary">{baseChange.intro}</p>
			<ul class="mt-6 max-w-3xl space-y-4">
				{baseChange.routes.map((route) => (
					<li class="rounded-[1rem] bg-surface/50 p-4 ring-1 ring-line-subtle">
						<h3 class="text-base font-semibold text-primary">{route.heading}</h3>
						<p class="mt-2 text-sm leading-6 text-secondary" set:html={route.body} />
					</li>
				))}
			</ul>
		</section>

		<section id="build-calendar" class="container-shell scroll-mt-24 border-t border-line-subtle py-10 lg:py-12" aria-labelledby="build-calendar-title">
			<h2 id="build-calendar-title" class="max-w-3xl text-2xl font-semibold tracking-[-0.04em] text-primary sm:text-3xl">
				{buildCalendar.title}
			</h2>
			<p class="mt-3 max-w-3xl text-base leading-7 text-secondary">{buildCalendar.body}</p>

			<div class="mt-8 premium-card rounded-[2rem] p-4 sm:p-5" data-holiday-planner>
				<div class="rounded-[1.5rem] bg-surface-elevated p-4 shadow-[inset_0_1px_0_rgba(255,255,255,0.07)] sm:p-5">
					<p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">Visitation holiday planner</p>
					<p class="mt-2 text-sm leading-6 text-secondary">Assign holiday access blocks for the limited-time parent. Mark which holidays replace or add to regular Fri–Sun visits.</p>

					<form class="mt-5 grid gap-4" data-holiday-form>
						<div class="grid gap-4 sm:grid-cols-2">
							<label class="grid gap-1.5">
								<span class="text-sm font-medium text-secondary">Visitation parent name</span>
								<input name="parentBName" value="Parent B" aria-label="Visitation parent name" class="w-full min-w-0 rounded-2xl bg-page px-4 py-2 text-sm text-primary shadow-[inset_0_0_0_1px_var(--border-subtle)]" />
							</label>
							<label class="grid gap-1.5">
								<span class="text-sm font-medium text-secondary">Primary parent name</span>
								<input name="parentAName" value="Parent A" aria-label="Primary parent name" class="w-full min-w-0 rounded-2xl bg-page px-4 py-2 text-sm text-primary shadow-[inset_0_0_0_1px_var(--border-subtle)]" />
							</label>
						</div>
						<div class="grid gap-4 sm:grid-cols-3">
							<label class="grid gap-1.5">
								<span class="text-sm font-medium text-secondary">Year</span>
								<input name="year" type="number" min="2024" max="2100" step="1" value={currentYear} class="w-full min-w-0 rounded-2xl bg-page px-4 py-2 text-sm text-primary shadow-[inset_0_0_0_1px_var(--border-subtle)]" />
							</label>
							<label class="grid gap-1.5">
								<span class="text-sm font-medium text-secondary">Rotation type</span>
								<select name="rotationType" class="w-full min-w-0 rounded-2xl bg-page px-4 py-2 text-sm text-primary shadow-[inset_0_0_0_1px_var(--border-subtle)]">
									<option value="alternate-years">Alternate years</option>
									<option value="alternate-holidays">Alternate holidays</option>
									<option value="fixed-assignment">Fixed to visitation parent</option>
								</select>
							</label>
							<label class="grid gap-1.5">
								<span class="text-sm font-medium text-secondary">Holiday set</span>
								<select name="holidaySet" class="w-full min-w-0 rounded-2xl bg-page px-4 py-2 text-sm text-primary shadow-[inset_0_0_0_1px_var(--border-subtle)]">
									<option value="major-us">Major US holidays</option>
									<option value="school-breaks">School breaks</option>
								</select>
							</label>
						</div>
					</form>

					<div class="mt-5 grid grid-cols-2 gap-2" aria-label="Holiday assignment summary">
						<div class="rounded-2xl bg-page/55 p-3 shadow-[inset_0_0_0_1px_var(--border-subtle)]">
							<p class="truncate text-xs font-medium text-secondary" data-summary-parent-b-label>Parent B</p>
							<p class="mt-1 text-[30px] font-bold leading-none tracking-[-0.05em] text-accent" data-summary-parent-b-count>8</p>
							<p class="mt-1 text-xs text-muted">holiday access blocks</p>
						</div>
						<div class="rounded-2xl bg-page/55 p-3 shadow-[inset_0_0_0_1px_var(--border-subtle)]">
							<p class="truncate text-xs font-medium text-secondary" data-summary-parent-a-label>Parent A</p>
							<p class="mt-1 text-[30px] font-bold leading-none tracking-[-0.05em] text-parent-b" data-summary-parent-a-count>0</p>
							<p class="mt-1 text-xs text-muted">holiday access blocks</p>
						</div>
					</div>

					<div class="mt-4 rounded-2xl bg-page/55 p-4 shadow-[inset_0_0_0_1px_var(--border-subtle)]" data-holiday-print>
						<h3 class="text-xl font-semibold tracking-[-0.04em] text-primary" data-holiday-preview-title>
							{currentYear} visitation holiday access
						</h3>
						<div class="mt-4 overflow-x-auto">
							<table class="w-full min-w-[520px] border-collapse text-left text-sm">
								<thead class="text-xs uppercase tracking-[0.14em] text-muted">
									<tr class="border-b border-line-subtle">
										<th class="py-3 pr-4 font-semibold">Holiday</th>
										<th class="px-4 py-3 font-semibold">Date</th>
										<th class="py-3 pl-4 font-semibold">Access parent</th>
									</tr>
								</thead>
								<tbody class="divide-y divide-line-subtle text-secondary" data-holiday-table-body>
									{initialHolidays.map((holiday) => (
										<tr>
											<td class="py-3 pr-4 font-semibold text-primary">{holiday.name}</td>
											<td class="px-4 py-3">{holiday.date}</td>
											<td class="py-3 pl-4">{holiday.parent}</td>
										</tr>
									))}
								</tbody>
							</table>
						</div>
					</div>

					<div class="mt-4 grid w-full min-w-0 grid-cols-1 gap-3 sm:grid-cols-2">
						<button type="button" class="btn-secondary flex h-12 w-full items-center justify-center rounded-full px-4 text-sm font-semibold" data-copy-holiday-schedule>
							Copy access table
						</button>
						<button type="button" class="btn-primary flex h-12 w-full items-center justify-center rounded-full px-4 text-sm font-semibold" data-print-holiday-schedule>
							Print access table
						</button>
					</div>
				</div>
			</div>
		</section>

		<section id="convert-cta" class="container-shell scroll-mt-24 border-t border-line-subtle py-10 lg:py-12" aria-labelledby="convert-cta-title">
			<div class="max-w-2xl rounded-[1.25rem] border border-line bg-surface/40 p-6 sm:p-7">
				<h2 id="convert-cta-title" class="text-2xl font-semibold tracking-[-0.04em] text-primary sm:text-[1.65rem]">
					{postContentCta.heading}
				</h2>
				<p class="mt-3 text-sm leading-6 text-secondary sm:text-base sm:leading-7">{postContentCta.body}</p>
				<div class="mt-5 flex flex-col gap-3 sm:flex-row sm:items-center sm:gap-5">
					<CtaButton href={postContentCta.primaryHref} variant="primary" size="large">
						{postContentCta.primaryLabel}
					</CtaButton>
					<a
						href={postContentCta.secondaryHref}
						class="text-sm font-semibold text-accent underline decoration-line underline-offset-4 hover:text-primary"
					>
						{postContentCta.secondaryLabel}
					</a>
				</div>
			</div>
		</section>

		<FAQ items={faqItems} title={faqSection.title} description={faqSection.description} />
	</main>
	<Footer />
</BaseLayout>

<script>
	function formatDate(date) {
		return date.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
	}

	function getNthWeekday(year, monthIndex, weekday, occurrence) {
		const date = new Date(year, monthIndex, 1);
		const offset = (weekday - date.getDay() + 7) % 7;
		return new Date(year, monthIndex, 1 + offset + (occurrence - 1) * 7);
	}

	function getLastWeekday(year, monthIndex, weekday) {
		const date = new Date(year, monthIndex + 1, 0);
		const offset = (date.getDay() - weekday + 7) % 7;
		return new Date(year, monthIndex, date.getDate() - offset);
	}

	function getHolidayOptions(year, holidaySet) {
		const majorHolidays = [
			{ name: "New Year's Day", date: new Date(year, 0, 1) },
			{ name: 'Spring Break', date: new Date(year, 2, 17) },
			{ name: 'Memorial Day', date: getLastWeekday(year, 4, 1) },
			{ name: 'July 4th', date: new Date(year, 6, 4) },
			{ name: 'Labor Day', date: getNthWeekday(year, 8, 1, 1) },
			{ name: 'Thanksgiving', date: getNthWeekday(year, 10, 4, 4) },
			{ name: 'Christmas Eve', date: new Date(year, 11, 24) },
			{ name: 'Christmas Day', date: new Date(year, 11, 25) },
		];

		if (holidaySet === 'school-breaks') {
			return [
				{ name: 'Spring Break', date: new Date(year, 2, 17) },
				{ name: 'Summer Break Start', date: new Date(year, 5, 1) },
				{ name: 'Fall Break', date: new Date(year, 9, 14) },
				{ name: 'Thanksgiving Break', date: getNthWeekday(year, 10, 4, 4) },
				{ name: 'Winter Break Start', date: new Date(year, 11, 23) },
				{ name: "New Year's Day", date: new Date(year, 0, 1) },
			];
		}

		return majorHolidays;
	}

	function getAssignedParent(index, year, rotationType) {
		if (rotationType === 'fixed-assignment') return 'B';
		if (rotationType === 'alternate-holidays') return index % 2 === 0 ? 'B' : 'A';
		return (year + index) % 2 === 0 ? 'B' : 'A';
	}

	const form = document.querySelector('[data-holiday-form]');
	const tableBody = document.querySelector('[data-holiday-table-body]');
	const previewTitle = document.querySelector('[data-holiday-preview-title]');
	const parentALabel = document.querySelector('[data-summary-parent-a-label]');
	const parentBLabel = document.querySelector('[data-summary-parent-b-label]');
	const parentACount = document.querySelector('[data-summary-parent-a-count]');
	const parentBCount = document.querySelector('[data-summary-parent-b-count]');
	const copyButton = document.querySelector('[data-copy-holiday-schedule]');
	const printButton = document.querySelector('[data-print-holiday-schedule]');
	let currentRows = [];

	function getState() {
		if (!(form instanceof HTMLFormElement)) return undefined;
		const data = new FormData(form);
		return {
			parentAName: String(data.get('parentAName') || 'Parent A'),
			parentBName: String(data.get('parentBName') || 'Parent B'),
			year: Number(data.get('year')) || new Date().getFullYear(),
			rotationType: String(data.get('rotationType') || 'alternate-years'),
			holidaySet: String(data.get('holidaySet') || 'major-us'),
		};
	}

	function renderPlanner() {
		const state = getState();
		if (!state || !tableBody) return;

		const holidays = getHolidayOptions(state.year, state.holidaySet);
		let parentATotal = 0;
		let parentBTotal = 0;
		currentRows = holidays.map((holiday, index) => {
			const parentKey = getAssignedParent(index, state.year, state.rotationType);
			const parentName = parentKey === 'A' ? state.parentAName : state.parentBName;
			if (parentKey === 'A') parentATotal += 1;
			if (parentKey === 'B') parentBTotal += 1;
			return { holiday: holiday.name, date: formatDate(holiday.date), parent: parentName };
		});

		tableBody.textContent = '';
		currentRows.forEach((row) => {
			const tableRow = document.createElement('tr');
			[row.holiday, row.date, row.parent].forEach((text, i) => {
				const td = document.createElement('td');
				td.className = i === 0 ? 'py-3 pr-4 font-semibold text-primary' : i === 1 ? 'px-4 py-3' : 'py-3 pl-4';
				td.textContent = text;
				tableRow.appendChild(td);
			});
			tableBody.appendChild(tableRow);
		});

		if (previewTitle) previewTitle.textContent = `${state.year} visitation holiday access`;
		if (parentALabel) parentALabel.textContent = state.parentAName;
		if (parentBLabel) parentBLabel.textContent = state.parentBName;
		if (parentACount) parentACount.textContent = String(parentATotal);
		if (parentBCount) parentBCount.textContent = String(parentBTotal);
	}

	function buildCopyText() {
		const state = getState();
		return [
			`${state?.year || ''} Holiday Visitation Access`.trim(),
			...currentRows.map((row) => `${row.holiday}: ${row.date} - ${row.parent}`),
		].join('\n');
	}

	form?.addEventListener('input', renderPlanner);
	form?.addEventListener('change', renderPlanner);
	copyButton?.addEventListener('click', async () => {
		if (!(copyButton instanceof HTMLButtonElement)) return;
		const originalLabel = 'Copy access table';
		try {
			await navigator.clipboard.writeText(buildCopyText());
			copyButton.textContent = 'Copied';
		} catch {
			copyButton.textContent = 'Copy failed';
		}
		window.setTimeout(() => { copyButton.textContent = originalLabel; }, 2000);
	});
	printButton?.addEventListener('click', () => window.print());
	renderPlanner();
</script>
