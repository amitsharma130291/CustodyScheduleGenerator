---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import FAQ from '../components/FAQ.astro';
import CtaButton from '../components/CtaButton.astro';
import ScheduleHeroGeneratorPanel from '../components/schedules/ScheduleHeroGeneratorPanel.astro';
import ClauseHierarchyGraphic from '../components/schedules/parenting-plan-template/ClauseHierarchyGraphic.astro';
import DecisionTreeGraphic from '../components/schedules/parenting-plan-template/DecisionTreeGraphic.astro';
import SectionFlowGraphic from '../components/schedules/parenting-plan-template/SectionFlowGraphic.astro';
import { generateSchedule } from '../lib/schedules/generateSchedule';
import { getDefaultStartDate } from '../lib/schedules/format';
import { getCanonicalUrl } from '../lib/seo/metadata';
import { buildArticleSchema, buildBreadcrumbSchema, buildFAQSchema, buildWebPageSchema } from '../lib/seo/schema';
import {
	articleTocItems, clauseHierarchy, decisionTree, disputes, editorialReview, faqItems, faqSection,
	holidayReference, hero, heroKeyStats, heroTrustSignals, meta, scheduleReference, sectionFlow,
} from '../data/parentingPlanTemplate';

const canonical = '/parenting-plan-template/';
const canonicalUrl = getCanonicalUrl(canonical);
const generatedSchedule = generateSchedule({ scheduleId: '2-2-5-5', startDate: getDefaultStartDate(), parentNames: { parentA: 'Parent A', parentB: 'Parent B' } });
const breadcrumbs = [{ name: 'Home', url: getCanonicalUrl('/') }, { name: 'Parenting Plan Template', url: canonicalUrl }];
const schema = [
	buildWebPageSchema({ name: meta.title, description: meta.description, url: canonicalUrl }),
	buildArticleSchema({ headline: hero.headline, description: meta.description, url: canonicalUrl, datePublished: meta.datePublished, dateModified: meta.dateModified, authorName: editorialReview.reviewer }),
	buildFAQSchema(faqItems), buildBreadcrumbSchema(breadcrumbs),
	{ '@context': 'https://schema.org', '@type': 'WebApplication', name: 'Parenting Plan Outline Builder', description: meta.description, url: canonicalUrl, inLanguage: 'en-US', areaServed: 'US', applicationCategory: 'LegalApplication', operatingSystem: 'Web', offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' } },
];
---

<BaseLayout title={meta.title} description={meta.description} canonical={canonical}>
	<JsonLd slot="head" data={schema} />
	<Navbar /><Breadcrumbs items={breadcrumbs} />
	<main>
		<section class="container-shell grid grid-cols-1 gap-5 py-4 sm:py-5 lg:grid-cols-[minmax(0,0.88fr)_minmax(704px,1.12fr)] lg:items-start lg:gap-7 lg:py-6 xl:w-[min(100%,1360px)]" id="schedule-generator">
			<div class="order-1 min-w-0 lg:col-start-1 lg:row-start-1 lg:pt-1">
				<h1 class="max-w-3xl text-4xl font-semibold leading-[0.98] tracking-[-0.055em] text-primary sm:text-5xl">{hero.headline}</h1>
				<dl class="mt-4 grid grid-cols-3 gap-2">{heroKeyStats.map((s) => (<div class="rounded-[1rem] bg-accent/10 px-2 py-2.5 text-center sm:px-3"><dd class="text-lg font-bold text-accent sm:text-xl">{s.value}</dd><dt class="mt-0.5 text-[10px] font-semibold uppercase text-secondary">{s.label}</dt></div>))}</dl>
				<p class="mt-3 max-w-2xl text-base leading-7 text-secondary">{hero.intro}</p>
				<p class="mt-3 max-w-2xl text-sm leading-6 text-secondary" set:html={hero.boundary} />
				<div class="mt-3 max-w-2xl text-xs leading-5 text-muted">
					<p class="font-semibold text-secondary">Reviewed for:</p><ul class="mt-1 list-inside list-disc">{editorialReview.reviewedFor.map((i) => <li>{i}</li>)}</ul>
					<p class="mt-2">Reviewed by <a href={editorialReview.reviewerHref} class="font-semibold text-secondary underline">{editorialReview.reviewer}</a> · <a href={editorialReview.methodologyHref} class="font-semibold text-secondary underline">{editorialReview.methodologyLabel}</a> · {editorialReview.disclaimer}</p>
				</div>
			</div>
			<ScheduleHeroGeneratorPanel selectedScheduleId="2-2-5-5" generatedSchedule={generatedSchedule} heroTrustSignals={heroTrustSignals} />
		</section>
		<nav class="container-shell border-y border-line-subtle py-3" aria-label="On this page"><ul class="flex flex-wrap gap-x-4 gap-y-1 text-xs font-semibold text-secondary">{articleTocItems.map((i) => <li><a href={`#${i.id}`} class="hover:text-accent">{i.label}</a></li>)}</ul></nav>

		<section id="plan-builder" class="container-shell scroll-mt-24 py-10 lg:py-12">
			<div class="max-w-2xl premium-card rounded-[1.5rem] p-5" data-parenting-plan-builder>
				<p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">Plan outline builder</p>
				<h2 class="mt-2 text-xl font-semibold text-primary">Draft section headers before attaching exhibits</h2>
				<form class="mt-4 grid gap-3" data-parenting-plan-form>
					<div class="grid gap-3 sm:grid-cols-2">
						<label class="grid gap-1"><span class="text-xs font-medium text-secondary">Schedule exhibit type</span>
							<select name="scheduleType" class="rounded-xl bg-page px-3 py-2 text-sm shadow-[inset_0_0_0_1px_var(--border-subtle)]"><option>50/50 custody schedule</option><option>60/40 custody schedule</option><option>Every-other-weekend</option><option>Custom schedule</option></select></label>
						<label class="grid gap-1"><span class="text-xs font-medium text-secondary">Holiday exhibit type</span>
							<select name="holidayPlan" class="rounded-xl bg-page px-3 py-2 text-sm shadow-[inset_0_0_0_1px_var(--border-subtle)]"><option>Alternating holidays</option><option>Split major holidays</option><option>Visitation holiday access</option></select></label>
					</div>
					<label class="grid gap-1"><span class="text-xs font-medium text-secondary">Default exchange location</span>
						<input name="exchangeLocation" placeholder="School curb, neutral site" class="rounded-xl bg-page px-3 py-2 text-sm shadow-[inset_0_0_0_1px_var(--border-subtle)]" /></label>
					<div class="grid gap-3 sm:grid-cols-2">
						<label class="grid gap-1"><span class="text-xs font-medium text-secondary">Parent A</span><input name="parentA" value="Parent A" class="rounded-xl bg-page px-3 py-2 text-sm shadow-[inset_0_0_0_1px_var(--border-subtle)]" /></label>
						<label class="grid gap-1"><span class="text-xs font-medium text-secondary">Parent B</span><input name="parentB" value="Parent B" class="rounded-xl bg-page px-3 py-2 text-sm shadow-[inset_0_0_0_1px_var(--border-subtle)]" /></label>
					</div>
				</form>
				<p class="mt-3 text-sm text-secondary" data-plan-preview-summary>Parent A and Parent B: 50/50 custody schedule, alternating holidays.</p>
				<div class="mt-4 flex gap-3"><button type="button" class="btn-primary rounded-full px-5 py-2 text-sm font-semibold" data-print-parenting-plan>Print outline</button><button type="button" class="btn-secondary rounded-full px-5 py-2 text-sm font-semibold" data-copy-parenting-plan>Copy outline</button></div>
			</div>
		</section>

		<section id="clause-hierarchy" class="container-shell scroll-mt-24 border-t border-line-subtle py-10 lg:py-12"><div class="grid gap-8 lg:grid-cols-[1fr_360px]"><div><h2 class="text-2xl font-semibold text-primary sm:text-3xl">{clauseHierarchy.title}</h2><p class="mt-3 text-secondary">{clauseHierarchy.intro}</p><ul class="mt-6 space-y-4">{clauseHierarchy.layers.map((l) => <li class="border-l-2 border-accent/30 pl-4"><h3 class="font-semibold text-primary">{l.heading}</h3><p class="mt-2 text-sm text-secondary">{l.body}</p></li>)}</ul></div><ClauseHierarchyGraphic /></div></section>
		<section id="decision-tree" class="container-shell scroll-mt-24 border-t border-line-subtle py-10 lg:py-12"><div class="grid gap-8 lg:grid-cols-[1fr_360px]"><div><h2 class="text-2xl font-semibold text-primary sm:text-3xl">{decisionTree.title}</h2><p class="mt-3 text-secondary">{decisionTree.intro}</p><ul class="mt-6 space-y-4">{decisionTree.branches.map((b) => <li class="border-l-2 border-accent/30 pl-4"><h3 class="font-semibold text-primary">{b.heading}</h3><p class="mt-2 text-sm text-secondary">{b.body}</p></li>)}</ul></div><DecisionTreeGraphic /></div></section>
		<section id="section-flow" class="container-shell scroll-mt-24 border-t border-line-subtle py-10 lg:py-12"><div class="grid gap-8 lg:grid-cols-[1fr_360px]"><div><h2 class="text-2xl font-semibold text-primary sm:text-3xl">{sectionFlow.title}</h2><p class="mt-3 text-secondary">{sectionFlow.intro}</p><ul class="mt-6 space-y-3">{sectionFlow.sections.map((s) => <li class="rounded-lg bg-surface/50 p-3 ring-1 ring-line-subtle"><h3 class="font-semibold text-primary">{s.name}</h3><p class="mt-1 text-sm text-secondary">{s.detail}</p></li>)}</ul></div><SectionFlowGraphic /></div></section>
		<section id="schedule-reference" class="container-shell scroll-mt-24 border-t border-line-subtle py-10 lg:py-12"><div class="max-w-2xl rounded-[1.25rem] border border-line bg-surface/40 p-6"><h2 class="text-2xl font-semibold text-primary">{scheduleReference.title}</h2><p class="mt-3 text-secondary">{scheduleReference.body}</p><div class="mt-5 flex flex-col gap-3 sm:flex-row"><CtaButton href={scheduleReference.primaryHref} variant="primary" size="large">{scheduleReference.primaryLabel}</CtaButton><a href={scheduleReference.secondaryHref} class="text-sm font-semibold text-accent underline">{scheduleReference.secondaryLabel}</a></div></div></section>
		<section id="holiday-reference" class="container-shell scroll-mt-24 border-t border-line-subtle py-10 lg:py-12"><h2 class="text-2xl font-semibold text-primary sm:text-3xl">{holidayReference.title}</h2><p class="mt-3 max-w-3xl text-secondary">{holidayReference.body}</p><p class="mt-4"><a href={holidayReference.linkHref} class="font-semibold text-accent underline">{holidayReference.linkLabel}</a></p></section>
		<section id="disputes" class="container-shell scroll-mt-24 border-t border-line-subtle py-10 lg:py-12"><h2 class="text-2xl font-semibold text-primary sm:text-3xl">{disputes.title}</h2><p class="mt-3 max-w-3xl text-secondary">{disputes.intro}</p><ul class="mt-6 max-w-3xl space-y-4">{disputes.steps.map((s) => <li class="border-l-2 border-accent/30 pl-4"><h3 class="font-semibold text-primary">{s.heading}</h3><p class="mt-2 text-sm text-secondary" set:html={s.body} /></li>)}</ul></section>
		<FAQ items={faqItems} title={faqSection.title} description={faqSection.description} />
	</main>
	<Footer />
	<script>
		const form = document.querySelector('[data-parenting-plan-form]');
		const summary = document.querySelector('[data-plan-preview-summary]');
		function getPlanState() {
			if (!(form instanceof HTMLFormElement)) return { scheduleType: '50/50 custody schedule', holidayPlan: 'Alternating holidays', exchangeLocation: 'School curb', parentA: 'Parent A', parentB: 'Parent B' };
			const data = new FormData(form);
			return { scheduleType: String(data.get('scheduleType') || ''), holidayPlan: String(data.get('holidayPlan') || ''), exchangeLocation: String(data.get('exchangeLocation') || ''), parentA: String(data.get('parentA') || 'Parent A'), parentB: String(data.get('parentB') || 'Parent B') };
		}
		function buildOutline() {
			const s = getPlanState();
			return ['Parenting Plan Outline', '', `Parents: ${s.parentA} / ${s.parentB}`, '', `Exhibit A — Regular schedule: ${s.scheduleType}`, `Exhibit B — Holidays: ${s.holidayPlan}`, `Exchanges: ${s.exchangeLocation}`, '', 'Communication:', 'Medical decisions:', 'School decisions:', 'Travel notice:', 'Expenses:', 'Dispute resolution:', 'Review date:', '', 'Educational planning tool. Not legal advice.'].join('\n');
		}
		function updatePreview() {
			const s = getPlanState();
			if (summary) summary.textContent = `${s.parentA} and ${s.parentB}: ${s.scheduleType}, ${s.holidayPlan.toLowerCase()}, exchanges at ${s.exchangeLocation || 'TBD'}.`;
		}
		form?.addEventListener('input', updatePreview);
		form?.addEventListener('change', updatePreview);
		document.querySelector('[data-print-parenting-plan]')?.addEventListener('click', () => window.print());
		document.querySelector('[data-copy-parenting-plan]')?.addEventListener('click', async (e) => {
			const btn = e.currentTarget;
			if (!(btn instanceof HTMLButtonElement)) return;
			try { await navigator.clipboard.writeText(buildOutline()); btn.textContent = 'Copied'; } catch { btn.textContent = 'Copy failed'; }
			setTimeout(() => { btn.textContent = 'Copy outline'; }, 1800);
		});
		updatePreview();
	</script>
</BaseLayout>
