---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import FAQ from '../components/FAQ.astro';
import TexasChildSupportCalculator from '../components/tool/TexasChildSupportCalculator.astro';
import TexasIncomeFlowGraphic from '../components/tools/texas-child-support-calculator/TexasIncomeFlowGraphic.astro';
import SupportWorksheetGraphic from '../components/tools/texas-child-support-calculator/SupportWorksheetGraphic.astro';
import GuidelineCalculationGraphic from '../components/tools/texas-child-support-calculator/GuidelineCalculationGraphic.astro';
import { getCanonicalUrl } from '../lib/seo/metadata';
import {
	buildArticleSchema,
	buildBreadcrumbSchema,
	buildFAQSchema,
	buildOrganizationSchema,
	buildSoftwareApplicationSchema,
	buildWebPageSchema,
} from '../lib/seo/schema';
import {
	articleTocItems,
	editorialReview,
	estimateDifferences,
	faqItems,
	faqSection,
	hero,
	howCalculated,
	incomeExamples,
	incomeFlow,
	meta,
	officialResources,
	relatedReading,
	worksheetFields,
} from '../data/texasChildSupportCalculatorPage';

const canonical = '/texas-child-support-calculator/';
const canonicalUrl = getCanonicalUrl(canonical);
const breadcrumbs = [
	{ name: 'Home', url: getCanonicalUrl('/') },
	{ name: 'Texas Child Support Calculator', url: canonicalUrl },
];
const schema = [
	buildWebPageSchema({ name: meta.title, description: meta.description, url: canonicalUrl }),
	buildArticleSchema({
		headline: hero.headline,
		description: meta.description,
		url: canonicalUrl,
		datePublished: meta.datePublished,
		dateModified: meta.dateModified,
		authorName: editorialReview.reviewer,
	}),
	buildFAQSchema(faqItems),
	buildBreadcrumbSchema(breadcrumbs),
	buildOrganizationSchema({ name: 'CustodyBuilder', url: getCanonicalUrl('/') }),
	{
		...buildSoftwareApplicationSchema({
			name: 'Texas Child Support Calculator',
			description: meta.description,
			url: canonicalUrl,
			applicationCategory: 'LegalApplication',
		}),
		operatingSystem: 'Web',
		offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
	},
];
---

<BaseLayout title={meta.title} description={meta.description} canonical={canonical}>
	<JsonLd slot="head" data={schema} />
	<Navbar />
	<Breadcrumbs items={breadcrumbs} />
	<main>
		<section class="container-shell grid gap-5 py-4 sm:py-5 lg:grid-cols-[minmax(0,0.85fr)_minmax(0,1.15fr)] lg:items-start lg:gap-7 lg:py-6 xl:w-[min(100%,1360px)]" id="calculator">
			<div class="lg:pt-2">
				<h1 class="max-w-3xl text-4xl font-semibold leading-[0.98] tracking-[-0.055em] text-primary sm:text-5xl">{hero.headline}</h1>
				<p class="mt-4 text-base leading-7 text-secondary">{hero.opening}</p>
				<p class="mt-3 text-sm leading-6 text-secondary">{hero.closing}</p>
				<div class="mt-4 text-xs leading-5 text-muted">
					<p class="font-semibold text-secondary">Reviewed for:</p>
					<ul class="mt-1 list-inside list-disc">{editorialReview.reviewedFor.map((i) => <li>{i}</li>)}</ul>
					<p class="mt-2">
						Reviewed by <a href={editorialReview.reviewerHref} class="font-semibold text-secondary underline">{editorialReview.reviewer}</a>
						{' · '}<a href={editorialReview.methodologyHref} class="font-semibold text-secondary underline">{editorialReview.methodologyLabel}</a>
						{' · '}{editorialReview.disclaimer}
					</p>
				</div>
			</div>
			<TexasChildSupportCalculator />
		</section>

		<nav class="container-shell border-y border-line-subtle py-3" aria-label="On this page">
			<ul class="flex flex-wrap gap-x-4 gap-y-1 text-xs font-semibold text-secondary">
				{articleTocItems.map((i) => <li><a href={`#${i.id}`} class="hover:text-accent">{i.label}</a></li>)}
			</ul>
		</nav>

		<section id="income-flow" class="container-shell scroll-mt-24 py-10 lg:py-12">
			<div class="grid gap-8 lg:grid-cols-[1fr_360px]">
				<div>
					<h2 class="text-2xl font-semibold text-primary sm:text-3xl">{incomeFlow.title}</h2>
					<p class="mt-3 text-secondary">{incomeFlow.intro}</p>
					<ol class="mt-6 space-y-3">
						{incomeFlow.flow.map((step, i) => (
							<li class="flex gap-3">
								<span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-accent/15 text-xs font-bold text-accent">{i + 1}</span>
								<div><p class="font-semibold text-primary">{step.label}</p><p class="mt-1 text-sm text-secondary">{step.detail}</p></div>
							</li>
						))}
					</ol>
				</div>
				<TexasIncomeFlowGraphic />
			</div>
		</section>

		<section id="how-calculated" class="container-shell scroll-mt-24 border-t border-line-subtle py-10 lg:py-12">
			<div class="grid gap-8 lg:grid-cols-[1fr_360px]">
				<div>
					<h2 class="text-2xl font-semibold text-primary sm:text-3xl">{howCalculated.title}</h2>
					<p class="mt-3 text-secondary">{howCalculated.intro}</p>
					<div class="mt-6 space-y-5">
						{howCalculated.steps.map((item) => (
							<article><h3 class="font-semibold text-primary">{item.step}</h3><p class="mt-2 text-sm text-secondary">{item.body}</p></article>
						))}
					</div>
					<p class="mt-4 text-sm text-secondary">{howCalculated.close}</p>
				</div>
				<GuidelineCalculationGraphic />
			</div>
		</section>

		<section id="worksheet" class="container-shell scroll-mt-24 border-t border-line-subtle py-10 lg:py-12">
			<div class="grid gap-8 lg:grid-cols-[1fr_360px]">
				<div>
					<h2 class="text-2xl font-semibold text-primary sm:text-3xl">{worksheetFields.title}</h2>
					<p class="mt-3 text-secondary">{worksheetFields.intro}</p>
					<ul class="mt-6 space-y-4">
						{worksheetFields.fields.map((f) => (
							<li class="border-l-2 border-accent/30 pl-4"><h3 class="font-semibold text-primary">{f.label}</h3><p class="mt-2 text-sm text-secondary">{f.body}</p></li>
						))}
					</ul>
					<p class="mt-4 text-sm text-secondary">{worksheetFields.close}</p>
				</div>
				<SupportWorksheetGraphic />
			</div>
		</section>

		<section id="income-examples" class="container-shell scroll-mt-24 border-t border-line-subtle py-10 lg:py-12">
			<h2 class="text-2xl font-semibold text-primary sm:text-3xl">{incomeExamples.title}</h2>
			<p class="mt-3 max-w-3xl text-secondary">{incomeExamples.intro}</p>
			<p class="mt-2 text-sm text-muted">{incomeExamples.tableCaution}</p>
			<div class="mt-6 max-w-4xl overflow-x-auto rounded-[1.5rem] ring-1 ring-line-subtle">
				<table class="w-full min-w-[640px] text-left text-sm">
					<thead class="bg-surface-elevated text-primary">
						<tr>
							<th class="px-4 py-3 font-semibold">Monthly gross income</th>
							<th class="px-4 py-3 font-semibold">Est. net resources</th>
							<th class="px-4 py-3 font-semibold">1 child</th>
							<th class="px-4 py-3 font-semibold">2 children</th>
							<th class="px-4 py-3 font-semibold">3 children</th>
						</tr>
					</thead>
					<tbody class="divide-y divide-line-subtle text-secondary">
						{incomeExamples.rows.map((row) => (
							<tr>{row.map((cell) => <td class="px-4 py-3">{cell}</td>)}</tr>
						))}
					</tbody>
				</table>
			</div>
			<p class="mt-4 text-sm text-secondary">{incomeExamples.note}</p>
		</section>

		<section id="estimate-differences" class="container-shell scroll-mt-24 border-t border-line-subtle py-10 lg:py-12">
			<h2 class="text-2xl font-semibold text-primary sm:text-3xl">{estimateDifferences.title}</h2>
			<p class="mt-3 max-w-3xl text-secondary">{estimateDifferences.intro}</p>
			<ul class="mt-6 max-w-3xl space-y-4">
				{estimateDifferences.factors.map((f) => (
					<li><h3 class="font-semibold text-primary">{f.heading}</h3><p class="mt-2 text-sm text-secondary">{f.body}</p></li>
				))}
			</ul>
			<p class="mt-4 max-w-3xl text-sm text-secondary">{estimateDifferences.close}</p>
		</section>

		<section id="related-reading" class="container-shell scroll-mt-24 border-t border-line-subtle py-10 lg:py-12">
			<h2 class="text-2xl font-semibold text-primary sm:text-3xl">{relatedReading.title}</h2>
			<div class="mt-4 max-w-3xl space-y-3 text-secondary">
				{relatedReading.paragraphs.map((p) => <p set:html={p} />)}
			</div>
			<div class="mt-6 max-w-3xl grid gap-2">
				{officialResources.links.map((link) => (
					<a href={link.href} target="_blank" rel="noopener noreferrer" class="text-sm font-semibold text-accent underline">{link.title}</a>
				))}
			</div>
		</section>

		<FAQ items={faqItems} title={faqSection.title} description={faqSection.description} />
	</main>
	<Footer />
	<script>
		import { trackGa4Event } from '../lib/analytics/ga4';
		trackGa4Event('view_texas_child_support');
	</script>
</BaseLayout>
