---

<BaseLayout
	title={title}
	description={description}
	canonical={canonical}
	ogTitle={title}
	ogDescription={description}
>
	<JsonLd slot="head" data={schema} />
	<Navbar />
	<Breadcrumbs items={breadcrumbs} />
	<main>
		<section id="calculator" class="container-shell grid gap-5 py-4 sm:py-5 lg:grid-cols-[minmax(0,0.8fr)_minmax(0,1.2fr)] lg:items-start lg:gap-7 lg:py-6 xl:w-[min(100%,1360px)]">
			<div class="lg:pt-2">
				<p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">Texas child support estimate</p>
				<h1 class="mt-2.5 max-w-3xl text-4xl font-semibold leading-[0.98] tracking-[-0.055em] text-primary sm:text-5xl lg:text-[3.35rem]">
					Texas Child Support Calculator 2026
				</h1>
				<a id="texas-child-support-2025-cap-notice" href="#cap-update" class="mt-4 block rounded-2xl bg-[rgba(34,197,94,0.12)] p-3 text-sm leading-6 text-secondary shadow-[inset_0_0_0_1px_rgba(34,197,94,0.28)] transition-colors hover:text-primary">
					<strong class="text-primary">2025 update:</strong> Starting September 1, 2025, Texas increases the child support cap from $9,200 to $11,700 in monthly net resources. Guideline percentages remain unchanged.
				</a>
				<p class="mt-3 text-base leading-7 text-secondary">
					Estimate monthly Texas child support using Texas guideline percentages, net resources, child count, the 2025 cap update, and custody schedule considerations.
				</p>
				<div class="mt-3 rounded-2xl bg-page/70 p-3 text-sm leading-6 text-secondary shadow-[inset_0_0_0_1px_var(--border-subtle)]">
					This calculator is for planning only and is not legal advice or an official court calculation.
				</div>
			</div>

			<TexasChildSupportCalculator />
		</section>

		<section class="container-shell pb-8" aria-label="Child support planning actions">
			<div class="soft-card grid gap-4 rounded-[1.5rem] p-5 sm:p-6 lg:grid-cols-[1fr_auto] lg:items-center">
				<div>
					<p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">After your estimate</p>
					<h2 class="mt-2 text-2xl font-semibold tracking-[-0.04em] text-primary">Connect support planning to the parenting calendar.</h2>
					<p class="mt-2 text-sm leading-6 text-secondary">Child support estimates are easier to discuss when you can also show the custody schedule, parenting time, and visitation calendar behind the plan.</p>
				</div>
				<div class="flex flex-col gap-3 sm:flex-row sm:flex-wrap lg:justify-end">
					{calculatorCtas.map((cta) => (
						<a href={cta.href} class={`${cta.style === 'primary' ? 'btn-primary' : 'btn-secondary'} ${ctaClass} w-full sm:w-auto`}>
							{cta.label}
						</a>
					))}
				</div>
			</div>
		</section>

		<section class="container-shell grid gap-6 py-10 lg:grid-cols-[280px_minmax(0,1fr)] lg:gap-8 lg:py-14 xl:w-[min(100%,1360px)]">
			<aside class="soft-card h-fit rounded-[1.25rem] p-4 lg:sticky lg:top-24 lg:max-w-[280px]">
