---
import ThemeToggle from './ThemeToggle.astro';

interface NavItem {
	label: string;
	href: string;
	isActive?: boolean;
	sectionId?: string;
}

type NavConfigItem =
	| { label: string; href: string; type: 'page' }
	| { label: string; anchor: string; type: 'home-anchor' };

const homepageNavigationConfig: NavConfigItem[] = [
	{ label: 'Generator', href: '/custody-schedule-generator/', type: 'page' },
	{
		label: 'Tools',
		anchor: 'tools',
		type: 'home-anchor',
	},
	{ label: 'Schedules', anchor: 'schedules', type: 'home-anchor' },
	{ label: 'Calculators', anchor: 'calculators', type: 'home-anchor' },
	{ label: 'Resources', anchor: 'resources', type: 'home-anchor' },
	{ label: 'FAQ', anchor: 'faq', type: 'home-anchor' },
];

const generatorNavigationConfig: NavConfigItem[] = [
	{ label: 'Home', href: '/', type: 'page' },
	{ label: 'Generator', href: '/custody-schedule-generator/', type: 'page' },
	{ label: 'Schedules', anchor: 'schedules', type: 'home-anchor' },
	{ label: 'Calculators', anchor: 'calculators', type: 'home-anchor' },
	{ label: 'Resources', anchor: 'resources', type: 'home-anchor' },
	{ label: 'FAQ', anchor: 'faq', type: 'home-anchor' },
];

const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';
const isHome = pathname === '/';
const isGeneratorPage = pathname === '/custody-schedule-generator/';
const getHomeSectionHref = (anchor: string) => (isHome ? `#${anchor}` : `/#${anchor}`);
const isSchedulePage = /^\/(?:schedules\/)?(?:\d+-\d+-\d+(?:-\d+)?|week-on-week-off|every-other-weekend|50-50|60-40|70-30|80-20)-custody-schedule$/.test(pathname);
const isCalculatorPage = pathname.includes('calculator') || pathname.startsWith('/calculators/');
const navigationConfig = isGeneratorPage ? generatorNavigationConfig : homepageNavigationConfig;

const navItems: NavItem[] = navigationConfig.map((item) => {
	if (item.type === 'page') {
		return {
			label: item.label,
			href: item.href,
			isActive: pathname === item.href,
		};
	}

	let isActive = false;
	if (!isHome) {
		if (item.anchor === 'schedules') isActive = isSchedulePage;
		if (item.anchor === 'calculators') isActive = isCalculatorPage;
		if (item.anchor === 'resources') isActive = pathname.startsWith('/blog/') || pathname.includes('template') || pathname.includes('guide');
	}

	return {
		label: item.label,
		href: getHomeSectionHref(item.anchor),
		sectionId: item.anchor,
		isActive,
	};
});
---

<header class="site-header sticky top-0 z-[1000] border-b shadow-[0_1px_0_rgba(15,23,42,0.02)] backdrop-blur-[16px]">
	<nav class="container-shell relative flex h-16 items-center justify-between gap-3 sm:h-[68px] sm:gap-4">
		<a href="/" class="group flex min-w-0 shrink-0 items-center lg:ml-7" aria-label="CustodyBuilder home">
			<span class="site-logo-lockup inline-flex max-w-[164px] items-center transition-transform duration-200 group-hover:-translate-y-0.5 sm:max-w-[190px] xl:max-w-none">
				<img src="/logo/custodybuilder-logo-light.svg" alt="CustodyBuilder custody schedule generator logo" width="498" height="120" class="theme-logo-light h-9 w-auto sm:h-11" decoding="async" />
				<img src="/logo/custodybuilder-logo-dark.svg" alt="" width="498" height="120" class="theme-logo-dark hidden h-9 w-auto sm:h-11" decoding="async" aria-hidden="true" />
			</span>
		</a>

		<div class="site-nav-pill hidden min-w-0 flex-1 overflow-visible rounded-full border px-1.5 py-1 shadow-[0_8px_24px_rgba(15,23,42,0.04)] backdrop-blur-xl lg:flex lg:items-center lg:justify-start xl:justify-center">
			{navItems.map((item) => (
				<a
					href={item.href}
					class="site-nav-link shrink-0 whitespace-nowrap rounded-full px-3.5 py-2 text-sm font-medium transition-colors duration-200 xl:px-4"
					aria-current={item.isActive ? 'page' : undefined}
					data-home-section={isHome ? item.sectionId : undefined}
				>
					{item.label}
				</a>
			))}
		</div>

		<div class="flex shrink-0 items-center gap-2">
			<ThemeToggle />
			<button
				type="button"
				class="site-mobile-menu-button inline-flex h-11 w-11 items-center justify-center rounded-full border text-primary shadow-[0_8px_24px_rgba(15,23,42,0.04)] transition-colors duration-200 hover:bg-surface-hover focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent lg:hidden"
				aria-label="Open navigation menu"
				aria-expanded="false"
				aria-controls="mobile-navigation-menu"
				data-mobile-menu-button
			>
				<span class="sr-only">Menu</span>
				<span class="relative h-4 w-5" aria-hidden="true">
					<span class="absolute left-0 top-0 h-0.5 w-5 rounded-full bg-current transition-transform duration-200" data-menu-line-top></span>
					<span class="absolute left-0 top-[7px] h-0.5 w-5 rounded-full bg-current transition-opacity duration-200" data-menu-line-middle></span>
					<span class="absolute bottom-0 left-0 h-0.5 w-5 rounded-full bg-current transition-transform duration-200" data-menu-line-bottom></span>
				</span>
			</button>
		</div>

	</nav>
	<div
		id="mobile-navigation-menu"
		class="site-mobile-menu absolute left-4 right-4 top-full z-[999] hidden rounded-3xl border p-2 shadow-[0_20px_50px_rgba(15,23,42,0.16)] lg:hidden"
		data-mobile-menu
	>
		{navItems.map((item) => (
			<>
				<a
					href={item.href}
					class="site-nav-link flex min-h-12 w-full items-center rounded-2xl px-[18px] py-3.5 text-left text-base font-semibold transition-colors duration-200"
					aria-current={item.isActive ? 'page' : undefined}
					data-home-section={isHome ? item.sectionId : undefined}
					data-mobile-menu-link
				>
					{item.label}
				</a>
			</>
		))}
	</div>
	<script>
		const button = document.querySelector('[data-mobile-menu-button]');
		const menu = document.querySelector('[data-mobile-menu]');
		const links = Array.from(document.querySelectorAll('[data-mobile-menu-link]'));
		const topLine = document.querySelector('[data-menu-line-top]');
		const middleLine = document.querySelector('[data-menu-line-middle]');
		const bottomLine = document.querySelector('[data-menu-line-bottom]');

		function setMenuOpen(isOpen) {
			if (!(button instanceof HTMLButtonElement) || !(menu instanceof HTMLElement)) return;

			button.setAttribute('aria-expanded', String(isOpen));
			button.setAttribute('aria-label', isOpen ? 'Close navigation menu' : 'Open navigation menu');
			menu.classList.toggle('hidden', !isOpen);
			topLine?.classList.toggle('translate-y-[7px]', isOpen);
			topLine?.classList.toggle('rotate-45', isOpen);
			middleLine?.classList.toggle('opacity-0', isOpen);
			bottomLine?.classList.toggle('-translate-y-[7px]', isOpen);
			bottomLine?.classList.toggle('-rotate-45', isOpen);
		}

		button?.addEventListener('click', (event) => {
			event.stopPropagation();
			const isOpen = button instanceof HTMLButtonElement && button.getAttribute('aria-expanded') === 'true';
			setMenuOpen(!isOpen);
		});

		links.forEach((link) => {
			link.addEventListener('click', () => setMenuOpen(false));
		});

		document.addEventListener('click', (event) => {
			if (!(menu instanceof HTMLElement) || !(button instanceof HTMLButtonElement)) return;
			const target = event.target;
			if (!(target instanceof Node)) return;
			if (menu.classList.contains('hidden')) return;
			if (menu.contains(target) || button.contains(target)) return;
			setMenuOpen(false);
		});

		document.addEventListener('keydown', (event) => {
			if (event.key === 'Escape') setMenuOpen(false);
		});

		const sectionLinks = Array.from(document.querySelectorAll('[data-home-section]'));
		const sectionIds = Array.from(new Set(sectionLinks.map((link) => link.getAttribute('data-home-section')).filter(Boolean)));
		const sections = sectionIds
			.map((id) => document.getElementById(id))
			.filter((section) => section instanceof HTMLElement);

		function setActiveSection(sectionId) {
			sectionLinks.forEach((link) => {
				if (!(link instanceof HTMLAnchorElement)) return;
				if (link.getAttribute('data-home-section') === sectionId) {
					link.setAttribute('aria-current', 'true');
				} else if (link.getAttribute('aria-current') === 'true') {
					link.removeAttribute('aria-current');
				}
			});
		}

		if (sections.length > 0 && 'IntersectionObserver' in window) {
			const visibleSections = new Map();
			const observer = new IntersectionObserver(
				(entries) => {
					entries.forEach((entry) => {
						if (!(entry.target instanceof HTMLElement)) return;
						if (entry.isIntersecting) {
							visibleSections.set(entry.target.id, entry.intersectionRatio);
						} else {
							visibleSections.delete(entry.target.id);
						}
					});

					const activeSection = Array.from(visibleSections.entries()).sort((a, b) => b[1] - a[1])[0]?.[0];
					if (activeSection) setActiveSection(activeSection);
				},
				{ rootMargin: '-18% 0px -62% 0px', threshold: [0.01, 0.2, 0.45] },
			);

			sections.forEach((section) => observer.observe(section));
		}

		sectionLinks.forEach((link) => {
			link.addEventListener('click', () => {
				const sectionId = link.getAttribute('data-home-section');
				if (sectionId) setActiveSection(sectionId);
			});
		});
	</script>
</header>
