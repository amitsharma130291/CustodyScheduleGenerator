---
import ThemeToggle from './ThemeToggle.astro';

const navItems = [
	{ label: 'Generator', href: '#generator' },
	{ label: 'Schedules', href: '#schedules' },
	{ label: 'How it works', href: '#how-it-works' },
	{ label: 'FAQ', href: '#faq' },
];
---

<header class="sticky top-0 z-50 border-b border-line-subtle/60 bg-page/78 shadow-[0_1px_0_rgba(255,255,255,0.03)] backdrop-blur-2xl">
	<nav class="container-shell flex h-16 items-center justify-between gap-3 sm:h-20 sm:gap-6">
		<a href="/" class="group flex min-w-0 items-center" aria-label="CustodyBuilder home">
			<span class="inline-flex max-w-[178px] items-center rounded-2xl bg-white px-3 py-1.5 shadow-[0_10px_28px_rgba(0,0,0,0.16),inset_0_0_0_1px_rgba(15,23,42,0.08)] transition-all duration-200 group-hover:-translate-y-0.5 group-hover:shadow-[0_14px_34px_rgba(0,0,0,0.20),inset_0_0_0_1px_rgba(15,23,42,0.12)] sm:max-w-none sm:px-3.5 sm:py-2">
				<img src="/logo/logo.svg" alt="CustodyBuilder" class="h-8 w-auto sm:h-10" decoding="async" />
			</span>
		</a>

		<div class="hidden rounded-full border border-line-subtle bg-surface/55 px-2 py-1 shadow-[inset_0_1px_0_rgba(255,255,255,0.04)] backdrop-blur-xl md:flex md:items-center md:justify-center">
			{navItems.map((item) => (
				<a
					href={item.href}
					class="rounded-full px-4 py-2 text-[13px] font-medium text-muted transition-colors duration-200 hover:bg-surface-hover hover:text-primary"
				>
					{item.label}
				</a>
			))}
		</div>

		<div class="flex shrink-0 items-center gap-2">
			<ThemeToggle />
			<a
				href="#generator"
				class="btn-primary hidden whitespace-nowrap rounded-full px-5 py-2.5 text-[13px] font-semibold transition-all duration-200 ease-out hover:-translate-y-px hover:shadow-[0_10px_30px_rgba(94,106,210,0.14)] active:translate-y-0 sm:inline-flex"
			>
				Build my schedule
			</a>
		</div>
	</nav>
</header>
