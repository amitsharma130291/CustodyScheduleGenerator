---
interface Props {
	date?: string;
}

const { date } = Astro.props;
const buildDate = date ? new Date(`${date}T00:00:00`) : new Date();
const isoDate = buildDate.toISOString().slice(0, 10);
const displayDate = buildDate.toLocaleDateString('en-US', {
	month: 'long',
	day: 'numeric',
	year: 'numeric',
});
---

<p class="mt-4 text-sm font-medium text-muted">
	Last Updated: <time datetime={isoDate}>{displayDate}</time>
</p>
