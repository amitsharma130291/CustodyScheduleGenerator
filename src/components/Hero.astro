---
import CalendarPreview from './tool/CalendarPreview.astro';
import ExportActions from './tool/ExportActions.astro';
import GeneratorPanel from './tool/GeneratorPanel.astro';
import { generateSchedule } from '../lib/schedules/generateSchedule';
import { getDefaultStartDate } from '../lib/schedules/format';

const startDate = getDefaultStartDate();
const schedule = generateSchedule({
	scheduleId: '223',
	startDate,
});
---

<section class="atmosphere hero-tool-section container-shell grid items-center gap-5 py-6 scroll-mt-24 sm:gap-6 sm:py-8">
	<div class="relative z-10">
		<p class="inline-flex rounded-full border border-line-subtle bg-surface/50 px-4 py-2 text-xs font-semibold uppercase tracking-[0.18em] text-muted shadow-[inset_0_1px_0_rgba(255,255,255,0.04)] backdrop-blur-xl">
			Parenting time calendar builder
		</p>
		<h1 class="mt-5 max-w-[720px] text-[clamp(44px,13vw,56px)] font-semibold leading-[0.97] tracking-[-0.055em] text-primary lg:text-[clamp(52px,5vw,64px)] lg:leading-[0.96] xl:text-[clamp(60px,4.8vw,72px)] xl:leading-[0.94]">
			Custody Schedule Generator
		</h1>
		<p class="mt-4 max-w-[620px] text-lg leading-[1.5] text-secondary lg:mt-5 lg:text-xl lg:leading-[1.55] xl:mt-5 xl:leading-[1.5]">
			Create a custody schedule, compare parenting schedules, build a custody calendar, and estimate parenting time percentages using common custody arrangements.
		</p>
		<div class="mt-3 flex max-w-2xl flex-wrap gap-2 text-xs font-semibold text-muted" aria-label="Popular custody schedule options">
			<span class="rounded-full bg-surface/55 px-3 py-1.5 shadow-[inset_0_0_0_1px_var(--border-subtle)]">50/50 Custody</span>
			<span class="rounded-full bg-surface/55 px-3 py-1.5 shadow-[inset_0_0_0_1px_var(--border-subtle)]">60/40 Custody</span>
			<span class="rounded-full bg-surface/55 px-3 py-1.5 shadow-[inset_0_0_0_1px_var(--border-subtle)]">70/30 Custody</span>
			<span class="rounded-full bg-surface/55 px-3 py-1.5 shadow-[inset_0_0_0_1px_var(--border-subtle)]">80/20 Custody</span>
			<span class="rounded-full bg-surface/55 px-3 py-1.5 shadow-[inset_0_0_0_1px_var(--border-subtle)]">2-2-3 Schedule</span>
			<span class="rounded-full bg-surface/55 px-3 py-1.5 shadow-[inset_0_0_0_1px_var(--border-subtle)]">2-2-5-5 Schedule</span>
		</div>
		<p class="mt-3 max-w-[620px] text-sm font-semibold leading-6 text-muted">
			Free custody calendar builder • Parenting time calculator • Printable PDF exports
		</p>
		<p class="mt-1.5 max-w-[620px] text-xs font-medium leading-5 text-muted">
			<span class="font-semibold text-primary">Reviewed by CustodyBuilder Editorial Team</span>
			<span aria-hidden="true"> · </span>
			Last updated: June 17, 2026
		</p>

		<div class="mt-4 flex flex-col gap-3 sm:flex-row lg:mt-4 xl:mt-4">
			<a
				href="#generator"
				class="btn-primary inline-flex h-13 w-full items-center justify-center whitespace-nowrap rounded-full px-8 text-base font-semibold transition-all duration-200 ease-out hover:-translate-y-px active:translate-y-0 sm:w-auto"
			>
				Start with the generator
			</a>
			<a
				href="#find-a-schedule"
				class="btn-secondary inline-flex h-13 w-full items-center justify-center rounded-full px-8 text-base font-semibold transition-all duration-200 ease-out hover:-translate-y-px hover:shadow-[0_10px_24px_rgba(0,0,0,0.12)] active:translate-y-0 sm:w-auto"
			>
				Find the right schedule
			</a>
		</div>

		<div class="mt-3 flex max-w-2xl flex-wrap gap-2 text-xs font-semibold text-secondary" aria-label="CustodyBuilder trust signals">
			<span class="inline-flex items-center gap-1.5 rounded-full bg-surface/70 px-3 py-1.5 shadow-[inset_0_0_0_1px_var(--border-subtle)]"><span class="text-parent-b" aria-hidden="true">✓</span> No account required</span>
			<span class="inline-flex items-center gap-1.5 rounded-full bg-surface/70 px-3 py-1.5 shadow-[inset_0_0_0_1px_var(--border-subtle)]"><span class="text-parent-b" aria-hidden="true">✓</span> No signup required</span>
			<span class="inline-flex items-center gap-1.5 rounded-full bg-surface/70 px-3 py-1.5 shadow-[inset_0_0_0_1px_var(--border-subtle)]"><span class="text-parent-b" aria-hidden="true">✓</span> Printable PDF exports</span>
		</div>

	</div>

	<div id="generator" class="hero-generator-shell relative scroll-mt-24 lg:-mt-3 xl:-mt-5">
		<div class="absolute -inset-8 rounded-full bg-[radial-gradient(circle,rgba(37,99,235,0.2),transparent_66%)] blur-3xl" aria-hidden="true"></div>
		<div class="premium-card hero-generator-card relative overflow-visible rounded-[1.75rem] border-line p-4 sm:rounded-[2.25rem] sm:p-5">
			<div class="absolute inset-x-10 top-0 h-px bg-gradient-to-r from-transparent via-white/30 to-transparent" aria-hidden="true"></div>
			<div class="hero-generator-inner rounded-[1.4rem] bg-surface-elevated p-0 shadow-[inset_0_1px_0_rgba(255,255,255,0.07)] sm:rounded-[1.8rem]">
				<div class="hero-generator-grid">
					<GeneratorPanel selectedScheduleId="223" compact />
					<div class="hero-calendar-column grid gap-3">
						<CalendarPreview schedule={schedule}>
							<ExportActions slot="actions" />
						</CalendarPreview>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>
