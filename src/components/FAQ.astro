---
interface FAQItem {
	question: string;
	answer: string;
	links?: {
		label: string;
		href: string;
	}[];
}

interface Props {
	items: FAQItem[];
	platformItems?: FAQItem[];
	eyebrow?: string;
	title?: string;
	description?: string;
	scheduleHeading?: string;
}

const {
	items,
	platformItems = [],
	eyebrow = 'FAQ',
	title = 'Common Questions About Custody Schedules',
	description = 'Learn how popular custody schedules work and compare parenting time arrangements before creating your calendar.',
	scheduleHeading,
} = Astro.props;
---

<section id="faq" class="faq-accordion container-shell scroll-mt-24 py-section-loose">
	<div class="mx-auto max-w-3xl text-center">
		<p class="text-[11px] font-semibold uppercase tracking-[0.22em] text-muted">{eyebrow}</p>
		<h2 class="mt-2.5 text-4xl font-semibold leading-[1.04] tracking-[-0.05em] text-primary sm:text-5xl">
			{title}
		</h2>
		<p class="mt-4 text-lg leading-[1.65] text-secondary">
			{description}
		</p>
	</div>

	<div class="premium-card mx-auto mt-8 max-w-4xl overflow-hidden rounded-[2rem] shadow-[0_28px_80px_rgba(15,23,42,0.07),inset_0_1px_0_rgba(255,255,255,0.72)]">
		{platformItems.length > 0 && (
			<div class="border-b border-line-subtle/80 bg-surface/45 px-5 py-3.5 sm:px-6">
				<h3 class="text-[11px] font-semibold uppercase tracking-[0.2em] text-muted">About CustodyBuilder</h3>
			</div>
		)}
		<div class="divide-y divide-line-subtle/80">
			{platformItems.map((item) => (
				<details
					class="group p-5 open:bg-surface-elevated/80 hover:bg-surface-hover/70 sm:p-5"
					data-faq-question={item.question}
					data-faq-group="about_custodybuilder"
				>
					<summary class="flex cursor-pointer list-none items-center justify-between gap-5 text-left text-lg font-semibold leading-snug tracking-[-0.025em] text-primary">
						{item.question}
						<span class="grid h-8 w-8 shrink-0 place-items-center rounded-full bg-surface/80 text-muted shadow-[inset_0_0_0_1px_var(--border-subtle)] transition-all duration-180 ease-out group-hover:border-accent/20 group-hover:text-primary group-open:rotate-45 group-open:bg-accent/10 group-open:text-accent" aria-hidden="true">
							+
						</span>
					</summary>
					<p class="mt-3.5 max-w-3xl text-sm leading-[1.65] text-secondary">{item.answer}</p>
					{item.links && item.links.length > 0 && (
						<div class="mt-3 flex flex-wrap gap-2">
							{item.links.map((link) => (
								<a href={link.href} class="inline-flex rounded-full bg-surface px-3 py-1.5 text-xs font-semibold text-accent underline decoration-line underline-offset-4 shadow-[inset_0_0_0_1px_var(--border-subtle)] transition-colors duration-180 hover:text-primary focus-visible:outline-none focus-visible:ring-[3px] focus-visible:ring-[var(--focus-ring)]">
									{link.label} →
								</a>
							))}
						</div>
					)}
				</details>
			))}
		</div>

		{scheduleHeading && (
			<div class="border-y border-line-subtle/80 bg-surface/45 px-5 py-3.5 sm:px-6">
				<h3 class="text-[11px] font-semibold uppercase tracking-[0.2em] text-muted">{scheduleHeading}</h3>
			</div>
		)}
		<div class="divide-y divide-line-subtle/80">
			{items.map((item) => (
			<details
				class="group p-5 open:bg-surface-elevated/80 hover:bg-surface-hover/70 sm:p-5"
				data-faq-question={item.question}
				data-faq-group="custody_schedule_questions"
			>
				<summary class="flex cursor-pointer list-none items-center justify-between gap-5 text-left text-lg font-semibold leading-snug tracking-[-0.025em] text-primary">
					{item.question}
					<span class="grid h-8 w-8 shrink-0 place-items-center rounded-full bg-surface/80 text-muted shadow-[inset_0_0_0_1px_var(--border-subtle)] transition-all duration-180 ease-out group-hover:border-accent/20 group-hover:text-primary group-open:rotate-45 group-open:bg-accent/10 group-open:text-accent" aria-hidden="true">
						+
					</span>
				</summary>
				<p class="mt-3.5 max-w-3xl text-sm leading-[1.65] text-secondary">{item.answer}</p>
				{item.links && item.links.length > 0 && (
					<div class="mt-3 flex flex-wrap gap-2">
						{item.links.map((link) => (
							<a href={link.href} class="inline-flex rounded-full bg-surface px-3 py-1.5 text-xs font-semibold text-accent underline decoration-line underline-offset-4 shadow-[inset_0_0_0_1px_var(--border-subtle)] transition-colors duration-180 hover:text-primary focus-visible:outline-none focus-visible:ring-[3px] focus-visible:ring-[var(--focus-ring)]">
								{link.label} →
							</a>
						))}
					</div>
				)}
			</details>
			))}
		</div>
	</div>
</section>
