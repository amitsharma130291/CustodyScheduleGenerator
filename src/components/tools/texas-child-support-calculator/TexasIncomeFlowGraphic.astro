---
const steps = [
	{ label: 'Gross income', sub: '$6,500 / mo', active: true },
	{ label: 'Deductions', sub: 'Taxes · union dues · health', active: false },
	{ label: 'Net resources', sub: '$4,850 / mo', active: false },
	{ label: 'Guideline %', sub: '20% · 1 child', active: false },
	{ label: 'Support', sub: '$970 / mo', active: false },
];
---

<figure class="texas-income-flow w-full max-w-full overflow-hidden rounded-[1.25rem] border border-line bg-surface/50 p-4 sm:p-5 shadow-[inset_0_0_0_1px_var(--border-subtle)]">
	<figcaption class="text-sm font-semibold tracking-[-0.02em] text-primary sm:text-base">
		Texas income flow — gross to guideline support
	</figcaption>
	<p class="mt-2 text-xs leading-5 text-secondary">
		Obligor net resources × percentage table → monthly child support.
	</p>

	<div class="mt-5 flex flex-col items-center gap-1">
		{steps.map((step, i) => (
			<>
				<div
					class:list={[
						'w-full rounded-lg px-4 py-3',
						step.active
							? 'bg-accent/15 ring-2 ring-accent/40'
							: i === steps.length - 1
								? 'bg-accent/10 ring-1 ring-accent/30'
								: 'bg-surface ring-1 ring-line-subtle',
					]}
				>
					<p class="text-sm font-semibold text-primary">{step.label}</p>
					<p class="mt-0.5 text-xs tabular-nums text-secondary">{step.sub}</p>
				</div>
				{i < steps.length - 1 && (
					<span class="text-muted" aria-hidden="true">↓</span>
				)}
			</>
		))}
	</div>
</figure>
