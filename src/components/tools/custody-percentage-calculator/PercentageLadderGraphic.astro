---
const bands = [
	{ split: '50 / 50', range: '182 – 183 nights', primary: '183', secondary: '182', highlight: false },
	{ split: '60 / 40', range: '219 – 146 nights', primary: '219', secondary: '146', highlight: true },
	{ split: '70 / 30', range: '256 – 109 nights', primary: '256', secondary: '109', highlight: false },
	{ split: '80 / 20', range: '292 – 73 nights', primary: '292', secondary: '73', highlight: false },
];
---

<figure class="percentage-ladder w-full max-w-full overflow-hidden rounded-[1.25rem] border border-line bg-surface/50 p-4 sm:p-5 shadow-[inset_0_0_0_1px_var(--border-subtle)]">
	<figcaption class="text-sm font-semibold tracking-[-0.02em] text-primary sm:text-base">
		Percentage ladder — common splits on a 365-night year
	</figcaption>
	<p class="mt-2 text-xs leading-5 text-secondary">
		Primary parent holds the larger block; ranges assume full-year counting.
	</p>

	<ol class="mt-5 space-y-2" aria-label="Custody percentage bands">
		{bands.map((band, i) => (
			<li
				class:list={[
					'flex flex-col gap-2 rounded-lg px-3 py-3 sm:flex-row sm:items-center sm:justify-between',
					band.highlight
						? 'bg-accent/10 ring-2 ring-accent/30'
						: 'bg-surface ring-1 ring-line-subtle',
					i === bands.length - 1 && 'ml-0 sm:ml-6',
					i === bands.length - 2 && 'ml-0 sm:ml-4',
					i === bands.length - 3 && 'ml-0 sm:ml-2',
				]}
			>
				<div class="min-w-0">
					<p class="text-sm font-bold tabular-nums text-primary">{band.split}</p>
					<p class="mt-0.5 text-[10px] text-muted">{band.range}</p>
				</div>
				<div class="flex shrink-0 items-center gap-2 text-xs">
					<span class="rounded bg-accent/20 px-2 py-1 font-bold tabular-nums text-accent">{band.primary}</span>
					<span class="text-muted">/</span>
					<span class="rounded bg-page/80 px-2 py-1 font-bold tabular-nums text-secondary shadow-[inset_0_0_0_1px_var(--border-subtle)]">{band.secondary}</span>
				</div>
			</li>
		))}
	</ol>

	<p class="mt-4 text-center text-[11px] leading-5 text-muted">
		Leap years add one night — recalculate before filing exhibits
	</p>
</figure>
