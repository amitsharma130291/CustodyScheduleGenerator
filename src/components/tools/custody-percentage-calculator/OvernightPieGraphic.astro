---
const parentA = 182;
const parentB = 183;
const total = parentA + parentB;
const percentA = Math.round((parentA / total) * 1000) / 10;
const percentB = Math.round((parentB / total) * 1000) / 10;
const pieGradient = `conic-gradient(var(--color-accent, #2563eb) 0 ${percentA}%, var(--border-subtle, #e2e8f0) ${percentA}% 100%)`;
---

<figure class="overnight-pie w-full max-w-full overflow-hidden rounded-[1.25rem] border border-line bg-surface/50 p-4 sm:p-5 shadow-[inset_0_0_0_1px_var(--border-subtle)]">
	<figcaption class="text-sm font-semibold tracking-[-0.02em] text-primary sm:text-base">
		Annual overnight split — 182 / 183 on a 365-night year
	</figcaption>
	<p class="mt-2 text-xs leading-5 text-secondary">
		True 50/50 rarely lands on exactly half — count every overnight, not weekdays alone.
	</p>

	<div class="mt-5 flex flex-col items-center gap-5 sm:flex-row sm:justify-center">
		<div
			class="relative h-36 w-36 shrink-0 rounded-full shadow-[inset_0_0_0_1px_var(--border-subtle)]"
			style={`background: ${pieGradient}`}
			role="img"
			aria-label={`Parent A ${parentA} overnights (${percentA}%), Parent B ${parentB} overnights (${percentB}%)`}
		>
			<div class="absolute inset-4 flex items-center justify-center rounded-full bg-surface/95 text-center shadow-[inset_0_0_0_1px_var(--border-subtle)]">
				<div>
					<p class="text-[10px] font-bold uppercase tracking-[0.1em] text-muted">Total</p>
					<p class="text-xl font-bold tabular-nums text-primary">{total}</p>
					<p class="text-[10px] text-muted">overnights</p>
				</div>
			</div>
		</div>

		<ul class="min-w-0 space-y-3">
			<li class="flex items-center gap-3 rounded-lg bg-accent/10 px-3 py-2.5 ring-1 ring-accent/25">
				<span class="h-4 w-4 shrink-0 rounded-full bg-accent" aria-hidden="true"></span>
				<div class="min-w-0">
					<p class="text-xs font-semibold text-primary">Parent A</p>
					<p class="text-sm font-bold tabular-nums text-accent">
						{parentA} nights · {percentA}%
					</p>
				</div>
			</li>
			<li class="flex items-center gap-3 rounded-lg bg-surface px-3 py-2.5 shadow-[inset_0_0_0_1px_var(--border-subtle)]">
				<span class="h-4 w-4 shrink-0 rounded-full bg-line" aria-hidden="true"></span>
				<div class="min-w-0">
					<p class="text-xs font-semibold text-primary">Parent B</p>
					<p class="text-sm font-bold tabular-nums text-secondary">
						{parentB} nights · {percentB}%
					</p>
				</div>
			</li>
		</ul>
	</div>
</figure>
