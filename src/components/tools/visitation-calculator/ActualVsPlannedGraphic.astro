---
const parents = [
	{
		label: 'Parent A',
		planned: 42,
		actual: 38,
		tone: 'a' as const,
	},
	{
		label: 'Parent B',
		planned: 22,
		actual: 26,
		tone: 'b' as const,
	},
];
const maxNights = 45;
---

<figure class="actual-vs-planned w-full max-w-full overflow-hidden rounded-[1.25rem] border border-line bg-surface/50 p-4 sm:p-5 shadow-[inset_0_0_0_1px_var(--border-subtle)]">
	<figcaption class="text-sm font-semibold tracking-[-0.02em] text-primary sm:text-base">
		Planned vs actual — overnight counts by parent
	</figcaption>
	<p class="mt-2 text-xs leading-5 text-secondary">
		Q1 sample: order promised 64 total nights; logs show 64 with a different split.
	</p>

	<div class="mt-5 space-y-5">
		{parents.map((parent) => (
			<div class="min-w-0">
				<p class="text-xs font-semibold text-primary">{parent.label}</p>
				<div class="mt-2 grid gap-3 sm:grid-cols-2">
					<div>
						<div class="flex items-baseline justify-between text-[10px]">
							<span class="font-bold uppercase tracking-[0.08em] text-muted">Planned</span>
							<span class="font-bold tabular-nums text-secondary">{parent.planned}</span>
						</div>
						<div class="mt-1 h-3 overflow-hidden rounded-full bg-page/80 shadow-[inset_0_0_0_1px_var(--border-subtle)]">
							<span
								class="block h-full rounded-full bg-muted/50"
								style={`width: ${Math.round((parent.planned / maxNights) * 100)}%`}
								aria-hidden="true"
							></span>
						</div>
					</div>
					<div>
						<div class="flex items-baseline justify-between text-[10px]">
							<span class="font-bold uppercase tracking-[0.08em] text-accent">Actual</span>
							<span class="font-bold tabular-nums text-accent">{parent.actual}</span>
						</div>
						<div class="mt-1 h-3 overflow-hidden rounded-full bg-page/80 shadow-[inset_0_0_0_1px_var(--border-subtle)]">
							<span
								class:list={[
									'block h-full rounded-full',
									parent.tone === 'a' ? 'bg-accent/60' : 'bg-accent/35',
								]}
								style={`width: ${Math.round((parent.actual / maxNights) * 100)}%`}
								aria-hidden="true"
							></span>
						</div>
					</div>
				</div>
			</div>
		))}
	</div>

	<p class="mt-4 rounded-lg bg-surface px-3 py-2 text-center text-[11px] leading-5 text-muted ring-1 ring-line-subtle">
		Gap rows highlight make-up weekends and missed exchanges
	</p>
</figure>
