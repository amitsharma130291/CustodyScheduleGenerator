---
const bars = [
	{ label: 'Thu practice + exchange', load: 90 },
	{ label: 'Sat job wrong weekend', load: 85 },
	{ label: 'Prom on off-week', load: 70 },
	{ label: 'WOW single exchange', load: 35 },
];
---

<figure class="teen-activity-pressure w-full overflow-hidden rounded-[1.25rem] border border-line bg-surface/50 p-4 sm:p-5">
	<figcaption class="text-sm font-semibold text-primary">Teen activity pressure — calendar conflict intensity</figcaption>
	<div class="mt-4 space-y-3">
		{bars.map((b) => (
			<div>
				<div class="flex justify-between text-[11px]">
					<span class="text-secondary">{b.label}</span>
					<span class="font-semibold text-primary">{b.load}%</span>
				</div>
				<div class="mt-1 h-2 overflow-hidden rounded-full bg-line">
					<div class="h-full rounded-full bg-accent/60" style={`width: ${b.load}%`}></div>
				</div>
			</div>
		))}
	</div>
</figure>
