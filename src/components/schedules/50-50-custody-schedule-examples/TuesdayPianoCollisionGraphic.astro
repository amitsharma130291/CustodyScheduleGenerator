---
const days223 = [
	{ day: 'Mon', parent: 'A', conflict: false },
	{ day: 'Tue', parent: 'B', conflict: true },
	{ day: 'Wed', parent: 'A', conflict: false },
	{ day: 'Thu', parent: 'B', conflict: false },
	{ day: 'Fri', parent: 'A', conflict: false },
	{ day: 'Sat', parent: 'A', conflict: false },
	{ day: 'Sun', parent: 'A', conflict: false },
];

const daysFixed = [
	{ day: 'Mon', parent: 'A', conflict: false },
	{ day: 'Tue', parent: 'A', conflict: false },
	{ day: 'Wed', parent: 'A', conflict: false },
	{ day: 'Thu', parent: 'B', conflict: false },
	{ day: 'Fri', parent: 'B', conflict: false },
	{ day: 'Sat', parent: 'B', conflict: false },
	{ day: 'Sun', parent: 'B', conflict: false },
];
---

<figure class="piano-collision w-full overflow-hidden rounded-[1.25rem] border border-line bg-surface/50 p-4 sm:p-5 shadow-[inset_0_0_0_1px_var(--border-subtle)]">
	<figcaption class="text-sm font-semibold tracking-[-0.02em] text-primary sm:text-base">
		2-2-3 vs fixed Tuesday — piano every week
	</figcaption>

	<p class="mt-3 text-xs font-semibold text-secondary">2-2-3 — Tuesday alternates</p>
	<div class="mt-2 grid grid-cols-7 gap-1">
		{days223.map((d) => (
			<div class="text-center">
				<span class="block text-[10px] font-bold text-muted">{d.day}</span>
				<span
					class:list={[
						'mt-1 block rounded-md py-1.5 text-[10px] font-bold',
						d.conflict
							? 'bg-rose-500/25 text-rose-700 ring-1 ring-rose-500/50'
							: d.parent === 'A'
								? 'bg-parent-a/20 text-parent-a'
								: 'bg-parent-b/20 text-parent-b',
					]}
				>
					{d.conflict ? '🎹' : d.parent}
				</span>
			</div>
		))}
	</div>

	<p class="mt-4 text-xs font-semibold text-secondary">2-2-5-5 — Mom owns every Tuesday</p>
	<div class="mt-2 grid grid-cols-7 gap-1">
		{daysFixed.map((d) => (
			<div class="text-center">
				<span class="block text-[10px] font-bold text-muted">{d.day}</span>
				<span
					class:list={[
						'mt-1 block rounded-md py-1.5 text-[10px] font-bold',
						d.day === 'Tue'
							? 'bg-accent/20 text-accent ring-1 ring-accent/40'
							: d.parent === 'A'
								? 'bg-parent-a/20 text-parent-a'
								: 'bg-parent-b/20 text-parent-b',
					]}
				>
					{d.day === 'Tue' ? '🎹' : d.parent}
				</span>
			</div>
		))}
	</div>
</figure>
