---
const nights = [
	{ night: 'Mon', twoTwoFiveFive: 'A', twoTwoThree: 'A / B' },
	{ night: 'Tue', twoTwoFiveFive: 'A', twoTwoThree: 'A / B' },
	{ night: 'Wed', twoTwoFiveFive: 'B', twoTwoThree: 'B / A' },
	{ night: 'Thu', twoTwoFiveFive: 'B', twoTwoThree: 'B / A' },
];
---

<figure class="school-night-matrix w-full overflow-hidden rounded-[1.25rem] border border-line bg-surface/50 p-4 sm:p-5">
	<figcaption class="text-sm font-semibold text-primary">School-night ownership — 2-2-5-5 vs 2-2-3</figcaption>
	<div class="mt-4 overflow-x-auto">
		<table class="w-full min-w-[280px] text-left text-xs">
			<thead>
				<tr class="border-b border-line text-muted">
					<th class="py-2 pr-4">Night</th>
					<th class="py-2 pr-4">2-2-5-5</th>
					<th class="py-2">2-2-3</th>
				</tr>
			</thead>
			<tbody class="text-secondary">
				{nights.map((n) => (
					<tr class="border-b border-line-subtle">
						<td class="py-2 font-semibold text-primary">{n.night}</td>
						<td class="py-2">{n.twoTwoFiveFive}</td>
						<td class="py-2">{n.twoTwoThree}</td>
					</tr>
				))}
			</tbody>
		</table>
	</div>
	<p class="mt-3 text-[11px] text-muted">2255: fixed weekly. 223: alternates by fortnight.</p>
</figure>
