---
const rows = [
	{ pattern: '2-2-3', count: '3–4', bar: 4 },
	{ pattern: '2-2-5-5', count: '2', bar: 2 },
	{ pattern: '5-2-2-5', count: '2', bar: 2 },
	{ pattern: 'WOW', count: '1', bar: 1 },
];
---

<figure class="exchange-count w-full overflow-hidden rounded-[1.25rem] border border-line bg-surface/50 p-4 sm:p-5">
	<figcaption class="text-sm font-semibold text-primary">School-week exchanges per fortnight — by pattern</figcaption>
	<div class="mt-5 space-y-3">
		{rows.map((r) => (
			<div>
				<div class="flex justify-between text-xs">
					<span class="font-semibold text-primary">{r.pattern}</span>
					<span class="text-muted">{r.count}</span>
				</div>
				<div class="mt-1.5 flex gap-1">
					{Array.from({ length: r.bar }).map(() => (
						<div class="h-2 flex-1 rounded-sm bg-accent/40"></div>
					))}
					{r.bar < 4 && Array.from({ length: 4 - r.bar }).map(() => (
						<div class="h-2 flex-1 rounded-sm bg-line"></div>
					))}
				</div>
			</div>
		))}
	</div>
</figure>
