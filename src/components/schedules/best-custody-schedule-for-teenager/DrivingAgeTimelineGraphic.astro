---
const stages = [
	{ age: '15', label: 'Learner permit', detail: 'Parent logs practice hours' },
	{ age: '16', label: 'License', detail: 'Self-pickup from practice' },
	{ age: '17', label: 'Job + car', detail: 'Shift ends after curfew' },
];
---

<figure class="driving-timeline w-full overflow-hidden rounded-[1.25rem] border border-line bg-surface/50 p-4 sm:p-5">
	<figcaption class="text-sm font-semibold text-primary">Driving-age timeline — transport stops being parent-only</figcaption>
	<ol class="mt-5 space-y-0">
		{stages.map((s, i) => (
			<li class="relative flex gap-4 pb-5 last:pb-0">
				{i < stages.length - 1 && <span class="absolute left-3 top-8 h-full w-px bg-line" aria-hidden="true"></span>}
				<span class="relative z-10 flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-accent/15 text-[10px] font-bold text-accent ring-1 ring-accent/30">{s.age}</span>
				<div>
					<p class="text-sm font-semibold text-primary">{s.label}</p>
					<p class="text-xs text-secondary">{s.detail}</p>
				</div>
			</li>
		))}
	</ol>
</figure>
