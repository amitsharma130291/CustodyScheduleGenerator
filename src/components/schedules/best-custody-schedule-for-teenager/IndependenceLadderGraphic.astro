---
const rungs = [
	{ level: 'Parent drives everywhere', era: 'Age 7' },
	{ level: 'Parent carpools to practice', era: 'Age 10' },
	{ level: 'Teen drives, curfew applies', era: 'Age 16' },
	{ level: 'Teen negotiates swaps', era: 'Age 17' },
];
---

<figure class="independence-ladder w-full overflow-hidden rounded-[1.25rem] border border-line bg-surface/50 p-4 sm:p-5">
	<figcaption class="text-sm font-semibold text-primary">Independence ladder — who controls the weekly rhythm</figcaption>
	<ol class="mt-4 space-y-2">
		{rungs.map((r, i) => (
			<li
				class:list={[
					'flex items-center gap-3 rounded-lg px-3 py-2.5',
					i === 0 && 'ml-0',
					i === 1 && 'ml-3',
					i === 2 && 'ml-6',
					i === 3 && 'ml-9 bg-accent/10 ring-1 ring-accent/25',
					i < 3 && 'bg-surface ring-1 ring-line-subtle',
				]}
			>
				<span class="text-[10px] font-bold uppercase text-muted">{r.era}</span>
				<span class="text-xs font-semibold text-primary">{r.level}</span>
			</li>
		))}
	</ol>
</figure>
