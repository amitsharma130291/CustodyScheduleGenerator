---
const days = [
	{ day: 'Mon', activity: 'School', custody: 'Parent A' },
	{ day: 'Tue', activity: 'Soccer 5:30', custody: 'Parent A', highlight: true },
	{ day: 'Wed', activity: 'Piano', custody: 'Parent B' },
	{ day: 'Thu', activity: 'School', custody: 'Parent B' },
	{ day: 'Fri', activity: 'Party?', custody: 'Exchange', highlight: true },
];
---

<figure class="weekly-activity-map w-full overflow-hidden rounded-[1.25rem] border border-line bg-surface/50 p-4 sm:p-5">
	<figcaption class="text-sm font-semibold text-primary">Weekly activity map — custody blocks vs. fixed obligations</figcaption>
	<p class="mt-2 text-sm text-secondary">Tuesday soccer does not move because the calendar flipped — it needs a driver on the parent who holds that block.</p>
	<div class="mt-5 grid grid-cols-5 gap-2">
		{days.map((d) => (
			<div
				class:list={[
					'rounded-lg p-2 text-center sm:p-3',
					d.highlight ? 'bg-amber-500/10 ring-2 ring-amber-500/30' : 'bg-surface ring-1 ring-line-subtle',
				]}
			>
				<p class="text-[10px] font-bold uppercase text-muted">{d.day}</p>
				<p class="mt-1 text-xs font-semibold text-primary">{d.activity}</p>
				<p class="mt-1 text-[10px] text-secondary">{d.custody}</p>
			</div>
		))}
	</div>
</figure>
