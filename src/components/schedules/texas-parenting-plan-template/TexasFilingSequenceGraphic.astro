---
const steps = [
	{ label: 'Calendar', sub: 'Mark SPO weekends + Thu overnights', active: true },
	{ label: 'Summer mark', sub: '30-day election window', active: false },
	{ label: 'Clauses', sub: 'Medical · school · travel language', active: false },
	{ label: 'Support check', sub: 'Guidelines worksheet attached', active: false },
];
---

<figure class="texas-filing-sequence w-full overflow-hidden rounded-[1.25rem] border border-line bg-surface/50 p-4 sm:p-5 shadow-[inset_0_0_0_1px_var(--border-subtle)]">
	<figcaption class="text-sm font-semibold tracking-[-0.02em] text-primary sm:text-base">
		Texas filing sequence — calendar to support check
	</figcaption>

	<div class="mt-5 flex flex-col gap-1">
		{steps.map((step, i) => (
			<>
				<div
					class:list={[
						'flex items-center gap-3 rounded-lg px-4 py-3',
						step.active
							? 'bg-accent/15 ring-2 ring-accent/40'
							: 'bg-surface ring-1 ring-line-subtle',
					]}
				>
					<span class="text-lg font-bold tabular-nums text-accent">{i + 1}</span>
					<div>
						<p class="text-sm font-semibold text-primary">{step.label}</p>
						<p class="text-xs text-secondary">{step.sub}</p>
					</div>
				</div>
				{i < steps.length - 1 && (
					<span class="ml-6 text-muted" aria-hidden="true">↓</span>
				)}
			</>
		))}
	</div>
</figure>
