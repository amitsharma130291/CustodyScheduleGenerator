---
const segments = [
	{ label: 'Friday evening', note: 'Arrival · settle in', width: '22%' },
	{ label: 'Saturday', note: 'Full day · activities', width: '38%' },
	{ label: 'Sunday', note: 'Return looms', width: '28%' },
	{ label: 'Return', note: 'Exchange · drive home', width: '12%' },
];
---

<figure class="eow-reality w-full rounded-[1.25rem] border border-line bg-surface/50 p-4 sm:p-5 shadow-[inset_0_0_0_1px_var(--border-subtle)]">
	<figcaption class="text-sm font-semibold tracking-[-0.02em] text-primary sm:text-base">
		Where the weekend actually goes
	</figcaption>
	<p class="mt-2 text-sm leading-6 text-secondary">
		Travel and Sunday return trim a Fri–Sun block before it feels like three full days.
	</p>
	<div class="mt-4 flex h-12 w-full overflow-hidden rounded-lg shadow-[inset_0_0_0_1px_var(--border-subtle)]" role="img" aria-label="Friday evening arrival, Saturday full day, shortened Sunday, and return exchange">
		{segments.map((seg, i) => (
			<div
				class:list={[
					'flex flex-col items-center justify-center border-r border-line/50 px-0.5 text-center last:border-r-0',
					i === 1 ? 'bg-accent/25' : 'bg-surface/90',
				]}
				style={`width: ${seg.width}`}
			>
				<span class="text-[9px] font-bold leading-tight text-primary sm:text-[10px]">{seg.label}</span>
			</div>
		))}
	</div>
	<ul class="mt-3 grid grid-cols-2 gap-x-3 gap-y-1 sm:grid-cols-4">
		{segments.map((seg) => (
			<li class="text-[10px] leading-4 text-muted">
				<span class="font-semibold text-secondary">{seg.label}:</span> {seg.note}
			</li>
		))}
	</ul>
</figure>
