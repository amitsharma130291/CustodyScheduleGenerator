---
const items = [
	{ label: 'Regular visit', detail: 'EOW Fri–Sun', icon: '📅' },
	{ label: 'Holiday visit', detail: 'Thu–Sun Thanksgiving', icon: '🦃' },
	{ label: 'Make-up time', detail: 'Next open weekend', icon: '↩' },
	{ label: 'Video call', detail: 'If travel blocks overnight', icon: '📞' },
];
---

<figure class="limited-parent-map w-full overflow-hidden rounded-[1.25rem] border border-line bg-surface/50 p-4 sm:p-5 shadow-[inset_0_0_0_1px_var(--border-subtle)]">
	<figcaption class="text-sm font-semibold tracking-[-0.02em] text-primary sm:text-base">
		Limited-time parent holiday map
	</figcaption>

	<ul class="mt-4 space-y-2">
		{items.map((item) => (
			<li class="flex items-center gap-3 rounded-lg bg-surface px-3 py-2.5 ring-1 ring-line-subtle">
				<span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-accent/10 text-sm" aria-hidden="true">
					{item.icon}
				</span>
				<div>
					<p class="text-[10px] font-bold uppercase tracking-[0.1em] text-muted">{item.label}</p>
					<p class="text-sm font-semibold text-primary">{item.detail}</p>
				</div>
			</li>
		))}
	</ul>
</figure>
