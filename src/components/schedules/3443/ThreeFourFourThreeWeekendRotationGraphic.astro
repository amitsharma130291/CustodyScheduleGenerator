---
/** Fri–Sun block shape across four weekends in a 3-4-4-3 month */
const weekends = [
	{ label: 'Weekend 1', type: 'full', parent: 'B', detail: '4-day Thu–Sun block' },
	{ label: 'Weekend 2', type: 'split', parent: 'B', detail: 'Fri exchange · 3-day Fri–Sun' },
	{ label: 'Weekend 3', type: 'full', parent: 'B', detail: 'Cycle repeats' },
	{ label: 'Weekend 4', type: 'split', parent: 'B', detail: 'Cycle repeats' },
];
---

<figure class="tfft-weekend-rotation w-full rounded-[1.25rem] border border-line bg-surface/50 p-4 sm:p-5 shadow-[inset_0_0_0_1px_var(--border-subtle)]">
	<figcaption class="text-sm font-semibold tracking-[-0.02em] text-primary sm:text-base">
		How weekend blocks rotate in a 3-4-4-3 cycle
	</figcaption>
	<p class="mt-2 text-sm leading-6 text-secondary">
		Week one ends with a four-day stretch through Sunday. Week two exchanges Friday after a Mon–Thu block — same weekend days, different block shape. Start date swaps which parent holds each segment.
	</p>
	<div class="mt-4 grid gap-2 sm:grid-cols-2">
		{weekends.map((weekend) => (
			<div
				class:list={[
					'rounded-lg p-3 shadow-[inset_0_0_0_1px_var(--border-subtle)]',
					weekend.type === 'full' ? 'bg-accent/8' : 'bg-surface/80',
				]}
			>
				<div class="flex items-center justify-between gap-2">
					<span class="text-xs font-semibold uppercase tracking-[0.08em] text-muted">{weekend.label}</span>
					<span
						class:list={[
							'rounded-md px-2 py-0.5 text-[10px] font-bold uppercase',
							weekend.type === 'full' ? 'bg-accent/15 text-accent' : 'bg-surface text-secondary ring-1 ring-accent/25',
						]}
					>
						{weekend.type === 'full' ? 'Full block' : 'Split Fri'}
					</span>
				</div>
				<div class="mt-2 flex gap-1.5">
					{['Fri', 'Sat', 'Sun'].map((day) => (
						<div class="flex flex-1 flex-col items-center rounded-md bg-surface/90 py-2 shadow-[inset_0_0_0_1px_var(--border-subtle)]">
							<span class="text-[9px] text-muted">{day}</span>
							<span class="mt-1 text-sm font-bold text-accent">{weekend.parent}</span>
						</div>
					))}
				</div>
				<p class="mt-2 text-[11px] leading-4 text-muted">{weekend.detail}</p>
			</div>
		))}
	</div>
</figure>
