---
const dayLabels = ['M', 'T', 'W', 'T', 'F', 'S', 'S'];
const baseDays = ['A', 'A', 'A', 'B', 'B', 'B', 'B'];
const overrideDays = [false, false, true, true, true, false, false];
---

<figure class="holiday-overlay w-full overflow-hidden rounded-[1.25rem] border border-line bg-surface/50 p-4 sm:p-5 shadow-[inset_0_0_0_1px_var(--border-subtle)]">
	<figcaption class="text-sm font-semibold tracking-[-0.02em] text-primary sm:text-base">
		Holiday overlay — base month with hatched override days
	</figcaption>

	<p class="mt-2 text-xs text-secondary">Regular rotation underneath; holiday rule replaces Wed–Fri nights.</p>

	<div class="mt-4 flex gap-0.5">
		{dayLabels.map((label, i) => (
			<div class="flex flex-1 flex-col items-center gap-1">
				<span class="text-[9px] text-muted">{label}</span>
				<div
					class:list={[
						'flex h-10 w-full items-center justify-center rounded text-[10px] font-bold',
						overrideDays[i]
							? 'bg-[repeating-linear-gradient(45deg,var(--accent)_0,var(--accent)_2px,transparent_2px,transparent_6px)] text-primary ring-2 ring-accent/50'
							: baseDays[i] === 'A'
								? 'bg-accent/20 text-accent'
								: 'bg-surface text-secondary shadow-[inset_0_0_0_1px_var(--border-subtle)]',
					]}
				>
					{overrideDays[i] ? 'H' : baseDays[i]}
				</div>
			</div>
		))}
	</div>

	<p class="mt-3 text-[10px] text-muted">H = holiday override block</p>
</figure>
