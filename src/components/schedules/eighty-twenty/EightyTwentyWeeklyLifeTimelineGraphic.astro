---
const weekDays = [
	{ day: 'Mon', event: 'Homework', onParentingTime: false },
	{ day: 'Tue', event: 'Practice', onParentingTime: false },
	{ day: 'Wed', event: 'Teacher msg', onParentingTime: false },
	{ day: 'Thu', event: 'Field trip form', onParentingTime: false },
	{ day: 'Fri', event: 'Exchange', onParentingTime: true },
	{ day: 'Sat', event: 'Parent B time', onParentingTime: true },
	{ day: 'Sun', event: 'Return', onParentingTime: true },
];
---

<figure class="e8020-week-timeline w-full rounded-[1.25rem] border border-line bg-surface/50 p-4 sm:p-5 shadow-[inset_0_0_0_1px_var(--border-subtle)]">
	<figcaption class="text-sm font-semibold tracking-[-0.02em] text-primary sm:text-base">
		Most life events fall outside parenting days
	</figcaption>
	<p class="mt-2 text-sm leading-6 text-secondary">
		A typical week: four weekdays of school life, then a short Parent B block — then the pattern repeats.
	</p>

	<div class="mt-4 grid grid-cols-7 gap-1">
		{weekDays.map((item) => (
			<div class="flex flex-col items-center gap-1.5">
				<span class="text-[10px] font-bold uppercase tracking-[0.06em] text-muted">{item.day}</span>
				<div
					class:list={[
						'flex min-h-[4.5rem] w-full flex-col items-center justify-center rounded-lg px-1 py-2 text-center',
						item.onParentingTime
							? 'bg-accent/15 ring-1 ring-accent/30'
							: 'bg-surface shadow-[inset_0_0_0_1px_var(--border-subtle)]',
					]}
				>
					<span class="text-[9px] font-semibold leading-3 text-primary">{item.event}</span>
				</div>
			</div>
		))}
	</div>

	<div class="mt-4 flex flex-wrap items-center justify-center gap-4 text-[11px] text-secondary">
		<span class="inline-flex items-center gap-1.5">
			<span class="h-2.5 w-2.5 rounded-sm bg-surface shadow-[inset_0_0_0_1px_var(--border-subtle)]" aria-hidden="true"></span>
			Between visits
		</span>
		<span class="inline-flex items-center gap-1.5">
			<span class="h-2.5 w-2.5 rounded-sm bg-accent/30 ring-1 ring-accent/40" aria-hidden="true"></span>
			Parent B parenting time
		</span>
	</div>
</figure>
