---
const stages = [
	{ label: 'Short daytime visit', duration: '1–3 hrs', active: true },
	{ label: 'Longer daytime block', duration: 'Half day', active: false },
	{ label: 'First overnight', duration: '1 night', active: false },
	{ label: 'Two overnights', duration: '2 nights', active: false },
	{ label: 'Equal-time testing', duration: 'Pattern TBD', active: false },
];
---

<figure class="baby-step-up-timeline w-full max-w-full overflow-hidden rounded-[1.25rem] border border-line bg-surface/50 p-4 sm:p-5 shadow-[inset_0_0_0_1px_var(--border-subtle)]">
	<figcaption class="text-sm font-semibold tracking-[-0.02em] text-primary sm:text-base">
		Baby step-up timeline — expand time only after each stage holds
	</figcaption>
	<p class="mt-2 text-xs leading-5 text-secondary sm:text-sm sm:leading-6">
		Each stage proves feeding and sleep stability before the next — not a calendar deadline.
	</p>

	<ol class="mt-6 space-y-0" aria-label="Baby custody step-up stages">
		{stages.map((stage, index) => (
			<li class="relative flex gap-3 pb-5 last:pb-0">
				{index < stages.length - 1 && (
					<span
						class="absolute left-[0.6875rem] top-7 h-[calc(100%-1.25rem)] w-px bg-line"
						aria-hidden="true"
					></span>
				)}
				<span
					class:list={[
						'relative z-10 flex h-6 w-6 shrink-0 items-center justify-center rounded-full text-[10px] font-bold ring-1',
						index === 0
							? 'bg-accent/15 text-accent ring-accent/30'
							: 'bg-surface text-muted ring-line',
					]}
				>
					{index + 1}
				</span>
				<div class="min-w-0 flex-1 pt-0.5">
					<p class="text-sm font-semibold text-primary">{stage.label}</p>
					<p class="mt-0.5 text-xs text-muted">{stage.duration}</p>
				</div>
			</li>
		))}
	</ol>

	<p class="mt-4 rounded-lg bg-accent/[0.06] px-3 py-2 text-center text-[11px] leading-5 text-secondary ring-1 ring-accent/15">
		Pattern names (2-2-3, week-on/week-off) belong after equal-time testing — not at stage 1
	</p>
</figure>
