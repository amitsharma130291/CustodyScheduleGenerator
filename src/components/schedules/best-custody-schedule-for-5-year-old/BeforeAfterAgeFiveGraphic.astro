---
const beforeItems = [
	'Flexible daycare pickup',
	'Nap-window handoffs',
	'Stroller + snack timing',
	'Playdate-length visits',
];

const afterItems = [
	'School bell + bus stop',
	'Folder + permission slips',
	'Early bedtime on school nights',
	'Pickup authorization list',
];
---

<figure class="before-after-age-five w-full max-w-full overflow-hidden rounded-[1.25rem] border border-line bg-surface/50 p-4 sm:p-5 shadow-[inset_0_0_0_1px_var(--border-subtle)]">
	<figcaption class="text-sm font-semibold tracking-[-0.02em] text-primary sm:text-base">
		Before and after age five — what the custody week must carry
	</figcaption>

	<div class="mt-6 grid gap-4 sm:grid-cols-2">
		<div class="rounded-xl bg-surface p-4 shadow-[inset_0_0_0_1px_var(--border-subtle)]">
			<p class="text-[10px] font-bold uppercase tracking-[0.14em] text-muted">Before kindergarten</p>
			<p class="mt-1 text-sm font-semibold text-primary">Daycare flexibility</p>
			<ul class="mt-3 space-y-2">
				{beforeItems.map((item) => (
					<li class="flex items-start gap-2 text-xs leading-5 text-secondary">
						<span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-muted" aria-hidden="true"></span>
						{item}
					</li>
				))}
			</ul>
		</div>

		<div class="rounded-xl bg-accent/[0.06] p-4 ring-1 ring-accent/20">
			<p class="text-[10px] font-bold uppercase tracking-[0.14em] text-accent">After kindergarten starts</p>
			<p class="mt-1 text-sm font-semibold text-primary">School-year routine</p>
			<ul class="mt-3 space-y-2">
				{afterItems.map((item) => (
					<li class="flex items-start gap-2 text-xs leading-5 text-secondary">
						<span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-accent" aria-hidden="true"></span>
						{item}
					</li>
				))}
			</ul>
		</div>
	</div>

	<p class="mt-4 text-center text-xs leading-5 text-muted">
		Toddler handoff guide → kindergarten logistics → 7-year-old activity guide
	</p>
</figure>
