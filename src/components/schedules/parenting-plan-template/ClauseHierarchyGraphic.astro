---
const layers = [
	{ label: 'Identifiers', sub: 'Children · parties · case caption', active: false },
	{ label: 'Schedule exhibit', sub: 'Regular rotation + exchange map', active: true },
	{ label: 'Holiday exhibit', sub: 'Override table + return date', active: false },
	{ label: 'Operational clauses', sub: 'Communication · travel · disputes', active: false },
];
---

<figure class="clause-hierarchy w-full overflow-hidden rounded-[1.25rem] border border-line bg-surface/50 p-4 sm:p-5 shadow-[inset_0_0_0_1px_var(--border-subtle)]">
	<figcaption class="text-sm font-semibold tracking-[-0.02em] text-primary sm:text-base">
		Clause hierarchy — what stacks on the base plan
	</figcaption>

	<div class="mt-5 flex flex-col gap-2">
		{layers.map((layer) => (
			<div
				class:list={[
					'rounded-lg px-4 py-3',
					layer.active
						? 'bg-accent/15 ring-2 ring-accent/40'
						: 'bg-surface ring-1 ring-line-subtle',
				]}
			>
				<p class="text-sm font-semibold text-primary">{layer.label}</p>
				<p class="mt-0.5 text-xs text-secondary">{layer.sub}</p>
			</div>
		))}
	</div>
</figure>
