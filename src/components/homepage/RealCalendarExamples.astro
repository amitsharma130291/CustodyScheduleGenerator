---
import CalendarPreview from '../tool/CalendarPreview.astro';
import { generateSchedule } from '../../lib/schedules/generateSchedule';
import { getDefaultStartDate } from '../../lib/schedules/format';
import type { ScheduleInputType } from '../../lib/schedules/types';

interface CalendarExample {
	scheduleId: string;
	name: string;
	href: string;
	exchanges: string;
	advantages: string;
	tradeoffs: string;
}

interface Props {
	examples: CalendarExample[];
}

const { examples } = Astro.props;
const startDate = getDefaultStartDate();
const examplesWithSchedules = examples.map((example) => ({
	...example,
	schedule: generateSchedule({
		scheduleId: example.scheduleId as ScheduleInputType,
		startDate,
	}),
}));
---

<section id="schedule-examples" class="container-shell scroll-mt-24 py-section" aria-labelledby="schedule-examples-title">
	<div class="max-w-3xl">
		<p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">Real calendar examples</p>
		<h2 id="schedule-examples-title" class="mt-3 text-3xl font-semibold leading-[1.08] tracking-[-0.045em] text-primary sm:text-4xl">
			See what common schedules feel like on a calendar.
		</h2>
		<p class="mt-4 text-base leading-7 text-secondary">
			These examples show how exchanges and parenting time appear once the schedule becomes real dates.
		</p>
	</div>

	<div class="mt-6 grid gap-5 lg:grid-cols-2">
		{examplesWithSchedules.map((example) => (
			<article class="premium-card rounded-[1.75rem] p-3">
				<div class="rounded-[1.45rem] bg-surface-elevated p-4">
					<div class="mb-4 flex items-start justify-between gap-4">
						<div>
							<p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">Example</p>
							<h3 class="mt-2 text-xl font-semibold tracking-[-0.035em] text-primary">{example.name}</h3>
						</div>
						<a href={example.href} class="shrink-0 rounded-full bg-page px-3 py-1.5 text-xs font-semibold text-accent underline decoration-line underline-offset-4 shadow-[inset_0_0_0_1px_var(--border-subtle)]">Guide →</a>
					</div>
					<CalendarPreview schedule={example.schedule} />
					<div class="mt-4 grid gap-3 text-sm leading-6 text-secondary">
						<p><strong class="text-primary">Exchanges:</strong> {example.exchanges}</p>
						<p><strong class="text-primary">Advantages:</strong> {example.advantages}</p>
						<p><strong class="text-primary">Tradeoffs:</strong> {example.tradeoffs}</p>
					</div>
					<button type="button" class="btn-primary mt-4 inline-flex h-11 w-full items-center justify-center rounded-full px-5 text-sm font-semibold" data-use-schedule={example.scheduleId}>
						Use this schedule
					</button>
				</div>
			</article>
		))}
	</div>
	<a href="#popular-schedules" class="btn-secondary mt-5 inline-flex h-11 items-center justify-center rounded-full px-5 text-sm font-semibold">
		View real calendar examples
	</a>
</section>
