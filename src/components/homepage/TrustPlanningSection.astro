<section class="container-shell py-10 lg:py-12" aria-labelledby="trust-planning-title">
	<div class="premium-card rounded-[2rem] p-3">
		<div class="rounded-[1.7rem] bg-surface-elevated/80 p-5 sm:p-7 lg:p-8">
			<div class="grid gap-8 lg:grid-cols-[0.8fr_1.2fr] lg:items-start">
				<div>
					<p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">Planning clarity</p>
					<h2 id="trust-planning-title" class="mt-4 text-4xl font-semibold leading-[1.05] tracking-[-0.045em] text-primary sm:text-5xl">
						Built for practical custody planning.
					</h2>
					<p class="mt-5 text-base leading-8 text-secondary">
						CustodyBuilder is designed for parents who need to turn schedule ideas into something visible, printable, and easier to discuss.
					</p>
				</div>
				<div class="grid gap-4 sm:grid-cols-2">
					{[
						['Compare schedules', 'See how common rotations differ before choosing one.'],
						['Prepare for mediation', 'Bring a calendar and clear schedule examples into discussion.'],
						['Review parenting time', 'Check overnight splits and practical exchange patterns.'],
						['Create printable calendars', 'Export a schedule that is easier to share and review.'],
					].map(([title, copy]) => (
						<article class="soft-card rounded-[1.5rem] p-5">
							<h3 class="text-lg font-semibold tracking-[-0.03em] text-primary">{title}</h3>
							<p class="mt-2 text-sm leading-6 text-secondary">{copy}</p>
						</article>
					))}
					<p class="sm:col-span-2 rounded-2xl bg-page/55 p-4 text-sm leading-6 text-muted shadow-[inset_0_0_0_1px_var(--border-subtle)]">
						CustodyBuilder provides planning tools and educational information and does not provide legal advice.
					</p>
				</div>
			</div>
		</div>
	</div>
</section>
