---
const pattern = [
	'A', 'A', 'B', 'B', 'A', 'A', 'A',
	'B', 'B', 'A', 'A', 'B', 'B', 'B',
	'A', 'A', 'A', 'B', 'B', 'A', 'A',
	'B', 'B', 'B', 'A', 'A', 'B', 'B',
	'A', 'A', 'B',
];
const exchangeDays = new Set([3, 7, 10, 14, 17, 21, 24, 28]);
const generatorHref = '/custody-schedule-generator/';
---

<a
	href={generatorHref}
	aria-label="Open custody schedule generator"
	class="hero-calendar-preview group block overflow-hidden rounded-[1.5rem] border border-line bg-surface/60 p-4 shadow-[0_20px_48px_rgba(15,23,42,0.08)] transition-[border-color,box-shadow,transform] duration-200 ease-out hover:border-accent/35 hover:shadow-[0_24px_56px_rgba(15,23,42,0.12)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent active:scale-[0.995] sm:p-5"
>
	<div class="flex items-center justify-between gap-2">
		<p class="text-sm font-semibold text-primary">March 2026 — 2-2-3 preview</p>
		<span class="rounded-full bg-accent/10 px-2.5 py-1 text-[10px] font-bold uppercase tracking-[0.1em] text-accent" aria-hidden="true">Live grid</span>
	</div>

	<div class="mt-4 grid grid-cols-7 gap-1 text-center text-[9px] font-bold uppercase tracking-[0.08em] text-muted" aria-hidden="true">
		{['M', 'T', 'W', 'T', 'F', 'S', 'S'].map((d) => <span>{d}</span>)}
	</div>

	<div class="mt-1.5 grid grid-cols-7 gap-1" aria-hidden="true">
		{pattern.map((parent, index) => {
			const day = index + 1;
			const isExchange = exchangeDays.has(day);
			return (
				<span
					class={`relative grid aspect-square place-items-center rounded-lg text-[10px] font-bold ${
						parent === 'A' ? 'bg-parent-a/18 text-parent-a' : 'bg-parent-b/18 text-parent-b'
					} ${isExchange ? 'ring-2 ring-accent/50 ring-offset-1 ring-offset-surface' : ''}`}
				>
					{day}
				</span>
			);
		})}
	</div>

	<div class="mt-4 flex flex-wrap items-center justify-between gap-2 border-t border-line-subtle pt-3 text-[10px] font-semibold text-secondary" aria-hidden="true">
		<div class="flex gap-3">
			<span><span class="text-parent-a">■</span> Parent A</span>
			<span><span class="text-parent-b">■</span> Parent B</span>
		</div>
		<span class="text-accent">◆ Exchange day</span>
	</div>
</a>

<style>
	.hero-calendar-preview {
		cursor: pointer;
		text-decoration: none;
		color: inherit;
	}
</style>
