---
import MiniCalendarPreview from './MiniCalendarPreview.astro';
import ParentingTimePreview from './ParentingTimePreview.astro';

interface Props {
	type: string;
}

const { type } = Astro.props;
---

<div class="mb-4" aria-hidden="true">
	{type === 'selector' && (
		<div class="rounded-[1.15rem] bg-page/70 p-3 shadow-[inset_0_0_0_1px_var(--border-subtle)]">
			<p class="text-xs font-semibold text-primary">Schedule Type</p>
			<div class="mt-2 flex flex-wrap gap-1.5 text-[10px] font-semibold">
				<span class="rounded-full bg-parent-b/15 px-2.5 py-1 text-parent-b">2-2-3</span>
				<span class="rounded-full bg-surface px-2.5 py-1 text-secondary">2-2-5-5</span>
				<span class="rounded-full bg-surface px-2.5 py-1 text-secondary">50/50</span>
			</div>
		</div>
	)}
	{type === 'calendar' && <MiniCalendarPreview />}
	{type === 'parenting-time' && <ParentingTimePreview parentA={57} parentB={43} />}
	{type === 'holidays' && (
		<div class="rounded-[1.15rem] bg-page/70 p-3 shadow-[inset_0_0_0_1px_var(--border-subtle)]">
			<p class="text-xs font-semibold text-primary">Holiday Overrides</p>
			<div class="mt-2 grid gap-1.5 text-[11px] font-semibold text-secondary">
				<div class="flex justify-between rounded-lg bg-surface px-2 py-1.5"><span>Nov 28</span><span>Thanksgiving</span></div>
				<div class="flex justify-between rounded-lg bg-surface px-2 py-1.5"><span>Dec 24</span><span>Winter break</span></div>
			</div>
		</div>
	)}
	{type === 'agreement' && (
		<div class="rounded-[1.15rem] bg-page/70 p-3 shadow-[inset_0_0_0_1px_var(--border-subtle)]">
			<p class="text-xs font-semibold text-primary">Plan Terms</p>
			<div class="mt-2 grid gap-1.5 text-[11px] font-semibold text-secondary">
				<span>✓ Exchanges</span>
				<span>✓ Expenses</span>
				<span>✓ Responsibilities</span>
			</div>
		</div>
	)}
	{type === 'export' && (
		<div class="rounded-[1.15rem] bg-page/70 p-3 shadow-[inset_0_0_0_1px_var(--border-subtle)]">
			<p class="text-xs font-semibold text-primary">Export Options</p>
			<div class="mt-2 grid grid-cols-2 gap-2 text-[10px] font-bold text-secondary">
				<span class="rounded-lg bg-surface px-2 py-2 text-center">PDF</span>
				<span class="rounded-lg bg-surface px-2 py-2 text-center">Print</span>
			</div>
			<div class="mt-2 h-12 rounded-lg bg-surface shadow-[inset_0_0_0_1px_var(--border-subtle)]"></div>
		</div>
	)}
</div>
