---
interface Props {
	parentA?: number;
	parentB?: number;
}

const { parentA = 57, parentB = 43 } = Astro.props;
---

<div class="rounded-[1.15rem] bg-page/70 p-3 shadow-[inset_0_0_0_1px_var(--border-subtle)]" aria-hidden="true">
	<div class="mb-3 flex items-center justify-between">
		<p class="text-xs font-semibold text-primary">Parenting Time</p>
		<span class="rounded-full bg-surface px-2 py-1 text-[10px] font-semibold text-muted">Estimate</span>
	</div>
	<div class="grid gap-2">
		<div>
			<div class="mb-1 flex justify-between text-[11px] font-semibold text-secondary">
				<span>Parent A</span>
				<span>{parentA}%</span>
			</div>
			<div class="h-2 rounded-full bg-surface">
				<div class="h-2 rounded-full bg-parent-a" style={`width: ${parentA}%`}></div>
			</div>
		</div>
		<div>
			<div class="mb-1 flex justify-between text-[11px] font-semibold text-secondary">
				<span>Parent B</span>
				<span>{parentB}%</span>
			</div>
			<div class="h-2 rounded-full bg-surface">
				<div class="h-2 rounded-full bg-parent-b" style={`width: ${parentB}%`}></div>
			</div>
		</div>
	</div>
</div>
