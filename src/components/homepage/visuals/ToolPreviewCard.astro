---
interface Props {
	type: string;
	muted?: boolean;
}

const { type, muted = false } = Astro.props;
const opacityClass = muted ? 'opacity-70' : '';
---

<div class={`mb-4 ${opacityClass}`} aria-hidden="true">
	{type === 'calendar' && (
		<div class="rounded-[1.15rem] bg-page/70 p-3 shadow-[inset_0_0_0_1px_var(--border-subtle)]">
			<div class="flex items-center justify-between">
				<p class="text-xs font-semibold text-primary">2-2-5-5 Plan</p>
				<span class="rounded-full bg-accent/10 px-2 py-1 text-[10px] font-semibold text-accent">50/50</span>
			</div>
			<div class="mt-3 grid grid-cols-7 gap-1 text-center text-[9px] font-bold uppercase tracking-[0.08em] text-muted">
				{['M', 'T', 'W', 'T', 'F', 'S', 'S'].map((day) => <span>{day}</span>)}
			</div>
			<div class="mt-2 grid grid-cols-7 gap-1.5">
				{['A', 'A', 'B', 'B', 'A', 'A', 'A', 'A', 'A', 'B', 'B', 'B', 'B', 'B'].map((parent) => (
					<span class={parent === 'A' ? 'grid h-7 place-items-center rounded-lg bg-parent-a/20 text-[10px] font-bold text-accent' : 'grid h-7 place-items-center rounded-lg bg-parent-b/15 text-[10px] font-bold text-parent-b'}>
						{parent}
					</span>
				))}
			</div>
		</div>
	)}
	{type === 'parenting-time' && (
		<div class="rounded-[1.15rem] bg-page/70 p-3 shadow-[inset_0_0_0_1px_var(--border-subtle)]">
			<div class="flex items-center justify-between">
				<p class="text-xs font-semibold text-primary">Parenting Time</p>
				<span class="rounded-full bg-accent/10 px-2 py-1 text-[10px] font-semibold text-accent">50/50 split</span>
			</div>
			<div class="mt-3 grid gap-2">
				<div class="rounded-xl bg-surface p-2.5">
					<div class="flex justify-between text-[11px] font-semibold text-secondary"><span>Parent A</span><span>182 overnights</span></div>
					<div class="mt-2 h-2 overflow-hidden rounded-full bg-page"><span class="block h-full w-[50%] rounded-full bg-parent-a/70"></span></div>
				</div>
				<div class="rounded-xl bg-surface p-2.5">
					<div class="flex justify-between text-[11px] font-semibold text-secondary"><span>Parent B</span><span>183 overnights</span></div>
					<div class="mt-2 h-2 overflow-hidden rounded-full bg-page"><span class="block h-full w-[50%] rounded-full bg-parent-b/60"></span></div>
				</div>
			</div>
		</div>
	)}
	{type === 'support' && (
		<div class="rounded-[1.15rem] bg-page/70 p-3 shadow-[inset_0_0_0_1px_var(--border-subtle)]">
			<div class="flex items-center justify-between">
				<p class="text-xs font-semibold text-primary">Support Estimate</p>
				<span class="rounded-full bg-surface px-2 py-1 text-[10px] font-semibold text-muted">Planning</span>
			</div>
			<div class="mt-3 rounded-xl bg-surface p-3">
				<p class="text-[10px] font-semibold uppercase tracking-[0.14em] text-muted">Monthly estimate</p>
				<p class="mt-1 text-2xl font-semibold tracking-[-0.04em] text-primary">$1,240</p>
				<div class="mt-3 grid gap-1 text-[10px] font-semibold text-secondary">
					<span>Based on: parenting time</span>
					<span>Children: 2</span>
					<span>State: Texas</span>
				</div>
			</div>
		</div>
	)}
	{type === 'holidays' && (
		<div class="rounded-[1.15rem] bg-page/70 p-3 shadow-[inset_0_0_0_1px_var(--border-subtle)]">
			<p class="text-xs font-semibold text-primary">Holiday Plan</p>
			<div class="mt-2 grid gap-1.5 text-[11px] font-semibold text-secondary">
				<div class="flex justify-between rounded-lg bg-surface px-2 py-1.5"><span>Christmas</span><span>Split</span></div>
				<div class="flex justify-between rounded-lg bg-surface px-2 py-1.5"><span>Spring Break</span><span>Parent B</span></div>
				<div class="flex justify-between rounded-lg bg-surface px-2 py-1.5"><span>Birthdays</span><span>Alternate</span></div>
				<div class="flex justify-between rounded-lg bg-surface px-2 py-1.5"><span>Summer break</span><span>Blocks</span></div>
			</div>
		</div>
	)}
	{type === 'agreement' && (
		<div class="rounded-[1.15rem] bg-page/70 p-3 shadow-[inset_0_0_0_1px_var(--border-subtle)]">
			<p class="text-xs font-semibold text-primary">Agreement Draft</p>
			<div class="mt-3 grid gap-2">
				<span class="h-2 rounded-full bg-parent-a/25"></span>
				<span class="h-2 w-5/6 rounded-full bg-surface"></span>
				<span class="h-2 w-4/6 rounded-full bg-surface"></span>
				<div class="mt-1 grid gap-1.5 text-[10px] font-semibold text-secondary">
					<span>✓ Exchange location</span>
					<span>✓ Holiday schedule</span>
					<span>✓ Decision making</span>
					<span>✓ Expenses</span>
				</div>
			</div>
		</div>
	)}
	{type === 'reports' && (
		<div class="rounded-[1.15rem] bg-page/70 p-3 shadow-[inset_0_0_0_1px_var(--border-subtle)]">
			<div class="flex items-center justify-between">
				<p class="text-xs font-semibold text-primary">Reports</p>
				<span class="rounded-full bg-surface px-2 py-1 text-[10px] font-semibold text-muted">Export</span>
			</div>
			<div class="mt-3 grid gap-1.5 text-[11px] font-semibold text-secondary">
				<div class="rounded-xl bg-surface p-2.5">
					<div class="flex justify-between"><span>Annual summary</span><span>Ready</span></div>
					<div class="mt-2 h-1.5 rounded-full bg-accent/30"></div>
				</div>
				<div class="flex justify-between rounded-lg bg-surface px-2 py-1.5"><span>PDF export</span><span>Calendar</span></div>
				<div class="flex justify-between rounded-lg bg-surface px-2 py-1.5"><span>Parenting time report</span><span>365 days</span></div>
			</div>
		</div>
	)}
	{type === 'comparison' && (
		<div class="rounded-[1.15rem] bg-page/70 p-3 shadow-[inset_0_0_0_1px_var(--border-subtle)]">
			<p class="text-xs font-semibold text-primary">Schedule Compare</p>
			<div class="mt-2 grid grid-cols-2 gap-2 text-[10px] font-semibold">
				<div class="rounded-xl bg-surface p-2">
					<p class="text-muted">2-2-3</p>
					<div class="mt-2 h-2 rounded-full bg-parent-a/25"></div>
					<div class="mt-1 h-2 rounded-full bg-parent-b/25"></div>
				</div>
				<div class="rounded-xl bg-surface p-2">
					<p class="text-muted">60/40</p>
					<div class="mt-2 h-2 w-4/5 rounded-full bg-parent-a/25"></div>
					<div class="mt-1 h-2 w-3/5 rounded-full bg-parent-b/25"></div>
				</div>
			</div>
		</div>
	)}
</div>
