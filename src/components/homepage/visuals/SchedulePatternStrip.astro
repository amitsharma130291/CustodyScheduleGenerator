---
interface Props {
	pattern?: string[];
	label?: string;
}

const {
	pattern = ['A', 'A', 'B', 'B', 'A', 'A', 'A', 'B', 'B', 'A', 'A', 'B', 'B', 'B'],
	label = 'Custody schedule pattern preview',
} = Astro.props;
---

<div class="rounded-[1.15rem] bg-page/70 p-3 shadow-[inset_0_0_0_1px_var(--border-subtle)]" aria-hidden="true" aria-label={label}>
	<div class="flex items-center justify-between text-[10px] font-semibold uppercase tracking-[0.14em] text-muted">
		<span>Parent A</span>
		<span>Parent B</span>
	</div>
	<div class="mt-2 grid gap-1 [grid-template-columns:repeat(14,minmax(0,1fr))]">
		{pattern.map((parent) => (
			<span class={`h-7 rounded-lg ${parent === 'A' ? 'bg-parent-a/20 shadow-[inset_0_0_0_1px_rgba(37,99,235,0.18)]' : 'bg-parent-b/20 shadow-[inset_0_0_0_1px_rgba(45,212,191,0.18)]'}`}></span>
		))}
	</div>
</div>
