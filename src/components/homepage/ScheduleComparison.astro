---
interface ComparisonRow {
	schedule: string;
	href: string;
	split: string;
	exchanges: string;
	age: string;
	stability: string;
	useCase: string;
}

interface Props {
	rows: ComparisonRow[];
}

const { rows } = Astro.props;
---

<section id="compare" class="container-shell scroll-mt-24 py-8 lg:py-10" aria-labelledby="schedule-comparison-title">
	<div class="max-w-3xl">
		<p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">Decision guide</p>
		<h2 id="schedule-comparison-title" class="mt-3 text-3xl font-semibold leading-[1.08] tracking-[-0.045em] text-primary sm:text-4xl">
			Compare common custody schedules
		</h2>
		<p class="mt-4 text-base leading-7 text-secondary">
			The best schedule is not just the one with the right percentage. Exchange frequency, school stability, and age fit usually matter just as much.
		</p>
	</div>

	<div class="mt-6 grid gap-4 md:grid-cols-2 xl:grid-cols-4">
		{rows.map((row) => (
			<a href={row.href} class="soft-card rounded-[1.5rem] p-4 transition-all duration-200 hover:-translate-y-0.5 hover:border-accent/40 hover:shadow-[0_18px_44px_rgba(15,23,42,0.08)]">
				<div class="flex items-start justify-between gap-4">
					<h3 class="text-lg font-semibold tracking-[-0.03em] text-primary">{row.schedule}</h3>
					<span class="rounded-full bg-surface-elevated px-3 py-1 text-xs font-semibold text-accent shadow-[inset_0_0_0_1px_var(--border-subtle)]">{row.split}</span>
				</div>
				<dl class="mt-4 grid gap-2 text-sm leading-6 text-secondary">
					<div class="flex justify-between gap-4"><dt>Exchanges</dt><dd class="font-medium text-primary">{row.exchanges}</dd></div>
					<div class="flex justify-between gap-4"><dt>Best age</dt><dd class="font-medium text-primary">{row.age}</dd></div>
					<div class="flex justify-between gap-4"><dt>Stability</dt><dd class="font-medium text-primary">{row.stability}</dd></div>
					<div><dt class="text-muted">Typical use</dt><dd class="mt-1 text-primary">{row.useCase}</dd></div>
				</dl>
			</a>
		))}
	</div>
	<a href="/blog" class="btn-secondary mt-5 inline-flex h-11 items-center justify-center rounded-full px-5 text-sm font-semibold">
		Compare all custody schedules
	</a>
</section>
