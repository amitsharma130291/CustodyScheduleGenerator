---
interface RelatedTool {
	title: string;
	href: string;
	when: string;
}

interface Props {
	tools: RelatedTool[];
}

const { tools } = Astro.props;
---

<section id="related-tools" class="container-shell py-section" aria-labelledby="related-tools-title">
	<div class="max-w-3xl">
		<p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">Related tools</p>
		<h2 id="related-tools-title" class="mt-3 text-3xl font-semibold leading-[1.08] tracking-[-0.045em] text-primary sm:text-4xl">
			Use the right tool for the next question.
		</h2>
		<p class="mt-4 text-base leading-7 text-secondary">
			Once the calendar looks close, these tools help with percentages, templates, visitation planning, holiday schedules, and support estimates.
		</p>
	</div>

	<div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
		{tools.map((tool) => (
			<a href={tool.href} class="soft-card group flex h-full flex-col rounded-[1.5rem] p-4 transition-all duration-200 hover:-translate-y-0.5 hover:border-accent/40 hover:shadow-[0_18px_44px_rgba(15,23,42,0.08)]">
				<h3 class="text-lg font-semibold tracking-[-0.03em] text-primary">{tool.title}</h3>
				<p class="mt-2 text-sm leading-6 text-secondary">{tool.when}</p>
				<span class="mt-auto pt-3 text-sm font-semibold text-accent underline decoration-line underline-offset-4 transition-colors group-hover:text-primary">Open tool →</span>
			</a>
		))}
	</div>
</section>
