---
import ScheduleMiniCalendar from './ScheduleMiniCalendar.astro';

interface PopularSchedule {
	scheduleId: string;
	name: string;
	href: string;
	split: string;
	previewPattern: string[];
	description: string;
	bestFor: string;
	tradeoff: string;
}

interface Props {
	schedules: PopularSchedule[];
}

const { schedules } = Astro.props;
---

<section id="popular-schedules" class="container-shell scroll-mt-24 py-8 lg:py-10" aria-labelledby="popular-schedules-title">
	<div class="max-w-3xl">
		<p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">Most popular custody schedules</p>
		<h2 id="popular-schedules-title" class="mt-3 text-3xl font-semibold leading-[1.08] tracking-[-0.045em] text-primary sm:text-4xl">
			Common Custody Schedules and Parenting Plans
		</h2>
		<p class="mt-4 text-base leading-7 text-secondary">
			Use these cards to narrow the first decision: frequent contact, stable weekdays, fewer exchanges, or a primary-home routine.
		</p>
	</div>

	<div class="mt-6 grid gap-4 sm:grid-cols-2 xl:grid-cols-4">
		{schedules.map((schedule) => (
			<article class="soft-card group flex h-full flex-col rounded-[1.5rem] p-4 transition-all duration-200 ease-out hover:-translate-y-0.5 hover:border-accent/40 hover:shadow-[0_18px_44px_rgba(15,23,42,0.08)]">
				<div class="flex items-start justify-between gap-4">
					<h3 class="text-xl font-semibold tracking-[-0.035em] text-primary">{schedule.name}</h3>
					<span class="shrink-0 rounded-full bg-surface-elevated px-3 py-1 text-xs font-semibold text-accent shadow-[inset_0_0_0_1px_var(--border-subtle)]">{schedule.split}</span>
				</div>
				<div class="mt-3">
					<ScheduleMiniCalendar pattern={schedule.previewPattern} label={`${schedule.name} mini preview`} />
				</div>
				<p class="mt-3 text-sm leading-6 text-secondary">{schedule.description}</p>
				<dl class="mt-3 grid gap-1.5 text-sm leading-6">
					<div>
						<dt class="font-semibold text-primary">Best for</dt>
						<dd class="text-secondary">{schedule.bestFor}</dd>
					</div>
					<div>
						<dt class="font-semibold text-primary">Tradeoff</dt>
						<dd class="text-secondary">{schedule.tradeoff}</dd>
					</div>
				</dl>
				<div class="mt-auto flex flex-col gap-2 pt-4">
					<button type="button" class="btn-primary inline-flex h-11 w-full items-center justify-center whitespace-nowrap rounded-full px-4 text-sm font-semibold" data-use-schedule={schedule.scheduleId}>
						Use this schedule
					</button>
					<a href={schedule.href} class="text-center text-sm font-semibold text-accent underline decoration-line underline-offset-4 transition-colors hover:text-primary">
						Read guide →
					</a>
				</div>
			</article>
		))}
	</div>
</section>
