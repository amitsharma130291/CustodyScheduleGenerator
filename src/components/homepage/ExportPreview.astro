<section class="container-shell py-8 lg:py-10" aria-labelledby="export-preview-title">
	<div class="premium-card rounded-[2rem] p-3">
		<div class="grid gap-6 rounded-[1.7rem] bg-surface-elevated/80 p-5 sm:p-6 lg:grid-cols-[0.9fr_1.1fr] lg:items-center lg:p-7">
			<div>
				<p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">Printable exports</p>
				<h2 id="export-preview-title" class="mt-3 text-3xl font-semibold leading-[1.08] tracking-[-0.045em] text-primary sm:text-4xl">
					Preview a printable custody calendar before you export.
				</h2>
				<p class="mt-4 text-base leading-7 text-secondary">
					Generate monthly or yearly PDF calendars that are easier to review, print, and bring into co-parenting discussions.
				</p>
				<ul class="mt-5 grid gap-2 text-sm leading-6 text-secondary sm:grid-cols-2">
					<li><span class="font-semibold text-parent-b">✓</span> printable calendar</li>
					<li><span class="font-semibold text-parent-b">✓</span> parent labels</li>
					<li><span class="font-semibold text-parent-b">✓</span> overnight split</li>
					<li><span class="font-semibold text-parent-b">✓</span> schedule dates</li>
					<li><span class="font-semibold text-parent-b">✓</span> planning notes</li>
					<li><span class="font-semibold text-parent-b">✓</span> educational disclaimer</li>
				</ul>
				<a href="#generator" class="btn-primary mt-5 inline-flex h-11 items-center justify-center rounded-full px-5 text-sm font-semibold">
					Generate printable calendar
				</a>
			</div>

			<div class="rounded-[1.5rem] bg-page p-4 shadow-[inset_0_0_0_1px_var(--border-subtle)]">
				<div class="rounded-xl bg-surface-elevated p-3 shadow-[inset_0_0_0_1px_var(--border-subtle)]">
					<div class="flex items-start justify-between gap-4 border-b border-line-subtle pb-3">
						<div>
							<p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">Monthly PDF</p>
							<p class="mt-1 text-lg font-semibold tracking-[-0.03em] text-primary">Custody Calendar</p>
						</div>
						<p class="rounded-full bg-page px-3 py-1 text-xs font-semibold text-accent shadow-[inset_0_0_0_1px_var(--border-subtle)]">50/50</p>
					</div>
					<div class="mt-3 grid grid-cols-7 gap-1">
						{Array.from({ length: 28 }).map((_, index) => (
							<span class={`grid aspect-square place-items-center rounded-lg text-[10px] font-semibold ${index % 5 < 2 ? 'bg-[rgba(37,99,235,0.2)] text-accent' : 'bg-[rgba(45,212,191,0.14)] text-parent-b'}`}>
								{index + 1}
							</span>
						))}
					</div>
					<div class="mt-3 grid grid-cols-2 gap-2">
						<div class="rounded-xl bg-page/70 p-2 text-xs text-secondary shadow-[inset_0_0_0_1px_var(--border-subtle)]">
							<p class="font-semibold text-primary">Parent A</p>
							<p class="mt-1">14 overnights</p>
						</div>
						<div class="rounded-xl bg-page/70 p-2 text-xs text-secondary shadow-[inset_0_0_0_1px_var(--border-subtle)]">
							<p class="font-semibold text-primary">Parent B</p>
							<p class="mt-1">14 overnights</p>
						</div>
					</div>
					<p class="mt-3 text-[11px] leading-4 text-muted">Planning tool. Not legal advice.</p>
				</div>
			</div>
		</div>
	</div>
</section>
