<script>
	function prefersReducedMotion() {
		return window.matchMedia('(prefers-reduced-motion: reduce)').matches;
	}

	function useScheduleInGenerator(scheduleId) {
		const generator = document.querySelector('#generator');
		const select = document.querySelector('[data-schedule-select]');
		const generateButton = document.querySelector('[data-generate-calendar]');

		if (!(select instanceof HTMLSelectElement)) return;

		select.value = scheduleId;
		select.dispatchEvent(new Event('input', { bubbles: true }));
		select.dispatchEvent(new Event('change', { bubbles: true }));

		if (generateButton instanceof HTMLButtonElement) {
			generateButton.click();
		}

		if (generator instanceof HTMLElement) {
			generator.scrollIntoView({
				block: 'start',
				behavior: prefersReducedMotion() ? 'auto' : 'smooth',
			});
		}
	}

	document.addEventListener('click', (event) => {
		const target = event.target;
		const button = target instanceof Element ? target.closest('[data-use-schedule]') : null;

		if (!(button instanceof HTMLElement)) return;
		const scheduleId = button.dataset.useSchedule;
		if (!scheduleId) return;

		event.preventDefault();
		useScheduleInGenerator(scheduleId);
	});
</script>
