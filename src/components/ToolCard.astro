---
import { ArrowRight, CalendarDays, Clock3 } from 'lucide-astro';

interface Props {
	label: string;
	title: string;
	description: string;
	pattern: string;
	href: string;
	accent?: 'indigo' | 'green';
}

const { label, title, description, pattern, href, accent = 'indigo' } = Astro.props;
const accentClass = accent === 'green' ? 'text-parent-b' : 'text-accent';
---

<a href={href} class="soft-card group flex min-h-[19.75rem] cursor-pointer flex-col rounded-[1.5rem] p-6 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-accent">
	<div class="flex items-start justify-between gap-4">
		<div>
			<p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">{label}</p>
			<h3 class="mt-3 text-xl font-semibold tracking-[-0.03em] text-primary">{title}</h3>
		</div>
		<span class={`rounded-full bg-surface-elevated/80 p-2.5 shadow-[inset_0_0_0_1px_var(--border-subtle)] transition-transform duration-200 group-hover:-translate-y-0.5 ${accentClass}`}>
			<CalendarDays size={18} aria-hidden="true" />
		</span>
	</div>

	<p class="mt-4 text-sm leading-6 text-secondary">{description}</p>

	<div class="mt-5 rounded-2xl bg-page/45 p-4 shadow-[inset_0_0_0_1px_var(--border-subtle)] transition-colors duration-200 group-hover:bg-surface/70 group-hover:shadow-[inset_0_0_0_1px_color-mix(in_srgb,var(--accent)_22%,var(--border-subtle))]">
		<div class="flex items-center gap-2 text-sm font-medium text-primary">
			<Clock3 size={16} class={accentClass} aria-hidden="true" />
			<span>{pattern}</span>
		</div>
		<div class="mt-4 grid grid-cols-7 gap-1" aria-hidden="true">
			{Array.from({ length: 14 }).map((_, index) => {
				const isFirstParent = index % 5 < 2;
				const color = isFirstParent
					? 'bg-[rgba(94,106,210,0.22)] text-accent'
					: 'bg-[rgba(34,197,94,0.14)] text-parent-b';
				return <span class={`h-7 rounded-lg text-center text-[10px] font-semibold leading-7 transition-transform duration-200 group-hover:scale-[1.03] ${color}`}>{index + 1}</span>;
			})}
		</div>
	</div>

	<div class="mt-auto flex items-center gap-2 pt-4 text-sm font-medium text-secondary transition-colors duration-200 group-hover:text-primary">
		<span class={accentClass}>View schedule</span>
		<ArrowRight size={16} class={`${accentClass} transition-transform duration-200 group-hover:translate-x-0.5`} aria-hidden="true" />
	</div>
</a>
