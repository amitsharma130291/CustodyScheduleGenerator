---
import CtaButton from '../CtaButton.astro';
import CalendarPreview from '../tool/CalendarPreview.astro';
import { generateSchedule } from '../../lib/schedules/generateSchedule';
import { getDefaultStartDate } from '../../lib/schedules/format';
import type { ScheduleInputType } from '../../lib/schedules/types';

interface Props {
	scheduleId: string;
	title: string;
	description?: string;
	exchanges: string;
	longestAway: string;
	bestFor: string;
	highlights: string[];
	cta: string;
	href: string;
}

const { scheduleId, title, description, exchanges, longestAway, bestFor, highlights, cta, href } = Astro.props;

const schedule = generateSchedule({
	scheduleId: scheduleId as ScheduleInputType,
	startDate: getDefaultStartDate(),
});
---

<article class="premium-card rounded-[1.75rem] p-3">
	<div class="rounded-[1.45rem] bg-surface-elevated p-4 sm:p-5">
		<h3 class="text-xl font-semibold tracking-[-0.035em] text-primary">{title}</h3>
		{description && <p class="mt-2 text-sm leading-6 text-secondary">{description}</p>}
		<div class="mt-4">
			<CalendarPreview schedule={schedule} embedded />
		</div>
		<dl class="mt-4 grid gap-2 text-sm leading-6 text-secondary">
			<div><dt class="inline font-semibold text-primary">Exchanges:</dt> <dd class="inline">{exchanges}</dd></div>
			<div><dt class="inline font-semibold text-primary">Longest stretch away:</dt> <dd class="inline">{longestAway}</dd></div>
			<div><dt class="inline font-semibold text-primary">Best for:</dt> <dd class="inline">{bestFor}</dd></div>
		</dl>
		<ul class="mt-3 list-disc space-y-1 pl-4 text-sm leading-6 text-secondary">
			{highlights.map((item) => <li>{item}</li>)}
		</ul>
		<div class="mt-4">
			<CtaButton href={href} variant="primary" size="small" class="w-full justify-center sm:w-auto">
				{cta}
			</CtaButton>
		</div>
	</div>
</article>
