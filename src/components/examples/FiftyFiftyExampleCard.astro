---
import CtaButton from '../CtaButton.astro';
import ScheduleMiniCalendar from '../homepage/ScheduleMiniCalendar.astro';
import { getScheduleCustomizeUrl } from '../../data/fiftyFiftyScheduleExamples';

interface RecommendationLink {
	label: string;
	href: string;
}

interface Props {
	id?: string;
	ageLabel?: string;
	name: string;
	bestFor: string;
	pattern: string[];
	exchanges: string;
	pros: string[];
	challenges: string[];
	scheduleId?: string;
	guideHref?: string;
	guideLabel?: string;
	calendarLabel?: string;
	recommendedPattern?: string;
	recommendationReason?: string;
	recommendationLinks?: RecommendationLink[];
	metrics?: {
		exchangeLevel: string;
		predictability: string;
		bestAge: string;
	};
	compact?: boolean;
}

const {
	id,
	ageLabel,
	name,
	bestFor,
	pattern,
	exchanges,
	pros,
	challenges,
	scheduleId,
	guideHref,
	guideLabel,
	calendarLabel,
	recommendedPattern,
	recommendationReason,
	recommendationLinks,
	metrics,
	compact = false,
} = Astro.props;

const customizeHref = getScheduleCustomizeUrl(scheduleId);
---

<article id={id} class="soft-card flex h-full flex-col rounded-[1.5rem] p-5 transition-all duration-200 hover:-translate-y-0.5 hover:border-accent/30 hover:shadow-[0_18px_44px_rgba(15,23,42,0.08)]">
	<div>
		{ageLabel ? (
			<p class="text-[11px] font-semibold uppercase tracking-[0.16em] text-accent">{ageLabel}</p>
		) : (
			<p class="text-[11px] font-semibold uppercase tracking-[0.16em] text-muted">Example</p>
		)}
		<h3 class="mt-1 text-lg font-semibold tracking-[-0.03em] text-primary">{name}</h3>
	</div>
	{recommendedPattern && (
		<div class="mt-3 rounded-xl bg-page/45 p-3 text-sm leading-6 text-secondary shadow-[inset_0_0_0_1px_var(--border-subtle)]">
			<p><span class="font-semibold text-primary">Recommended pattern:</span> {recommendedPattern}</p>
			{recommendationReason && (
				<p class="mt-1"><span class="font-semibold text-primary">Why:</span> {recommendationReason}</p>
			)}
			{recommendationLinks && recommendationLinks.length > 0 && (
				<div class="mt-2 flex flex-wrap gap-2">
					{recommendationLinks.map((link) => (
						<a href={link.href} class="text-xs font-semibold text-accent underline decoration-line underline-offset-4 hover:text-primary">
							{link.label}
						</a>
					))}
				</div>
			)}
		</div>
	)}
	<p class="mt-2 text-sm leading-6 text-secondary"><span class="font-semibold text-primary">Best for:</span> {bestFor}</p>
	{metrics && (
		<dl class="mt-3 grid grid-cols-3 gap-2 rounded-xl bg-page/45 p-3 text-center text-[11px] shadow-[inset_0_0_0_1px_var(--border-subtle)]">
			<div>
				<dt class="font-semibold uppercase tracking-[0.12em] text-muted">Exchanges</dt>
				<dd class="mt-1 font-semibold text-primary">{metrics.exchangeLevel}</dd>
			</div>
			<div>
				<dt class="font-semibold uppercase tracking-[0.12em] text-muted">Predictability</dt>
				<dd class="mt-1 font-semibold text-primary">{metrics.predictability}</dd>
			</div>
			<div>
				<dt class="font-semibold uppercase tracking-[0.12em] text-muted">Best age</dt>
				<dd class="mt-1 font-semibold leading-4 text-primary">{metrics.bestAge}</dd>
			</div>
		</dl>
	)}
	<div class="mt-4">
		<ScheduleMiniCalendar pattern={pattern} label={calendarLabel ?? `${name} two-week pattern`} />
	</div>
	{!compact && (
		<dl class="mt-4 grid gap-2 text-sm leading-6 text-secondary">
			<div><dt class="inline font-semibold text-primary">Exchange days:</dt> <dd class="inline">{exchanges}</dd></div>
			<div>
				<dt class="font-semibold text-primary">Pros</dt>
				<dd class="mt-1">
					<ul class="list-disc space-y-1 pl-4">
						{pros.map((item) => <li>{item}</li>)}
					</ul>
				</dd>
			</div>
			<div>
				<dt class="font-semibold text-primary">Challenges</dt>
				<dd class="mt-1">
					<ul class="list-disc space-y-1 pl-4">
						{challenges.map((item) => <li>{item}</li>)}
					</ul>
				</dd>
			</div>
		</dl>
	)}
	<div class="mt-auto flex flex-col gap-2 pt-4">
		<CtaButton href={customizeHref} variant="primary" size="small" class="w-full justify-center">
			Customize this example
		</CtaButton>
		{guideHref && guideLabel && (
			<CtaButton href={guideHref} variant="secondary" size="small" class="w-full justify-center">
				{guideLabel}
			</CtaButton>
		)}
	</div>
</article>
