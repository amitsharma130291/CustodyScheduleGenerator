---
import CtaButton from './CtaButton.astro';

interface Props {
	title: string;
	ageGroup?: 'toddler' | 'five' | 'seven' | 'teen';
	quizType?: 'age' | 'fiftyFifty' | 'sixtyForty';
	useContainer?: boolean;
}

const { title, ageGroup = 'five', quizType = 'age', useContainer = true } = Astro.props;

const ageQuestions = {
	toddler: {
		question: 'Does the child have sensitive nap, sleep, or separation needs?',
		name: 'ageNeed',
		options: [
			['very', 'Yes, very sensitive'],
			['somewhat', 'Somewhat'],
			['not', 'Not usually'],
		],
	},
	five: {
		question: 'Is the child in kindergarten or a consistent school routine?',
		name: 'ageNeed',
		options: [
			['yes', 'Yes'],
			['soon', 'Starting soon'],
			['not', 'Not yet'],
		],
	},
	seven: {
		question: 'Does the child have regular homework, sports, or activities?',
		name: 'ageNeed',
		options: [
			['many', 'Yes, several weekly commitments'],
			['some', 'Some commitments'],
			['few', 'Not many yet'],
		],
	},
	teen: {
		question: 'Does the teenager drive, work, play sports, or have major social commitments?',
		name: 'ageNeed',
		options: [
			['many', 'Yes, several commitments'],
			['some', 'Some commitments'],
			['few', 'Not many'],
		],
	},
};

const agePageQuestions = [
	{
		question: 'Do both parents live close enough for regular school/daycare exchanges?',
		name: 'distance',
		options: [
			['close', 'Yes, within 15-20 minutes'],
			['somewhat', 'Somewhat, 20-45 minutes'],
			['far', 'No, farther apart'],
		],
	},
	{
		question: 'Is equal parenting time a major goal?',
		name: 'equalTime',
		options: [
			['yes', 'Yes'],
			['somewhat', 'Somewhat'],
			['no', 'No'],
		],
	},
	{
		question: 'How well does the child handle transitions?',
		name: 'transitions',
		options: [
			['well', 'Handles them well'],
			['somewhat', 'Sometimes struggles'],
			['struggles', 'Strongly struggles'],
		],
	},
	{
		question: 'Are school, daycare, activities, or work schedules predictable?',
		name: 'predictability',
		options: [
			['predictable', 'Mostly predictable'],
			['somewhat', 'Somewhat predictable'],
			['unpredictable', 'Very unpredictable'],
		],
	},
	ageQuestions[ageGroup],
];

const fiftyFiftyQuestions = [
	{
		question: 'Child age',
		name: 'childAge',
		options: [
			['toddler', 'Toddler'],
			['schoolYoung', '5-7'],
			['schoolOlder', '8-12'],
			['teen', 'Teenager'],
		],
	},
	{
		question: 'Distance between homes',
		name: 'homeDistance',
		options: [
			['under15', 'Under 15 minutes'],
			['fifteen45', '15-45 minutes'],
			['over45', 'More than 45 minutes'],
		],
	},
	{
		question: 'School/daycare routine',
		name: 'schoolRoutine',
		options: [
			['stable', 'Very predictable'],
			['somewhat', 'Somewhat predictable'],
			['unstable', 'Often changes'],
		],
	},
	{
		question: 'Activity level',
		name: 'activityLevel',
		options: [
			['busy', 'Very busy'],
			['moderate', 'Moderate'],
			['minimal', 'Minimal'],
		],
	},
	{
		question: 'Parent work schedules',
		name: 'workSchedules',
		options: [
			['predictable', 'Predictable'],
			['variable', 'Somewhat variable'],
			['highlyVariable', 'Highly variable'],
		],
	},
	{
		question: 'Child transition tolerance',
		name: 'transitionTolerance',
		options: [
			['easy', 'Handles transitions well'],
			['somewhat', 'Sometimes struggles'],
			['hard', 'Strongly struggles'],
		],
	},
];

const sixtyFortyQuestions = [
	{
		question: 'Child age',
		name: 'childAge',
		options: [
			['toddler', 'Toddler'],
			['preschool', 'Preschool'],
			['schoolYoung', '5-7'],
			['schoolOlder', '8-12'],
			['teen', 'Teenager'],
		],
	},
	{
		question: 'Distance between homes',
		name: 'homeDistance',
		options: [
			['close', 'Under 15 minutes'],
			['moderate', '15-35 minutes'],
			['far', 'More than 35 minutes'],
		],
	},
	{
		question: 'School situation',
		name: 'schoolSituation',
		options: [
			['oneAnchor', 'One parent handles most school routines'],
			['shared', 'Both parents can handle school routines'],
			['unstable', 'School transportation is difficult'],
		],
	},
	{
		question: 'Parent work schedule',
		name: 'workSchedule',
		options: [
			['predictable', 'Mostly predictable'],
			['uneven', 'Uneven but manageable'],
			['variable', 'Highly variable'],
		],
	},
	{
		question: 'Desired parenting split',
		name: 'desiredSplit',
		options: [
			['equal', 'As close to 50/50 as possible'],
			['middle', 'A middle ground with one school-week anchor'],
			['primary', 'One primary home with regular time for the other parent'],
		],
	},
	{
		question: 'Child transition tolerance',
		name: 'transitionTolerance',
		options: [
			['easy', 'Handles transitions well'],
			['somewhat', 'Sometimes struggles'],
			['hard', 'Strongly struggles'],
		],
	},
];

const questions = quizType === 'fiftyFifty'
	? fiftyFiftyQuestions
	: quizType === 'sixtyForty'
		? sixtyFortyQuestions
		: agePageQuestions;
---

<section class:list={[useContainer && 'container-shell', 'py-section']} data-schedule-quiz data-age-group={ageGroup} data-quiz-type={quizType}>
	<div class="premium-card rounded-[2rem] p-6 lg:p-8">
		<div class="grid gap-6 lg:grid-cols-[0.85fr_1.15fr]">
			<div>
				<p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">Educational quiz</p>
				<h2 class="mt-3 text-4xl font-semibold leading-[1.05] tracking-[-0.045em] text-primary">{title}</h2>
				<p class="mt-4 text-base leading-7 text-secondary">
					Answer a few practical questions to see which custody schedule may be worth comparing first. Nothing is saved, submitted, or collected.
				</p>
				<p class="mt-4 rounded-[1.25rem] border border-line bg-surface-elevated p-4 text-sm leading-6 text-secondary">
					This quiz is educational only and does not provide legal advice. The right schedule depends on your child, your parenting plan, and any court orders or local rules that apply.
				</p>
			</div>
			<div class="soft-card rounded-[1.5rem] p-5">
				<div class="mb-5 flex items-center justify-between gap-4">
					<p class="text-sm font-semibold text-primary">Schedule fit check</p>
					<p class="rounded-full bg-surface-elevated px-3 py-1 text-xs font-semibold text-muted" data-quiz-progress>Step 1 of {questions.length}</p>
				</div>
				<form class="grid gap-4" data-quiz-form>
					{questions.map((question, questionIndex) => (
						<fieldset class:list={['grid gap-3 rounded-[1.25rem] border border-line bg-surface p-4', questionIndex === 0 ? '' : 'hidden']} data-quiz-step={questionIndex}>
							<legend class="text-base font-semibold leading-6 text-primary">{question.question}</legend>
							<div class="mt-1 grid gap-2">
								{question.options.map(([value, label], optionIndex) => (
									<label class="group flex cursor-pointer items-start gap-3 rounded-2xl border border-line bg-surface-elevated px-4 py-3 text-sm leading-6 text-secondary transition-all duration-200 hover:-translate-y-0.5 hover:border-accent/40 hover:text-primary">
										<input
											class="mt-1 h-4 w-4 accent-[var(--accent)]"
											type="radio"
											name={question.name}
											value={value}
											checked={optionIndex === 0}
										/>
										<span>{label}</span>
									</label>
								))}
							</div>
						</fieldset>
					))}
					<div class="quiz-nav-group">
						<CtaButton variant="primary" size="small" data-quiz-next>Next</CtaButton>
						<CtaButton variant="secondary" size="small" data-quiz-prev disabled>Back</CtaButton>
					</div>
				</form>
				<div class="mt-5 rounded-[1.25rem] border border-line bg-surface-elevated p-4 text-sm leading-6 text-secondary" aria-live="polite" data-quiz-result>
					<p class="font-semibold text-primary">2-2-5-5 may be a good starting point.</p>
					<p class="mt-2">Nearby homes, equal-time goals, predictable routines, and manageable transitions make 2-2-5-5 worth comparing first.</p>
					<div class="cta-group mt-4">
						<CtaButton href="/2-2-5-5-custody-schedule/" variant="secondary" size="small">View 2-2-5-5 Schedule</CtaButton>
						<CtaButton href="/custody-schedule-generator/" variant="primary" size="small">Test this schedule on a calendar</CtaButton>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>

<script is:inline>
	(() => {
		const quizzes = document.querySelectorAll('[data-schedule-quiz]');
		if (!quizzes.length) return;

		const results = {
			twoTwoFiveFive: {
				title: '2-2-5-5 may be a good starting point.',
				body: 'This tends to fit nearby homes, equal-time goals, predictable routines, and children who handle transitions reasonably well.',
				avoid: 'Avoid starting here if five-day blocks feel too long or school items are hard to track between homes.',
				actions: [
					['View 2-2-5-5 Schedule', '/2-2-5-5-custody-schedule/', 'secondary'],
					['Test this schedule on a calendar', '/custody-schedule-generator/', 'primary'],
				],
			},
			twoTwoThree: {
				title: '2-2-3 may be a good starting point.',
				body: 'This may fit younger children who benefit from frequent contact with both parents and families who can manage more frequent exchanges calmly.',
				avoid: 'Avoid starting here if exchanges are high-conflict, homes are far apart, or the child struggles strongly with transitions.',
				actions: [
					['View 2-2-3 Schedule', '/2-2-3-custody-schedule/', 'secondary'],
					['Test this schedule on a calendar', '/custody-schedule-generator/', 'primary'],
				],
			},
			fiveTwoTwoFive: {
				title: '5-2-2-5 may be a good starting point.',
				body: 'This can fit families who want equal time but need predictable weekday blocks and fewer confusing transitions.',
				avoid: 'Avoid starting here if either home cannot manage full school-night routines during longer blocks.',
				actions: [
					['View 5-2-2-5 Schedule', '/5-2-2-5-custody-schedule/', 'secondary'],
					['Calculate Parenting Time', '/custody-percentage-calculator/', 'primary'],
				],
			},
			sixtyForty: {
				title: '60/40 may be a good starting point.',
				body: 'This may fit when one parent anchors more school routines, homes are not very close, or equal time would create too much transportation or transition stress.',
				avoid: 'Compare 50/50 first if both homes are close, both parents can handle school routines, and the child handles transitions well.',
				actions: [
					['View 60/40 Schedule', '/60-40-custody-schedule/', 'secondary'],
					['Calculate Parenting Time', '/parenting-time-calculator/', 'primary'],
				],
			},
			fiftyFiftyCompare: {
				title: '50/50 may be worth comparing.',
				body: 'If both homes are close, school routines are realistic from either home, and both parents want equal time, a 50/50 schedule may be practical.',
				avoid: 'Avoid forcing equal time if commute times, school mornings, work schedules, or frequent exchanges repeatedly create problems.',
				actions: [
					['Compare 50/50 Schedules', '/50-50-custody-schedule/', 'secondary'],
					['Test a Calendar', '/custody-schedule-generator/', 'primary'],
				],
			},
			seventyThirtyCompare: {
				title: '70/30 may be worth comparing.',
				body: 'This may fit when one parent needs to handle most school-week logistics or distance makes frequent overnights hard, while the other parent still has predictable time.',
				avoid: 'Avoid moving to 70/30 only because it is simpler if a realistic 60/40 plan would support the child and both parent relationships.',
				actions: [
					['Compare 70/30 Schedule', '/70-30-custody-schedule/', 'secondary'],
					['Calculate Parenting Time', '/custody-percentage-calculator/', 'primary'],
				],
			},
			everyOtherWeekend: {
				title: 'Every other weekend plus holidays may be more realistic.',
				body: 'This may fit families with long distance, limited parent availability, or situations where fewer exchanges are better.',
				avoid: 'Avoid using this as the default if both parents live close and can reliably support ordinary weekday routines.',
				actions: [
					['View Every Other Weekend Schedule', '/every-other-weekend-custody-schedule/', 'secondary'],
					['Plan Holidays', '/holiday-custody-schedule/', 'primary'],
				],
			},
			flexible: {
				title: 'A flexible/custom schedule may be best.',
				body: 'This may fit teenagers with driving, work, sports, or major social commitments, or families whose standard weekly patterns do not fit real life.',
				avoid: 'Avoid leaving the plan vague; flexible schedules still need written rules for notice, exchanges, and make-up time.',
				actions: [
					['Test this schedule on a calendar', '/custody-schedule-generator/', 'primary'],
					['Create Parenting Plan', '/parenting-plan-template/', 'secondary'],
				],
			},
			weekOnWeekOff: {
				title: 'Week-on/week-off may be a good starting point.',
				body: 'This may fit older children and teenagers who can handle full-week blocks and benefit from fewer exchanges around school, activities, work, or social plans.',
				avoid: 'Avoid starting here if the child needs more frequent contact or a full week away from either parent feels too long.',
				actions: [
					['View Week-On Week-Off', '/week-on-week-off-custody-schedule/', 'secondary'],
					['Test this schedule on a calendar', '/custody-schedule-generator/', 'primary'],
				],
			},
			customSchedule: {
				title: 'A custom schedule may be better.',
				body: 'This may fit families with highly variable work schedules, long travel times, or commitments that standard 50/50 patterns do not handle well.',
				avoid: 'Avoid making it informal only; custom schedules work best when the rules are still clear and written down.',
				actions: [
					['Test this schedule on a calendar', '/custody-schedule-generator/', 'primary'],
					['Create Parenting Plan', '/parenting-plan-template/', 'secondary'],
				],
			},
		};

		const getFiftyFiftyResultKey = (form) => {
			const childAge = form.get('childAge');
			const homeDistance = form.get('homeDistance');
			const schoolRoutine = form.get('schoolRoutine');
			const activityLevel = form.get('activityLevel');
			const workSchedules = form.get('workSchedules');
			const transitionTolerance = form.get('transitionTolerance');

			if (workSchedules === 'highlyVariable' || homeDistance === 'over45' || schoolRoutine === 'unstable') return 'customSchedule';
			if (childAge === 'toddler') return transitionTolerance === 'easy' && homeDistance === 'under15' ? 'twoTwoThree' : 'fiveTwoTwoFive';
			if (childAge === 'teen') return activityLevel === 'busy' || workSchedules !== 'predictable' ? 'customSchedule' : 'weekOnWeekOff';
			if (transitionTolerance === 'hard') return homeDistance === 'under15' ? 'fiveTwoTwoFive' : 'customSchedule';
			if (childAge === 'schoolOlder' && activityLevel === 'minimal' && workSchedules === 'predictable') return 'weekOnWeekOff';
			if (activityLevel === 'busy') return 'fiveTwoTwoFive';
			return 'twoTwoFiveFive';
		};

		const getSixtyFortyResultKey = (form) => {
			const childAge = form.get('childAge');
			const homeDistance = form.get('homeDistance');
			const schoolSituation = form.get('schoolSituation');
			const workSchedule = form.get('workSchedule');
			const desiredSplit = form.get('desiredSplit');
			const transitionTolerance = form.get('transitionTolerance');

			if (workSchedule === 'variable' || schoolSituation === 'unstable') return 'customSchedule';
			if (desiredSplit === 'equal' && homeDistance === 'close' && schoolSituation === 'shared' && transitionTolerance !== 'hard') return 'fiftyFiftyCompare';
			if (desiredSplit === 'primary' || homeDistance === 'far' || transitionTolerance === 'hard') return 'seventyThirtyCompare';
			if (childAge === 'teen' && homeDistance === 'close' && desiredSplit === 'equal') return 'fiftyFiftyCompare';
			return 'sixtyForty';
		};

		const getResultKey = (form, ageGroup) => {
			const distance = form.get('distance');
			const equalTime = form.get('equalTime');
			const transitions = form.get('transitions');
			const predictability = form.get('predictability');
			const ageNeed = form.get('ageNeed');

			if (ageGroup === 'teen' && (ageNeed === 'many' || predictability === 'unpredictable')) return 'flexible';
			if (predictability === 'unpredictable') return 'flexible';
			if (distance === 'far') return equalTime === 'no' || transitions === 'struggles' ? 'everyOtherWeekend' : 'sixtyForty';
			if (distance === 'somewhat' && (equalTime !== 'yes' || transitions === 'struggles')) return 'sixtyForty';
			if (ageGroup === 'toddler' && ageNeed === 'very') return transitions === 'well' && equalTime === 'yes' ? 'fiveTwoTwoFive' : 'sixtyForty';
			if (transitions === 'struggles') return equalTime === 'yes' && distance === 'close' ? 'fiveTwoTwoFive' : 'sixtyForty';
			if (equalTime === 'yes' && distance === 'close' && predictability === 'predictable') {
				return transitions === 'well' ? 'twoTwoFiveFive' : 'fiveTwoTwoFive';
			}
			if (equalTime === 'somewhat') return transitions === 'well' ? 'fiveTwoTwoFive' : 'sixtyForty';
			if (equalTime === 'no') return distance === 'close' ? 'sixtyForty' : 'everyOtherWeekend';
			return 'fiveTwoTwoFive';
		};

		const renderResult = (quiz) => {
			const form = quiz.querySelector('[data-quiz-form]');
			const result = quiz.querySelector('[data-quiz-result]');
			if (!form || !result) return;

			const formData = new FormData(form);
			const resultKey = quiz.dataset.quizType === 'fiftyFifty'
				? getFiftyFiftyResultKey(formData)
				: quiz.dataset.quizType === 'sixtyForty'
					? getSixtyFortyResultKey(formData)
					: getResultKey(formData, quiz.dataset.ageGroup);
			const recommendation = results[resultKey];
			const actions = recommendation.actions.map(([label, href, style]) => {
				const klass = style === 'primary' ? 'btn-primary' : 'btn-secondary';
				return `<a href="${href}" class="${klass} h-11">${label}</a>`;
			}).join('');

			result.innerHTML = `
				<p class="font-semibold text-primary">${recommendation.title}</p>
				<p class="mt-2">${recommendation.body}</p>
				${recommendation.avoid ? `<p class="mt-2"><span class="font-semibold text-primary">When to avoid:</span> ${recommendation.avoid}</p>` : ''}
				<p class="mt-2 text-xs leading-5 text-muted">This is an educational starting point, not a legal recommendation.</p>
				<div class="cta-group mt-4">${actions}</div>
			`;
		};

		quizzes.forEach((quiz) => {
			const steps = Array.from(quiz.querySelectorAll('[data-quiz-step]'));
			const prev = quiz.querySelector('[data-quiz-prev]');
			const next = quiz.querySelector('[data-quiz-next]');
			const progress = quiz.querySelector('[data-quiz-progress]');
			let activeStep = 0;

			const showStep = () => {
				steps.forEach((step, index) => {
					step.classList.toggle('hidden', index !== activeStep);
				});
				if (prev) prev.disabled = activeStep === 0;
				if (next) next.textContent = activeStep === steps.length - 1 ? 'Update result' : 'Next';
				if (progress) progress.textContent = `Step ${activeStep + 1} of ${steps.length}`;
				renderResult(quiz);
			};

			prev?.addEventListener('click', () => {
				activeStep = Math.max(0, activeStep - 1);
				showStep();
			});

			next?.addEventListener('click', () => {
				activeStep = Math.min(steps.length - 1, activeStep + 1);
				showStep();
			});

			quiz.addEventListener('change', () => renderResult(quiz));
			showStep();
		});
	})();
</script>
