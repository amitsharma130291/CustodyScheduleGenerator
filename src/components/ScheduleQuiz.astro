---
interface Props {
	title: string;
	ageGroup: 'toddler' | 'five' | 'seven' | 'teen';
}

const { title, ageGroup } = Astro.props;

const ageQuestions = {
	toddler: {
		question: 'Does the child have sensitive nap, sleep, or separation needs?',
		name: 'ageNeed',
		options: [
			['very', 'Yes, very sensitive'],
			['somewhat', 'Somewhat'],
			['not', 'Not usually'],
		],
	},
	five: {
		question: 'Is the child in kindergarten or a consistent school routine?',
		name: 'ageNeed',
		options: [
			['yes', 'Yes'],
			['soon', 'Starting soon'],
			['not', 'Not yet'],
		],
	},
	seven: {
		question: 'Does the child have regular homework, sports, or activities?',
		name: 'ageNeed',
		options: [
			['many', 'Yes, several weekly commitments'],
			['some', 'Some commitments'],
			['few', 'Not many yet'],
		],
	},
	teen: {
		question: 'Does the teenager drive, work, play sports, or have major social commitments?',
		name: 'ageNeed',
		options: [
			['many', 'Yes, several commitments'],
			['some', 'Some commitments'],
			['few', 'Not many'],
		],
	},
};

const questions = [
	{
		question: 'Do both parents live close enough for regular school/daycare exchanges?',
		name: 'distance',
		options: [
			['close', 'Yes, within 15-20 minutes'],
			['somewhat', 'Somewhat, 20-45 minutes'],
			['far', 'No, farther apart'],
		],
	},
	{
		question: 'Is equal parenting time a major goal?',
		name: 'equalTime',
		options: [
			['yes', 'Yes'],
			['somewhat', 'Somewhat'],
			['no', 'No'],
		],
	},
	{
		question: 'How well does the child handle transitions?',
		name: 'transitions',
		options: [
			['well', 'Handles them well'],
			['somewhat', 'Sometimes struggles'],
			['struggles', 'Strongly struggles'],
		],
	},
	{
		question: 'Are school, daycare, activities, or work schedules predictable?',
		name: 'predictability',
		options: [
			['predictable', 'Mostly predictable'],
			['somewhat', 'Somewhat predictable'],
			['unpredictable', 'Very unpredictable'],
		],
	},
	ageQuestions[ageGroup],
];
---

<section class="container-shell py-8 lg:py-10" data-schedule-quiz data-age-group={ageGroup}>
	<div class="premium-card rounded-[2rem] p-6 lg:p-8">
		<div class="grid gap-6 lg:grid-cols-[0.85fr_1.15fr]">
			<div>
				<p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">Educational quiz</p>
				<h2 class="mt-3 text-4xl font-semibold leading-[1.05] tracking-[-0.045em] text-primary">{title}</h2>
				<p class="mt-4 text-base leading-7 text-secondary">
					Answer a few practical questions to see which custody schedule may be worth comparing first. Nothing is saved, submitted, or collected.
				</p>
				<p class="mt-4 rounded-[1.25rem] border border-line bg-surface-elevated p-4 text-sm leading-6 text-secondary">
					This quiz is educational only and does not provide legal advice. The right schedule depends on your child, your parenting plan, and any court orders or local rules that apply.
				</p>
			</div>
			<div class="soft-card rounded-[1.5rem] p-5">
				<div class="mb-5 flex items-center justify-between gap-4">
					<p class="text-sm font-semibold text-primary">Schedule fit check</p>
					<p class="rounded-full bg-surface-elevated px-3 py-1 text-xs font-semibold text-muted" data-quiz-progress>Step 1 of {questions.length}</p>
				</div>
				<form class="grid gap-4" data-quiz-form>
					{questions.map((question, questionIndex) => (
						<fieldset class:list={['grid gap-3 rounded-[1.25rem] border border-line bg-surface p-4', questionIndex === 0 ? '' : 'hidden']} data-quiz-step={questionIndex}>
							<legend class="text-base font-semibold leading-6 text-primary">{question.question}</legend>
							<div class="mt-1 grid gap-2">
								{question.options.map(([value, label], optionIndex) => (
									<label class="group flex cursor-pointer items-start gap-3 rounded-2xl border border-line bg-surface-elevated px-4 py-3 text-sm leading-6 text-secondary transition-all duration-200 hover:-translate-y-0.5 hover:border-accent/40 hover:text-primary">
										<input
											class="mt-1 h-4 w-4 accent-[var(--accent)]"
											type="radio"
											name={question.name}
											value={value}
											checked={optionIndex === 0}
										/>
										<span>{label}</span>
									</label>
								))}
							</div>
						</fieldset>
					))}
					<div class="flex flex-col gap-2 sm:flex-row">
						<button type="button" class="btn-secondary inline-flex h-11 items-center justify-center rounded-full px-5 text-sm font-semibold disabled:cursor-not-allowed disabled:opacity-50" data-quiz-prev disabled>Back</button>
						<button type="button" class="btn-primary inline-flex h-11 items-center justify-center rounded-full px-5 text-sm font-semibold" data-quiz-next>Next</button>
					</div>
				</form>
				<div class="mt-5 rounded-[1.25rem] border border-line bg-surface-elevated p-4 text-sm leading-6 text-secondary" aria-live="polite" data-quiz-result>
					<p class="font-semibold text-primary">2-2-5-5 may be a good starting point.</p>
					<p class="mt-2">Nearby homes, equal-time goals, predictable routines, and manageable transitions make 2-2-5-5 worth comparing first.</p>
					<div class="mt-4 flex flex-col gap-2 sm:flex-row">
						<a href="/2-2-5-5-custody-schedule" class="btn-secondary inline-flex h-10 items-center justify-center rounded-full px-4 text-sm font-semibold">View 2-2-5-5 Schedule</a>
						<a href="/custody-schedule-generator" class="btn-primary inline-flex h-10 items-center justify-center rounded-full px-4 text-sm font-semibold">Generate Calendar</a>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>

<script is:inline>
	(() => {
		const quizzes = document.querySelectorAll('[data-schedule-quiz]');
		if (!quizzes.length) return;

		const results = {
			twoTwoFiveFive: {
				title: '2-2-5-5 may be a good starting point.',
				body: 'This tends to fit nearby homes, equal-time goals, predictable routines, and children who handle transitions reasonably well.',
				actions: [
					['View 2-2-5-5 Schedule', '/2-2-5-5-custody-schedule', 'secondary'],
					['Generate Calendar', '/custody-schedule-generator', 'primary'],
				],
			},
			fiveTwoTwoFive: {
				title: '5-2-2-5 may be a good starting point.',
				body: 'This can fit families who want equal time but need predictable weekday blocks and fewer confusing transitions.',
				actions: [
					['View 5-2-2-5 Schedule', '/5-2-2-5-custody-schedule', 'secondary'],
					['Calculate Parenting Time', '/custody-percentage-calculator', 'primary'],
				],
			},
			sixtyForty: {
				title: '60/40 may be more practical.',
				body: 'This may work better when one parent handles more school or daycare logistics, distance adds stress, or equal time creates too much travel.',
				actions: [
					['View 60/40 Schedule', '/60-40-custody-schedule', 'secondary'],
					['Calculate Parenting Time', '/parenting-time-calculator', 'primary'],
				],
			},
			everyOtherWeekend: {
				title: 'Every other weekend plus holidays may be more realistic.',
				body: 'This may fit families with long distance, limited parent availability, or situations where fewer exchanges are better.',
				actions: [
					['View Every Other Weekend Schedule', '/every-other-weekend-custody-schedule', 'secondary'],
					['Plan Holidays', '/holiday-custody-schedule', 'primary'],
				],
			},
			flexible: {
				title: 'A flexible/custom schedule may be best.',
				body: 'This may fit teenagers with driving, work, sports, or major social commitments, or families whose standard weekly patterns do not fit real life.',
				actions: [
					['Open Generator', '/custody-schedule-generator', 'primary'],
					['Create Parenting Plan', '/parenting-plan-template', 'secondary'],
				],
			},
		};

		const getResultKey = (form, ageGroup) => {
			const distance = form.get('distance');
			const equalTime = form.get('equalTime');
			const transitions = form.get('transitions');
			const predictability = form.get('predictability');
			const ageNeed = form.get('ageNeed');

			if (ageGroup === 'teen' && (ageNeed === 'many' || predictability === 'unpredictable')) return 'flexible';
			if (predictability === 'unpredictable') return 'flexible';
			if (distance === 'far') return equalTime === 'no' || transitions === 'struggles' ? 'everyOtherWeekend' : 'sixtyForty';
			if (distance === 'somewhat' && (equalTime !== 'yes' || transitions === 'struggles')) return 'sixtyForty';
			if (ageGroup === 'toddler' && ageNeed === 'very') return transitions === 'well' && equalTime === 'yes' ? 'fiveTwoTwoFive' : 'sixtyForty';
			if (transitions === 'struggles') return equalTime === 'yes' && distance === 'close' ? 'fiveTwoTwoFive' : 'sixtyForty';
			if (equalTime === 'yes' && distance === 'close' && predictability === 'predictable') {
				return transitions === 'well' ? 'twoTwoFiveFive' : 'fiveTwoTwoFive';
			}
			if (equalTime === 'somewhat') return transitions === 'well' ? 'fiveTwoTwoFive' : 'sixtyForty';
			if (equalTime === 'no') return distance === 'close' ? 'sixtyForty' : 'everyOtherWeekend';
			return 'fiveTwoTwoFive';
		};

		const renderResult = (quiz) => {
			const form = quiz.querySelector('[data-quiz-form]');
			const result = quiz.querySelector('[data-quiz-result]');
			if (!form || !result) return;

			const resultKey = getResultKey(new FormData(form), quiz.dataset.ageGroup);
			const recommendation = results[resultKey];
			const actions = recommendation.actions.map(([label, href, style]) => {
				const klass = style === 'primary' ? 'btn-primary' : 'btn-secondary';
				return `<a href="${href}" class="${klass} inline-flex h-10 items-center justify-center rounded-full px-4 text-sm font-semibold">${label}</a>`;
			}).join('');

			result.innerHTML = `
				<p class="font-semibold text-primary">${recommendation.title}</p>
				<p class="mt-2">${recommendation.body}</p>
				<p class="mt-2 text-xs leading-5 text-muted">This is an educational starting point, not a legal recommendation.</p>
				<div class="mt-4 flex flex-col gap-2 sm:flex-row">${actions}</div>
			`;
		};

		quizzes.forEach((quiz) => {
			const steps = Array.from(quiz.querySelectorAll('[data-quiz-step]'));
			const prev = quiz.querySelector('[data-quiz-prev]');
			const next = quiz.querySelector('[data-quiz-next]');
			const progress = quiz.querySelector('[data-quiz-progress]');
			let activeStep = 0;

			const showStep = () => {
				steps.forEach((step, index) => {
					step.classList.toggle('hidden', index !== activeStep);
				});
				if (prev) prev.disabled = activeStep === 0;
				if (next) next.textContent = activeStep === steps.length - 1 ? 'Update result' : 'Next';
				if (progress) progress.textContent = `Step ${activeStep + 1} of ${steps.length}`;
				renderResult(quiz);
			};

			prev?.addEventListener('click', () => {
				activeStep = Math.max(0, activeStep - 1);
				showStep();
			});

			next?.addEventListener('click', () => {
				activeStep = Math.min(steps.length - 1, activeStep + 1);
				showStep();
			});

			quiz.addEventListener('change', () => renderResult(quiz));
			showStep();
		});
	})();
</script>
