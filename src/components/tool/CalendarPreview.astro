---
import type { GeneratedSchedule } from '../../lib/schedules/types';

interface Props {
	schedule: GeneratedSchedule;
}

const { schedule } = Astro.props;
const totalDays = schedule.parentDayCounts.parentA + schedule.parentDayCounts.parentB || 1;
const parentAPercentage = Math.round((schedule.parentDayCounts.parentA / totalDays) * 100);
const parentBPercentage = 100 - parentAPercentage;
---

<section class="box-border min-w-0 overflow-hidden rounded-[1.5rem] bg-page/55 p-3 shadow-[inset_0_0_0_1px_var(--border-subtle)]" data-calendar-preview>
	<div class="hidden" data-print-header>
		<h1>Custody Schedule</h1>
		<dl>
			<div>
				<dt>Schedule</dt>
				<dd data-print-schedule-name>{schedule.definition.name}</dd>
			</div>
			<div>
				<dt>Start date</dt>
				<dd data-print-start-date>{schedule.startDate}</dd>
			</div>
			<div>
				<dt>Parent A</dt>
				<dd data-print-parent-a-name>{schedule.parentNames.parentA}</dd>
			</div>
			<div>
				<dt>Parent B</dt>
				<dd data-print-parent-b-name>{schedule.parentNames.parentB}</dd>
			</div>
		</dl>
		<p>Planning tool only. Not legal advice.</p>
	</div>

	<div class="flex flex-col gap-2 border-b border-line-subtle pb-3 sm:flex-row sm:items-center sm:justify-between">
		<div>
			<p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">Calendar preview</p>
			<h2 class="mt-1 text-xl font-semibold tracking-[-0.04em] text-primary" data-calendar-month>
				{schedule.monthLabel}
			</h2>
		</div>
		<div class="flex flex-wrap gap-3 text-xs text-secondary">
			<span class="inline-flex items-center gap-2"><i class="h-2.5 w-2.5 rounded-full bg-accent"></i><span data-parent-a-label>{schedule.parentNames.parentA}</span></span>
			<span class="inline-flex items-center gap-2"><i class="h-2.5 w-2.5 rounded-full bg-parent-b"></i><span data-parent-b-label>{schedule.parentNames.parentB}</span></span>
		</div>
	</div>

	<div class="mt-3 grid min-w-0 grid-cols-7 gap-1 text-center text-[10px] font-semibold uppercase tracking-[0.08em] text-muted sm:gap-1.5 sm:text-[11px]" aria-hidden="true">
		{['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'].map((day) => <span>{day}</span>)}
	</div>

	<div class="mt-2.5 grid min-w-0 grid-cols-7 gap-1 sm:gap-1.5" data-calendar-grid>
		{schedule.days.map((day) => {
			const color = !day.isCurrentMonth
				? 'text-muted opacity-30 shadow-[inset_0_0_0_1px_var(--border-subtle)]'
				: day.parent === 'parentA'
					? 'bg-[rgba(94,106,210,0.2)] text-accent shadow-[inset_0_0_0_1px_rgba(94,106,210,0.28)]'
					: 'bg-[rgba(34,197,94,0.14)] text-parent-b shadow-[inset_0_0_0_1px_rgba(34,197,94,0.18)]';

			return (
				<span
					class={`calendar-day-cell flex aspect-square max-h-[34px] min-h-0 items-center justify-center rounded-xl text-xs font-semibold sm:max-h-[34px] sm:rounded-2xl sm:text-sm ${color}`}
					title={`${day.parentName} - ${day.date}`}
				>
					{day.dayOfMonth}
				</span>
			);
		})}
	</div>

	<div class="mt-2.5 grid grid-cols-2 gap-2" aria-label="Parenting time summary" aria-live="polite">
		<div class="min-w-0 rounded-2xl bg-surface/70 p-1.5 shadow-[inset_0_0_0_1px_var(--border-subtle)]">
			<p class="inline-flex max-w-full items-center gap-1.5 text-xs font-medium leading-none text-secondary">
				<i class="h-2 w-2 shrink-0 rounded-full bg-accent" aria-hidden="true"></i>
				<span class="truncate" data-summary-parent-a-label>{schedule.parentNames.parentA}</span>
			</p>
			<p class="mt-1 text-[28px] font-bold leading-none tracking-[-0.05em] text-accent" data-summary-parent-a-percent>
				{parentAPercentage}%
			</p>
			<p class="mt-0.5 text-xs leading-none text-muted" data-summary-parent-a-days>{schedule.parentDayCounts.parentA} overnights</p>
		</div>
		<div class="min-w-0 rounded-2xl bg-surface/70 p-1.5 shadow-[inset_0_0_0_1px_var(--border-subtle)]">
			<p class="inline-flex max-w-full items-center gap-1.5 text-xs font-medium leading-none text-secondary">
				<i class="h-2 w-2 shrink-0 rounded-full bg-parent-b" aria-hidden="true"></i>
				<span class="truncate" data-summary-parent-b-label>{schedule.parentNames.parentB}</span>
			</p>
			<p class="mt-1 text-[28px] font-bold leading-none tracking-[-0.05em] text-parent-b" data-summary-parent-b-percent>
				{parentBPercentage}%
			</p>
			<p class="mt-0.5 text-xs leading-none text-muted" data-summary-parent-b-days>{schedule.parentDayCounts.parentB} overnights</p>
		</div>
	</div>

	<div class="mt-3 w-full min-w-0">
		<slot name="actions" />
	</div>
</section>
