---
import type { GeneratedSchedule } from '../../lib/schedules/types';

interface Props {
	schedule: GeneratedSchedule;
	/** Use non-heading month label when embedded inside cards (avoids nested H2). */
	embedded?: boolean;
	/** Optional subtitle under the month label. */
	headerNote?: string;
	/** Hide overnight summary stats (e.g. holiday demo calendars). */
	showSummary?: boolean;
}

const { schedule, embedded = false, headerNote, showSummary = true } = Astro.props;
const MonthLabelTag = embedded ? 'p' : 'h2';
const totalDays = schedule.parentDayCounts.parentA + schedule.parentDayCounts.parentB || 1;
const parentAPercentage = Math.round((schedule.parentDayCounts.parentA / totalDays) * 100);
const parentBPercentage = 100 - parentAPercentage;
---

<section class="box-border min-w-0 overflow-hidden rounded-[1.5rem] bg-page/60 p-4 shadow-[inset_0_0_0_1px_var(--border-subtle)]" data-calendar-preview>
	<div class="hidden" data-print-header>
		<h2>Custody Schedule</h2>
		<dl>
			<div>
				<dt>Schedule</dt>
				<dd data-print-schedule-name>{schedule.definition.name}</dd>
			</div>
			<div>
				<dt>Pattern</dt>
				<dd data-print-pattern-name>Default pattern</dd>
			</div>
			<div>
				<dt>Start date</dt>
				<dd data-print-start-date>{schedule.startDate}</dd>
			</div>
			<div>
				<dt>Generated date</dt>
				<dd data-print-generated-date>{new Date().toLocaleDateString('en-US')}</dd>
			</div>
			<div>
				<dt>Parent A</dt>
				<dd data-print-parent-a-name>{schedule.parentNames.parentA}</dd>
			</div>
			<div>
				<dt>Parent B</dt>
				<dd data-print-parent-b-name>{schedule.parentNames.parentB}</dd>
			</div>
		</dl>
		<p>Educational planning tool. Not legal advice.</p>
	</div>

	<div class="flex flex-col gap-2.5 border-b border-line-subtle pb-3.5 sm:flex-row sm:items-center sm:justify-between">
		<div>
			<p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">Parenting calendar preview</p>
			<MonthLabelTag class="mt-1 text-xl font-semibold tracking-[-0.04em] text-primary" data-calendar-month>
				{schedule.monthLabel}
			</MonthLabelTag>
			<p class="mt-1 text-[11px] leading-4 text-muted">{headerNote ?? 'Based on your selected start date.'}</p>
		</div>
		<div class="flex flex-wrap gap-3 text-xs text-secondary">
			<span class="inline-flex items-center gap-2"><i class="h-2.5 w-2.5 rounded-full bg-accent"></i><span data-parent-a-label>{schedule.parentNames.parentA}</span></span>
			<span class="inline-flex items-center gap-2"><i class="h-2.5 w-2.5 rounded-full bg-parent-b"></i><span data-parent-b-label>{schedule.parentNames.parentB}</span></span>
		</div>
	</div>

	<div class="mt-3.5 grid min-w-0 grid-cols-7 gap-1 text-center text-[10px] font-semibold uppercase tracking-[0.08em] text-muted sm:gap-1.5 sm:text-[11px]" aria-hidden="true">
		{['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'].map((day) => <span>{day}</span>)}
	</div>

	<div class="mt-3 grid min-w-0 grid-cols-7 gap-1 sm:gap-1.5" data-calendar-grid>
		{schedule.days.map((day) => {
			if (day.isPlaceholder) {
				return (
					<span
						class="calendar-day-cell calendar-day-cell--placeholder flex aspect-square max-h-[34px] min-h-0 items-center justify-center rounded-xl px-0.5 sm:max-h-[34px] sm:rounded-2xl"
						aria-hidden="true"
					></span>
				);
			}

			const holidayOverride = day.isHolidayOverride && day.isCurrentMonth;
			const color = !day.isCurrentMonth
				? 'text-muted opacity-30 shadow-[inset_0_0_0_1px_var(--border-subtle)]'
				: holidayOverride
					? 'bg-warning/20 text-primary shadow-[inset_0_0_0_2px_rgba(245,158,11,0.55)] ring-1 ring-warning/40'
					: day.parent === 'parentA'
						? 'bg-[rgba(37,99,235,0.2)] text-accent shadow-[inset_0_0_0_1px_rgba(37,99,235,0.28)]'
						: 'bg-[rgba(45,212,191,0.14)] text-parent-b shadow-[inset_0_0_0_1px_rgba(45,212,191,0.18)]';

			return (
				<span
					class={`calendar-day-cell flex aspect-square max-h-[34px] min-h-0 items-center justify-center rounded-xl px-0.5 text-xs font-semibold sm:max-h-[34px] sm:rounded-2xl sm:text-sm ${color}`}
					title={holidayOverride ? 'Thanksgiving override' : undefined}
				>
					<span class="leading-none">{day.dayOfMonth}</span>
				</span>
			);
		})}
	</div>

	{showSummary && (
	<div class="mt-3 grid grid-cols-2 gap-2.5" aria-label="Parenting time summary" aria-live="polite">
		<div class="min-w-0 rounded-2xl bg-surface/75 p-2 shadow-[inset_0_0_0_1px_var(--border-subtle)]">
			<p class="inline-flex max-w-full items-center gap-1.5 text-xs font-medium leading-none text-secondary">
				<i class="h-2 w-2 shrink-0 rounded-full bg-accent" aria-hidden="true"></i>
				<span class="truncate" data-summary-parent-a-label>{schedule.parentNames.parentA}</span>
			</p>
			<p class="mt-1 text-[9px] font-semibold uppercase tracking-[0.16em] text-muted" data-current-view-label>Overnight estimate</p>
			<p class="mt-1 text-[28px] font-bold leading-none tracking-[-0.05em] text-accent" data-summary-parent-a-percent>
				{parentAPercentage}%
			</p>
			<p class="mt-0.5 text-[11px] leading-none text-muted/90" data-summary-parent-a-days>{schedule.parentDayCounts.parentA} overnights</p>
		</div>
		<div class="min-w-0 rounded-2xl bg-surface/75 p-2 shadow-[inset_0_0_0_1px_var(--border-subtle)]">
			<p class="inline-flex max-w-full items-center gap-1.5 text-xs font-medium leading-none text-secondary">
				<i class="h-2 w-2 shrink-0 rounded-full bg-parent-b" aria-hidden="true"></i>
				<span class="truncate" data-summary-parent-b-label>{schedule.parentNames.parentB}</span>
			</p>
			<p class="mt-1 text-[9px] font-semibold uppercase tracking-[0.16em] text-muted" data-current-view-label>Overnight estimate</p>
			<p class="mt-1 text-[28px] font-bold leading-none tracking-[-0.05em] text-parent-b" data-summary-parent-b-percent>
				{parentBPercentage}%
			</p>
			<p class="mt-0.5 text-[11px] leading-none text-muted/90" data-summary-parent-b-days>{schedule.parentDayCounts.parentB} overnights</p>
		</div>
		<p class="col-span-2 -mt-0.5 text-center text-[11px] leading-none text-muted" data-annual-estimate>
			Annual estimate shown when available.
		</p>
	</div>
	)}

	<div class="mt-2 w-full min-w-0">
		<slot name="actions" />
	</div>

	<p class="mt-1.5 flex items-start gap-1.5 text-[11px] leading-4 text-muted print:hidden" data-sixty-forty-range-note>
		<span class="mt-0.5 inline-flex h-3.5 w-3.5 shrink-0 items-center justify-center rounded-full bg-surface-elevated text-[9px] font-semibold text-secondary shadow-[inset_0_0_0_1px_var(--border-subtle)]" aria-hidden="true">i</span>
		<span data-sixty-forty-range-note-text>Overnight estimate only.</span>
	</p>
</section>
