<div class="grid w-full min-w-0 grid-cols-1 gap-3 sm:grid-cols-2" data-export-actions>
	<button type="button" class="btn-primary flex h-12 w-full min-w-0 items-center justify-center overflow-hidden text-ellipsis whitespace-nowrap rounded-full px-4 text-sm font-semibold transition-all duration-200 ease-out hover:-translate-y-px hover:shadow-[0_10px_30px_rgba(94,106,210,0.14)] active:translate-y-0 active:scale-[0.99] disabled:cursor-not-allowed disabled:opacity-70 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent" data-print-schedule>
		Print
	</button>
	<button type="button" class="btn-secondary flex h-12 w-full min-w-0 items-center justify-center overflow-hidden text-ellipsis whitespace-nowrap rounded-full px-4 text-sm font-semibold transition-all duration-200 ease-out hover:-translate-y-px hover:shadow-[inset_0_0_0_1px_color-mix(in_srgb,var(--accent)_28%,var(--border-subtle)),0_10px_24px_rgba(0,0,0,0.12)] active:translate-y-0 active:scale-[0.99] disabled:cursor-not-allowed disabled:opacity-70 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent" data-copy-share-url>
		Copy link
	</button>
</div>

<script>
	import { copyShareLink, printSchedule } from '../../lib/schedules/share';

	function getCurrentScheduleState() {
		const form = document.querySelector('[data-generator-form]');
		if (!(form instanceof HTMLFormElement)) return undefined;

		const data = new FormData(form);
		const schedule = data.get('scheduleId');
		const pattern = data.get('pattern');
		const start = data.get('startDate');
		const parentAName = data.get('parentA') || 'Parent A';
		const parentBName = data.get('parentB') || 'Parent B';

		if (!schedule || !start) return undefined;

		return {
			schedule: String(schedule),
			start: String(start),
			parentAName: String(parentAName),
			parentBName: String(parentBName),
			pattern: schedule === '60-40' && pattern ? String(pattern) : undefined,
		};
	}

	document.addEventListener('click', async (event) => {
		const target = event.target;
		if (!(target instanceof HTMLButtonElement)) return;

		if (target.matches('[data-print-schedule]')) {
			printSchedule(() => window.print());
		}

		if (target.matches('[data-copy-share-url]')) {
			const defaultLabel = 'Copy link';
			target.disabled = true;
			target.textContent = 'Copying...';

			try {
				await copyShareLink({
					currentUrl: window.location.href,
					clipboard: navigator.clipboard,
					state: getCurrentScheduleState(),
				});
				target.textContent = 'Copied';
				window.setTimeout(() => {
					target.textContent = defaultLabel;
					target.disabled = false;
				}, 2000);
			} catch {
				target.textContent = 'Copy failed';
				window.setTimeout(() => {
					target.textContent = defaultLabel;
					target.disabled = false;
				}, 2000);
			}
		}
	});
</script>
