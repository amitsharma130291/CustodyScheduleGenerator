<div class="grid w-full min-w-0 grid-cols-1 gap-3 sm:grid-cols-2" data-export-actions>
	<button type="button" class="btn-primary flex h-12 w-full min-w-0 items-center justify-center overflow-hidden text-ellipsis whitespace-nowrap rounded-full px-4 text-sm font-semibold transition-all duration-200 ease-out hover:-translate-y-px hover:shadow-[0_10px_30px_rgba(94,106,210,0.14)] active:translate-y-0 active:scale-[0.99] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent" data-print-schedule>
		Print
	</button>
	<button type="button" class="btn-secondary flex h-12 w-full min-w-0 items-center justify-center overflow-hidden text-ellipsis whitespace-nowrap rounded-full px-4 text-sm font-semibold transition-all duration-200 ease-out hover:-translate-y-px hover:shadow-[inset_0_0_0_1px_color-mix(in_srgb,var(--accent)_28%,var(--border-subtle)),0_10px_24px_rgba(0,0,0,0.12)] active:translate-y-0 active:scale-[0.99] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent" data-copy-share-url>
		Copy link
	</button>
</div>

<script is:inline>
	document.addEventListener('click', async (event) => {
		const target = event.target;
		if (!(target instanceof HTMLElement)) return;

		if (target.matches('[data-print-schedule]')) {
			window.print();
		}

		if (target.matches('[data-copy-share-url]')) {
			try {
				await navigator.clipboard.writeText(window.location.href);
				target.textContent = 'URL copied';
				window.setTimeout(() => {
					target.textContent = 'Copy link';
				}, 1800);
			} catch {
				target.textContent = 'Copy failed';
			}
		}
	});
</script>
