---
import { scheduleDefinitionList } from '../../lib/schedules/definitions';
import { defaultRatioSchedulePatterns, ratioSchedulePatternOptions } from '../../lib/schedules/patterns';
import { normalizeScheduleType } from '../../lib/schedules/patterns';
import type { ScheduleInputType } from '../../lib/schedules/types';

interface Props {
	selectedScheduleId: ScheduleInputType;
	startDate?: string;
	parentA?: string;
	parentB?: string;
	compact?: boolean;
}

const {
	selectedScheduleId,
	startDate,
	parentA = 'Parent A',
	parentB = 'Parent B',
	compact = false,
} = Astro.props;
const normalizedSelectedScheduleId = normalizeScheduleType(selectedScheduleId);
const isEightyTwentySchedule = normalizedSelectedScheduleId === '80-20';
const isRatioSchedule = normalizedSelectedScheduleId === '60-40' || normalizedSelectedScheduleId === '70-30' || normalizedSelectedScheduleId === '80-20';
const initialPatternLabel = normalizedSelectedScheduleId === '80-20' ? '80/20 pattern' : normalizedSelectedScheduleId === '70-30' ? '70/30 pattern' : '60/40 pattern';
const initialPatternAriaLabel = normalizedSelectedScheduleId === '80-20' ? '80/20 schedule pattern' : normalizedSelectedScheduleId === '70-30' ? '70/30 schedule pattern' : '60/40 schedule pattern';
const initialPatternOptions = isRatioSchedule ? ratioSchedulePatternOptions[normalizedSelectedScheduleId as keyof typeof ratioSchedulePatternOptions] : [];
const initialDefaultPattern = isRatioSchedule ? defaultRatioSchedulePatterns[normalizedSelectedScheduleId as keyof typeof defaultRatioSchedulePatterns] : '';
const initialPatternOption = initialPatternOptions.find((option) => option.id === initialDefaultPattern);
---

<section class={`soft-card rounded-[1.5rem] ${compact ? 'p-3' : isEightyTwentySchedule ? 'p-4' : 'p-6 sm:p-7'}`} data-generator-panel>
	<p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">Schedule builder</p>
	<h2 class={`${compact ? 'mt-1.5 text-lg' : isEightyTwentySchedule ? 'mt-2 text-xl' : 'mt-3 text-2xl'} font-semibold tracking-[-0.04em] text-primary`}>Create a parenting calendar</h2>
	{!compact && !isEightyTwentySchedule && (
		<p class="mt-3 text-sm leading-6 text-secondary">
			Choose a schedule, start date, and parent labels. CustodyBuilder turns them into a calendar preview for planning.
		</p>
	)}
	{compact && (
		<p class="mt-2 text-xs leading-5 text-secondary">
			Preview dates, check overnight estimates, and save a PDF when the schedule is ready to discuss.
		</p>
	)}

	<form class={`${compact ? 'mt-4 gap-3' : isEightyTwentySchedule ? 'mt-4 gap-3' : 'mt-6 gap-4'} grid`} data-generator-form>
		<label class="grid min-w-0 gap-2">
			<span class="text-sm font-medium text-secondary">Parenting schedule</span>
			<select id="schedule-type" name="scheduleId" aria-label="Parenting schedule" aria-describedby="schedule-type-help" class="w-full min-w-0 truncate rounded-2xl bg-page px-4 py-2.5 pr-9 text-sm text-primary shadow-[inset_0_0_0_1px_var(--border-subtle)] transition-all duration-200 ease-out hover:bg-surface focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent" data-schedule-select>
				{scheduleDefinitionList.map((definition) => (
					<option value={definition.id} selected={definition.id === normalizedSelectedScheduleId}>
						{definition.name}
					</option>
				))}
			</select>
			<span id="schedule-type-help" class="text-xs leading-5 text-muted">Switch anytime to compare another pattern.</span>
		</label>

		<div class={`${isRatioSchedule ? 'grid' : 'hidden'} min-w-0 gap-1.5`} data-ratio-pattern-field>
			<label class="grid min-w-0 gap-2">
				<span class="text-sm font-medium text-secondary" data-ratio-pattern-label>{initialPatternLabel}</span>
				<select name="pattern" aria-label={initialPatternAriaLabel} class="w-full min-w-0 truncate rounded-2xl bg-page px-4 py-2.5 pr-9 text-sm text-primary shadow-[inset_0_0_0_1px_var(--border-subtle)] transition-all duration-200 ease-out hover:bg-surface focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent" data-ratio-pattern-select>
					{initialPatternOptions.map((option) => (
						<option value={option.id} selected={option.id === initialDefaultPattern}>
							{option.label}
						</option>
					))}
				</select>
			</label>
			<p class={`${isEightyTwentySchedule ? 'hidden' : 'line-clamp-2'} text-xs leading-5 text-muted`} data-ratio-pattern-description>
				{initialPatternOption?.description}
			</p>
			<div class={`${isEightyTwentySchedule ? 'flex' : 'hidden'} min-w-0 flex-wrap gap-1.5`} data-pattern-chip-row>
				<span class="rounded-full bg-page/55 px-2 py-1 text-[10px] font-medium leading-none text-secondary shadow-[inset_0_0_0_1px_var(--border-subtle)]" data-pattern-chip-split>Estimated split</span>
				<span class="rounded-full bg-page/55 px-2 py-1 text-[10px] font-medium leading-none text-secondary shadow-[inset_0_0_0_1px_var(--border-subtle)]" data-pattern-chip-exchanges>Monthly exchanges</span>
				<span class="rounded-full bg-page/55 px-2 py-1 text-[10px] font-medium leading-none text-secondary shadow-[inset_0_0_0_1px_var(--border-subtle)]" data-pattern-chip-decision>{initialPatternOption?.heroDecisionChip}</span>
			</div>
		</div>

		<label class="grid min-w-0 gap-2">
			<span class="text-sm font-medium text-secondary">Start date</span>
			<input name="startDate" type="date" value={startDate ?? ''} aria-label="Schedule start date" aria-describedby="schedule-start-date-help schedule-form-status" class="w-full min-w-0 rounded-2xl bg-page px-4 py-2.5 text-sm text-primary shadow-[inset_0_0_0_1px_var(--border-subtle)] transition-all duration-200 ease-out hover:bg-surface focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent" />
			<span id="schedule-start-date-help" class="text-xs leading-5 text-muted">Use the first day the schedule should begin.</span>
		</label>

		<div class="hero-form-fields grid gap-3">
			<label class="grid min-w-0 gap-2">
				<span class="text-sm font-medium text-secondary">First parent</span>
				<input name="parentA" value={parentA} aria-label="First parent label" aria-describedby="parent-labels-help" class="w-full min-w-0 rounded-2xl bg-page px-4 py-2.5 text-sm text-primary shadow-[inset_0_0_0_1px_var(--border-subtle)] transition-all duration-200 ease-out hover:bg-surface focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent" />
			</label>
			<label class="grid min-w-0 gap-2">
				<span class="text-sm font-medium text-secondary">Second parent</span>
				<input name="parentB" value={parentB} aria-label="Second parent label" aria-describedby="parent-labels-help" class="w-full min-w-0 rounded-2xl bg-page px-4 py-2.5 text-sm text-primary shadow-[inset_0_0_0_1px_var(--border-subtle)] transition-all duration-200 ease-out hover:bg-surface focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent" />
			</label>
			<p id="parent-labels-help" class="text-xs leading-5 text-muted sm:col-span-2">These names are calendar labels only.</p>
		</div>
		<p id="schedule-form-status" class="hidden rounded-2xl bg-warning/15 p-3 text-sm leading-6 text-primary" role="status" aria-live="polite" data-form-status></p>
		<div class="mt-2 mb-2 grid w-full min-w-0 gap-3" data-pdf-export-actions>
			<div class="grid gap-1">
				<p class="mb-0 text-xs font-semibold uppercase tracking-[0.16em] text-muted">Save your calendar</p>
				<p class="text-xs leading-5 text-muted">PDFs are for planning and discussion.</p>
			</div>
			<div class="grid w-full min-w-0 gap-3">
				<button type="button" class="btn-primary flex h-14 w-full min-w-0 cursor-pointer items-center justify-center gap-2.5 whitespace-nowrap rounded-full px-5 text-center text-[15px] font-semibold leading-none transition-all duration-150 ease-out hover:-translate-y-px active:translate-y-0 active:scale-[0.99] disabled:cursor-not-allowed disabled:opacity-70 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent" data-download-monthly-pdf>
					<svg class="btn-icon" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 15V3" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/><path d="M7 11l5 5 5-5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/><path d="M4 19h16" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
					<span class="leading-none" data-pdf-button-label>Download monthly PDF</span>
				</button>
				<button type="button" class="btn-primary flex h-14 w-full min-w-0 cursor-pointer items-center justify-center gap-2.5 whitespace-nowrap rounded-full px-5 text-center text-[15px] font-semibold leading-none transition-all duration-150 ease-out hover:-translate-y-px active:translate-y-0 active:scale-[0.99] disabled:cursor-not-allowed disabled:opacity-70 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent" data-download-yearly-pdf>
					<svg class="btn-icon" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 15V3" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/><path d="M7 11l5 5 5-5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/><path d="M4 19h16" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
					<span class="leading-none" data-pdf-button-label>Download yearly PDF</span>
				</button>
			</div>
		</div>
	</form>
</section>

<script>
	import { format, isValid, parseISO, startOfMonth } from 'date-fns';
	import { trackGa4Event } from '../../lib/analytics/ga4';
	import { buildMonthCalendarDays } from '../../lib/schedules/calendarGrid';
	import { defaultRatioSchedulePatterns, eightyTwentyPatternOptions, generateVisibleMonthSchedule, getAllSchedules, normalizeEightyTwentyPattern, normalizeScheduleType, normalizeSeventyThirtyPattern, normalizeSixtyFortyPattern, ratioSchedulePatternOptions } from '../../lib/schedules';
	import { downloadSchedulePdf } from '../../lib/schedules/pdfExport';

	const definitions = getAllSchedules();
	const form = document.querySelector('[data-generator-form]');
	const ratioPatternField = document.querySelector('[data-ratio-pattern-field]');
	const ratioPatternLabel = document.querySelector('[data-ratio-pattern-label]');
	const ratioPatternSelect = document.querySelector('[data-ratio-pattern-select]');
	const ratioPatternDescription = document.querySelector('[data-ratio-pattern-description]');
	const patternChipRow = document.querySelector('[data-pattern-chip-row]');
	const patternChipSplit = document.querySelector('[data-pattern-chip-split]');
	const patternChipExchanges = document.querySelector('[data-pattern-chip-exchanges]');
	const patternChipDecision = document.querySelector('[data-pattern-chip-decision]');
	const exampleSectionTitle = document.querySelector('[data-example-section-title]');
	const exampleSectionDescription = document.querySelector('[data-example-section-description]');
	const calendarGrid = document.querySelector('[data-calendar-grid]');
	const calendarMonth = document.querySelector('[data-calendar-month]');
	const parentALabel = document.querySelector('[data-parent-a-label]');
	const parentBLabel = document.querySelector('[data-parent-b-label]');
	const summaryParentALabel = document.querySelector('[data-summary-parent-a-label]');
	const summaryParentBLabel = document.querySelector('[data-summary-parent-b-label]');
	const summaryParentAPercent = document.querySelector('[data-summary-parent-a-percent]');
	const summaryParentBPercent = document.querySelector('[data-summary-parent-b-percent]');
	const summaryParentADays = document.querySelector('[data-summary-parent-a-days]');
	const summaryParentBDays = document.querySelector('[data-summary-parent-b-days]');
	const annualEstimate = document.querySelector('[data-annual-estimate]');
	const currentViewLabels = document.querySelectorAll('[data-current-view-label]');
	const sixtyFortyRangeNote = document.querySelector('[data-sixty-forty-range-note]');
	const sixtyFortyRangeNoteText = document.querySelector('[data-sixty-forty-range-note-text]');
	const printDescription = document.querySelector('[data-print-description]');
	const printTitle = document.querySelector('[data-print-title]');
	const printScheduleName = document.querySelector('[data-print-schedule-name]');
	const printPatternName = document.querySelector('[data-print-pattern-name]');
	const printStartDate = document.querySelector('[data-print-start-date]');
	const printGeneratedDate = document.querySelector('[data-print-generated-date]');
	const printParentAName = document.querySelector('[data-print-parent-a-name]');
	const printParentBName = document.querySelector('[data-print-parent-b-name]');
	const formStatus = document.querySelector('[data-form-status]');
	const scheduleCache = new Map();

	// Calendar cell colours — use semantic cal-* tokens for richer, premium look
	const parentColors = {
		A: 'cal-cell-a',
		B: 'cal-cell-b',
		inactive: 'cal-cell-inactive',
	};

	function getBrowserLocalDate() {
		const today = new Date();
		const year = today.getFullYear();
		const month = String(today.getMonth() + 1).padStart(2, '0');
		const day = String(today.getDate()).padStart(2, '0');
		return `${year}-${month}-${day}`;
	}

	function setFormStatus(message) {
		if (!(formStatus instanceof HTMLElement)) return;
		formStatus.textContent = message || '';
		formStatus.classList.toggle('hidden', !message);
	}

	function applyQueryParamsToForm() {
		if (!(form instanceof HTMLFormElement)) return;

		const params = new URLSearchParams(window.location.search);
		const schedule = params.get('schedule');
		const pattern = params.get('pattern');
		const start = params.get('start');
		const parentA = params.get('a');
		const parentB = params.get('b');
		const scheduleInput = form.elements.namedItem('scheduleId');
		const patternInput = form.elements.namedItem('pattern');
		const startInput = form.elements.namedItem('startDate');
		const parentAInput = form.elements.namedItem('parentA');
		const parentBInput = form.elements.namedItem('parentB');

		if (scheduleInput instanceof HTMLSelectElement && schedule) {
			try {
				scheduleInput.value = normalizeScheduleType(schedule);
			} catch {}
		}

		if (patternInput instanceof HTMLSelectElement) {
			const normalizedSchedule = scheduleInput instanceof HTMLSelectElement ? scheduleInput.value : '';
			updateRatioPatternField(normalizedSchedule, pattern);
		}
		if (startInput instanceof HTMLInputElement) {
			startInput.value = start || startInput.value || getBrowserLocalDate();
		}
		if (parentAInput instanceof HTMLInputElement && parentA) parentAInput.value = parentA;
		if (parentBInput instanceof HTMLInputElement && parentB) parentBInput.value = parentB;
	}

	function getRatioPatternOptions(scheduleId) {
		return ratioSchedulePatternOptions[String(scheduleId)] || [];
	}

	function getDefaultRatioPattern(scheduleId) {
		return defaultRatioSchedulePatterns[String(scheduleId)] || '';
	}

	function normalizeRatioPattern(scheduleId, patternId) {
		if (String(scheduleId) === '80-20') return normalizeEightyTwentyPattern(patternId);
		if (String(scheduleId) === '70-30') return normalizeSeventyThirtyPattern(patternId);
		if (String(scheduleId) === '60-40') return normalizeSixtyFortyPattern(patternId);
		return '';
	}

	function updateRatioPatternField(scheduleId, patternId) {
		const isRatioSchedule = String(scheduleId) === '60-40' || String(scheduleId) === '70-30' || String(scheduleId) === '80-20';
		const normalizedPattern = normalizeRatioPattern(scheduleId, patternId || getDefaultRatioPattern(scheduleId));
		const options = getRatioPatternOptions(scheduleId);

		ratioPatternField?.classList.toggle('hidden', !isRatioSchedule);
		ratioPatternField?.classList.toggle('grid', isRatioSchedule);

		if (ratioPatternLabel) {
			ratioPatternLabel.textContent = String(scheduleId) === '80-20' ? '80/20 pattern' : String(scheduleId) === '70-30' ? '70/30 pattern' : '60/40 pattern';
		}

		if (ratioPatternSelect instanceof HTMLSelectElement) {
			ratioPatternSelect.setAttribute('aria-label', String(scheduleId) === '80-20' ? '80/20 schedule pattern' : String(scheduleId) === '70-30' ? '70/30 schedule pattern' : '60/40 schedule pattern');
			ratioPatternSelect.innerHTML = options
				.map((option) => `<option value="${option.id}">${option.label}</option>`)
				.join('');
			ratioPatternSelect.value = normalizedPattern || getDefaultRatioPattern(scheduleId);
		}

		if (ratioPatternDescription) {
			const option = options.find((item) => item.id === normalizedPattern) || options.find((item) => item.id === getDefaultRatioPattern(scheduleId));
			const ratioContext = option ? 'Monthly totals can differ from the long-term target.' : '';
			ratioPatternDescription.textContent = option ? [option.description, option.note, ratioContext].filter(Boolean).join(' ') : '';
		}

		const option = options.find((item) => item.id === normalizedPattern) || options.find((item) => item.id === getDefaultRatioPattern(scheduleId));
		patternChipRow?.classList.toggle('hidden', String(scheduleId) !== '80-20');
		patternChipRow?.classList.toggle('flex', String(scheduleId) === '80-20');
		if (String(scheduleId) === '80-20' && option) {
			if (patternChipSplit) patternChipSplit.textContent = 'Estimated split';
			if (patternChipExchanges) patternChipExchanges.textContent = 'Monthly exchanges';
			if (patternChipDecision) patternChipDecision.textContent = option.heroDecisionChip || option.heroChips?.[1] || option.note || 'Pattern';
		}
	}

	function getSixtyFortyLongTermAverage(patternId) {
		if (patternId === 'exact-60-40') {
			return {
				parentA: 60,
				parentB: 40,
			};
		}

		if (patternId === 'extended-weekend') {
			return {
				parentA: 57,
				parentB: 43,
			};
		}

		return {
			parentA: 57,
			parentB: 43,
		};
	}

	function getSixtyFortyRangeNote(patternId, visibleParentAPercentage, visibleParentBPercentage) {
		const longTerm = getSixtyFortyLongTermAverage(patternId);
		const longTermText = patternId === 'exact-60-40'
			? 'Long-term target: 60% / 40%.'
			: `Long-term average: approximately ${longTerm.parentA}% / ${longTerm.parentB}%.`;

		if (visibleParentAPercentage === longTerm.parentA && visibleParentBPercentage === longTerm.parentB) {
			return longTermText;
		}

		return `Visible month: ${visibleParentAPercentage}% / ${visibleParentBPercentage}%. ${longTermText}`;
	}

	function getSeventyThirtyRangeNote(patternId) {
		if (patternId === 'alternating-weekends') {
			return 'Estimated long-term split: approximately 86% / 14% by overnights.';
		}

		if (patternId === 'every-3rd-week' || patternId === 'every-3rd-day') {
			return 'Estimated long-term split: approximately 67% / 33% by overnights.';
		}

		return 'Estimated long-term split: approximately 71% / 29% by overnights.';
	}

	function getSeventyThirtyLongTermAverage(patternId) {
		if (patternId === 'alternating-weekends') {
			return {
				parentA: 86,
				parentB: 14,
			};
		}

		if (patternId === 'every-3rd-week' || patternId === 'every-3rd-day') {
			return {
				parentA: 67,
				parentB: 33,
			};
		}

		return {
			parentA: 71,
			parentB: 29,
		};
	}

	function updateEightyTwentyExampleSection(scheduleId, patternId) {
		if (!(exampleSectionTitle instanceof HTMLElement) || !(exampleSectionDescription instanceof HTMLElement)) return;
		if (String(scheduleId) !== '80-20') return;

		const option = eightyTwentyPatternOptions.find((item) => item.id === patternId) || eightyTwentyPatternOptions.find((item) => item.id === defaultRatioSchedulePatterns['80-20']);
		if (!option) return;

		exampleSectionTitle.textContent = `${option.name} example calendar`;
		exampleSectionDescription.textContent = `${option.description} Best for: ${option.bestFor} The calculator below shows the current month and generated annual average from the selected pattern.`;
	}

	function getCachedVisibleSchedule({ scheduleId, startDate, parentA, parentB, pattern }) {
		const cacheKey = JSON.stringify({ scheduleId, startDate, parentA, parentB, pattern });
		const cachedSchedule = scheduleCache.get(cacheKey);
		if (cachedSchedule) return cachedSchedule;

		const generatedSchedule = generateVisibleMonthSchedule({
			scheduleType: String(scheduleId),
			startDate: String(startDate),
			monthDate: String(startDate),
			parentAName: String(parentA),
			parentBName: String(parentB),
			sixtyFortyPattern: scheduleId === '60-40' ? pattern : undefined,
			seventyThirtyPattern: scheduleId === '70-30' ? pattern : undefined,
			eightyTwentyPattern: scheduleId === '80-20' ? pattern : undefined,
		});
		scheduleCache.set(cacheKey, generatedSchedule);
		return generatedSchedule;
	}

	function getCurrentPdfState() {
		if (!(form instanceof HTMLFormElement)) return undefined;

		const data = new FormData(form);
		const schedule = data.get('scheduleId');
		const pattern = data.get('pattern');
		const start = data.get('startDate');
		const parentAName = data.get('parentA') || 'Parent A';
		const parentBName = data.get('parentB') || 'Parent B';

		if (!schedule || !start) return undefined;

		return {
			schedule: String(schedule),
			start: String(start),
			parentAName: String(parentAName),
			parentBName: String(parentBName),
			pattern: (schedule === '60-40' || schedule === '70-30' || schedule === '80-20') && pattern ? String(pattern) : undefined,
		};
	}

	async function handlePdfExportClick(event) {
		const target = event.target;
		const button = target instanceof Element ? target.closest('[data-download-monthly-pdf], [data-download-yearly-pdf]') : null;
		if (!(button instanceof HTMLButtonElement)) return;

		event.preventDefault();
		event.stopPropagation();

		const range = button.matches('[data-download-yearly-pdf]') ? 'yearly' : 'monthly';
		const label = button.querySelector('[data-pdf-button-label]');
		const defaultLabel = label?.textContent?.trim() || (range === 'yearly' ? 'Download yearly PDF' : 'Download monthly PDF');
		const state = getCurrentPdfState();

		button.disabled = true;
		button.dataset.state = 'loading';
		button.setAttribute('aria-busy', 'true');
		if (label) label.textContent = 'Preparing PDF...';

		try {
			if (!state) throw new Error('Schedule state is incomplete.');
			await downloadSchedulePdf(range, state);
			trackGa4Event(range === 'yearly' ? 'export_yearly_pdf' : 'export_monthly_pdf');
			button.dataset.state = 'success';
			if (label) label.textContent = 'PDF downloaded';
		} catch (error) {
			console.error('Failed to generate custody schedule PDF:', error);
			button.dataset.state = 'error';
			if (label) label.textContent = 'PDF could not be created';
		}

		window.setTimeout(() => {
			if (label) label.textContent = defaultLabel;
			button.disabled = false;
			button.removeAttribute('data-state');
			button.removeAttribute('aria-busy');
		}, 2000);
	}

	function renderSchedule(updateUrl = true) {
		if (!(form instanceof HTMLFormElement) || !calendarGrid) return false;

		const data = new FormData(form);
		const scheduleId = data.get('scheduleId');
		const startDateValue = data.get('startDate');
		const parentA = data.get('parentA') || 'Parent A';
		const parentB = data.get('parentB') || 'Parent B';
		const definition = definitions.find((item) => item.id === scheduleId) || definitions[0];
		const selectedPattern = normalizeRatioPattern(definition.id, String(data.get('pattern') || getDefaultRatioPattern(definition.id)));
		updateRatioPatternField(definition.id, selectedPattern);
		updateEightyTwentyExampleSection(definition.id, selectedPattern);
		const startDate = parseISO(String(startDateValue));
		if (!isValid(startDate)) {
			setFormStatus('Enter a valid start date to preview the calendar.');
			return false;
		}
		setFormStatus('');
		const monthStart = startOfMonth(startDate);

		let schedule;

		try {
			schedule = getCachedVisibleSchedule({
				scheduleId: definition.id,
				startDate: String(startDateValue),
				parentA: String(parentA),
				parentB: String(parentB),
				pattern: selectedPattern,
			});
		} catch {
			setFormStatus('We could not create that preview. Check the schedule and date, then try again.');
			return false;
		}

		const daysByDate = new Map(schedule.days.map((day) => [day.date, day]));
		const eventsByDate = new Map();
		for (const event of schedule.events ?? []) {
			eventsByDate.set(event.date, [...(eventsByDate.get(event.date) ?? []), event]);
		}
		const { days: gridDays } = buildMonthCalendarDays({
			monthDate: monthStart,
			daysByDate,
			eventsByDate,
			parentNames: { parentA: String(parentA), parentB: String(parentB) },
		});

		calendarGrid.innerHTML = gridDays
			.map((day) => {
				if (day.isPlaceholder) {
					return `<span class="calendar-day-cell calendar-day-cell--placeholder flex aspect-square max-h-[34px] min-h-0 items-center justify-center rounded-xl px-0.5 sm:max-h-[34px] sm:rounded-2xl" aria-hidden="true"></span>`;
				}

				const generatedDay = daysByDate.get(day.date);
				const isActive = Boolean(generatedDay);
				const color = isActive && generatedDay ? parentColors[generatedDay.parent] : parentColors.inactive;

				return `<span class="calendar-day-cell flex aspect-square max-h-[34px] min-h-0 items-center justify-center rounded-xl px-0.5 text-xs font-semibold sm:max-h-[34px] sm:rounded-2xl sm:text-sm ${color}"><span class="leading-none">${day.dayOfMonth}</span></span>`;
			})
			.join('');

		const monthLabel = format(monthStart, 'MMMM yyyy');
		const {
			parentADays,
			parentBDays,
			parentAPercentage,
			parentBPercentage,
		} = schedule.summary;

		if (calendarMonth) calendarMonth.textContent = monthLabel;
		if (parentALabel) parentALabel.textContent = parentA;
		if (parentBLabel) parentBLabel.textContent = parentB;
		if (summaryParentALabel) summaryParentALabel.textContent = parentA;
		if (summaryParentBLabel) summaryParentBLabel.textContent = parentB;
		if (summaryParentAPercent) summaryParentAPercent.textContent = `${parentAPercentage}%`;
		if (summaryParentBPercent) summaryParentBPercent.textContent = `${parentBPercentage}%`;
		if (summaryParentADays) summaryParentADays.textContent = `${parentADays} overnights`;
		if (summaryParentBDays) summaryParentBDays.textContent = `${parentBDays} overnights`;
		if (annualEstimate) {
			annualEstimate.textContent = schedule.patternSummary?.annualAverage
				? `Estimated annual split: ${schedule.patternSummary.annualAverage.parentAPercentage}% / ${schedule.patternSummary.annualAverage.parentBPercentage}% by overnights`
				: 'Annual split appears when this pattern supports yearly averages.';
		}
		if (definition.id === '80-20' && patternChipSplit && schedule.patternSummary?.annualAverage) {
			patternChipSplit.textContent = `${schedule.patternSummary.annualAverage.parentAPercentage}%/${schedule.patternSummary.annualAverage.parentBPercentage}% estimate`;
		}
		if (definition.id === '80-20' && patternChipExchanges && schedule.patternSummary?.exchangeFrequencyText) {
			patternChipExchanges.textContent = schedule.patternSummary.exchangeFrequencyText.replace(' exchanges this month', ' monthly exchanges').replace(' exchange this month', ' monthly exchange');
		}
		const baseNote = definition.id === '80-20'
			? 'Overnight estimate only.'
			: 'Overnight estimate only. Daytime visits are not included.';
		const ratioNote = definition.id === '70-30'
			? getSeventyThirtyRangeNote(selectedPattern)
			: definition.id === '60-40'
				? getSixtyFortyRangeNote(selectedPattern, parentAPercentage, parentBPercentage)
				: '';
		if (sixtyFortyRangeNoteText) sixtyFortyRangeNoteText.textContent = [baseNote, ratioNote].filter(Boolean).join(' ');
		sixtyFortyRangeNote?.classList.remove('hidden');
		sixtyFortyRangeNote?.classList.add('flex');
		currentViewLabels.forEach((label) => {
			label.textContent = 'Overnight estimate';
			label.classList.remove('hidden');
		});
		if (printTitle) printTitle.textContent = `${definition.shortName} custody calendar`;
		if (printScheduleName) printScheduleName.textContent = definition.name;
		if (printPatternName) {
			printPatternName.textContent = definition.id === '60-40' || definition.id === '70-30' || definition.id === '80-20'
				? getRatioPatternOptions(definition.id).find((item) => item.id === selectedPattern)?.label || getDefaultRatioPattern(definition.id)
				: 'Default pattern';
		}
		if (printStartDate) printStartDate.textContent = String(startDateValue);
		if (printGeneratedDate) printGeneratedDate.textContent = new Date().toLocaleDateString('en-US');
		if (printParentAName) printParentAName.textContent = String(parentA);
		if (printParentBName) printParentBName.textContent = String(parentB);
		if (printDescription) {
			const patternText = definition.id === '60-40' || definition.id === '70-30' || definition.id === '80-20'
				? ` Pattern: ${getRatioPatternOptions(definition.id).find((item) => item.id === selectedPattern)?.label || getDefaultRatioPattern(definition.id)}.`
				: '';
			const annualText = schedule.patternSummary?.annualAverage
				? ` Annual average: ${parentA} ${schedule.patternSummary.annualAverage.parentAPercentage}%, ${parentB} ${schedule.patternSummary.annualAverage.parentBPercentage}%.`
				: '';
			printDescription.textContent = `${monthLabel} preview starting ${startDateValue}.${patternText} ${parentA}: ${parentADays} overnights (${parentAPercentage}%). ${parentB}: ${parentBDays} overnights (${parentBPercentage}%).${annualText}`;
		}

		if (updateUrl) {
			const params = new URLSearchParams(window.location.search);
			params.set('schedule', definition.id);
			params.set('start', startDateValue);
			params.set('a', parentA);
			params.set('b', parentB);
			if (definition.id === '60-40' || definition.id === '70-30' || definition.id === '80-20') {
				params.set('pattern', selectedPattern);
			} else {
				params.delete('pattern');
			}
			window.history.replaceState({}, '', `${window.location.pathname}?${params.toString()}`);
		}
		return true;
	}

	form?.addEventListener('input', () => renderSchedule());
	form?.addEventListener('change', () => renderSchedule());
	form?.addEventListener('click', handlePdfExportClick);
	window.addEventListener('popstate', () => {
		applyQueryParamsToForm();
		renderSchedule(false);
	});
	applyQueryParamsToForm();
	renderSchedule(false);
</script>

<style>
/*
 * Calendar cell semantic colours using CSS token system.
 * These classes are applied by the client hydration script (renderSchedule)
 * via innerHTML, so the generated cells never carry Astro's scoping attribute.
 * They MUST stay :global() — a scoped selector (.cal-cell-a[data-astro-cid-…])
 * would not match the JS-injected cells and the calendar renders colourless.
 */
:global(.cal-cell-a) {
	background-color: var(--cal-parent-a-soft);
	color: var(--cal-parent-a);
	box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--cal-parent-a) 28%, transparent);
}
:global(.cal-cell-b) {
	background-color: var(--cal-parent-b-soft);
	color: var(--cal-parent-b);
	box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--cal-parent-b) 22%, transparent);
}
:global(.cal-cell-inactive) {
	color: var(--text-muted);
	opacity: 0.3;
	box-shadow: inset 0 0 0 1px var(--border-subtle);
}
</style>
