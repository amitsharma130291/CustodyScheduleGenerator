---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../Navbar.astro';
import Footer from '../Footer.astro';
import Breadcrumbs from '../seo/Breadcrumbs.astro';
import JsonLd from '../seo/JsonLd.astro';
import { getCanonicalUrl } from '../../lib/seo/metadata';
import { buildBreadcrumbSchema, buildWebPageSchema } from '../../lib/seo/schema';

const title = 'Custody Schedule Blog';
const description = 'Guides to custody schedules, parenting time, custody calendars, and shared parenting templates.';
const canonical = '/blog';
const canonicalUrl = getCanonicalUrl(canonical);
const breadcrumbs = [
	{ name: 'Home', url: getCanonicalUrl('/') },
	{ name: 'Blog', url: canonicalUrl },
];
const schema = [
	buildBreadcrumbSchema(breadcrumbs),
	buildWebPageSchema({ name: title, description, url: canonicalUrl }),
];
---

<BaseLayout title={`${title} | Custody Schedule Generator`} description={description} canonical={canonical}>
	<JsonLd slot="head" data={schema} />
	<Navbar />
	<Breadcrumbs items={breadcrumbs} />
	<main>
		<section class="container-shell py-12 lg:py-16">
			<div class="premium-card rounded-[2rem] p-6 lg:p-8">
				<p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">Blog</p>
				<h1 class="mt-4 max-w-3xl text-5xl font-semibold leading-[0.98] tracking-[-0.055em] text-primary lg:text-6xl">Custody Schedule Blog</h1>
				<p class="mt-6 max-w-3xl text-lg leading-8 text-secondary">
					Practical guides for comparing custody schedules, understanding parenting time, and turning a schedule into a printable custody calendar.
				</p>
				<div class="mt-8 grid gap-4 md:grid-cols-3">
					<a href="/2-2-3-custody-schedule" class="soft-card rounded-[1.5rem] p-5">How does a 2-2-3 schedule work?</a>
					<a href="/50-50-custody-schedule" class="soft-card rounded-[1.5rem] p-5">Best 50/50 custody schedules</a>
					<a href="/custody-percentage-calculator" class="soft-card rounded-[1.5rem] p-5">Parenting time percentage explained</a>
				</div>
			</div>
		</section>
	</main>
	<Footer />
</BaseLayout>
