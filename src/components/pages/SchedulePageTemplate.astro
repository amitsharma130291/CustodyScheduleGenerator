---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../Navbar.astro';
import Footer from '../Footer.astro';
import JsonLd from '../seo/JsonLd.astro';
import LastUpdated from '../seo/LastUpdated.astro';
import GeneratorPanel from '../tool/GeneratorPanel.astro';
import CalendarPreview from '../tool/CalendarPreview.astro';
import PrintableSchedule from '../tool/PrintableSchedule.astro';
import ExportActions from '../tool/ExportActions.astro';
import { generateSchedule } from '../../lib/schedules/generateSchedule';
import { getDefaultStartDate } from '../../lib/schedules/format';
import { getCanonicalUrl } from '../../lib/seo/metadata';
import {
	buildBreadcrumbSchema,
	buildFAQSchema,
	buildWebPageSchema,
} from '../../lib/seo/schema';
import { getRelatedSchedules } from '../../content/schedules';
import type { ScheduleContent } from '../../content/schedules/types';

interface Props {
	schedule: ScheduleContent;
}

const { schedule } = Astro.props;
const canonical = `/${schedule.slug}`;
const canonicalUrl = getCanonicalUrl(canonical);
const startDate = getDefaultStartDate();
const generatedSchedule = generateSchedule({
	scheduleId: schedule.id,
	startDate,
	parentNames: {
		parentA: 'Parent A',
		parentB: 'Parent B',
	},
});
const relatedSchedules = getRelatedSchedules(schedule);
const scheduleLinkLibrary = [
	{ title: '2-2-3 Custody Schedule', slug: '2-2-3-custody-schedule', description: 'Compare a frequent-contact 50/50 rotation with alternating weekends.' },
	{ title: '2-2-5-5 Custody Schedule', slug: '2-2-5-5-custody-schedule', description: 'Review a stable-weekday shared parenting schedule with longer blocks.' },
	{ title: '5-2-2-5 Custody Schedule', slug: '5-2-2-5-custody-schedule', description: 'See a two-week 50/50 schedule with predictable five-day blocks.' },
	{ title: '3-4-4-3 Custody Schedule', slug: '3-4-4-3-custody-schedule', description: 'Compare a shared schedule with alternating three- and four-day blocks.' },
	{ title: 'Week-On Week-Off Custody Schedule', slug: 'week-on-week-off-custody-schedule', description: 'Preview a simple weekly rotation with fewer exchanges.' },
	{ title: 'Every Other Weekend Custody Schedule', slug: 'every-other-weekend-custody-schedule', description: 'Compare an alternating weekend visitation-style schedule.' },
	{ title: '50/50 Custody Schedule', slug: '50-50-custody-schedule', description: 'Compare common equal parenting time schedule options.' },
	{ title: '60/40 Custody Schedule', slug: '60-40-custody-schedule', description: 'Review schedules with substantial time in both homes.' },
	{ title: '70/30 Custody Schedule', slug: '70-30-custody-schedule', description: 'Explore majority-time schedules with regular overnights.' },
	{ title: '80/20 Custody Schedule', slug: '80-20-custody-schedule', description: 'Compare primary-home schedules and weekend parenting time patterns.' },
	{ title: 'Custody Schedule By Age', slug: 'custody-schedule-by-age', description: 'Choose schedules based on toddler, school-age, and teen needs.' },
	{ title: 'Holiday Custody Schedule', slug: 'holiday-custody-schedule', description: 'Plan holiday overnights, birthdays, school breaks, and special days.' },
	{ title: 'Custody Calendar Template', slug: 'custody-calendar-template', description: 'Turn a custody schedule into a printable parenting calendar.' },
	{ title: 'Custody Schedule Template', slug: 'custody-schedule-template', description: 'Document a parenting time rotation in a printable schedule template.' },
	{ title: 'Parenting Plan Template', slug: 'parenting-plan-template', description: 'Organize schedules, exchanges, holidays, decisions, and communication rules.' },
	{ title: 'Custody Percentage Calculator', slug: 'custody-percentage-calculator', description: 'Estimate parenting time percentages from overnight totals.' },
	{ title: 'Parenting Time Calculator', slug: 'parenting-time-calculator', description: 'Compare parenting time totals and overnight counts.' },
	{ title: 'Visitation Calculator', slug: 'visitation-calculator', description: 'Estimate visitation time and compare calendar-based arrangements.' },
	{ title: 'Texas Child Support Calculator', slug: 'texas-child-support-calculator', description: 'Estimate Texas guideline child support after comparing parenting schedules.' },
];
const contextualRelatedSlugs = {
	'223': ['2-2-5-5-custody-schedule', '5-2-2-5-custody-schedule', '50-50-custody-schedule', 'custody-schedule-by-age', 'custody-calendar-template', 'parenting-plan-template'],
	'2255': ['2-2-3-custody-schedule', '5-2-2-5-custody-schedule', '3-4-4-3-custody-schedule', '50-50-custody-schedule', 'custody-calendar-template', 'custody-percentage-calculator'],
	'5225': ['2-2-5-5-custody-schedule', '2-2-3-custody-schedule', '3-4-4-3-custody-schedule', '50-50-custody-schedule', 'parenting-time-calculator', 'parenting-plan-template'],
	'3443': ['5-2-2-5-custody-schedule', '2-2-5-5-custody-schedule', 'week-on-week-off-custody-schedule', '50-50-custody-schedule', 'custody-calendar-template', 'custody-percentage-calculator'],
	'week-on-week-off': ['50-50-custody-schedule', '5-2-2-5-custody-schedule', '3-4-4-3-custody-schedule', 'best-custody-schedule-for-teenager', 'custody-calendar-template', 'parenting-plan-template'],
	'50-50': ['2-2-3-custody-schedule', '2-2-5-5-custody-schedule', '5-2-2-5-custody-schedule', '3-4-4-3-custody-schedule', 'week-on-week-off-custody-schedule', 'custody-percentage-calculator'],
	'60-40': ['50-50-custody-schedule', '70-30-custody-schedule', '2-2-5-5-custody-schedule', 'every-other-weekend-custody-schedule', 'custody-percentage-calculator', 'custody-calendar-template'],
	'70-30': ['60-40-custody-schedule', '80-20-custody-schedule', 'every-other-weekend-custody-schedule', 'holiday-custody-schedule', 'custody-percentage-calculator', 'parenting-plan-template'],
	'80-20': ['70-30-custody-schedule', '60-40-custody-schedule', 'every-other-weekend-custody-schedule', 'holiday-custody-schedule', 'visitation-calculator', 'parenting-plan-template'],
	'every-other-weekend': ['80-20-custody-schedule', '70-30-custody-schedule', '60-40-custody-schedule', 'holiday-visitation-schedule', 'visitation-calculator', 'custody-calendar-template'],
};
const manualRelatedLinks = schedule.relatedLinks ?? [
	...relatedSchedules.map((related) => ({
		title: related.title,
		slug: related.slug,
		description: related.description,
	})),
	...schedule.relatedTools,
];
const fallbackRelatedLinks = [
	...(contextualRelatedSlugs[schedule.id as keyof typeof contextualRelatedSlugs] ?? []),
	'custody-schedule-by-age',
	'holiday-custody-schedule',
	'custody-calendar-template',
	'parenting-plan-template',
	'custody-percentage-calculator',
	'blog',
]
	.map((slug) => scheduleLinkLibrary.find((link) => link.slug === slug))
	.filter(Boolean);
const relatedLinks = [...manualRelatedLinks, ...fallbackRelatedLinks]
	.filter((link, index, links) => Boolean(link) && link.slug !== schedule.slug && links.findIndex((candidate) => candidate.slug === link.slug) === index)
	.slice(0, 8);
const scheduleGuidance = {
	'223': {
		ageGroups: [
			'Best for toddlers, preschoolers, and early school-age children who benefit from frequent contact with both parents.',
			'Can also work for older children when parents live close together and can manage frequent exchanges without disrupting school or activities.',
		],
		variations: [
			'Exchange at school or daycare to reduce direct handoff stress.',
			'Add a consistent dinner visit or video call if a child needs extra connection during the three-day block.',
			'Use a 2-2-5-5 custody schedule instead when stable weekdays matter more than frequent exchanges.',
		],
	},
	'2255': {
		ageGroups: [
			'Often useful for school-age children who do better when the same parent handles the same weekdays each week.',
			'Can work for younger children if the five-day blocks do not feel too long and both homes support consistent routines.',
		],
		variations: [
			'Assign Monday and Tuesday to one parent and Wednesday and Thursday to the other, with weekends alternating through the five-day blocks.',
			'Move exchange times to school pickup or after work to reduce schedule friction.',
			'Compare with a 5-2-2-5 custody schedule if one parent needs the longer block to begin before the weekend.',
		],
	},
	'5225': {
		ageGroups: [
			'Best for school-age children and preteens who can manage longer blocks while still seeing both parents each week.',
			'May work for teenagers when both homes can support activities, homework, transportation, and weekend plans.',
		],
		variations: [
			'Use school-based exchanges to make the two-day blocks easier to manage.',
			'Keep clothing, homework materials, medication, and activity gear available in both homes.',
			'Compare with 2-2-5-5 when weekday stability is the main priority.',
		],
	},
	'50-50': {
		ageGroups: [
			'Can work for many school-age children when parents live close enough to support school, activities, and transportation from both homes.',
			'Older children and teenagers may prefer longer-block 50/50 options with fewer transitions.',
		],
		variations: [
			'Use 2-2-3 for frequent contact and alternating weekends.',
			'Use 2-2-5-5 or 5-2-2-5 for more stable weekdays and longer blocks.',
			'Use week-on/week-off for older children who can handle full weeks in each home.',
		],
	},
	'60-40': {
		ageGroups: [
			'Often fits school-age children when one home anchors more school-week routines while the other parent still has substantial time.',
			'Can also support children who need fewer exchanges than a 50/50 schedule but more time than alternating weekends.',
		],
		variations: [
			'Use a 4-3 pattern for a simple weekly rhythm.',
			'Use an extended weekend pattern when one parent handles most school nights.',
			'Add holiday and school-break time if the lower-time parent needs more annual parenting time.',
		],
	},
	'70-30': {
		ageGroups: [
			'Can work for children who need a primary school-week home with regular scheduled time in the other home.',
			'May fit families with longer distances, demanding work schedules, or a child who needs fewer transitions.',
		],
		variations: [
			'Use every weekend or a 5-2 schedule for predictable weekly time.',
			'Add weekday dinners, calls, holidays, or summer blocks to support the lower-time parent relationship.',
			'Compare with 60/40 or 80/20 if the calendar feels too balanced or too limited.',
		],
	},
	'80-20': {
		ageGroups: [
			'Often used when one home manages most school-week logistics and the other parent has regular but less frequent overnights.',
			'May fit long-distance parenting plans or families where weekday exchanges are not practical.',
		],
		variations: [
			'Use alternating weekends as the simplest starting point.',
			'Add one weekday overnight, school-break time, or summer blocks to increase connection.',
			'Use a holiday custody schedule so the lower-time parent has meaningful special-day parenting time.',
		],
	},
};
const defaultGuidance = {
	ageGroups: [
		'Best age fit depends on the child’s developmental needs, school routine, distance between homes, and ability to manage transitions.',
		'Use the calendar preview to test whether the schedule creates long gaps, rushed exchanges, or avoidable school-week stress.',
	],
	variations: [
		'Adjust exchange times around school pickup, work schedules, and activity commitments.',
		'Add holiday, school-break, or summer rules when the regular weekly pattern does not cover special dates.',
		'Compare nearby schedule types before finalizing a parenting plan.',
	],
};
const guidance = scheduleGuidance[schedule.id as keyof typeof scheduleGuidance] ?? defaultGuidance;
const comparisonHasWeekendPattern = schedule.comparison?.rows.some((row) => Boolean(row.weekendPattern)) ?? false;
const comparisonLabels = {
	schedule: schedule.comparison?.columnLabels?.schedule ?? 'Schedule',
	bestFor: schedule.comparison?.columnLabels?.bestFor ?? 'Best for',
	exchangeFrequency: schedule.comparison?.columnLabels?.exchangeFrequency ?? 'Exchange frequency',
	weekendPattern: schedule.comparison?.columnLabels?.weekendPattern ?? 'Weekend pattern',
	notes: schedule.comparison?.columnLabels?.notes ?? 'Notes',
};
const breadcrumbs = [
	{ name: 'Home', url: getCanonicalUrl('/') },
	{ name: 'Schedules', url: getCanonicalUrl('/custody-schedule-generator') },
	{ name: schedule.title, url: canonicalUrl },
];
const schema = [
	buildFAQSchema(schedule.faq),
	buildBreadcrumbSchema(breadcrumbs),
	buildWebPageSchema({
		name: schedule.metaTitle,
		description: schedule.metaDescription,
		url: canonicalUrl,
	}),
];
---

<BaseLayout title={schedule.metaTitle} description={schedule.metaDescription} canonical={canonical}>
	<JsonLd slot="head" data={schema} />
	<Navbar />
	<main>
		<section class="container-shell schedule-hero-section grid gap-10 py-10 lg:grid-cols-[0.88fr_1.12fr] lg:items-start lg:py-14" id="schedule-generator">
			<div>
				<nav aria-label="Breadcrumb">
					<ol class="flex flex-wrap items-center gap-2 text-sm text-muted">
						{breadcrumbs.map((item, index) => (
							<li class="flex items-center gap-2">
								{index > 0 && <span aria-hidden="true">/</span>}
								{index === breadcrumbs.length - 1 ? (
									<span aria-current="page" class="text-secondary">{item.name}</span>
								) : (
									<a href={item.url} class="transition-colors duration-200 hover:text-primary">{item.name}</a>
								)}
							</li>
						))}
					</ol>
				</nav>
				<p class="mt-5 text-xs font-semibold uppercase tracking-[0.18em] text-muted">Custody schedule generator</p>
				<h1 class="mt-4 max-w-3xl text-5xl font-semibold leading-[0.98] tracking-[-0.055em] text-primary lg:text-6xl">
					{schedule.title}
				</h1>
				<LastUpdated />
				<p class="mt-6 max-w-2xl text-lg leading-8 text-secondary">{schedule.lede}</p>
				<div class="mt-8 flex flex-col gap-3 sm:flex-row">
					<a href="#schedule-generator" class="btn-primary inline-flex h-13 w-full items-center justify-center rounded-full px-8 text-base font-semibold transition-all duration-200 ease-out hover:-translate-y-px hover:shadow-[0_10px_30px_rgba(94,106,210,0.14)] active:translate-y-0 sm:w-auto">
						Start with this schedule
					</a>
					<a href="#example" class="btn-secondary inline-flex h-13 w-full items-center justify-center rounded-full px-8 text-base font-semibold transition-all duration-200 ease-out hover:-translate-y-px hover:shadow-[0_10px_24px_rgba(0,0,0,0.12)] active:translate-y-0 sm:w-auto">
						View schedule examples
					</a>
				</div>
			</div>

			<div class="hero-generator-shell schedule-generator-shell relative">
				<div class="absolute -inset-8 rounded-full bg-[radial-gradient(circle,rgba(94,106,210,0.16),transparent_66%)] blur-3xl" aria-hidden="true"></div>
				<div class="premium-card hero-generator-card schedule-generator-card relative overflow-visible rounded-[1.75rem] border-line p-4 sm:rounded-[2.25rem] sm:p-5">
					<div class="absolute inset-x-10 top-0 h-px bg-gradient-to-r from-transparent via-white/30 to-transparent" aria-hidden="true"></div>
					<div class="hero-generator-inner rounded-[1.4rem] bg-surface-elevated p-0 shadow-[inset_0_1px_0_rgba(255,255,255,0.07)] sm:rounded-[1.8rem]">
						<div class="hero-generator-grid">
							<GeneratorPanel selectedScheduleId={schedule.id} compact />
							<div class="hero-calendar-column grid gap-3">
								<CalendarPreview schedule={generatedSchedule}>
									<ExportActions slot="actions" />
								</CalendarPreview>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<section class="container-shell grid gap-8 py-12 lg:grid-cols-[0.72fr_1.28fr] lg:py-16">
			<aside class="soft-card h-fit rounded-[1.5rem] p-6">
				<p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">On this page</p>
				<ul class="mt-4 space-y-3 text-sm text-secondary">
					<li><a href="#overview" class="hover:text-primary">Overview</a></li>
					{schedule.howItWorks && <li><a href="#how-it-works" class="hover:text-primary">How it works</a></li>}
					{schedule.comparison && <li><a href="#comparison" class="hover:text-primary">Comparison table</a></li>}
					<li><a href="#example" class="hover:text-primary">Calendar example</a></li>
					{schedule.examples && <li><a href="#schedule-examples" class="hover:text-primary">Schedule examples</a></li>}
					<li><a href="#child-support" class="hover:text-primary">Child support</a></li>
					<li><a href="#pros-cons" class="hover:text-primary">Pros and cons</a></li>
					<li><a href="#best-age-groups" class="hover:text-primary">Best age groups</a></li>
					<li><a href="#common-variations" class="hover:text-primary">Common variations</a></li>
					<li><a href="#faq" class="hover:text-primary">FAQ</a></li>
					<li><a href="#related" class="hover:text-primary">Related schedules</a></li>
				</ul>
			</aside>

			<div class="grid gap-10">
				<section id="overview" class="grid gap-4">
					<h2 class="text-3xl font-semibold tracking-[-0.04em] text-primary">{schedule.overviewTitle ?? `How the ${schedule.title} works`}</h2>
					{schedule.overview.map((paragraph) => (
						<p class="text-base leading-8 text-secondary">{paragraph}</p>
					))}
				</section>

				{schedule.howItWorks && (
					<section id="how-it-works" class="grid gap-4">
						<h2 class="text-3xl font-semibold tracking-[-0.04em] text-primary">{schedule.howItWorks.title}</h2>
						{schedule.howItWorks.description.map((paragraph) => (
							<p class="text-base leading-8 text-secondary">{paragraph}</p>
						))}
					</section>
				)}

				{schedule.comparison && (
					<section id="comparison" class="grid gap-5">
						<div>
							<h2 class="text-3xl font-semibold tracking-[-0.04em] text-primary">{schedule.comparison.title}</h2>
							<p class="mt-3 text-base leading-8 text-secondary">{schedule.comparison.description}</p>
						</div>
						<div class="grid gap-4 md:hidden">
							{schedule.comparison.rows.map((row) => (
								<article class="soft-card rounded-[1.5rem] p-5">
									<h3 class="text-lg font-semibold tracking-[-0.03em] text-primary">
										<a href={row.href} class="hover:text-accent">{row.schedule}</a>
									</h3>
									<dl class="mt-4 grid gap-3 text-sm">
										<div>
											<dt class="text-xs font-semibold uppercase tracking-[0.14em] text-muted">{comparisonLabels.bestFor}</dt>
											<dd class="mt-1 text-secondary">{row.bestFor}</dd>
										</div>
										<div>
											<dt class="text-xs font-semibold uppercase tracking-[0.14em] text-muted">{comparisonLabels.exchangeFrequency}</dt>
											<dd class="mt-1 text-secondary">{row.exchangeFrequency}</dd>
										</div>
										{comparisonHasWeekendPattern && (
											<div>
												<dt class="text-xs font-semibold uppercase tracking-[0.14em] text-muted">{comparisonLabels.weekendPattern}</dt>
												<dd class="mt-1 text-secondary">{row.weekendPattern}</dd>
											</div>
										)}
										<div>
											<dt class="text-xs font-semibold uppercase tracking-[0.14em] text-muted">{comparisonLabels.notes}</dt>
											<dd class="mt-1 text-secondary">{row.notes}</dd>
										</div>
									</dl>
								</article>
							))}
						</div>
						<div class="premium-card hidden overflow-x-auto rounded-[1.5rem] md:block">
							<table class="w-full min-w-[760px] border-collapse text-left text-sm">
								<thead class="text-xs uppercase tracking-[0.14em] text-muted">
									<tr class="border-b border-line-subtle">
										<th class="px-5 py-4 font-semibold">{comparisonLabels.schedule}</th>
										<th class="px-5 py-4 font-semibold">{comparisonLabels.bestFor}</th>
										<th class="px-5 py-4 font-semibold">{comparisonLabels.exchangeFrequency}</th>
										{comparisonHasWeekendPattern && <th class="px-5 py-4 font-semibold">{comparisonLabels.weekendPattern}</th>}
										<th class="px-5 py-4 font-semibold">{comparisonLabels.notes}</th>
									</tr>
								</thead>
								<tbody class="divide-y divide-line-subtle text-secondary">
									{schedule.comparison.rows.map((row) => (
										<tr>
											<td class="px-5 py-4 font-semibold text-primary"><a href={row.href} class="hover:text-accent">{row.schedule}</a></td>
											<td class="px-5 py-4">{row.bestFor}</td>
											<td class="px-5 py-4">{row.exchangeFrequency}</td>
											{comparisonHasWeekendPattern && <td class="px-5 py-4">{row.weekendPattern}</td>}
											<td class="px-5 py-4">{row.notes}</td>
										</tr>
									))}
								</tbody>
							</table>
						</div>
						{schedule.comparison.cta && (
							<div class="soft-card rounded-[1.5rem] p-5">
								<h3 class="text-xl font-semibold tracking-[-0.03em] text-primary">{schedule.comparison.cta.title}</h3>
								<div class="mt-4 grid gap-4 md:grid-cols-2">
									{schedule.comparison.cta.links.map((link) => (
										<a href={`/${link.slug}`} class="rounded-2xl bg-surface/70 p-4 shadow-[inset_0_0_0_1px_var(--border-subtle)] transition-colors duration-200 hover:bg-surface-hover">
											<h4 class="text-base font-semibold tracking-[-0.02em] text-primary">{link.title}</h4>
											<p class="mt-2 text-sm leading-6 text-secondary">{link.description}</p>
										</a>
									))}
								</div>
							</div>
						)}
					</section>
				)}

				<section id="example" class="grid gap-5">
					<h2 class="text-3xl font-semibold tracking-[-0.04em] text-primary" data-example-section-title>{schedule.example.title}</h2>
					<p class="text-base leading-8 text-secondary" data-example-section-description>{schedule.example.description}</p>
					{schedule.example.weeks && (
						<div class="premium-card overflow-hidden rounded-[1.5rem]">
							<div class="grid divide-y divide-line-subtle md:grid-cols-2 md:divide-x md:divide-y-0">
								{schedule.example.weeks.map((week) => (
									<div class="p-5">
										<h3 class="text-lg font-semibold tracking-[-0.03em] text-primary">{week.label}</h3>
										<div class="mt-4 grid gap-3">
											{week.blocks.map((block) => (
												<div class="grid grid-cols-[0.45fr_0.55fr] items-center gap-4 rounded-2xl bg-surface/70 p-3 shadow-[inset_0_0_0_1px_var(--border-subtle)]">
													<p class="text-sm font-semibold text-primary">{block.parent}</p>
													<p class="text-sm text-secondary">{block.days}</p>
												</div>
											))}
										</div>
									</div>
								))}
							</div>
						</div>
					)}
					<PrintableSchedule schedule={generatedSchedule} />
				</section>

				{schedule.examples && (
					<section id="schedule-examples" class="grid gap-5">
						<div>
							<h2 class="text-3xl font-semibold tracking-[-0.04em] text-primary">{schedule.examples.title}</h2>
							<p class="mt-3 text-base leading-8 text-secondary">{schedule.examples.description}</p>
						</div>
						<div class="grid gap-4 md:grid-cols-3">
							{schedule.examples.items.map((item) => (
								<article class="soft-card rounded-[1.5rem] p-5">
									<h3 class="text-lg font-semibold tracking-[-0.03em] text-primary">
										{item.href ? <a href={item.href} class="hover:text-accent">{item.title}</a> : item.title}
									</h3>
									<p class="mt-3 text-sm leading-6 text-secondary">{item.description}</p>
									{(item.approxSplit || item.bestUseCase) && (
										<dl class="mt-4 grid gap-2 text-sm">
											{item.approxSplit && (
												<div class="rounded-2xl bg-surface/70 p-3 shadow-[inset_0_0_0_1px_var(--border-subtle)]">
													<dt class="text-[11px] font-semibold uppercase tracking-[0.14em] text-muted">Approx overnight split</dt>
													<dd class="mt-1 text-secondary">{item.approxSplit}</dd>
												</div>
											)}
											{item.bestUseCase && (
												<div class="rounded-2xl bg-surface/70 p-3 shadow-[inset_0_0_0_1px_var(--border-subtle)]">
													<dt class="text-[11px] font-semibold uppercase tracking-[0.14em] text-muted">Best use case</dt>
													<dd class="mt-1 text-secondary">{item.bestUseCase}</dd>
												</div>
											)}
										</dl>
									)}
								</article>
							))}
						</div>
					</section>
				)}

				<section id="child-support" class="grid gap-5">
					<div>
						<p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">Support planning</p>
						<h2 class="mt-2 text-3xl font-semibold tracking-[-0.04em] text-primary">How This Schedule May Affect Child Support</h2>
						<p class="mt-3 text-base leading-8 text-secondary">
							Texas usually calculates child support from monthly net resources, not simply from the name of a parenting schedule. Still, the actual parenting arrangement can influence negotiations, budgeting, and the facts a court may consider when reviewing support, expenses, and the child’s needs.
						</p>
						<p class="mt-3 text-base leading-8 text-secondary">
							Use the {schedule.title} calendar to understand exchanges, overnights, and practical responsibilities. Then estimate Texas guideline child support with income, children before the court, other supported children, and optional deductions.
						</p>
					</div>
					<div class="soft-card grid gap-4 rounded-[1.5rem] p-5 md:grid-cols-[1fr_auto] md:items-center">
						<div>
							<h3 class="text-xl font-semibold tracking-[-0.03em] text-primary">Compare the schedule with support.</h3>
							<p class="mt-2 text-sm leading-6 text-secondary">Parenting time may influence discussions, but the calculator helps keep the support estimate focused on Texas net resources and guideline percentages.</p>
						</div>
						<a href="/texas-child-support-calculator" class="btn-primary inline-flex h-11 items-center justify-center rounded-full px-5 text-sm font-semibold">Estimate Texas Child Support</a>
					</div>
				</section>

				<section id="pros-cons" class="grid gap-5">
					<div class="grid gap-5 md:grid-cols-2">
						<div class="soft-card rounded-[1.5rem] p-6">
							<h2 class="text-2xl font-semibold tracking-[-0.04em] text-primary">Benefits of a {schedule.title}</h2>
							<ul class="mt-4 space-y-3 text-sm leading-6 text-secondary">
								{schedule.pros.map((item) => <li>• {item}</li>)}
							</ul>
						</div>
						<div class="soft-card rounded-[1.5rem] p-6">
							<h2 class="text-2xl font-semibold tracking-[-0.04em] text-primary">Potential Drawbacks</h2>
							<ul class="mt-4 space-y-3 text-sm leading-6 text-secondary">
								{schedule.cons.map((item) => <li>• {item}</li>)}
							</ul>
						</div>
					</div>
				</section>

				<section id="best-age-groups" class="grid gap-5">
					<div>
						<p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">Age fit</p>
						<h2 class="mt-2 text-3xl font-semibold tracking-[-0.04em] text-primary">Best age groups for a {schedule.title}</h2>
						<p class="mt-3 text-base leading-8 text-secondary">
							Age does not decide a parenting schedule by itself, but it changes how children experience separations, exchanges, school routines, activities, and time away from each home.
						</p>
					</div>
					<div class="grid gap-4 md:grid-cols-2">
						{guidance.ageGroups.map((item) => (
							<div class="soft-card rounded-[1.5rem] p-5">
								<p class="text-sm leading-6 text-secondary">{item}</p>
							</div>
						))}
					</div>
				</section>

				<section id="common-variations" class="grid gap-5">
					<div>
						<p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">Schedule variations</p>
						<h2 class="mt-2 text-3xl font-semibold tracking-[-0.04em] text-primary">Common variations to consider</h2>
						<p class="mt-3 text-base leading-8 text-secondary">
							Most custody schedules need small adjustments for exchange location, school calendars, holidays, activity transportation, and the child’s comfort with transitions.
						</p>
					</div>
					<div class="grid gap-4 md:grid-cols-3">
						{guidance.variations.map((item) => (
							<div class="soft-card rounded-[1.5rem] p-5">
								<p class="text-sm leading-6 text-secondary">{item}</p>
							</div>
						))}
					</div>
				</section>

				<section id="faq" class="grid gap-5">
					<h2 class="text-3xl font-semibold tracking-[-0.04em] text-primary">FAQ</h2>
					<div class="premium-card divide-y divide-line-subtle overflow-hidden rounded-[1.5rem]">
						{schedule.faq.map((item, index) => (
							<details open={index === 0} class="group p-5 transition-colors duration-200 open:bg-surface-elevated/70 hover:bg-surface-hover/60">
								<summary class="flex cursor-pointer list-none items-center justify-between gap-6 text-left text-base font-semibold tracking-[-0.02em] text-primary">
									{item.question}
									<span class="grid h-7 w-7 shrink-0 place-items-center rounded-full bg-surface/80 text-muted shadow-[inset_0_0_0_1px_var(--border-subtle)] transition-transform duration-200 group-open:rotate-45">+</span>
								</summary>
								<p class="mt-4 text-sm leading-6 text-secondary" set:html={item.answerHtml ?? item.answer} />
							</details>
						))}
					</div>
				</section>

				<section id="related" class="grid gap-5">
					<h2 class="text-3xl font-semibold tracking-[-0.04em] text-primary">{schedule.relatedHeading ?? 'Related schedules and tools'}</h2>
					<div class="grid gap-4 md:grid-cols-2">
						{relatedLinks.map((link) => (
							<a href={`/${link.slug}`} class="soft-card rounded-[1.5rem] p-5">
								<h3 class="text-lg font-semibold tracking-[-0.03em] text-primary">{link.title}</h3>
								<p class="mt-2 text-sm leading-6 text-secondary">{link.description}</p>
							</a>
						))}
					</div>
				</section>
			</div>
		</section>
	</main>
	<Footer />
</BaseLayout>
