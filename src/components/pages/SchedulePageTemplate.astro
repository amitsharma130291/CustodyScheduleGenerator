	</main>
	{schedule.slug === '50-50-custody-schedule' && (
		<a
			href="#schedule-generator"
			class="btn-primary mobile-sticky-cta fixed inset-x-4 bottom-4 z-40 h-12 px-5 text-sm md:hidden"
			aria-label="Generate 50/50 custody calendar"
		>
			Generate Calendar
		</a>
	)}
	<Footer />
	<script>
		document.querySelectorAll('[data-faq-summary]').forEach((summary) => {
			const details = summary.closest('details');
			if (!(details instanceof HTMLDetailsElement)) return;

			const syncExpandedState = () => {
				summary.setAttribute('aria-expanded', details.open ? 'true' : 'false');
			};

			syncExpandedState();
			details.addEventListener('toggle', syncExpandedState);
		});
	</script>
</BaseLayout>
