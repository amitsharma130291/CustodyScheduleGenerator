---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../Navbar.astro';
import Footer from '../Footer.astro';
import JsonLd from '../seo/JsonLd.astro';
import LastUpdated from '../seo/LastUpdated.astro';
import GeneratorPanel from '../tool/GeneratorPanel.astro';
import CalendarPreview from '../tool/CalendarPreview.astro';
import PrintableSchedule from '../tool/PrintableSchedule.astro';
import ExportActions from '../tool/ExportActions.astro';
import ScheduleQuiz from '../ScheduleQuiz.astro';
import CtaButton from '../CtaButton.astro';
import { generateSchedule } from '../../lib/schedules/generateSchedule';
import { getDefaultStartDate } from '../../lib/schedules/format';
import { getCanonicalUrl } from '../../lib/seo/metadata';
import {
	buildBreadcrumbSchema,
	buildFAQSchema,
	buildWebPageSchema,
} from '../../lib/seo/schema';
import { getRelatedSchedules } from '../../content/schedules';
import { examplesLibraryPromo, fiftyFiftyPatternSlugs } from '../../data/fiftyFiftyScheduleExamples';
import type { ScheduleContent } from '../../content/schedules/types';

interface Props {
	schedule: ScheduleContent;
}

const { schedule } = Astro.props;
const canonical = `/${schedule.slug}`;
const canonicalUrl = getCanonicalUrl(canonical);
const robots = Astro.url.pathname.startsWith('/schedules/') ? 'noindex, follow' : 'index, follow';
const startDate = getDefaultStartDate();
const generatedSchedule = generateSchedule({
	scheduleId: schedule.id,
	startDate,
	parentNames: {
		parentA: 'Parent A',
		parentB: 'Parent B',
	},
});
const relatedSchedules = getRelatedSchedules(schedule);
const scheduleLinkLibrary = [
	{ title: '2-2-3 Custody Schedule', slug: '2-2-3-custody-schedule', description: 'Compare a frequent-contact 50/50 rotation with alternating weekends.' },
	{ title: '2-2-5-5 Custody Schedule', slug: '2-2-5-5-custody-schedule', description: 'Review a stable-weekday shared parenting schedule with longer blocks.' },
	{ title: '5-2-2-5 Custody Schedule', slug: '5-2-2-5-custody-schedule', description: 'See a two-week 50/50 schedule with predictable five-day blocks.' },
	{ title: '3-4-4-3 Custody Schedule', slug: '3-4-4-3-custody-schedule', description: 'Compare a shared schedule with alternating three- and four-day blocks.' },
	{ title: 'Week-On Week-Off Custody Schedule', slug: 'week-on-week-off-custody-schedule', description: 'Preview a simple weekly rotation with fewer exchanges.' },
	{ title: 'Every Other Weekend Custody Schedule', slug: 'every-other-weekend-custody-schedule', description: 'Compare an alternating weekend visitation-style schedule.' },
	{ title: '50/50 Custody Schedule', slug: '50-50-custody-schedule', description: 'Compare common equal parenting time schedule options.' },
	{ title: '60/40 Custody Schedule', slug: '60-40-custody-schedule', description: 'Review schedules with substantial time in both homes.' },
	{ title: '70/30 Custody Schedule', slug: '70-30-custody-schedule', description: 'Explore majority-time schedules with regular overnights.' },
	{ title: '80/20 Custody Schedule', slug: '80-20-custody-schedule', description: 'Compare primary-home schedules and weekend parenting time patterns.' },
	{ title: 'Custody Schedule By Age', slug: 'custody-schedule-by-age', description: 'Choose schedules based on toddler, school-age, and teen needs.' },
	{ title: 'Holiday Custody Schedule', slug: 'holiday-custody-schedule', description: 'Plan holiday overnights, birthdays, school breaks, and special days.' },
	{ title: 'Custody Calendar Template', slug: 'custody-calendar-template', description: 'Turn a custody schedule into a printable parenting calendar.' },
	{ title: 'Custody Schedule Template', slug: 'custody-schedule-template', description: 'Document a parenting time rotation in a printable schedule template.' },
	{ title: 'Parenting Plan Template', slug: 'parenting-plan-template', description: 'Organize schedules, exchanges, holidays, decisions, and communication rules.' },
	{ title: 'Custody Percentage Calculator', slug: 'custody-percentage-calculator', description: 'Estimate parenting time percentages from overnight totals.' },
	{ title: 'Parenting Time Calculator', slug: 'parenting-time-calculator', description: 'Compare parenting time totals and overnight counts.' },
	{ title: 'Visitation Calculator', slug: 'visitation-calculator', description: 'Estimate visitation time and compare calendar-based arrangements.' },
	{ title: 'Texas Child Support Calculator', slug: 'texas-child-support-calculator', description: 'Estimate Texas guideline child support after comparing parenting schedules.' },
];
const contextualRelatedSlugs = {
	'223': ['2-2-5-5-custody-schedule', '5-2-2-5-custody-schedule', '50-50-custody-schedule', 'custody-schedule-by-age', 'custody-calendar-template', 'parenting-plan-template'],
	'2255': ['2-2-3-custody-schedule', '5-2-2-5-custody-schedule', '3-4-4-3-custody-schedule', '50-50-custody-schedule', 'custody-calendar-template', 'custody-percentage-calculator'],
	'5225': ['2-2-5-5-custody-schedule', '2-2-3-custody-schedule', '3-4-4-3-custody-schedule', '50-50-custody-schedule', 'parenting-time-calculator', 'parenting-plan-template'],
	'3443': ['5-2-2-5-custody-schedule', '2-2-5-5-custody-schedule', 'week-on-week-off-custody-schedule', '50-50-custody-schedule', 'custody-calendar-template', 'custody-percentage-calculator'],
	'week-on-week-off': ['50-50-custody-schedule', '5-2-2-5-custody-schedule', '3-4-4-3-custody-schedule', 'best-custody-schedule-for-teenager', 'custody-calendar-template', 'parenting-plan-template'],
	'50-50': ['2-2-3-custody-schedule', '2-2-5-5-custody-schedule', '5-2-2-5-custody-schedule', '3-4-4-3-custody-schedule', 'week-on-week-off-custody-schedule', 'custody-percentage-calculator'],
	'60-40': ['50-50-custody-schedule', '70-30-custody-schedule', '2-2-5-5-custody-schedule', 'every-other-weekend-custody-schedule', 'custody-percentage-calculator', 'custody-calendar-template'],
	'70-30': ['60-40-custody-schedule', '80-20-custody-schedule', 'every-other-weekend-custody-schedule', 'holiday-custody-schedule', 'custody-percentage-calculator', 'parenting-plan-template'],
	'80-20': ['70-30-custody-schedule', '60-40-custody-schedule', 'every-other-weekend-custody-schedule', 'holiday-custody-schedule', 'visitation-calculator', 'parenting-plan-template'],
	'every-other-weekend': ['80-20-custody-schedule', '70-30-custody-schedule', '60-40-custody-schedule', 'holiday-visitation-schedule', 'visitation-calculator', 'custody-calendar-template'],
};
const manualRelatedLinks = schedule.relatedLinks ?? [
	...relatedSchedules.map((related) => ({
		title: related.title,
		slug: related.slug,
		description: related.description,
	})),
	...schedule.relatedTools,
];
const relatedLinkLimit = schedule.slug === '50-50-custody-schedule' ? 14 : 8;
const fallbackRelatedLinks = [
	...(contextualRelatedSlugs[schedule.id as keyof typeof contextualRelatedSlugs] ?? []),
	'custody-schedule-by-age',
	'holiday-custody-schedule',
	'custody-calendar-template',
	'parenting-plan-template',
	'custody-percentage-calculator',
	'blog',
]
	.map((slug) => scheduleLinkLibrary.find((link) => link.slug === slug))
	.filter(Boolean);
const relatedLinks = [...manualRelatedLinks, ...fallbackRelatedLinks]
	.filter((link, index, links) => Boolean(link) && link.slug !== schedule.slug && links.findIndex((candidate) => candidate.slug === link.slug) === index)
	.slice(0, relatedLinkLimit);
const scheduleGuidance = {
	'223': {
		ageGroups: [
			'Best for toddlers, preschoolers, and early school-age children who benefit from frequent contact with both parents.',
			'Can also work for older children when parents live close together and can manage frequent exchanges without disrupting school or activities.',
		],
		variations: [
			'Exchange at school or daycare to reduce direct handoff stress.',
			'Add a consistent dinner visit or video call if a child needs extra connection during the three-day block.',
			'Use a 2-2-5-5 custody schedule instead when stable weekdays matter more than frequent exchanges.',
		],
	},
	'2255': {
		ageGroups: [
			'Often useful for school-age children who do better when the same parent handles the same weekdays each week.',
			'Can work for younger children if the five-day blocks do not feel too long and both homes support consistent routines.',
		],
		variations: [
			'Assign Monday and Tuesday to one parent and Wednesday and Thursday to the other, with weekends alternating through the five-day blocks.',
			'Move exchange times to school pickup or after work to reduce schedule friction.',
			'Compare with a 5-2-2-5 custody schedule if one parent needs the longer block to begin before the weekend.',
		],
	},
	'5225': {
		ageGroups: [
			'Best for school-age children and preteens who can manage longer blocks while still seeing both parents each week.',
			'May work for teenagers when both homes can support activities, homework, transportation, and weekend plans.',
		],
		variations: [
			'Use school-based exchanges to make the two-day blocks easier to manage.',
			'Keep clothing, homework materials, medication, and activity gear available in both homes.',
			'Compare with 2-2-5-5 when weekday stability is the main priority.',
		],
	},
	'50-50': {
		ageGroups: [
			'Can work for many school-age children when parents live close enough to support school, activities, and transportation from both homes.',
			'Older children and teenagers may prefer longer-block 50/50 options with fewer transitions.',
		],
		variations: [
			'Use 2-2-3 for frequent contact and alternating weekends.',
			'Use 2-2-5-5 or 5-2-2-5 for more stable weekdays and longer blocks.',
			'Use week-on/week-off for older children who can handle full weeks in each home.',
		],
	},
	'60-40': {
		ageGroups: [
			'Often fits school-age children when one home anchors more school-week routines while the other parent still has substantial time.',
			'Can also support children who need fewer exchanges than a 50/50 schedule but more time than alternating weekends.',
		],
		variations: [
			'Use a 4-3 pattern for a simple weekly rhythm.',
			'Use an extended weekend pattern when one parent handles most school nights.',
			'Add holiday and school-break time if the lower-time parent needs more annual parenting time.',
		],
	},
	'70-30': {
		ageGroups: [
			'Can work for children who need a primary school-week home with regular scheduled time in the other home.',
			'May fit families with longer distances, demanding work schedules, or a child who needs fewer transitions.',
		],
		variations: [
			'Use every weekend or a 5-2 schedule for predictable weekly time.',
			'Add weekday dinners, calls, holidays, or summer blocks to support the lower-time parent relationship.',
			'Compare with 60/40 or 80/20 if the calendar feels too balanced or too limited.',
		],
	},
	'80-20': {
		ageGroups: [
			'Often used when one home manages most school-week logistics and the other parent has regular but less frequent overnights.',
			'May fit long-distance parenting plans or families where weekday exchanges are not practical.',
		],
		variations: [
			'Use alternating weekends as the simplest starting point.',
			'Add one weekday overnight, school-break time, or summer blocks to increase connection.',
			'Use a holiday custody schedule so the lower-time parent has meaningful special-day parenting time.',
		],
	},
};
const defaultGuidance = {
	ageGroups: [
		'Best age fit depends on the child’s developmental needs, school routine, distance between homes, and ability to manage transitions.',
		'Use the calendar preview to test whether the schedule creates long gaps, rushed exchanges, or avoidable school-week stress.',
	],
	variations: [
		'Adjust exchange times around school pickup, work schedules, and activity commitments.',
		'Add holiday, school-break, or summer rules when the regular weekly pattern does not cover special dates.',
		'Compare nearby schedule types before finalizing a parenting plan.',
	],
};
const guidanceKey = schedule.slug === '50-50-custody-schedule' ? '50-50' : schedule.id;
const guidance = scheduleGuidance[guidanceKey as keyof typeof scheduleGuidance] ?? defaultGuidance;
const comparisonHasWeekendPattern = schedule.comparison?.rows.some((row) => Boolean(row.weekendPattern)) ?? false;
const comparisonHasCons = schedule.comparison?.rows.some((row) => Boolean(row.cons)) ?? false;
const comparisonLabels = {
	schedule: schedule.comparison?.columnLabels?.schedule ?? 'Schedule',
	bestFor: schedule.comparison?.columnLabels?.bestFor ?? 'Best for',
	exchangeFrequency: schedule.comparison?.columnLabels?.exchangeFrequency ?? 'Exchange frequency',
	weekendPattern: schedule.comparison?.columnLabels?.weekendPattern ?? 'Weekend pattern',
	notes: schedule.comparison?.columnLabels?.notes ?? 'Notes',
};
const breadcrumbs = [
	{ name: 'Home', url: getCanonicalUrl('/') },
	{ name: 'Schedules', url: getCanonicalUrl('/custody-schedule-generator/') },
	{ name: schedule.title, url: canonicalUrl },
];
const schema = [
	buildFAQSchema(schedule.faq),
	buildBreadcrumbSchema(breadcrumbs),
	buildWebPageSchema({
		name: schedule.metaTitle,
		description: schedule.metaDescription,
		url: canonicalUrl,
	}),
	{
		'@context': 'https://schema.org',
		'@type': schedule.slug === '50-50-custody-schedule' ? 'SoftwareApplication' : 'WebApplication',
		name: `${schedule.title} Calendar Generator`,
		description: schedule.metaDescription,
		url: canonicalUrl,
		inLanguage: 'en-US',
		areaServed: 'US',
		applicationCategory: 'LegalApplication',
		operatingSystem: 'Web',
		offers: {
			'@type': 'Offer',
			price: '0',
			priceCurrency: 'USD',
		},
	},
	{
		'@context': 'https://schema.org',
		'@type': 'HowTo',
		name: `How to create a ${schedule.title}`,
		description: `Use the custody calendar generator to create, preview, print, and compare a ${schedule.title}.`,
		inLanguage: 'en-US',
		totalTime: 'PT5M',
		step: [
			{
				'@type': 'HowToStep',
				name: 'Choose the schedule type',
				text: `Select ${schedule.title} in the custody schedule generator.`,
			},
			{
				'@type': 'HowToStep',
				name: 'Enter the start date and parent names',
				text: 'Add the calendar start date and the names you want shown on the parenting calendar.',
			},
			{
				'@type': 'HowToStep',
				name: 'Generate and review the calendar',
				text: 'Review the monthly preview, overnight split, and exchange pattern before using it in planning conversations.',
			},
			{
				'@type': 'HowToStep',
				name: 'Print or export the schedule',
				text: 'Print the calendar or export a monthly or yearly PDF for mediation, co-parenting discussions, or parenting plan drafting.',
			},
		],
	},
	schedule.article && {
		'@context': 'https://schema.org',
		'@type': 'Article',
		headline: schedule.article.headline,
		description: schedule.metaDescription,
		url: canonicalUrl,
		mainEntityOfPage: canonicalUrl,
		inLanguage: 'en-US',
		datePublished: schedule.article.datePublished,
		dateModified: schedule.article.dateModified,
		author: {
			'@type': 'Organization',
			name: schedule.article.authorName,
			url: schedule.trust?.authorHref ? getCanonicalUrl(schedule.trust.authorHref) : getCanonicalUrl('/about/'),
		},
		reviewedBy: schedule.article.reviewerName ? {
			'@type': 'Organization',
			name: schedule.article.reviewerName,
			url: schedule.trust?.reviewerHref ? getCanonicalUrl(schedule.trust.reviewerHref) : getCanonicalUrl('/about/'),
		} : undefined,
		publisher: {
			'@type': 'Organization',
			name: 'CustodyBuilder',
			url: getCanonicalUrl('/'),
		},
	},
].filter(Boolean);
---

<BaseLayout title={schedule.metaTitle} description={schedule.metaDescription} canonical={canonical} robots={robots} ogTitle={schedule.ogTitle ?? schedule.metaTitle} ogDescription={schedule.ogDescription ?? schedule.metaDescription}>
	<JsonLd slot="head" data={schema} />
	<Navbar />
	<main>
		<section class="container-shell schedule-hero-section grid gap-12 py-12 xl:grid-cols-[minmax(0,1fr)_minmax(704px,720px)] xl:items-start xl:justify-center xl:gap-8 xl:py-20" id="schedule-generator">
			<div class="min-w-0 max-w-[820px]">
				<nav aria-label="Breadcrumb">
					<ol class="flex flex-wrap items-center gap-2 text-sm text-muted">
						{breadcrumbs.map((item, index) => (
							<li class="flex items-center gap-2">
								{index > 0 && <span aria-hidden="true">/</span>}
								{index === breadcrumbs.length - 1 ? (
									<span aria-current="page" class="text-secondary">{item.name}</span>
								) : (
									<a href={item.url} class="transition-colors duration-200 hover:text-primary">{item.name}</a>
								)}
							</li>
						))}
					</ol>
				</nav>
				<p class="mt-5 text-xs font-semibold uppercase tracking-[0.18em] text-muted">Custody schedule generator</p>
				<h1 class="mt-5 max-w-[820px] text-5xl font-semibold leading-[0.98] tracking-[-0.055em] text-primary lg:text-6xl">
					{schedule.title}
				</h1>
				<LastUpdated date={schedule.lastUpdated} />
				<p class="mt-7 max-w-[760px] text-lg leading-8 text-secondary">{schedule.lede}</p>
				{schedule.hero && (
					<div class="mt-7 grid max-w-[760px] gap-5">
						<div class="soft-card rounded-[1.5rem] p-6">
							<p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">{schedule.slug === '50-50-custody-schedule' ? 'Schedule summary' : 'Quick answer'}</p>
							<p class="mt-2 text-base font-semibold leading-7 text-primary">{schedule.hero.definition}</p>
							<p class="mt-3 text-sm leading-6 text-secondary">
								<span class="font-semibold text-primary">Best for:</span> {schedule.hero.bestFor}
							</p>
						</div>
						<div class="grid gap-3 sm:grid-cols-2">
							<div class="rounded-[1.25rem] bg-surface/70 p-4 shadow-[inset_0_0_0_1px_var(--border-subtle)]">
								<p class="text-xs font-semibold uppercase tracking-[0.16em] text-muted">{schedule.slug === '50-50-custody-schedule' ? 'Included' : 'Pros'}</p>
								<div class="mt-3 flex flex-wrap gap-2">
									{schedule.hero.proChips.map((chip) => (
										<span class="rounded-full bg-[rgba(45,212,191,0.12)] px-3 py-1.5 text-xs font-semibold text-primary">{chip}</span>
									))}
								</div>
							</div>
							<div class="rounded-[1.25rem] bg-surface/70 p-4 shadow-[inset_0_0_0_1px_var(--border-subtle)]">
								<p class="text-xs font-semibold uppercase tracking-[0.16em] text-muted">{schedule.slug === '50-50-custody-schedule' ? 'Planning notes' : 'Watch outs'}</p>
								<div class="mt-3 flex flex-wrap gap-2">
									{schedule.hero.conChips.map((chip) => (
										<span class="rounded-full bg-warning/15 px-3 py-1.5 text-xs font-semibold text-primary">{chip}</span>
									))}
								</div>
							</div>
						</div>
					</div>
				)}
				{schedule.trust && (
					<section id="review-disclaimer" class="mt-6 soft-card rounded-[1.5rem] p-5 scroll-mt-24" aria-label="Editorial review and legal disclaimer">
						<div class="grid gap-4 sm:grid-cols-2">
							<div>
								<p class="text-xs font-semibold uppercase tracking-[0.16em] text-muted">{schedule.trust.reviewerLabel}</p>
								{schedule.trust.reviewerHref ? (
									<a href={schedule.trust.reviewerHref} class="mt-2 inline-flex text-sm font-semibold text-primary underline decoration-line underline-offset-4 hover:text-accent">{schedule.trust.reviewerName}</a>
								) : (
									<p class="mt-2 text-sm font-semibold text-primary">{schedule.trust.reviewerName}</p>
								)}
								<p class="mt-1 text-sm leading-6 text-secondary">{schedule.trust.reviewerCredential}</p>
							</div>
							<div>
								<p class="text-xs font-semibold uppercase tracking-[0.16em] text-muted">Author</p>
								{schedule.trust.authorHref ? (
									<a href={schedule.trust.authorHref} class="mt-2 inline-flex text-sm font-semibold text-primary underline decoration-line underline-offset-4 hover:text-accent">{schedule.trust.authorName}</a>
								) : (
									<p class="mt-2 text-sm font-semibold text-primary">{schedule.trust.authorName}</p>
								)}
								<p class="mt-1 text-sm leading-6 text-secondary">{schedule.trust.authorTitle}</p>
							</div>
						</div>
						<p class="mt-4 border-t border-line-subtle pt-4 text-sm leading-6 text-secondary">{schedule.trust.authorBio}</p>
						<div class="mt-4 grid gap-3 text-sm sm:grid-cols-2">
							{schedule.trust.factCheckedDate && (
								<p class="rounded-2xl bg-page/55 p-3 leading-6 text-secondary shadow-[inset_0_0_0_1px_var(--border-subtle)]">
									<span class="font-semibold text-primary">Fact-checked:</span> <time datetime={schedule.trust.factCheckedDate}>{new Date(`${schedule.trust.factCheckedDate}T00:00:00`).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}</time>
								</p>
							)}
							{schedule.trust.legalReviewerPlaceholder && (
								<p class="rounded-2xl bg-page/55 p-3 leading-6 text-secondary shadow-[inset_0_0_0_1px_var(--border-subtle)]">
									<span class="font-semibold text-primary">Legal review:</span> {schedule.trust.legalReviewerPlaceholder}
								</p>
							)}
						</div>
						<p class="mt-4 rounded-2xl bg-page/55 p-3 text-sm leading-6 text-secondary shadow-[inset_0_0_0_1px_var(--border-subtle)]">{schedule.trust.disclaimer}</p>
					</section>
				)}
				{schedule.decisionGuide?.quickAnswer && (
					<div class="mt-6 soft-card rounded-[1.5rem] p-5">
						<p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">{schedule.decisionGuide.quickAnswer.title}</p>
						<p class="mt-2 text-sm leading-6 text-secondary">{schedule.decisionGuide.quickAnswer.description}</p>
						<div class="mt-4 grid gap-2">
							{schedule.decisionGuide.quickAnswer.items.map((item) => (
								<a href={item.href} class="flex flex-col gap-1 rounded-2xl bg-surface/70 p-3 text-sm shadow-[inset_0_0_0_1px_var(--border-subtle)] transition-colors duration-200 hover:bg-surface-hover sm:flex-row sm:items-center sm:justify-between">
									<span class="font-semibold text-primary">{item.label}</span>
									<span class="text-accent">{item.title}</span>
								</a>
							))}
						</div>
					</div>
				)}
				<div class="hero-cta-row mt-6 flex flex-wrap items-stretch gap-4" data-hero-cta-row>
					{schedule.hero ? (
						schedule.hero.ctas.map((cta) => (
							<CtaButton href={cta.href} variant={cta.variant} size="large">
								{cta.text}
							</CtaButton>
						))
					) : (
						<>
							<CtaButton href="#schedule-generator" variant="primary" size="large">
								Test this schedule on a calendar
							</CtaButton>
							<CtaButton href="#example" variant="secondary" size="large">
								Compare schedule examples
							</CtaButton>
						</>
					)}
				</div>
			</div>

			<div class="hero-generator-shell schedule-generator-shell schedule-page-generator-shell relative w-full max-w-none min-w-0 xl:sticky xl:top-24 xl:min-w-[704px] xl:max-w-[720px] xl:justify-self-end">
				<div class="absolute -inset-5 rounded-full bg-[radial-gradient(circle,rgba(37,99,235,0.12),transparent_66%)] blur-3xl" aria-hidden="true"></div>
				<div class="premium-card hero-generator-card schedule-generator-card relative overflow-visible rounded-[1.75rem] border-line p-4 sm:rounded-[2.25rem] sm:p-5">
					<div class="absolute inset-x-10 top-0 h-px bg-gradient-to-r from-transparent via-white/30 to-transparent" aria-hidden="true"></div>
					<div class="hero-generator-inner rounded-[1.4rem] bg-surface-elevated p-0 shadow-[inset_0_1px_0_rgba(255,255,255,0.07)] sm:rounded-[1.8rem]">
						<div class="hero-generator-grid generator-shell grid grid-cols-1 items-start gap-6 xl:grid-cols-[minmax(380px,1fr)_260px]">
							<div class="generator-form-panel min-w-0">
								<GeneratorPanel selectedScheduleId={schedule.id} compact />
							</div>
							<div class="hero-calendar-column calendar-preview-panel grid w-full min-w-0 gap-3 xl:w-[260px] xl:min-w-[260px]">
