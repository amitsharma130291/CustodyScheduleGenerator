---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../Navbar.astro';
import Footer from '../Footer.astro';
import Breadcrumbs from '../seo/Breadcrumbs.astro';
import JsonLd from '../seo/JsonLd.astro';
import { getCanonicalUrl } from '../../lib/seo/metadata';
import {
	buildBreadcrumbSchema,
	buildFAQSchema,
	buildSoftwareApplicationSchema,
	buildWebPageSchema,
} from '../../lib/seo/schema';

interface Props {
	title: string;
	description: string;
	slug: string;
	lede: string;
	faq: { question: string; answer: string }[];
}

const { title, description, slug, lede, faq } = Astro.props;
const canonical = `/${slug}`;
const canonicalUrl = getCanonicalUrl(canonical);
const breadcrumbs = [
	{ name: 'Home', url: getCanonicalUrl('/') },
	{ name: title, url: canonicalUrl },
];
const schema = [
	buildFAQSchema(faq),
	buildBreadcrumbSchema(breadcrumbs),
	buildWebPageSchema({ name: title, description, url: canonicalUrl }),
	buildSoftwareApplicationSchema({ name: title, description, url: canonicalUrl }),
];
---

<BaseLayout title={`${title} | Custody Schedule Generator`} description={description} canonical={canonical}>
	<JsonLd slot="head" data={schema} />
	<Navbar />
	<Breadcrumbs items={breadcrumbs} />
	<main>
		<section class="container-shell grid gap-8 py-12 lg:grid-cols-[0.9fr_1.1fr] lg:py-16">
			<div>
				<p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">Calculator</p>
				<h1 class="mt-4 text-5xl font-semibold leading-[0.98] tracking-[-0.055em] text-primary lg:text-6xl">{title}</h1>
				<p class="mt-6 max-w-2xl text-lg leading-8 text-secondary">{lede}</p>
			</div>
			<div class="premium-card rounded-[2rem] p-6">
				<h2 class="text-2xl font-semibold tracking-[-0.04em] text-primary">Calculator coming next</h2>
				<p class="mt-3 text-sm leading-6 text-secondary">
					This static SEO route is ready for the interactive calculator module. Use the schedule generator pages to preview custody calendars now.
				</p>
				<div class="mt-5 flex flex-wrap gap-3">
					<a href="/2-2-3-custody-schedule" class="btn-secondary rounded-full px-5 py-2.5 text-sm font-semibold">2-2-3 schedule</a>
					<a href="/custody-schedule-template" class="btn-secondary rounded-full px-5 py-2.5 text-sm font-semibold">Schedule template</a>
				</div>
			</div>
		</section>

		<section class="container-shell py-10 lg:py-12">
			<div class="grid gap-4 md:grid-cols-3">
				<a href="/custody-percentage-calculator" class="soft-card rounded-[1.5rem] p-5">Custody Percentage Calculator</a>
				<a href="/parenting-time-calculator" class="soft-card rounded-[1.5rem] p-5">Parenting Time Calculator</a>
				<a href="/visitation-calculator" class="soft-card rounded-[1.5rem] p-5">Visitation Calculator</a>
			</div>
		</section>
	</main>
	<Footer />
</BaseLayout>
