---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../Navbar.astro';
import Footer from '../Footer.astro';
import Breadcrumbs from '../seo/Breadcrumbs.astro';
import JsonLd from '../seo/JsonLd.astro';
import { getCanonicalUrl } from '../../lib/seo/metadata';
import { buildBreadcrumbSchema, buildFAQSchema, buildWebPageSchema } from '../../lib/seo/schema';

interface Props {
	title: string;
	description: string;
	slug: string;
	lede: string;
	faq: { question: string; answer: string }[];
}

const { title, description, slug, lede, faq } = Astro.props;
const canonical = `/${slug}`;
const canonicalUrl = getCanonicalUrl(canonical);
const breadcrumbs = [
	{ name: 'Home', url: getCanonicalUrl('/') },
	{ name: title, url: canonicalUrl },
];
const schema = [
	buildFAQSchema(faq),
	buildBreadcrumbSchema(breadcrumbs),
	buildWebPageSchema({ name: title, description, url: canonicalUrl }),
];
---

<BaseLayout title={`${title} | Custody Schedule Generator`} description={description} canonical={canonical}>
	<JsonLd slot="head" data={schema} />
	<Navbar />
	<Breadcrumbs items={breadcrumbs} />
	<main>
		<section class="container-shell py-12 lg:py-16">
			<div class="premium-card rounded-[2rem] p-6 lg:p-8">
				<p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">Template</p>
				<h1 class="mt-4 max-w-3xl text-5xl font-semibold leading-[0.98] tracking-[-0.055em] text-primary lg:text-6xl">{title}</h1>
				<p class="mt-6 max-w-3xl text-lg leading-8 text-secondary">{lede}</p>
				<div class="mt-8 grid gap-4 md:grid-cols-3">
					<a href="/custody-schedule-template" class="soft-card rounded-[1.5rem] p-5">Custody schedule template</a>
					<a href="/custody-calendar-template" class="soft-card rounded-[1.5rem] p-5">Custody calendar template</a>
					<a href="/parenting-plan-template" class="soft-card rounded-[1.5rem] p-5">Parenting plan template</a>
				</div>
			</div>
		</section>
	</main>
	<Footer />
</BaseLayout>
